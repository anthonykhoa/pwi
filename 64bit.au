	FUNC MASSPICKUP($COUNT, $ARRAY)
		$STR = "B800" & _HEX($COUNT)
		FOR $I = 0 TO $COUNT - 1
			$STR = $STR & _HEX($ARRAY[$I][0]) & _HEX($ARRAY[$I][1])
		NEXT
		SENDPACKET($STR, 6 + 8 * $COUNT, $GAME_PID)
	ENDFUNC
	FUNC SENDPACKET($PACKET, $PACKETSIZE = 0, $PID = 0)
		STATIC $HPACKETTIMER = TIMERINIT()
		STATIC $LASTPACKETPID = 0
		IF $PID == 0 THEN $PID = $GAME_PID
		IF $PACKETSIZE == 0 THEN $PACKETSIZE = INT(STRINGLEN($PACKET) / 2)
		$TIMEDIFF = TIMERDIFF($HPACKETTIMER)
		IF $TIMEDIFF < 2 AND $PID == $LASTPACKETPID THEN
			CONSOLEWRITE("WARNING COLLISION: " & $TIMEDIFF & " - " & $PACKET & @CRLF)
		ENDIF
		CONSOLEWRITE("Sending: " & $PACKET & @CRLF)
		LOCAL $PREMOTETHREAD, $VBUFFER, $LOOP, $RESULT, $OPCODE, $PROCESSHANDLE, $PACKETADDRESS
		$PROCESSHANDLE = $GAME_PROCESS[1]
		$FUNCTIONADDRESS = DLLCALL($KERNEL32, "ptr", "VirtualAllocEx", "handle", $PROCESSHANDLE, "ptr", 0, "ulong_ptr", 256, "dword", 4096, "dword", 64)
		$PACKETADDRESS = DLLCALL($KERNEL32, "ptr", "VirtualAllocEx", "handle", $PROCESSHANDLE, "ptr", 0, "ulong_ptr", $PACKETSIZE, "dword", 4096, "dword", 64)
		$OPCODE &= "60"
		$OPCODE &= "B8" & _HEX($ADDRESS_SENDPACKET)
		$OPCODE &= "8B0D" & _HEX($ADDRESS_BASE)
		$OPCODE &= "8B4920"
		$OPCODE &= "BF" & _HEX($PACKETADDRESS[0])
		$OPCODE &= "68" & _HEX($PACKETSIZE)
		$OPCODE &= "57"
		$OPCODE &= "FFD0"
		$OPCODE &= "61"
		$OPCODE &= "C3"
		$VBUFFER = DLLSTRUCTCREATE("byte[" & STRINGLEN($OPCODE) / 2 & "]")
		FOR $LOOP = 1 TO DLLSTRUCTGETSIZE($VBUFFER)
			DLLSTRUCTSETDATA($VBUFFER, 1, DEC(STRINGMID($OPCODE, ($LOOP - 1) * 2 + 1, 2)), $LOOP)
		NEXT
		DLLCALL($KERNEL32, "bool", "WriteProcessMemory", "handle", $PROCESSHANDLE, "ptr", $FUNCTIONADDRESS[0], "ptr", DLLSTRUCTGETPTR($VBUFFER), "ulong_ptr", DLLSTRUCTGETSIZE($VBUFFER), "ulong_ptr*", 0)
		$VBUFFER = DLLSTRUCTCREATE("byte[" & STRINGLEN($PACKET) / 2 & "]")
		FOR $LOOP = 1 TO DLLSTRUCTGETSIZE($VBUFFER)
			DLLSTRUCTSETDATA($VBUFFER, 1, DEC(STRINGMID($PACKET, ($LOOP - 1) * 2 + 1, 2)), $LOOP)
		NEXT
		DLLCALL($KERNEL32, "bool", "WriteProcessMemory", "handle", $PROCESSHANDLE, "ptr", $PACKETADDRESS[0], "ptr", DLLSTRUCTGETPTR($VBUFFER), "ulong_ptr", DLLSTRUCTGETSIZE($VBUFFER), "ulong_ptr*", 0)
		$HREMOTETHREAD = DLLCALL($KERNEL32, "handle", "CreateRemoteThread", "handle", $PROCESSHANDLE, "ptr", 0, "ulong_ptr", 0, "ptr", $FUNCTIONADDRESS[0], "ptr", 0, "dword", 0, "dword*", 0)
		$RESULT = DLLCALL("kernel32.dll", "dword", "WaitForSingleObject", "handle", $HREMOTETHREAD[0], "dword", -1)
		DLLCALL($KERNEL32, "bool", "CloseHandle", "handle", $HREMOTETHREAD[0])
		DLLCALL($KERNEL32, "bool", "VirtualFreeEx", "handle", $PROCESSHANDLE, "ptr", $FUNCTIONADDRESS[0], "ulong_ptr", 0, "dword", 32768)
		DLLCALL($KERNEL32, "bool", "VirtualFreeEx", "handle", $PROCESSHANDLE, "ptr", $PACKETADDRESS[0], "ulong_ptr", 0, "dword", 32768)
		$HPACKETTIMER = TIMERINIT()
		$LASTPACKETPID = $PID
		RETURN TRUE
	ENDFUNC
#EndRegion _Packets
#Region _Memory
	FUNC _MEMORYOPEN($IV_PID, $IV_DESIREDACCESS = 2035711, $IV_INHERITHANDLE = 1)
		IF NOT PROCESSEXISTS($IV_PID) THEN
			SETERROR(1)
			RETURN 0
		ENDIF
		LOCAL $AH_HANDLE[2] = [DLLOPEN("kernel32.dll")]
		IF @ERROR THEN
			SETERROR(2)
			RETURN 0
		ENDIF
		LOCAL $AV_OPENPROCESS = DLLCALL($AH_HANDLE[0], "handle", "OpenProcess", "dword", $IV_DESIREDACCESS, "bool", $IV_INHERITHANDLE, "dword", $IV_PID)
		IF @ERROR THEN
			DLLCLOSE($AH_HANDLE[0])
			SETERROR(3)
			RETURN 0
		ENDIF
		$AH_HANDLE[1] = $AV_OPENPROCESS[0]
		RETURN $AH_HANDLE
	ENDFUNC
	FUNC _MEMORYREAD($IV_ADDRESS, $AH_HANDLE, $SV_TYPE = "dword")
		IF NOT ISARRAY($AH_HANDLE) THEN
			SETERROR(1)
			RETURN 0
		ENDIF
		LOCAL $V_BUFFER = DLLSTRUCTCREATE($SV_TYPE)
		IF @ERROR THEN
			SETERROR(@ERROR + 1)
			RETURN 0
		ENDIF
		DLLCALL($AH_HANDLE[0], "bool", "ReadProcessMemory", "handle", $AH_HANDLE[1], "ptr", $IV_ADDRESS, "ptr", DLLSTRUCTGETPTR($V_BUFFER), "ulong_ptr", DLLSTRUCTGETSIZE($V_BUFFER), "ulong_ptr*", 0)
		IF NOT @ERROR THEN
			LOCAL $V_VALUE = DLLSTRUCTGETDATA($V_BUFFER, 1)
			RETURN $V_VALUE
		ELSE
			SETERROR(6)
			RETURN 0
		ENDIF
	ENDFUNC
	FUNC _MEMORYWRITE($IV_ADDRESS, $AH_HANDLE, $V_DATA, $SV_TYPE = "dword")
		IF NOT ISARRAY($AH_HANDLE) THEN
			SETERROR(1)
			RETURN 0
		ENDIF
		LOCAL $V_BUFFER = DLLSTRUCTCREATE($SV_TYPE)
		IF @ERROR THEN
			SETERROR(@ERROR + 1)
			RETURN 0
		ELSE
			DLLSTRUCTSETDATA($V_BUFFER, 1, $V_DATA)
			IF @ERROR THEN
				SETERROR(6)
				RETURN 0
			ENDIF
		ENDIF
		DLLCALL($AH_HANDLE[0], "bool", "WriteProcessMemory", "handle", $AH_HANDLE[1], "ptr", $IV_ADDRESS, "ptr", DLLSTRUCTGETPTR($V_BUFFER), "ulong_ptr", DLLSTRUCTGETSIZE($V_BUFFER), "ulong_ptr*", 0)
		IF NOT @ERROR THEN
			RETURN 1
		ELSE
			SETERROR(7)
			RETURN 0
		ENDIF
	ENDFUNC
	FUNC _MEMORYCLOSE($AH_HANDLE)
		IF NOT ISARRAY($AH_HANDLE) THEN
			SETERROR(1)
			RETURN 0
		ENDIF
		DLLCALL($AH_HANDLE[0], "bool", "CloseHandle", "handle", $AH_HANDLE[1])
		IF NOT @ERROR THEN
			DLLCLOSE($AH_HANDLE[0])
			RETURN 1
		ELSE
			DLLCLOSE($AH_HANDLE[0])
			SETERROR(2)
			RETURN 0
		ENDIF
	ENDFUNC
#EndRegion _Memory
GLOBAL $KERNEL32 = DLLOPEN("kernel32.dll")
DIM $GAME_EXE = "elementclient.exe"
DIM $GAME_PID = PROCESSEXISTS($GAME_EXE)
IF $GAME_PID = 0 THEN
	$GAME_EXE = "elementclient_64.exe"
	$GAME_PID = PROCESSEXISTS($GAME_EXE)
ENDIF
DIM $GAME_PROCESS = _MEMORYOPEN($GAME_PID)
DIM $CURRENT_CLIENT = 0
DIM $CLIENTS[0][6]
FUNC WAITTOFINISH($DELAY = 200)
	WHILE ACTIONFLAG()
		SLEEP($DELAY)
	WEND
	SLEEP($DELAY)
ENDFUNC
FUNC WAITSTOP($DELAY = 20, $MAX = -1)
	LOCAL $COUNT = 0
	WHILE $COUNT < $DELAY AND ALIVE()
		$COUNT = $COUNT + 1
		IF ACTIONFLAG() THEN
			$COUNT = 0
		ENDIF
		IF $MAX > 0 THEN $MAX = $MAX - 1
		IF $MAX == 0 THEN RETURN
		SLEEP(100)
	WEND
ENDFUNC
FUNC WAITSTOP2($DELAY = 20, $MAX = -1, $MAXTIME = -1)
	LOCAL $COUNT = 0
	$TIMER = TIMERINIT()
	WHILE $COUNT < $DELAY AND ALIVE()
		IF $MAXTIME <> -1 THEN
			IF TIMERDIFF($TIMER) > $MAXTIME THEN
				EXITLOOP
			ENDIF
		ENDIF
		$COUNT = $COUNT + 1
		IF ACTIONFLAG() THEN
			$COUNT = 0
		ENDIF
		IF $MAX > 0 THEN $MAX = $MAX - 1
		IF $MAX == 0 THEN RETURN
		SLEEP(50)
	WEND
ENDFUNC
FUNC BUILDCHI($MAXTIMETOBUILDCHI = 5000, $CHIVALUETOBUILDTO = 390)
	$TIMER = TIMERINIT()
	WHILE CHI() < $CHIVALUETOBUILDTO
		IF TIMERDIFF($TIMER) > $MAXTIMETOBUILDCHI THEN EXITLOOP
		EXECUTEMACRO(7, FALSE)
	WEND
ENDFUNC
FUNC SMARTSpeed($X, $Y, $USEDISTANCE = TRUE)
	$PLAYERPOS = PLAYERPOS()
	IF $USEDISTANCE AND DISTANCEBETWEEN($X, $Y, $PLAYERPOS[0], $PLAYERPOS[1]) < 10 THEN RETURN
	$CLASS = CLASS()
	IF TRANSPORTMODE() == 2 AND $CLASS <> 7 THEN
		SWITCHTOHUMANFORM()
		RETURN
	ENDIF
	IF $CLASS == 4 OR $CLASS == 14 THEN SWITCHTOSECONDFORM()
	IF HASESCORTCART() THEN RETURN
	IF $CLASS == 3 THEN HANDLEFORMCHANGE()
	$USEHOLYPATH = GETGLOBALSETTING("useholypath2")
	IF HASBUFF("", 44) THEN RETURN
	IF $USEHOLYPATH THEN
		IF GENIEENERGY() > 75 AND SKILLOFFCOOLDOWN(1022, 1) THEN
			CASTSKILL(1022, 1)
			RETURN
		ENDIF
	ENDIF
	IF HASBUFF("", 44) THEN RETURN
	CASTCLASSSpeedSKILL($CLASS)
ENDFUNC
FUNC HASESCORTCART()
	RETURN HASBUFF("", 295) OR HASBUFF("", 10011)
ENDFUNC
GLOBAL $BLADEMASTERSPEEDSKILLS[2][2] = [[76, 0], [176, 100]]
GLOBAL $WIZARDSPEEDSKILLS[5][2] = [[100, 20], [478, 10], [479, 20], [3199, 10], [3200, 20]]
GLOBAL $VENOSPEEDSKILLS[1][2] = [[657, 0]]
GLOBAL $SINSPEEDSKILLS[6][2] = [[1124, 0], [1310, 0], [1311, 0], [1189, 100], [1322, 100], [1323, 100]]
GLOBAL $SEEKERSPEEDSKILLS[6][2] = [[1360, 0], [1688, 0], [1689, 0], [1733, 20], [1734, 20], [4424, 0]]
GLOBAL $DUSKSPEEDSKILLS[4][2] = [[2772, 30], [3288, 30], [2774, 30], [6992, 30]]
GLOBAL $STORMBRINGERSPEEDSKILLS[3][2] = [[2596, 30], [2819, 30], [2820, 30]]
GLOBAL $TECHSPEEDSKILLS[19][2] = [[4944, 30], [4979, 30], [4980, 30], [4996, 30], [4997, 30], [5440, 30], [5441, 30], [5442, 30], [5443, 30], [5444, 30], [5445, 30], [5446, 30], [4952, 20], [5057, 0], [5058, 0], [5059, 0], [5060, 0], [5061, 0], [5062, 0]]
GLOBAL $CLERICSPEEDSKILLS[11][2] = [[6304, 20], [6301, 20], [6302, 20], [6303, 20], [6305, 20], [3575, 15], [4480, 0], [4476, 0], [4477, 0], [4478, 0], [4479, 0]]
GLOBAL $MYSTICSPEEDSKILLS[1][2] = [[1643, 100]]
FUNC CASTCLASSSpeedSKILL($CLASS)
	IF $CLASS == 0 THEN
		CASTFIRSTAVAILABLESKILL($BLADEMASTERSPEEDSKILLS)
	ELSEIF $CLASS == 1 THEN
		CASTFIRSTAVAILABLESKILL($WIZARDSPEEDSKILLS)
	ELSEIF $CLASS == 3 THEN
		CASTFIRSTAVAILABLESKILL($VENOSPEEDSKILLS)
	ELSEIF $CLASS == 5 THEN
		CASTFIRSTAVAILABLESKILL($SINSPEEDSKILLS)
	ELSEIF $CLASS == 7 THEN
		CASTFIRSTAVAILABLESKILL($CLERICSPEEDSKILLS)
	ELSEIF $CLASS == 8 THEN
		CASTFIRSTAVAILABLESKILL($SEEKERSPEEDSKILLS)
	ELSEIF $CLASS == 9 THEN
		CASTFIRSTAVAILABLESKILL($MYSTICSPEEDSKILLS)
	ELSEIF $CLASS == 10 THEN
		CASTFIRSTAVAILABLESKILL($DUSKSPEEDSKILLS)
	ELSEIF $CLASS == 11 THEN
		CASTFIRSTAVAILABLESKILL($STORMBRINGERSPEEDSKILLS)
	ELSEIF $CLASS == 12 THEN
		CASTFIRSTAVAILABLESKILL($TECHSPEEDSKILLS)
	ENDIF
ENDFUNC
FUNC CASTFIRSTAVAILABLESKILL($SKILLSARRAY)
	FOR $I = 0 TO UBOUND($SKILLSARRAY) - 1
		IF SKILLOFFCOOLDOWN($SKILLSARRAY[$I][0]) AND CHI() >= $SKILLSARRAY[$I][1] THEN
			CASTSKILL($SKILLSARRAY[$I][0])
			RETURN
		ENDIF
	NEXT
ENDFUNC
FUNC PLAYER()
	RETURN _MEMORYREAD(_MEMORYREAD(_MEMORYREAD($ADDRESS_BASE, $GAME_PROCESS) + 28, $GAME_PROCESS) + $PLAYER_OFFSET, $GAME_PROCESS)
ENDFUNC


; Function to read the base address
Func GetBaseAddress()
    Return _MEMORYREAD($BASE_ADDRESS, $GAME_PROCESS)
EndFunc

; Function to read the game pointer using the base address
Func GetGamePtr()
    Return _MEMORYREAD(GetBaseAddress() + $GAME_STRUCT_OFFSET, $GAME_PROCESS)
EndFunc

; Function to read the character pointer using the game pointer
Func GetCharPtr()
    Return _MEMORYREAD(GetGamePtr() + $CHAR_PTR_OFFSET, $GAME_PROCESS)
EndFunc

; Function to get the target using the character pointer and target offset
Func GetTarget()
    Return _MEMORYREAD(GetCharPtr() + $TARGET_OFFSET, $GAME_PROCESS)
EndFunc

; Function to get the target using the character pointer and target offset
Func GetSoulForce()
    Return _MEMORYREAD(GetCharPtr() + $SOULFORCE_OFFSET, $GAME_PROCESS)
EndFunc


FUNC PLAYERADDRESS()
	RETURN _MEMORYREAD(_MEMORYREAD(_MEMORYREAD($ADDRESS_BASE, $GAME_PROCESS) + 28, $GAME_PROCESS) + $PLAYER_OFFSET, $GAME_PROCESS)
ENDFUNC
FUNC MOVINGMODE()
	RETURN _MEMORYREAD(PLAYER() + $PLAYERMOVINGMODE_OFFSET, $GAME_PROCESS)
ENDFUNC
FUNC JUMP($HEIGHT = 2)
	$POS = PLAYERPOS()
	$DIR = PLAYERDIR()
	$POS[2] = $POS[2] + $HEIGHT
	JUMPPOS($POS)
ENDFUNC
FUNC TRUEJUMP()
	IF JUMPCOUNT() >= 2 THEN RETURN FALSE
	POSTMESSAGE(289, 1, 0)
	RETURN TRUE
ENDFUNC
FUNC JUMPPOS($POS)
	$PLAYER = PLAYERADDRESS()
	$DIFF = _MEMORYREAD($PLAYER + 64 + $PHYSPOSOFFSET, $GAME_PROCESS, "float") - _MEMORYREAD($PLAYER + 64, $GAME_PROCESS, "float")
	_MEMORYWRITE($PLAYER + 60 + $PHYSPOSOFFSET, $GAME_PROCESS, $POS[0], "float")
	_MEMORYWRITE($PLAYER + 60, $GAME_PROCESS, $POS[0], "float")
	_MEMORYWRITE($PLAYER + 68 + $PHYSPOSOFFSET, $GAME_PROCESS, $POS[1], "float")
	_MEMORYWRITE($PLAYER + 68, $GAME_PROCESS, $POS[1], "float")
	IF $POS[2] <> -1 THEN
		_MEMORYWRITE($PLAYER + 64 + $PHYSPOSOFFSET, $GAME_PROCESS, $POS[2] + $DIFF, "float")
		_MEMORYWRITE($PLAYER + 64, $GAME_PROCESS, $POS[2], "float")
	ENDIF
ENDFUNC
FUNC JUMPUP($SPEED = 12, $MODE = FALSE)
	$PLAYER = PLAYERADDRESS()
	_MEMORYWRITE($PLAYER + $PLAYERJUMPSPEED, $GAME_PROCESS, $SPEED, "float")
	IF $MODE THEN
		_MEMORYWRITE($PLAYER + $PLAYERJUMPMODE, $GAME_PROCESS, 0)
		SLEEP(100)
		_MEMORYWRITE($PLAYER + $PLAYERJUMPCOUNT, $GAME_PROCESS, 1)
	ENDIF
ENDFUNC
FUNC JUMPSPEED()
	RETURN _MEMORYREAD(PLAYERADDRESS() + $PLAYERJUMPSPEED, $GAME_PROCESS, "float")
ENDFUNC
FUNC JUMPCOUNT()
	RETURN _MEMORYREAD(PLAYERADDRESS() + $PLAYERJUMPCOUNT, $GAME_PROCESS)
ENDFUNC
FUNC ZEROFORWARDSPEEDINAIR()
	$PLAYER = PLAYERADDRESS()
	$XV = _MEMORYREAD($PLAYER + $PLAYERMOVESPEEDX, $GAME_PROCESS, "float")
	$YV = _MEMORYREAD($PLAYER + $PLAYERMOVESPEEDX + 8, $GAME_PROCESS, "float")
	IF $XV <> 0 OR $YV <> 0 THEN MOVETO2(1, 0, 0, 3)
ENDFUNC
FUNC PLAYERPOS()
	$PLAYER = PLAYERADDRESS()
	DIM $POS[3]
	$POS[0] = _MEMORYREAD($PLAYER + 60, $GAME_PROCESS, "float")
	$POS[1] = _MEMORYREAD($PLAYER + 68, $GAME_PROCESS, "float")
	$POS[2] = _MEMORYREAD($PLAYER + 64, $GAME_PROCESS, "float")
	RETURN $POS
ENDFUNC
FUNC PLAYERPOSPRINT()
	$PLAYER = PLAYERADDRESS()
	DIM $POS[3]
	$POS[0] = STRINGFORMAT("%.2f", _MEMORYREAD($PLAYER + 60, $GAME_PROCESS, "float"))
	$POS[1] = STRINGFORMAT("%.2f", _MEMORYREAD($PLAYER + 68, $GAME_PROCESS, "float"))
	$POS[2] = STRINGFORMAT("%.2f", _MEMORYREAD($PLAYER + 64, $GAME_PROCESS, "float"))
	SETSTATUS("x: " & $POS[0] & ", y: " & $POS[1] & ", z: " & $POS[2])
ENDFUNC
