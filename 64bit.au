			LOCAL $ACALL = DLLCALL("shell32.dll", "bool", "SHGetPathFromIDListW", "struct*", $PPIDL, "wstr", "")
			IF @ERROR OR NOT $ACALL[0] THEN RETURN SETERROR(@ERROR, @EXTENDED, "")
			RETURN $ACALL[2]
