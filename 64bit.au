	ClientsMoveAndWait(-193.04, -173.78, $CLIENTSINDEXES, 197)
	
	Local $result = MOVEWEAKESTCLIENT($CLIENTSINDEXES, -264.45, -174.39, -193.04, -173.78)

	; Retrieve the weakest client and other clients from the result
	Local $WeakestClient = $result[0]
	Local $OtherClientsIndexes = $result[1]
	MASSNUKEFINALBOSSTTR("Lethal Vengeance", True, True, True, False, True, 400, True, True, False, False, True, True, $WeakestClient, $OTHERCLIENTSINDEXES)
	


ENDFUNC


