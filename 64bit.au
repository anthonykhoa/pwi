ENDFUNC
FUNC UPDATEADVENTUREKINGDOM()
	$TEXT = "00:00:00"
	IF $HTUROTIMER THEN
		LOCAL $G_IHOUR, $G_IMINS, $G_ISECS
		$TIMESINCE = TIMERDIFF($HTUROTIMER)
		_TICKSTOTIME($TIMESINCE, $G_IHOUR, $G_IMINS, $G_ISECS)
		$TEXT = STRINGFORMAT("%02i:%02i:%02i", $G_IHOUR, $G_IMINS, $G_ISECS)
	ENDIF
	IF $TEXT <> GUICTRLREAD($HTUROTIMESINCELAST) THEN GUICTRLSETDATA($HTUROTIMESINCELAST, $TEXT)
	IF PLAYERID() == 0 THEN RETURN
	$RESULTS = TUROQUESTCOUNT()
	IF $RESULTS[0] <> GUICTRLREAD($HTUROQUESTFOUND) THEN GUICTRLSETDATA($HTUROQUESTFOUND, $RESULTS[0])
	IF $RESULTS[2] <> GUICTRLREAD($HTUROQUESTAVAIL) THEN GUICTRLSETDATA($HTUROQUESTAVAIL, $RESULTS[2])
ENDFUNC
HOTKEYSET("!+^t", "TESTTHINGS")
FUNC TESTTHINGS()
	FEEDGENIEDAILY()
ENDFUNC
HOTKEYSET("!+^o", "DISPLAYQUESTS3")
FUNC DISPLAYQUESTS3()
	$STRING = ""
	$ARRAY = QUESTARRAY()
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		$STRING &= $ARRAY[$I][0] & "," & $ARRAY[$I][1] & "," & $ARRAY[$I][2] & "," & $ARRAY[$I][3] & @CRLF
	NEXT
	MSGBOX(0, "Array", $STRING)
ENDFUNC
HOTKEYSET("!+^b", "DISPLAYBUFFS2")
FUNC DISPLAYBUFFS2()
	$BUFFS = BUFFARRAY()
	LOCAL $MESSAGE
	FOR $I = 0 TO UBOUND($BUFFS) - 1
		$MESSAGE &= "ID: " & $BUFFS[$I][0] & ", Stacks: " & $BUFFS[$I][2] & @CRLF
	NEXT
	MSGBOX(0, "Buffs List", $MESSAGE)
ENDFUNC
HOTKEYSET("!+^m", "MOVEMENTTEST")
FUNC MOVEMENTTEST()
	$INPUT = STRINGSPLIT(INPUTBOX("Move coords", "Enter move coords"), " ", 2)
	MOVE(NUMBER($INPUT[0]), NUMBER($INPUT[1]))
ENDFUNC
