FUNC CONVERTX($X)
	$CONVERTEDX = $X * 10 - 4000
	RETURN $CONVERTEDX
ENDFUNC
FUNC CONVERTY($Y)
	$CONVERTEDY = $Y * 10 - 5500
	RETURN $CONVERTEDY
ENDFUNC
FUNC CALLIGRAPHY($SWITCH)
	$INSTANCE = INSTANCEID()
	IF $INSTANCE <> 176 THEN
		SETSTATUS("Not inside UPD. Cannot execute calligraphy runes.")
		RETURN
	ENDIF
	$CLIENTSINDEXES = GETNEARBYALTS(90)
	$NUMBEROFCHAR = UBOUND($CLIENTSINDEXES)
	SWITCHTO($MAIN)
	IF $SWITCH == 1 THEN
		$CURRENTPOS = PLAYERPOS()
		IF DISTANCE2D(-30, 51) > 10 THEN
			SETSTATUS("UPD-Calligraphy - distance2d (-30, 51) is " & DISTANCE2D(-30, 51))
			SETSTATUS("Current coords are " & $CURRENTPOS[0] & "," & $CURRENTPOS[1])
			SETSTATUS("UPD-Calligraphy - too far from starting spot by boss. Please move closer to boss spot before executing runes.")
			RETURN
		ENDIF
		SETSTATUS("UPD-Calligraphy-Preparing runes to spawn boss. Doing runes 1 through " & $NUMBEROFCHAR & ".")
		$COORDSCOUNT = UBOUND($CALLIGRAPHYCOORDINATESSKIPLAST, 2)
		FOR $COORDINATE = 0 TO $COORDSCOUNT - 1
			IF MOVEKEY() <> 0 THEN
				SETSTATUS("UPD-Calligraphy-runes cancelled by user")
				RETURN
			ENDIF
			$TIMETOSLEEP = 100
			FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
				$INDEX = $CLIENTSINDEXES[$I]
				IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
				SWITCHTONUM($INDEX)
				IF $COORDINATE == 10 AND $INDEX == 4 THEN
					SPEEDPATH()
				ENDIF
				IF MOVEKEY() <> 0 THEN
					SETSTATUS("UPD-Calligraphy-runes cancelled by user")
					RETURN
				ENDIF
				IF CLASS() <> 7 THEN SWITCHTOHUMANFORM()
				$X = $CALLIGRAPHYCOORDINATESSKIPLAST[$I][$COORDINATE][0]
				IF $X == 0 THEN CONTINUELOOP
				$Y = $CALLIGRAPHYCOORDINATESSKIPLAST[$I][$COORDINATE][1]
				IF $COORDINATE > 1 AND $COORDINATE <= $COORDSCOUNT THEN
					$XOLD = CONVERTX($CALLIGRAPHYCOORDINATESSKIPLAST[$I][$COORDINATE - 1][0])
					$YOLD = CONVERTY($CALLIGRAPHYCOORDINATESSKIPLAST[$I][$COORDINATE - 1][1])
					IF DISTANCE2D($XOLD, $YOLD) > 0.05 THEN
						$TIMER = TIMERINIT()
						DO
							MOVETO2($XOLD, $YOLD)
							SLEEP(50)
							IF TIMERDIFF($TIMER) > 1000 THEN EXITLOOP
						UNTIL DISTANCE2D($XOLD, $YOLD) < 0.1
					ENDIF
					$TIMETOSLEEP += 35
					SLEEP($TIMETOSLEEP)
				ENDIF
				MOVESTRINGXYZ2($X, $Y)
			NEXT
			SLEEP(350)
		NEXT
		SWITCHTO($MAIN)
	ENDIF
	IF $SWITCH == 2 THEN
		SETSTATUS("UPD-Calligraphy-Doing final fire on each rune to spawn boss. Doing runes 1 through " & $NUMBEROFCHAR & ".")
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
			SWITCHTONUM($INDEX)
			$RUNE = 1
			FOR $J = 0 TO UBOUND($CALLIGRAPHYCOORDINATESONLYLAST) - 1
				SETSTATUS("Distance to coordinate " & $J + 1 & " = " & DISTANCE2D(CONVERTX($CALLIGRAPHYCOORDINATESONLYLAST[$J][0]), CONVERTY($CALLIGRAPHYCOORDINATESONLYLAST[$J][1])))
			NEXT
			IF DISTANCE2D(CONVERTX(395.118), CONVERTY(552.636)) < 2 OR DISTANCE2D(CONVERTX(395.373), CONVERTY(552.489)) < 3 THEN
				SETSTATUS("distance2d(CONVERTX(395.118),CONVERTY(552.636)) = " & DISTANCE2D(CONVERTX(395.118), CONVERTY(552.636)))
				$RUNE = 1
			ELSEIF DISTANCE2D(CONVERTX(396.262), CONVERTX(552.748)) < 2 OR DISTANCE2D(CONVERTX(396.683), CONVERTY(552.846)) < 3 THEN
				$RUNE = 2
			ELSEIF DISTANCE2D(CONVERTX(397.099), CONVERTY(553.133)) < 2 OR DISTANCE2D(CONVERTX(397.969), CONVERTY(553.536)) < 3 THEN
				$RUNE = 3
			ELSEIF DISTANCE2D(CONVERTX(398.494), CONVERTY(554.134)) < 2 OR DISTANCE2D(CONVERTX(398.993), CONVERTY(553.895)) < 3 THEN
				$RUNE = 4
			ELSEIF DISTANCE2D(CONVERTX(399.64), CONVERTY(555.26)) < 2 OR DISTANCE2D(CONVERTX(399.869), CONVERTY(554.636)) < 3 THEN
				$RUNE = 5
			ELSEIF DISTANCE2D(CONVERTX(396.366), CONVERTY(550.416)) < 2 OR DISTANCE2D(CONVERTX(396.76), CONVERTY(550.612)) < 3 THEN
				$RUNE = 6
			ELSEIF DISTANCE2D(CONVERTX(397.229), CONVERTY(551.439)) < 2 OR DISTANCE2D(CONVERTX(397.64), CONVERTY(551.383)) < 3 THEN
				$RUNE = 7
			ELSEIF DISTANCE2D(CONVERTX(397.997), CONVERTY(551.705)) < 2 OR DISTANCE2D(CONVERTX(398.671), CONVERTY(552.038)) < 3 THEN
				$RUNE = 8
			ELSEIF DISTANCE2D(CONVERTX(399.304), CONVERTY(551.887)) < 2 OR DISTANCE2D(CONVERTX(399.798), CONVERTY(551.982)) < 3 THEN
				$RUNE = 9
			ELSEIF DISTANCE2D(CONVERTX(400.493), CONVERTY(552.575)) < 2 OR DISTANCE2D(CONVERTX(400.543), CONVERTY(553.533)) < 3 THEN
				$RUNE = 10
			ENDIF
			$X = $CALLIGRAPHYCOORDINATESONLYLAST[$RUNE - 1][0]
			$Y = $CALLIGRAPHYCOORDINATESONLYLAST[$RUNE - 1][1]
			MOVESTRINGXYZ2($X, $Y)
		NEXT
		SLEEP(2000)
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
			SWITCHTONUM($INDEX)
			$RUNE = 1
			FOR $J = 0 TO UBOUND($CALLIGRAPHYCOORDINATESONLYLAST) - 1
				SETSTATUS("Distance to coordinate " & $J + 1 & " = " & DISTANCE2D(CONVERTX($CALLIGRAPHYCOORDINATESONLYLAST[$J][0]), CONVERTY($CALLIGRAPHYCOORDINATESONLYLAST[$J][1])))
			NEXT
			IF DISTANCE2D(CONVERTX(395.118), CONVERTY(552.636)) < 2 OR DISTANCE2D(CONVERTX(395.373), CONVERTY(552.489)) < 3 THEN
				SETSTATUS("distance2d(CONVERTX(395.118),CONVERTY(552.636)) = " & DISTANCE2D(CONVERTX(395.118), CONVERTY(552.636)))
				$RUNE = 1
			ELSEIF DISTANCE2D(CONVERTX(396.262), CONVERTX(552.748)) < 2 OR DISTANCE2D(CONVERTX(396.683), CONVERTY(552.846)) < 3 THEN
				$RUNE = 2
			ELSEIF DISTANCE2D(CONVERTX(397.099), CONVERTY(553.133)) < 2 OR DISTANCE2D(CONVERTX(397.969), CONVERTY(553.536)) < 3 THEN
				$RUNE = 3
			ELSEIF DISTANCE2D(CONVERTX(398.494), CONVERTY(554.134)) < 2 OR DISTANCE2D(CONVERTX(398.993), CONVERTY(553.895)) < 3 THEN
				$RUNE = 4
			ELSEIF DISTANCE2D(CONVERTX(399.64), CONVERTY(555.26)) < 2 OR DISTANCE2D(CONVERTX(399.869), CONVERTY(554.636)) < 3 THEN
				$RUNE = 5
			ELSEIF DISTANCE2D(CONVERTX(396.366), CONVERTY(550.416)) < 2 OR DISTANCE2D(CONVERTX(396.76), CONVERTY(550.612)) < 3 THEN
				$RUNE = 6
			ELSEIF DISTANCE2D(CONVERTX(397.229), CONVERTY(551.439)) < 2 OR DISTANCE2D(CONVERTX(397.64), CONVERTY(551.383)) < 3 THEN
				$RUNE = 7
			ELSEIF DISTANCE2D(CONVERTX(397.997), CONVERTY(551.705)) < 2 OR DISTANCE2D(CONVERTX(398.671), CONVERTY(552.038)) < 3 THEN
				$RUNE = 8
			ELSEIF DISTANCE2D(CONVERTX(399.304), CONVERTY(551.887)) < 2 OR DISTANCE2D(CONVERTX(399.798), CONVERTY(551.982)) < 3 THEN
				$RUNE = 9
			ELSEIF DISTANCE2D(CONVERTX(400.493), CONVERTY(552.575)) < 2 OR DISTANCE2D(CONVERTX(400.543), CONVERTY(553.533)) < 3 THEN
				$RUNE = 10
			ENDIF
			$X = $CALLIGRAPHYCOORDINATESONLYLAST[$RUNE - 1][0]
			$Y = $CALLIGRAPHYCOORDINATESONLYLAST[$RUNE - 1][1]
			IF DISTANCE2D($X, $Y) > 0.05 THEN
				DO
					MOVETO2($X, $Y)
				UNTIL DISTANCE2D($X, $Y) < 0.05
			ENDIF
		NEXT
		SWITCHTO($MAIN)
	ENDIF
	IF $SWITCH == 3 THEN
		SETSTATUS("UPD-Calligraphy-Doing runes after boss nuke within 60s. Doing runes 1 through " & $NUMBEROFCHAR & ".")
		$COORDSCOUNT = UBOUND($CALLIGRAPHYCOORDINATESFULL, 2)
		FOR $COORDINATE = 0 TO $COORDSCOUNT - 1
			IF MOVEKEY() <> 0 THEN
				SETSTATUS("UPD-Calligraphy-runes cancelled by user")
				RETURN
			ENDIF
			$TIMETOSLEEP = 100
			FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
				$INDEX = $CLIENTSINDEXES[$I]
				IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
				SWITCHTONUM($INDEX)
				IF CLASS() <> 7 THEN SWITCHTOHUMANFORM()
				$X = $CALLIGRAPHYCOORDINATESFULL[$I][$COORDINATE][0]
				IF $X == 0 THEN CONTINUELOOP
				$Y = $CALLIGRAPHYCOORDINATESFULL[$I][$COORDINATE][1]
				IF $COORDINATE > 0 AND $COORDINATE <= $COORDSCOUNT THEN
					$XOLD = $CALLIGRAPHYCOORDINATESFULL[$I][$COORDINATE - 1][0]
					$YOLD = $CALLIGRAPHYCOORDINATESFULL[$I][$COORDINATE - 1][1]
					MOVESTRINGXYZ2($XOLD, $YOLD)
					WAITTOFINISH()
					$TIMETOSLEEP += 30
					SLEEP($TIMETOSLEEP)
				ENDIF
				MOVESTRINGXYZ2($X, $Y)
			NEXT
		NEXT
		SWITCHTO($MAIN)
	ENDIF
ENDFUNC
FUNC ALTSFOLLOW($ALTSAMOUNT)
	SWITCHTO($MAIN)
	$TARGET = PLAYERID()
	$COUNT = 0
	$POS = PLAYERPOS()
	$CLIENTSINDEXES = GETNEARBYALTS()
	$TOTALNUMBEROFALTSNEARBY = UBOUND($CLIENTSINDEXES)
	$FURTHESTALTSOFAR = ""
	$FURTHESTDISTANCESOFAR = 0
	$AOER = 0
	$PLAYERTARGET = 0
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "alts") THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		$ALTPOS = PLAYERPOS()
		$HPMP = GETHPMP()
		$DISTANCE = DISTANCEBETWEEN($POS[0], $POS[1], $ALTPOS[0], $ALTPOS[1])
		IF $DISTANCE > $FURTHESTDISTANCESOFAR THEN
			$FURTHESTDISTANCESOFAR = $DISTANCE
			$FURTHESTALTSOFAR = $CLIENTS[$INDEX][2]
			IF $HPMP[0] <> $HPMP[1] THEN
				$AOER = $CLIENTS[$INDEX][2]
			ENDIF
		ENDIF
	NEXT
	IF $TOTALNUMBEROFALTSNEARBY < $ALTSAMOUNT THEN
		$ALTSAMOUNT = $TOTALNUMBEROFALTSNEARBY
	ENDIF
	SWITCHTO($MAIN)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		IF $COUNT >= $ALTSAMOUNT THEN EXITLOOP
		$INDEX = $CLIENTSINDEXES[$I]
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "alts") THEN CONTINUELOOP
		IF $CLIENTS[$INDEX][2] == $FURTHESTALTSOFAR AND $ALTSAMOUNT < 8 AND $TOTALNUMBEROFALTSNEARBY >= 9 THEN CONTINUELOOP
		IF $CLIENTS[$INDEX][2] == $FURTHESTALTSOFAR AND $ALTSAMOUNT >= 8 THEN
			SWITCHTONUM($INDEX)
			CANCELACTION()
			SLEEP(10)
			CANCELACTION()
			SLEEP(10)
			IF NOT HASBUFF("Paralyzed", 255) THEN
				MOVETO($POS[0], $POS[1])
				FOLLOWPLAYER($TARGET)
				IF DISTANCE2D($POS[0], $POS[1]) > 15 THEN SPEEDPATH()
				$COUNT += 1
			ENDIF
		ENDIF
		IF $CLIENTS[$INDEX][2] == $FURTHESTALTSOFAR AND $CLIENTS[$INDEX][2] <> $AOER THEN
			SWITCHTONUM($INDEX)
			$MOBTARGET = PLAYERTARGET()
			IF NOT HASBUFF("Paralyzed", 255) AND NOT ACTIONFLAG() THEN
				CANCELACTION()
				FOLLOWPLAYER($TARGET)
				IF DISTANCE2D($POS[0], $POS[1]) > 9.8 THEN SPEEDPATH()
				$COUNT += 1
			ENDIF
		ENDIF
		IF $CLIENTS[$INDEX][2] <> $FURTHESTALTSOFAR THEN
			SWITCHTONUM($INDEX)
			$MOBTARGET = PLAYERTARGET()
			IF NOT HASBUFF("Paralyzed", 255) AND NOT ACTIONFLAG() THEN
				CANCELACTION()
				FOLLOWPLAYER($TARGET)
				IF DISTANCE2D($POS[0], $POS[1]) > 9.8 THEN SPEEDPATH()
				$COUNT += 1
			ENDIF
		ENDIF
	NEXT
	SWITCHTO($MAIN)
	SETSTATUS($COUNT & " alts following.")
ENDFUNC
FUNC FAKEMOVEKEY()
	$PLAYER = PLAYERADDRESS()
	FOR $I = 0 TO 3
		_MEMORYWRITE($PLAYER + $PLAYERMOVEKEYDIRECTION, $GAME_PROCESS, 1)
	NEXT
ENDFUNC
