FUNC ISGLYPHEDSKILL($SKILL_ID)
	IF $SKILL_ID < 3391 THEN RETURN FALSE
	$CLASS = CLASS()
	$LEN = UBOUND($GLYPH_SKILL_FAMILY, 2) - 6
	FOR $IDX = 0 TO $LEN STEP 6
		IF $SKILL_ID == $GLYPH_SKILL_FAMILY[$CLASS][$IDX] THEN
			FOR $J = 1 TO 5
				IF ISGLYPHSKILL($GLYPH_SKILL_FAMILY[$CLASS][$IDX + $J]) THEN
					RETURN $GLYPH_SKILL_FAMILY[$CLASS][$IDX + $J]
				ENDIF
			NEXT
			RETURN 0
		ELSEIF $GLYPH_SKILL_FAMILY[$CLASS][$IDX] > $SKILL_ID THEN
			RETURN 0
		ENDIF
	NEXT
	RETURN 0
ENDFUNC
FUNC ISGLYPHSKILL($SKILL_ID)
	IF $SKILL_ID < 3391 THEN RETURN FALSE
	$PLAYER = PLAYERADDRESS()
	$SKILLOFFSET = $PLAYERGLYPHEDSKILL_OFFSET
	$SKILLBASE = _MEMORYREAD($PLAYER + $SKILLOFFSET, $GAME_PROCESS)
	$SKILLCOUNT = _MEMORYREAD($PLAYER + $SKILLOFFSET + 4, $GAME_PROCESS)
	FOR $I = 0 TO $SKILLCOUNT - 1
		$SKILL = _MEMORYREAD($SKILLBASE + 4 * $I, $GAME_PROCESS)
		$ID = _MEMORYREAD($SKILL + $SKILLID_OFFSET, $GAME_PROCESS)
		IF $ID == $SKILL_ID THEN RETURN TRUE
	NEXT
	RETURN FALSE
ENDFUNC
FUNC SKILLOFFCOOLDOWN($SKILL_ID, $TYPE = 0, $TRANSLATE = TRUE)
	$PLAYER = PLAYERADDRESS()
	$SKILLOFFSET = $PLAYERSKILL_OFFSET
	IF $TYPE == 0 THEN
		$GLYPHEDID = ISGLYPHEDSKILL($SKILL_ID)
		IF $GLYPHEDID THEN
			IF $TRANSLATE THEN
				$SKILL_ID = $GLYPHEDID
				$TYPE = 2
			ELSE
				RETURN 0
			ENDIF
		ELSEIF ISGLYPHSKILL($SKILL_ID) THEN
			$TYPE = 2
		ENDIF
	ENDIF
	IF $TYPE == 1 THEN
		$SKILLOFFSET = $PLAYERGENIESKILL_OFFSET
	ELSEIF $TYPE == 2 THEN
		$SKILLOFFSET = $PLAYERGLYPHEDSKILL_OFFSET
	ELSEIF $TYPE == 3 THEN
		$SKILLOFFSET = $PLAYERITEMSKILL_OFFSET
	ELSEIF $TYPE == 4 THEN
		$SKILLOFFSET = $PLAYERFACTIONSKILL_OFFSET
	ELSEIF $TYPE == 5 THEN
		$SKILLOFFSET = $PLAYERPETSKILL_OFFSET
	ELSEIF $TYPE == 6 THEN
		$SKILLOFFSET = $PLAYERPASSIVESKILL_OFFSET
	ENDIF
	$SKILLBASE = _MEMORYREAD($PLAYER + $SKILLOFFSET, $GAME_PROCESS)
	$SKILLCOUNT = _MEMORYREAD($PLAYER + $SKILLOFFSET + 4, $GAME_PROCESS)
	$SKILL = 0
	FOR $I = 0 TO $SKILLCOUNT - 1
		$SKILL = _MEMORYREAD($SKILLBASE + 4 * $I, $GAME_PROCESS)
		$ID = _MEMORYREAD($SKILL + $SKILLID_OFFSET, $GAME_PROCESS)
		IF $ID == $SKILL_ID THEN EXITLOOP
	NEXT
	IF $SKILL == 0 OR $ID <> $SKILL_ID THEN RETURN 0
	$COOLDOWN = _MEMORYREAD($SKILL + $SKILLCURCD_OFFSET, $GAME_PROCESS)
	IF $COOLDOWN > 0 THEN RETURN 0
	IF $TYPE <> 1 AND SKILLCHINEEDED($SKILL) > CHI() THEN RETURN 0
	SETEXTENDED($SKILL_ID)
	RETURN $SKILL
ENDFUNC
FUNC SKILLCOOLDOWNTIME($SKILL_ID, $TYPE = 0, $TRANSLATE = TRUE)
	$PLAYER = PLAYERADDRESS()
	$SKILLOFFSET = $PLAYERSKILL_OFFSET
	IF $TYPE == 0 THEN
		$GLYPHEDID = ISGLYPHEDSKILL($SKILL_ID)
		IF $GLYPHEDID THEN
			IF $TRANSLATE THEN
				$SKILL_ID = $GLYPHEDID
				$TYPE = 2
			ELSE
				RETURN -1
			ENDIF
		ELSEIF ISGLYPHSKILL($SKILL_ID) THEN
			$TYPE = 2
		ENDIF
	ENDIF
	IF $TYPE == 1 THEN
		$SKILLOFFSET = $PLAYERGENIESKILL_OFFSET
	ELSEIF $TYPE == 2 THEN
		$SKILLOFFSET = $PLAYERGLYPHEDSKILL_OFFSET
	ELSEIF $TYPE == 3 THEN
		$SKILLOFFSET = $PLAYERITEMSKILL_OFFSET
	ELSEIF $TYPE == 4 THEN
		$SKILLOFFSET = $PLAYERFACTIONSKILL_OFFSET
	ELSEIF $TYPE == 5 THEN
		$SKILLOFFSET = $PLAYERPETSKILL_OFFSET
	ELSEIF $TYPE == 6 THEN
		$SKILLOFFSET = $PLAYERPASSIVESKILL_OFFSET
	ENDIF
	$SKILLBASE = _MEMORYREAD($PLAYER + $SKILLOFFSET, $GAME_PROCESS)
	$SKILLCOUNT = _MEMORYREAD($PLAYER + $SKILLOFFSET + 4, $GAME_PROCESS)
	$SKILL = 0
	FOR $I = 0 TO $SKILLCOUNT - 1
		$SKILL = _MEMORYREAD($SKILLBASE + 4 * $I, $GAME_PROCESS)
		$ID = _MEMORYREAD($SKILL + $SKILLID_OFFSET, $GAME_PROCESS)
		IF $ID == $SKILL_ID THEN EXITLOOP
	NEXT
	IF $SKILL == 0 OR $ID <> $SKILL_ID THEN RETURN -1
	$COOLDOWN = _MEMORYREAD($SKILL + $SKILLCURCD_OFFSET, $GAME_PROCESS)
	RETURN $COOLDOWN
ENDFUNC
FUNC SKILLCHINEEDED($SKILL)
	RETURN _MEMORYREAD(_MEMORYREAD(_MEMORYREAD($SKILL + 4, $GAME_PROCESS) + 4, $GAME_PROCESS) + 52, $GAME_PROCESS)
ENDFUNC
FUNC SKILLCASTCONDITION($SKILL)
	DIM $PARAMS[1] = [$SKILL]
	RETURN CALLCLASSMETHOD(PLAYERADDRESS(), $ADDRESS_SKILLCASTCONDITION, $PARAMS, TRUE)
ENDFUNC
FUNC CURRENTSKILL()
	$PLAYER = PLAYERADDRESS()
	$SKILL = _MEMORYREAD($PLAYER + $PLAYERCURRENTSKILL_OFFSET, $GAME_PROCESS)
	IF $SKILL == 0 THEN
		RETURN 0
	ENDIF
	RETURN _MEMORYREAD($SKILL + $SKILLID_OFFSET, $GAME_PROCESS)
ENDFUNC
FUNC SKILLCASTTYPE()
	$PLAYER = PLAYERADDRESS()
	$SKILL = _MEMORYREAD($PLAYER + $PLAYERCURRENTSKILL_OFFSET, $GAME_PROCESS)
	IF $SKILL == 0 THEN
		RETURN 0
	ENDIF
	$SKILLDATA = _MEMORYREAD($SKILL + 4, $GAME_PROCESS)
	$SKILLDATADATA = _MEMORYREAD($SKILLDATA + 4, $GAME_PROCESS)
	$SKILLCASTTYPE = _MEMORYREAD($SKILLDATADATA + 89, $GAME_PROCESS, "byte")
	RETURN $SKILLCASTTYPE
ENDFUNC
FUNC SKILLCASTTYPE2($SKILL)
	$PLAYER = PLAYERADDRESS()
	IF $SKILL == 0 THEN
		RETURN 0
	ENDIF
	$SKILLDATA = _MEMORYREAD($SKILL + 4, $GAME_PROCESS)
	$SKILLDATADATA = _MEMORYREAD($SKILLDATA + 4, $GAME_PROCESS)
	$SKILLCASTTYPE = _MEMORYREAD($SKILLDATADATA + 89, $GAME_PROCESS, "byte")
	RETURN $SKILLCASTTYPE
ENDFUNC
FUNC ISCHARGINGSKILL()
	RETURN SKILLCASTTYPE() == 3
ENDFUNC
FUNC QUEUEDSKILL()
	$WORK = _MEMORYREAD(PLAYERADDRESS() + $OFFSET_ACTIONBASE, $GAME_PROCESS)
	$SKILLWORK = _MEMORYREAD($WORK + 64, $GAME_PROCESS)
	$SKILL = _MEMORYREAD($SKILLWORK + 52, $GAME_PROCESS)
	IF $SKILL == 0 THEN
		RETURN 0
	ENDIF
	RETURN _MEMORYREAD($SKILL + $SKILLID_OFFSET, $GAME_PROCESS)
ENDFUNC
FUNC INCOMBAT()
	$PLAYER = PLAYERADDRESS()
	RETURN _MEMORYREAD($PLAYER + $PLAYERCOMBATSTATUS_OFFSET, $GAME_PROCESS, "byte")
ENDFUNC
FUNC TELESTONECOOLDOWN()
	$PLAYER = PLAYERADDRESS()
	RETURN _MEMORYREAD($PLAYER + $PLAYERTELEPORTITEMCOOLDOWN_OFFSET, $GAME_PROCESS, "byte")
ENDFUNC
FUNC SKILLTARGET()
	$PLAYER = PLAYERADDRESS()
	$TARGET = _MEMORYREAD($PLAYER + $PLAYERCURRENTSKILL_OFFSET + 4, $GAME_PROCESS)
	RETURN $TARGET
ENDFUNC
FUNC CASTSKILL($SKILL_ID, $TYPE = 0)
	$SKILL = SKILLOFFCOOLDOWN($SKILL_ID, $TYPE)
	$SKILL_ID = @EXTENDED
	IF $SKILL == 0 THEN RETURN 0
	IF $TYPE <> 1 THEN
		$CONDITION = SKILLCASTCONDITION($SKILL)
		IF SKILLCASTCONDITION($SKILL) <> 0 THEN
			RETURN SETEXTENDED($CONDITION, 0)
		ENDIF
	ENDIF
	IF $TYPE == 0 OR $TYPE == 2 OR $TYPE == 3 OR $TYPE == 4 OR $TYPE == 5 OR $TYPE == 6 THEN
		CASTSKILLWITHPOINTER($SKILL, $SKILL_ID)
	ELSE
		USEGENIESKILL($SKILL_ID, PLAYERID())
	ENDIF
	RETURN 1
ENDFUNC
FUNC CANCELCASTSKILL($SKILL_ID, $TYPE, $SLEEP_DURATION, $TRIPLESPARK = FALSE)
	$SLEEP_TIME = $SLEEP_DURATION / 2
	WHILE MOVEKEY() == 0 AND GETHPMP()[0] > 0
		IF $TRIPLESPARK THEN
			IF CHI() > 390 THEN
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(25)
				WEND
				SLEEP(2800)
			ENDIF
		ENDIF
		CASTSKILL($SKILL_ID, $TYPE)
		SLEEP($SLEEP_TIME)
		CANCELACTION()
		SLEEP($SLEEP_TIME)
	WEND
ENDFUNC
FUNC CANCELCASTSKILL2($SKILL_ID, $TYPE, $SLEEP_DURATION)
	$RIGHTMOVE = 0.05
	$LEFTMOVE = -0.05
	$GORIGHT = TRUE
	WHILE MOVEKEY() == 0 AND GETHPMP()[0] > 0
		$POS = PLAYERPOS()
		CASTSKILL($SKILL_ID, $TYPE)
		CASTSKILL($SKILL_ID, $TYPE)
		SLEEP($SLEEP_DURATION)
		CANCELACTION()
		CANCELACTION()
		IF $GORIGHT THEN
			MOVETO2($POS[0] + $RIGHTMOVE, $POS[1])
			$GORIGHT = FALSE
		ELSE
			MOVETO2($POS[0] + $LEFTMOVE, $POS[1])
			$GORIGHT = TRUE
		ENDIF
	WEND
ENDFUNC
