FUNC HANDLEMATREYA()
	SETSTATUS("Heavenfall Tower - Room #" & CURRENTROOMNUMBER() & ": Matreya")
	STARTLISTENING()
	$SOUL = 8
	$STEP = 8
	$OLDKEYFRAME = 0
	$HTIMER = 0
	$HBOSSTIMER = 0
	$TIMER = TIMERINIT()
	$GLITCHTIMER = TIMERINIT()
	$ROOMNUMBER = CURRENTROOMNUMBER()
	STARTLISTENING()
	$POS = PLAYERPOS()
	$FLOORHEIGHT = $POS[2]
	$TRIPLESPARKCOUNT = 0
	$TRIPLESPARKTIMER = TIMERINIT()
	$FIGHTACTIVATED = FALSE
	WHILE HASQUEST(33795) AND TIMERDIFF($GLITCHTIMER) < 360000
		$PLAYERTARGET = PLAYERTARGET()
		IF NOT $PLAYERTARGET AND NOT ACTIONFLAG() THEN
			IF USEMACRO7CHI() THEN BUILDCHI(2000, 399)
			SLEEP(100)
		ENDIF
		IF GETNPCUNIQUEID("Master of Solitude") THEN EXITLOOP
		$INSTANCE = INSTANCEID()
		IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
			SETSTATUS("Kicked out of tower.")
			EXITLOOP
		ENDIF
		HEIGHTCHECK($FLOORHEIGHT)
		HEALUP()
		IF USEGENIECHI() THEN GENIECHISKILL()
		IF GETNPCUNIQUEID("Matreya the Corrupt") THEN
			IF NOT $HBOSSTIMER THEN $HBOSSTIMER = TIMERINIT()
			$SOUL = 8
			$STEP = 8
			$FRAME = NPCATTACKFRAME("Matreya the Corrupt")
			IF($FRAME <> $OLDKEYFRAME AND $FRAME == 56000 AND NPCDISTANCE("Matreya the Corrupt") < 17) THEN
				CANCELACTION()
				WHILE CURRENTSKILL()
					SLEEP(100)
					CANCELACTION()
				WEND
				CIRCLEAVOID("Matreya the Corrupt", 17, 19, -358.04, -239.09, 41, 2, 20, FALSE)
				$HTIMER = TIMERINIT()
			ELSEIF($HTIMER AND TIMERDIFF($HTIMER) < 5000) AND(ISMELEECLASS() OR NPCDISTANCE("Matreya the Corrupt") < 17) THEN
				IF TIMERDIFF($HTIMER) > 1000 AND NPCDISTANCE("Matreya the Corrupt") < 9 THEN
					SpeedPATH()
				ENDIF
				CIRCLEAVOID("Matreya the Corrupt", 17, 19, -358.04, -239.09, 41, 2, 20, FALSE)
				IF TIMERDIFF($HTIMER) < 3500 AND TIMERDIFF($HTIMER) > 2500 AND ACTIONFLAG() <> 0 THEN
					SENDTOWERBUFF(4)
				ENDIF
			ELSE
				IF NOT $FIGHTACTIVATED THEN
					$TRIPLESPARKTIMER = TIMERINIT()
					$FIGHTACTIVATED = TRUE
				ENDIF
				IF $TRIPLESPARKCOUNT == 0 AND CHI() > 300 THEN
					CANCELACTION()
					WHILE CHI() > 300
						TRIPLESPARK()
						SLEEP(50)
					WEND
					$TRIPLESPARKCOUNT += 1
				ENDIF
				IF TIMERDIFF($TRIPLESPARKTIMER) >= 7000 AND NPCALIVE("Matreya the Corrupt") THEN
					CANCELACTION()
					WHILE CHI() > 300
						TRIPLESPARK()
						SLEEP(50)
					WEND
					$TRIPLESPARKTIMER = TIMERINIT()
				ENDIF
				$TARGET = GETNPCUNIQUEID("Matreya the Corrupt")
				KILL("Matreya the Corrupt", 200, 2, 3)
				IF SEETEXT("Target is too close") THEN
					TOWERUNSTUCK(2)
					$TIMER = TIMERINIT()
					$POS = PLAYERPOS()
				ENDIF
				IF TIMERDIFF($TIMER) > 10000 THEN
					IF AREWESTUCK($TIMER, $POS[0], $POS[1]) THEN
						TOWERUNSTUCK(2)
					ENDIF
					$TIMER = TIMERINIT()
					$POS = PLAYERPOS()
				ENDIF
			ENDIF
			$OLDKEYFRAME = $FRAME
		ENDIF
		IF GETNPCUNIQUEID("Soul Container " & $SOUL) THEN
			KILLNAME("Soul Container " & $SOUL)
			$STEP = $STEP / 2
		ENDIF
		IF SEETEXT("seems to be pointing south") THEN
			$SOUL += $STEP
		ENDIF
		IF SEETEXT("seems to be pointing north") THEN
			$SOUL -= $STEP
		ENDIF
	WEND
ENDFUNC
FUNC HANDLEBODHI()
	SETSTATUS("Heavenfall Tower - Room #" & CURRENTROOMNUMBER() & ": Bodhi of Grief")
	STARTLISTENING()
	$IMMUNE = TRUE
	$ROOMNUMBER = CURRENTROOMNUMBER()
	$HTIMER = TIMERINIT()
	$TIMER = TIMERINIT()
	$GLITCHTIMER = TIMERINIT()
	$POS = PLAYERPOS()
	$FLOORHEIGHT = $POS[2]
	$TRIPLESPARKCOUNT = 0
	$TRIPLESPARKTIMER = TIMERINIT()
	$FIGHTACTIVATED = FALSE
	WHILE HASQUEST(33814) AND TIMERDIFF($GLITCHTIMER) < 360000
		$PLAYERTARGET = PLAYERTARGET()
		IF NOT $PLAYERTARGET AND NOT ACTIONFLAG() THEN
			IF USEMACRO7CHI() THEN BUILDCHI(2000, 399)
			SLEEP(100)
		ENDIF
		IF GETNPCUNIQUEID("Master of Solitude") THEN EXITLOOP
		$INSTANCE = INSTANCEID()
		IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
			SETSTATUS("Kicked out of tower.")
			EXITLOOP
		ENDIF
		HEIGHTCHECK($FLOORHEIGHT)
		HEALUP()
		IF USEGENIECHI() THEN GENIECHISKILL()
		$BODPOS = GETNPCPOSITION(47947, 1)
		IF NOT UBOUND($BODPOS) THEN
			CONTINUELOOP
		ENDIF
		$TARGET = GETNPCUNIQUEID("NoName 47956", 100, $BODPOS)
		$SEEDPOS = GETNPCPOSITION($TARGET, 0)
		IF SEETEXT("powers have been neutralized!") THEN
			$IMMUNE = FALSE
		ELSEIF SEETEXT("Bodhi of Grief is unleashing") THEN
			$ATTACKTIMER = TIMERINIT()
			WHILE TIMERDIFF($ATTACKTIMER) < 6000
				CIRCLEAVOID(47947, 22, 25, -344.95, 143.96, 41, 1, 0)
				SLEEP(100)
			WEND
		ELSEIF UBOUND($SEEDPOS) AND $IMMUNE AND TIMERDIFF($HTIMER) > 6000 THEN
			$CROSSDIST = DISTANCEBETWEEN3D($BODPOS, $SEEDPOS)
			MOVETO($BODPOS[0] + ($CROSSDIST + 10) / $CROSSDIST * ($SEEDPOS[0] - $BODPOS[0]), $BODPOS[1] + ($CROSSDIST + 10) / $CROSSDIST * ($SEEDPOS[1] - $BODPOS[1]))
			SLEEP(500)
		ELSEIF SEETEXT("powers have reactivated!") THEN
			$HTIMER = TIMERINIT()
			$IMMUNE = TRUE
		ELSE
			$TARGET = 47947
			IF NOT $FIGHTACTIVATED THEN
				$TRIPLESPARKTIMER = TIMERINIT()
				$FIGHTACTIVATED = TRUE
			ENDIF
			IF $TRIPLESPARKCOUNT == 0 THEN
				CANCELACTION()
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
				$TRIPLESPARKCOUNT += 1
			ENDIF
			IF TIMERDIFF($TRIPLESPARKTIMER) >= 7000 AND NPCALIVE("Bodhi of Grief") THEN
				CANCELACTION()
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
				$TRIPLESPARKTIMER = TIMERINIT()
			ENDIF
			MONKEYTELEPORTSKILL()
			KILL(47947, 200, 1, 0)
			IF SEETEXT("Target is too close") THEN
				TOWERUNSTUCK(1.5)
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
			IF TIMERDIFF($TIMER) > 10000 THEN
				IF AREWESTUCK($TIMER, $POS[0], $POS[1]) THEN
					TOWERUNSTUCK(1.5)
				ENDIF
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
		ENDIF
		SLEEP(100)
	WEND
ENDFUNC
FUNC HANDLEMARAPAPMAN()
	SETSTATUS("Heavenfall Tower - Room #" & CURRENTROOMNUMBER() & ": Mara Papman")
	STARTLISTENING()
	$ROOMNUMBER = CURRENTROOMNUMBER()
	$BUFFACTIVE = FALSE
	$TIMER = TIMERINIT()
	$GLITCHTIMER = TIMERINIT()
	$POS = PLAYERPOS()
	$FLOORHEIGHT = $POS[2]
	$TRIPLESPARKCOUNT = 0
	$TRIPLESPARKTIMER = TIMERINIT()
	$FIGHTACTIVATED = FALSE
	$CLASS = CLASS()
	$ALREADYRESETBUFFS = FALSE
	$ALREADYAPPLIEDBUFFS = FALSE
	$MOVEDTOBOSSAREA = FALSE
	$ISMELEECLASS = ISMELEECLASS()
	WHILE HASQUEST(33841) AND TIMERDIFF($GLITCHTIMER) < 900000
		$PLAYERTARGET = PLAYERTARGET()
		IF NOT $PLAYERTARGET AND NOT ACTIONFLAG() THEN
			IF USEMACRO7CHI() THEN BUILDCHI(2000, 399)
			SLEEP(100)
		ENDIF
		IF GETNPCUNIQUEID("Master of Solitude") THEN EXITLOOP
		$INSTANCE = INSTANCEID()
		IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
			SETSTATUS("Kicked out of tower.")
			EXITLOOP
		ENDIF
		HEIGHTCHECK($FLOORHEIGHT)
		HEALUP()
		IF USEGENIECHI() THEN GENIECHISKILL()
		IF NPCALIVE(48063, 1) THEN
			BUFFCHECK(TRUE)
			IF ISSTRONGCHARACTER() THEN SWAPGEAR(0)
			IF ISSTRONGCHARACTER() AND NOT $ALREADYAPPLIEDBUFFS THEN
				SWAPGEAR(0)
				IF NOT INHUMANFORM() THEN
					SWITCHTOHUMANFORM()
					SLEEP(500)
				ENDIF
				SWAPGEAR(0)
				HANDLEBUFFS()
				IF $CLASS == 3 THEN SUMMONPETWITHREVIVE(0)
				$ALREADYAPPLIEDBUFFS = TRUE
			ENDIF
			IF $ISMELEECLASS AND NOT $MOVEDTOBOSSAREA THEN MOVETO(58.85, -238.43)
			IF DISTANCE2D(58.85, -238.43) < 8 THEN $MOVEDTOBOSSAREA = TRUE
			IF ISSTRONGCHARACTER() THEN SWAPGEAR(0)
			IF NOT $FIGHTACTIVATED THEN
				$TRIPLESPARKTIMER = TIMERINIT()
				$FIGHTACTIVATED = TRUE
			ENDIF
			IF $TRIPLESPARKCOUNT == 0 THEN
				CANCELACTION()
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
				SLEEP(500)
				IF CHI() < 300 THEN
					$TRIPLESPARKCOUNT += 1
				ENDIF
			ENDIF
			IF $TRIPLESPARKCOUNT == 0 AND CHI() < 300 THEN
				GENIECHISKILL()
				SLEEP(200)
				IF CHI() > 300 THEN
					WHILE CHI() > 300
						TRIPLESPARK()
						SLEEP(50)
					WEND
					SLEEP(500)
					IF CHI() < 300 THEN
						$TRIPLESPARKCOUNT += 1
					ENDIF
				ENDIF
			ENDIF
			IF TIMERDIFF($TRIPLESPARKTIMER) >= 10000 THEN
				CANCELACTION()
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
				$TRIPLESPARKTIMER = TIMERINIT()
			ENDIF
			KILL(48063, 100, 1, 3)
			IF SEETEXT("Target is too close") THEN
				TOWERUNSTUCK(2)
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
			IF TIMERDIFF($TIMER) > 30000 THEN
				IF AREWESTUCK($TIMER, $POS[0], $POS[1]) THEN
					TOWERUNSTUCK(2)
				ENDIF
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
		ELSE
			IF ISSTRONGCHARACTER() AND NOT $ALREADYRESETBUFFS THEN
				SWAPGEAR(1)
				IF NOT INHUMANFORM() THEN
					SWITCHTOHUMANFORM()
					SLEEP(500)
				ENDIF
				SWAPGEAR(1)
				RESETBUFFS()
				SLEEP(1000)
				IF $CLASS == 3 THEN SUMMONPETWITHREVIVE(0)
				$MAXBUFF = 10
				HANDLEBUFFS($MAXBUFF)
				$ALREADYRESETBUFFS = TRUE
			ENDIF
			IF $CLASS == 5 THEN
				IF HASBUFF("Chill of the Deep. Reduces attack speed, increases attack level.", 165) THEN
					DIM $CHILLOFDEEPIDS = [1113, 2438, 2439, 1292]
					CASTFIRSTSKILL($CHILLOFDEEPIDS)
					$TRYTOBUFFTIMER = TIMERINIT()
					WHILE HASBUFF("Chill of the Deep. Reduces attack speed, increases attack level.", 165)
						IF TIMERDIFF($TRYTOBUFFTIMER) > 20000 THEN EXITLOOP
						CASTFIRSTSKILL($CHILLOFDEEPIDS)
					WEND
				ENDIF
			ENDIF
			IF SEETEXT("save the adventurers") THEN
				$BUFFACTIVE = TRUE
				IF NOT HASBUFF("", 44) AND $CLASS <> 6 AND $CLASS <> 12 THEN SpeedPATH()
			ELSEIF NOT GETNPCUNIQUEID("Mara Papman's Soul") THEN
				$BUFFACTIVE = FALSE
			ENDIF
			IF GETNPCUNIQUEID("Soul Prison") THEN
				MOVETONPC("Soul Prison")
			ELSEIF $BUFFACTIVE THEN
				DIM $ADVENTURERS[4] = ["Adventurer Petalfall", "Adventurer Streamfly", "Adventurer Wavebreak", "Adventurer Darkblade"]
				$TIMER = TIMERINIT()
				FOR $I = 0 TO 3
					WHILE GETNPCUNIQUEID($ADVENTURERS[$I]) AND GETNPCUNIQUEID("Mara Papman's Soul") AND $BUFFACTIVE
						REGULARATTACKTARGET(GETNPCUNIQUEID($ADVENTURERS[$I]))
						SLEEP(200)
						IF SEETEXT("was freed from its confinement!") THEN $BUFFACTIVE = FALSE
						IF NPCALIVE(48063, 1) THEN $BUFFACTIVE = FALSE
						IF TIMERDIFF($TIMER) > 20000 THEN $BUFFACTIVE = FALSE
					WEND
				NEXT
				WHILE NPCNAME("Mara Papman's Soul") AND $BUFFACTIVE AND NOT NPCALIVE(48063, 1)
					KILL(48063, 100, 1, 0)
					SLEEP(200)
					IF SEETEXT("was freed from its confinement!") THEN $BUFFACTIVE = FALSE
					IF TIMERDIFF($TIMER) > 20000 THEN $BUFFACTIVE = FALSE
				WEND
			ELSE
				IF ISSTRONGCHARACTER() THEN SWAPGEAR(1)
				KILL("Mara Papman's Soul", 200, 2, 0)
				IF SEETEXT("Target is too close") THEN
					TOWERUNSTUCK(2)
					$TIMER = TIMERINIT()
					$POS = PLAYERPOS()
				ENDIF
				IF TIMERDIFF($TIMER) > 30000 THEN
					IF AREWESTUCK($TIMER, $POS[0], $POS[1]) THEN
						TOWERUNSTUCK(2)
					ENDIF
					$TIMER = TIMERINIT()
					$POS = PLAYERPOS()
				ENDIF
			ENDIF
		ENDIF
		SLEEP(100)
	WEND
	IF ISSTRONGCHARACTER() THEN
		SWITCHTOHUMANFORM()
		SLEEP(500)
		SWAPGEAR(0)
	ENDIF
ENDFUNC
FUNC HANDLEKINGS()
	SETSTATUS("Heavenfall Tower - Room #" & CURRENTROOMNUMBER() & ": Kings")
	SLEEP(2000)
	$USEDSPELL = FALSE
	$SEHKFRAME = 0
	$SEHKSPIRITFRAME = 0
	$TIMER = TIMERINIT()
	$GLITCHTIMER = TIMERINIT()
	$ROOMNUMBER = CURRENTROOMNUMBER()
	STARTLISTENING()
	$POS = PLAYERPOS()
	$FLOORHEIGHT = $POS[2]
	$TRIPLESPARKCOUNT = 0
	$TRIPLESPARKTIMER = TIMERINIT()
	$FIGHTACTIVATED = FALSE
	WHILE HASQUEST(33805) AND TIMERDIFF($GLITCHTIMER) < 480000
		IF GETNPCUNIQUEID("Master of Solitude") THEN EXITLOOP
		$INSTANCE = INSTANCEID()
		IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
			SETSTATUS("Kicked out of tower.")
			EXITLOOP
		ENDIF
		IF NOT GETNPCUNIQUEID("Marei Sehk of the Howling Sea") AND NOT GETNPCUNIQUEID("Marei Tsou of the Noxious Swamp") AND NOT GETNPCUNIQUEID("Marei Hrul of Scorching Peaks") AND NOT GETNPCUNIQUEID("Marei Ciah of the Glacial Waste") THEN
			EXITLOOP
		ENDIF
		HEIGHTCHECK($FLOORHEIGHT)
		HEALUP()
		IF NOT HASBUFF("Invincible", 305) THEN
			IF GETNPCUNIQUEID("NoName 48010") AND GETNPCUNIQUEID("NoName 48016") THEN
				MOVETONPC2("NoName 48016", FALSE, 2, 2, 0, 20)
			ELSE
				IF CIRCLEAVOID(48017, 5, 5.5, -87.81, 182.2, 40, 1, 0) THEN CONTINUELOOP
				$OLDVAL = $SEHKFRAME
				$SEHKFRAME = NPCATTACKFRAME("Marei Sehk of the Howling Sea")
				IF $SEHKFRAME <> $OLDVAL THEN
					IF CIRCLEAVOID("Marei Sehk of the Howling Sea", 10, 33, -87.81, 182.2, 40) THEN CONTINUELOOP
				ENDIF
				$OLDVAL = $SEHKSPIRITFRAME
				$SEHKSPIRITFRAME = NPCATTACKFRAME("Marei Sehk's Spirit")
				IF $SEHKFRAME <> $OLDVAL THEN
					IF CIRCLEAVOID("Marei Sehk's Spirit", 10, 33, -87.81, 182.2, 40) THEN CONTINUELOOP
				ENDIF
				IF CURRENTROOMNUMBER() <> $ROOMNUMBER THEN EXITLOOP
			ENDIF
		ENDIF
		IF GETNPCUNIQUEID("Marei Sehk of the Howling Sea") THEN
			$TARGET = GETNPCUNIQUEID("Marei Sehk of the Howling Sea")
			IF NOT $FIGHTACTIVATED THEN
				$FIGHTACTIVATED = TRUE
				SLEEP(2000)
			ENDIF
			IF $TRIPLESPARKCOUNT == 0 AND CHI() > 300 THEN
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
				$TRIPLESPARKCOUNT += 1
			ENDIF
			IF TIMERDIFF($TRIPLESPARKTIMER) >= 7000 AND CHI() > 300 THEN
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
				$TRIPLESPARKTIMER = TIMERINIT()
			ENDIF
			MONKEYTELEPORTSKILL()
			KILL("Marei Sehk of the Howling Sea", 200, 2, 0)
			IF SEETEXT("Target is too close") THEN
				TOWERUNSTUCK(2)
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
			IF TIMERDIFF($TIMER) > 10000 THEN
				IF AREWESTUCK($TIMER, $POS[0], $POS[1]) THEN
					TOWERUNSTUCK(2)
				ENDIF
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
			IF CURRENTROOMNUMBER() <> $ROOMNUMBER THEN EXITLOOP
		ELSEIF GETNPCUNIQUEID("Marei Tsou of the Noxious Swamp") THEN
			$TARGET = GETNPCUNIQUEID("Marei Tsou of the Noxious Swamp")
			IF TIMERDIFF($TRIPLESPARKTIMER) >= 12000 AND CHI() > 300 THEN
				TRIPLESPARK()
				$TRIPLESPARKTIMER = TIMERINIT()
			ENDIF
			MONKEYTELEPORTSKILL()
			KILL("Marei Tsou of the Noxious Swamp", 200, 2, 0)
			IF SEETEXT("Target is too close") THEN
				TOWERUNSTUCK(2)
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
			IF TIMERDIFF($TIMER) > 10000 THEN
				IF AREWESTUCK($TIMER, $POS[0], $POS[1]) THEN
					TOWERUNSTUCK(2)
				ENDIF
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
			IF CURRENTROOMNUMBER() <> $ROOMNUMBER THEN EXITLOOP
		ELSEIF GETNPCUNIQUEID("Marei Hrul of Scorching Peaks") THEN
			$TARGET = GETNPCUNIQUEID("Marei Hrul of Scorching Peaks")
			IF TIMERDIFF($TRIPLESPARKTIMER) >= 12000 AND CHI() > 300 THEN
				TRIPLESPARK()
				$TRIPLESPARKTIMER = TIMERINIT()
			ENDIF
			MONKEYTELEPORTSKILL()
			KILL("Marei Hrul of Scorching Peaks", 200, 2, 0)
			IF SEETEXT("Target is too close") THEN
				TOWERUNSTUCK(2)
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
			IF TIMERDIFF($TIMER) > 10000 THEN
				IF AREWESTUCK($TIMER, $POS[0], $POS[1]) THEN
					TOWERUNSTUCK(2)
				ENDIF
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
			IF CURRENTROOMNUMBER() <> $ROOMNUMBER THEN EXITLOOP
		ELSEIF GETNPCUNIQUEID("Marei Ciah of the Glacial Waste") THEN
			IF NOT $USEDSPELL THEN
				SENDTOWERBUFF(4)
				$USEDSPELL = TRUE
				SLEEP(100)
			ENDIF
			$TARGET = GETNPCUNIQUEID("Marei Ciah of the Glacial Waste")
			IF TIMERDIFF($TRIPLESPARKTIMER) >= 12000 AND CHI() > 300 THEN
				TRIPLESPARK()
				$TRIPLESPARKTIMER = TIMERINIT()
			ENDIF
			MONKEYTELEPORTSKILL()
			KILL("Marei Ciah of the Glacial Waste", 200, 2, 0)
			IF SEETEXT("Target is too close") THEN
				TOWERUNSTUCK(2)
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
			IF TIMERDIFF($TIMER) > 10000 THEN
				IF AREWESTUCK($TIMER, $POS[0], $POS[1]) THEN
					TOWERUNSTUCK(2)
				ENDIF
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
		ENDIF
		SLEEP(150)
	WEND
ENDFUNC
FUNC HANDLEHIGHSAGEESHER()
	SETSTATUS("Heavenfall Tower - Room #" & CURRENTROOMNUMBER() & ": High Sage Esher")
	$ROOMNUMBER = CURRENTROOMNUMBER()
	$TIMER = TIMERINIT()
	$GLITCHTIMER = TIMERINIT()
	STARTLISTENING()
	$POS = PLAYERPOS()
	$FLOORHEIGHT = $POS[2]
	$TRIPLESPARKCOUNT = 0
	$TRIPLESPARKTIMER = TIMERINIT()
	$FIGHTACTIVATED = FALSE
	WHILE HASQUEST(33804) AND TIMERDIFF($GLITCHTIMER) < 600000
		$PLAYERTARGET = PLAYERTARGET()
		IF NOT $PLAYERTARGET AND NOT ACTIONFLAG() THEN
			IF USEMACRO7CHI() THEN BUILDCHI(2000, 399)
			SLEEP(100)
		ENDIF
		IF GETNPCUNIQUEID("Master of Solitude") THEN EXITLOOP
		$INSTANCE = INSTANCEID()
		IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
			SETSTATUS("Kicked out of tower.")
			EXITLOOP
		ENDIF
		HEIGHTCHECK($FLOORHEIGHT)
		HEALUP()
		IF USEGENIECHI() THEN GENIECHISKILL()
		IF GETNPCUNIQUEID("Mysterious Chest") AND GETNPCUNIQUEID("High Sage Esher") THEN
			GATHERALL("Dragonguard's Weapon", 30)
			IF ITEMCOUNT(47961) > 0 THEN
				$ESHERPOS = GETNPCPOSITION("High Sage Esher")
				$CHESTPOS = GETNPCPOSITION("Mysterious Chest")
				IF UBOUND($ESHERPOS) AND UBOUND($CHESTPOS) THEN
					$DIST = DISTANCEBETWEEN3D($ESHERPOS, $CHESTPOS)
					BUFFEREDSELECT(GETNPCUNIQUEID("Mysterious Chest"))
					MOVE($ESHERPOS[0] + ($DIST + 2) / $DIST * ($CHESTPOS[0] - $ESHERPOS[0]), $ESHERPOS[1] + ($DIST + 2) / $DIST * ($CHESTPOS[1] - $ESHERPOS[1]))
					USEITEMID(47961, 1)
				ENDIF
			ELSEIF GETNPCUNIQUEID("Celestial Dragonguard") THEN
				SMARTSELECT(GETNPCUNIQUEID("Celestial Dragonguard"))
				AOE()
			ENDIF
		ELSEIF GETNPCUNIQUEID("Golden Male Sage") THEN
			SMARTSELECT(GETNPCUNIQUEID("Golden Male Sage"))
			AOE()
		ELSEIF GETNPCUNIQUEID("Golden Female Sage") THEN
			SMARTSELECT(GETNPCUNIQUEID("Golden Female Sage"))
			AOE()
		ELSE
			$TARGET = 47968
			IF NOT $FIGHTACTIVATED THEN
				$TRIPLESPARKTIMER = TIMERINIT()
				$FIGHTACTIVATED = TRUE
			ENDIF
			IF $TRIPLESPARKCOUNT == 0 AND CHI() > 300 THEN
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
				$TRIPLESPARKCOUNT += 1
			ENDIF
			IF TIMERDIFF($TRIPLESPARKTIMER) >= 7000 AND CHI() > 300 THEN
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
				$TRIPLESPARKTIMER = TIMERINIT()
			ENDIF
			KILL(47968, 200, 1, 0)
			IF SEETEXT("Target is too close") THEN
				TOWERUNSTUCK(2)
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
			IF TIMERDIFF($TIMER) > 10000 THEN
				IF AREWESTUCK($TIMER, $POS[0], $POS[1]) THEN
					TOWERUNSTUCK(2)
				ENDIF
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
		ENDIF
		SLEEP(100)
	WEND
ENDFUNC
FUNC NORTHERNREALMTEAM()
	IF ISQUESTAVAILABLE(41949) THEN RETURN 2
	IF ISQUESTAVAILABLE(41944) THEN RETURN 1
	SETSTATUS("Can't enter Northern Realm")
	RETURN 0
ENDFUNC
FUNC TAKENORTHERNREALMWEEKLYREWARD()
	IF NORTHERNREALMTEAM() == 0 THEN RETURN
	$POINTS = NRPOINTS()
	IF $POINTS[7] == 1 THEN RETURN
	NORTHERNREALMREWARD()
ENDFUNC
FUNC ARCTICSCRAMBLE()
	$TEAM = NORTHERNREALMTEAM()
	IF $TEAM == 0 THEN RETURN
	$QUESTID = $TEAM == 1 ? 42021 : 42024
	IF NOT ISQUESTAVAILABLE($QUESTID) THEN RETURN
	SETSTATUS("Northern Realm - Arctic Scramble")
	TRANSFERMAP($MAP_NORTHERNREALM)
	$HEIGHT = RANDOM(45, 78, 1)
	$Y = RANDOM(-184, 239, 1)
	$X = RANDOM(-930, -376, 1)
	$CENTERX = 14
	$CENTERY = 50
	IF $TEAM == 1 THEN
		$X = 2 * $CENTERX - $X
	ENDIF
	$ASACTIVE = FALSE
	WHILE(INSTANCEVALUE(101681) + INSTANCEVALUE(101682)) == 0
		RETURNTOCAMP()
		SLEEP(10000)
		SETSTATUS("Northern Realms - Weekly Flags - Waiting...")
		RESURRECTIFDEAD()
	WEND
	WHILE NOT HASQUEST($QUESTID)
		SETSTATUS("Arctic Scramble - Joining...")
		STAGEIFATCAMP()
		FLYUP()
		IF NOT ACTIONFLAG() THEN
			NOBLOCKFLY($CENTERX, $CENTERY + 0.5 * ($Y - $CENTERY), $HEIGHT, 1)
		ENDIF
		SLEEP(1000)
	WEND
	WHILE HASQUEST($QUESTID)
		SETSTATUS("Northern Realms - Weekly Flags - Waiting for end...")
		RETURNTOCAMP()
		SLEEP(10000)
	WEND
ENDFUNC
FUNC NREVENTNUMBER()
	$TABLE = INSTANCEVALUETABLE()
	FOR $I = 0 TO UBOUND($TABLE) - 1
		IF $TABLE[$I][0] >= 101644 AND $TABLE[$I][0] <= 101655 AND $TABLE[$I][1] > 0 THEN
			PRINT("Event is " & $TABLE[$I][0] - 101644)
			RETURN $TABLE[$I][0] - 101644
		ENDIF
	NEXT
	RETURN -1
ENDFUNC
FUNC NRCONVOYDEST($TEAM, $EVENT)
	DIM $WAGONIDS[3][2] = [[63954, 63955], [63956, 63958], [63957, 63959]]
	FOR $I = 0 TO 2
		$POS = GETNPCPOSITION($WAGONIDS[$I][$TEAM - 1], 1)
		IF UBOUND($POS) THEN RETURN $POS
	NEXT
	$PATH = NRPATHFORTEAMEVENT($TEAM, $EVENT)
	$PERCENT = (@MIN * 60 + @SEC) / (15 * 60)
	RETURN PATHPERCENT($PATH, $PERCENT)
ENDFUNC
FUNC NRCATADEST($TEAM, $EVENT)
	DIM $CATAIDS[3] = [63365, 63735, 63736]
	FOR $I = 0 TO 2
		$POS = GETNPCPOSITION($CATAIDS[$I], 1)
		IF UBOUND($POS) THEN RETURN $POS
	NEXT
	$PATH = NRPATHFORTEAMEVENT($TEAM, $EVENT)
	$PERCENT = (INSTANCEVALUE(101574) - 300) / (2700 - 300)
	RETURN PATHPERCENT($PATH, (INSTANCEVALUE(101573) - 300) / (2700 - 300))
ENDFUNC
FUNC PATHPERCENT(BYREF $POINTARRAY, $PERCENT)
	PRINT("NR Path Percent " & $PERCENT)
	$PERCENT = $PERCENT > 1 ? 1 : ($PERCENT < 0 ? 0 : $PERCENT)
	DIM $RESULT[2] = [0, 0]
	$TOTALDIST = 0
	FOR $I = 0 TO UBOUND($POINTARRAY) - 2
		$TOTALDIST += DISTANCEBETWEEN($POINTARRAY[$I][0], $POINTARRAY[$I][1], $POINTARRAY[$I + 1][0], $POINTARRAY[$I + 1][1])
	NEXT
	$NEEDEDDIST = $PERCENT * $TOTALDIST
	FOR $I = 0 TO UBOUND($POINTARRAY) - 2
		$CURDIST = DISTANCEBETWEEN($POINTARRAY[$I][0], $POINTARRAY[$I][1], $POINTARRAY[$I + 1][0], $POINTARRAY[$I + 1][1])
		IF $NEEDEDDIST <= $CURDIST THEN
			$PERCENTSEG = $NEEDEDDIST / $CURDIST
			$RESULT[0] = $POINTARRAY[$I][0] * (1 - $PERCENTSEG) + $POINTARRAY[$I + 1][0] * $PERCENTSEG
			$RESULT[1] = $POINTARRAY[$I][1] * (1 - $PERCENTSEG) + $POINTARRAY[$I + 1][1] * $PERCENTSEG
			$NEEDEDDIST = 0
			EXITLOOP
		ENDIF
		$NEEDEDDIST -= $CURDIST
	NEXT
	IF $NEEDEDDIST <> 0 THEN
		$RESULT[0] = $POINTARRAY[UBOUND($POINTARRAY) - 1][0]
		$RESULT[1] = $POINTARRAY[UBOUND($POINTARRAY) - 1][1]
	ENDIF
	RETURN $RESULT
ENDFUNC
