FUNC JUMPUPLEDGE($X, $Y, $BACK = FALSE, $HEIGHT = 1)
	WHILE HASBUFF("", 371)
		SLEEP(100)
	WEND
	$INITPOS = PLAYERPOS()
	$COUNT = 0
	WHILE DISTANCE2D($X, $Y) > 0.3
		$DIST = DISTANCE2D($X, $Y)
		JUMPUP(12)
		MOVETO2($X, $Y)
		WHILE ACTIONFLAG() AND DISTANCE2D($X, $Y) <= $DIST
			$DIST = DISTANCE2D($X, $Y)
			SLEEP(100)
		WEND
		IF ACTIONFLAG() THEN
			MOVETO2(0, 0, 0, 3)
			WAITSTOP(2)
		ENDIF
		$NEWPOS = PLAYERPOS()
		IF $INITPOS[2] - $NEWPOS[2] > $HEIGHT THEN
			RETURN FALSE
		ELSEIF $NEWPOS[2] - $INITPOS[2] < $HEIGHT THEN
			MOVETO2($INITPOS[0], $INITPOS[1])
			WAITSTOP(3)
			$COUNT += 1
			IF $COUNT == 3 THEN RETURN FALSE
		ELSE
			EXITLOOP
		ENDIF
		SLEEP(100)
	WEND
	IF $BACK THEN
		MOVETO2($X, $Y)
		WAITSTOP(1)
	ENDIF
	RETURN TRUE
ENDFUNC
FUNC GETONPILLARS()
	MOVE2(-138.47, -136.2)
	IF NOT JUMPUPLEDGE(-137.12, -127.54) THEN RETURN FALSE
	WAITSTOP(5)
	MOVETO2(-137.25, -127.82)
	WAITSTOP(5)
	IF NOT JUMPUPLEDGE(-134.81, -122.7) THEN RETURN FALSE
	WAITSTOP(5)
	MOVETO2(-135.74, -124.12)
	WAITSTOP(5)
	IF NOT JUMPUPLEDGE(-131.59, -118.87) THEN RETURN FALSE
	MOVETO2(-133.46, -118)
	WHILE DISTANCE2D(-58.35, -118) > 8
		SLEEP(1000)
		IF DISTANCE2D(-133.46, -118) < 3 THEN
			IF DISTANCE2D(-133.46, -118) > 1 AND ACTIONFLAG() == 0 THEN
				MOVETO2(-133.46, -118)
			ENDIF
		ENDIF
	WEND
	WHILE ACTIONFLAG()
		SLEEP(100)
	WEND
	WAITSTOPMOVE()
	IF FALLOFFPILLARS() THEN RETURN FALSE
	MOVE2(-53.57, -118.07)
	GRABTIGERBUFF(9)
	RETURN TRUE
ENDFUNC
FUNC FALLOFFPILLARS()
	$POS = PLAYERPOS()
	IF $POS[2] < 45 OR DISTANCE2D(-136.68, -121.21) < 40 AND $POS[2] < 34 THEN
		SETSTATUS("Tiger Gauntlet - Fuck I fell off the Pillars")
		MOVE2(-140.26, -105.96)
		MOVE2(-140.4, -131.47)
		RETURN TRUE
	ENDIF
	RETURN FALSE
ENDFUNC
FUNC JUMPACROSSPILLARS()
	STATIC $HTIMER = 0
	IF $HTIMER == 0 THEN
		$HTIMER = TIMERINIT()
	ELSEIF TIMERDIFF($HTIMER) > 500000 THEN
		SLEEP(MOD(36000 - MOD(TIMERDIFF($HTIMER), 36000), 36000))
		$HTIMER = TIMERINIT()
	ELSE
		SLEEP(MOD(18000 + 36000 - MOD(TIMERDIFF($HTIMER), 36000), 36000))
		$HTIMER = TIMERINIT()
	ENDIF
	JUMPUPMOVE(-58.24, -98.97)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	SLEEP(4000 - TIMERDIFF($HTIMER))
	JUMPUPMOVE(-61.99, -80.35)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	SLEEP(8000 - TIMERDIFF($HTIMER))
	JUMPUPMOVE(-65.91, -60.87)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	SLEEP(12000 - TIMERDIFF($HTIMER))
	JUMPUPMOVE(-70.08, -40.16)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	JUMPUPMOVE(-73.53, -23.01)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	GRABTIGERBUFF(10)
	SLEEP(36000 - TIMERDIFF($HTIMER))
	JUMPUPMOVE(-77.18, -4.04)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	SLEEP(40000 - TIMERDIFF($HTIMER))
	JUMPUPMOVE(-86.29, 12.83)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	SLEEP(44000 - TIMERDIFF($HTIMER))
	JUMPUPMOVE(-96.75, 29.21)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	SLEEP(48000 - TIMERDIFF($HTIMER))
	JUMPUPMOVE(-103.81, 45, 10)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	JUMPUPMOVE(-112.76, 61.66, 10)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	GRABTIGERBUFF(11)
	RETURN TRUE
ENDFUNC
FUNC TIGERGAUNTLET2()
	WHILE ITEMCOUNT(56693)
		TIGERGAUNTLET()
	WEND
ENDFUNC
FUNC TIGERGAUNTLET()
	IF TIGERBUFFVALUE() == -1 THEN
		IF ITEMCOUNT(56693) == 0 THEN RETURN
		SETSTATUS("Heading to Tiger Gauntlet")
		ADVENTUREKINGDOMMAP()
		FLYUP()
		FLY(RANDOM(-380, -374), RANDOM(-364.7, -361))
		SETSTATUS("Waiting for Tiger Gauntlet to Open")
		WAITINHOMESTEADFORNPCHOUR("Tiger Gauntlet Manager")
		FLY(-374.23, -364.21)
		SLEEP(100)
		SWITCHTOHUMANFORM()
		SLEEP(1000)
		TAKEQUEST("Tiger Gauntlet Manager", 39164, -374.23, -364.21, 10, TRUE, FALSE)
	ENDIF
	SETSTATUS("Running Tiger Gauntlet")
	RUNGAUNTLET()
	WHILE TIGERBUFFVALUE() >= 0
		SLEEP(100)
	WEND
	SETSTATUS("Finished.")
ENDFUNC
FUNC MOVESTRAIGHTSPECIAL($X, $Y)
	RETURN MOVEWHILEJUMPING($X, $Y, -1, -1, FALSE)
ENDFUNC
FUNC JUMPUPTHENMOVEAK($X, $Y, $ZLIM = -1, $XA = -1, $YA = -1)
	STATIC $LASTX = -1
	STATIC $LASTY = -1
	IF $XA == -1 AND $YA == -1 AND $LASTX <> -1 AND $LASTY <> -1 THEN
		IF DISTANCE2D($LASTX, $LASTY) < 0.5 THEN
			$XA = $LASTX
			$YA = $LASTY
		ENDIF
	ENDIF
	$LASTX = $X
	$LASTY = $Y
	$RESULT = JUMPUPTHENMOVE($X, $Y, $XA, $YA, $ZLIM, 1)
	WAITSTOP(1)
	RETURN $RESULT
ENDFUNC
