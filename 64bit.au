					MOVE5(-290.54, -186.97, -1, 0, TRUE, FALSE, 30000, 5, TRUE, 176, 29000)
				ELSEIF DISTANCE(-308.8, -161.08, 126.22) < 5 THEN
					CANCELACTION()
					SLEEP(1000)
					TRUEJUMP()
					MOVE5(-290.54, -186.97, -1, 0, TRUE, FALSE, 30000, 5, TRUE, 176, 29000)
				ELSEIF DISTANCE(-319.23, -147.66, 127.01) < 5 THEN
					CANCELACTION()
					SLEEP(1000)
					MOVETO2(-319.23, -147.66)
					SLEEP(2000)
					JUMPUPTHENMOVEUPD(-308.8, -161.08, -1, -1, -1, 2, -1, FALSE, 3, 30000, 3.5)
					SLEEP(1000)
					TRUEJUMP()
					MOVE5(-290.54, -186.97, -1, 0, TRUE, FALSE, 30000, 5, TRUE, 176, 29000)
				ELSE
					SLEEP(1000)
					IF NOT TELEPORTINCENSE() THEN TOWNPORTAL()
