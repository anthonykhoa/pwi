FUNC ISMAIN()
	RETURN BITAND(PLAYERID(), 16613360) == 2128640
ENDFUNC
FUNC TAKESOKKAQUEST()
	IF ITEMCOUNT(43866) > 0 THEN
		FLY(-244.09, -906.8, 32)
		WAITSTOP(3)
		STARTNPCDIALOGUE(GETNPCUNIQUEID("Merchant Sokka"))
		SLEEP(300)
		OPENDIVINEQUESTS()
		SLEEP(300)
		$COUNT = 0
		ACCEPTVOIDQUEST(31525)
		CLOSENPCWINDOW()
		RETURN
		WHILE NOT HASQUEST(31579)
			ACCEPTVOIDQUEST(31579)
			SLEEP(300)
			ACCEPTVOIDQUEST(31588)
			SLEEP(3000)
			IF HASQUEST(31579) THEN
				EXITLOOP
			ELSEIF $COUNT < 5 THEN
				IF ITEMCOUNT(43866) > 1 THEN
					REFRESHDIVINEQUESTS(43866)
					SLEEP(300)
					$COUNT += 1
				ELSE
					EXITLOOP
				ENDIF
			ELSE
				EXITLOOP
			ENDIF
		WEND
	ENDIF
	CLOSENPCWINDOW()
ENDFUNC
FUNC SOMETHINGINTHESNOW()
	IF NOT HASQUEST(31505) AND NOT ISQUESTAVAILABLE(31505) THEN RETURN
	SETSTATUS("Primal World - Something in the Snow")
	IF CANTELEPORT() THEN
		TRANSFERMAP($MAP_PRIMAL, 2, 442.59, 82.75)
		FLYUP(305)
	ELSE
		TRANSFERMAP($MAP_PRIMAL, 2, 419.4, 80.1)
	ENDIF
	TAKEQUEST("Executor", 31505, 419.4, 80.1)
	FLY(347, 146, 32, 1)
	WHILE ITEMCOUNT(43501) < 5
		DIGITEM("Source of Ice and Snow")
		SLEEP(300)
	WEND
	TURNINQUEST("Frost Knight", 31510, 341.6, 299.3, 33)
	MOVE(347.7, 350.2)
	$DIST = 10000
	WHILE ITEMCOUNT(43716) > 0
		$ARRAY = NPCARRAY()
		DIM $DEST[2] = [323.62, 347.52]
		$THRALL = FINDCLOSEST($ARRAY, "Ice Thrall")
		$DIST = SQRT(($ARRAY[$THRALL][4] - $DEST[0]) ^ 2 + ($ARRAY[$THRALL][5] - $DEST[1]) ^ 2)
		$NEWDIST = $DIST - 8
		IF $NEWDIST < 0 THEN $NEWDIST = 0
		MOVE($DEST[0] + ($ARRAY[$THRALL][4] - $DEST[0]) * $NEWDIST / $DIST, $DEST[1] + ($ARRAY[$THRALL][5] - $DEST[1]) * $NEWDIST / $DIST)
		SELECTTARGET($ARRAY[$THRALL][0])
		SLEEP(200)
		USEITEMID(43716, 1)
		SLEEP(300)
	WEND
	USEANCIENTGIFT()
	TURNINQUEST("Executor", 31571, 419.4, 80.1, 35)
ENDFUNC
FUNC RACCOONALLIANCEPACT()
	IF NOT HASQUEST(30664) AND NOT ISQUESTAVAILABLE(30664) THEN RETURN
	SETSTATUS("Primal World - Raccoon Alliance Pact")
	TRANSFERMAP($MAP_PRIMAL, 1, -255, -441.7)
	TAKEQUEST("Bamboo Raccoon Chief", 30664, -255, -441.7)
	TIMEDSELFBUFF()
	MOVE(-244.7, -459.52)
	IF NOT HASQUEST(30664) THEN RETURN
	FLY(-362.37, -448.1, 32)
