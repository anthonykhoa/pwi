	BUFFCHECK()
	MASSMOVE3(411.95, 299.91)
	$TARGET3 = GETNPCUNIQUEID("Massaca Seben")
	IF $TARGET3 <> 0 THEN
		SELECTTARGET($TARGET3)
		MASSTRIPLESPARK()
		MASSNUKENOGENIECHI()
	ENDIF
	SLEEP(1000)
	MASSBUILDCHI(2000)
	SLEEP(1000)
	IF GETNPCUNIQUEID("Attendant") THEN
		IF ISQUESTAVAILABLE(26637) THEN
			TAKEQUEST("Attendant", 26637)
			MASSTRIPLESPARK()
			WAITFORNPC("Vile: Massaca Seben")
			$TARGET4 = GETNPCUNIQUEID("Vile: Massaca Seben")
			IF $TARGET4 <> 0 THEN
				SELECTTARGET($TARGET4)
				MASSATTACK()
			ENDIF
		ENDIF
	ENDIF
	SLEEP(500)
	STEALTHCHECK()
	GATHERALLNONAME()
	BUFFCHECK()
	MASSMOVE3(413.55, 328.51)
	SLEEP(1000)
	MASSMOVE3(413.32, 332.11)
	MASSMOVE3(413.37, 337.92)
	MASSMOVE3(413.5, 342.31)
	$CLIENTSINDEXES = GETSQUADALTS()
	TAKECLIENTSQUEST("Lin of Smythii", 9426, 413.94, 340.83, $CLIENTSINDEXES)
	MASSBUILDCHI(2000)
	SLEEP(10000)
	MASSMOVE3(-442.67, 281.86)
	KILLALLINRANGE(-442.67, 281.86, 40)
	BUFFCHECK()
	MASSMOVE3(-433.91, 364.27)
	KILLALLINRANGE(-433.91, 364.27, 20)
	MASSMOVE3(-406.09, 371.66)
	KILLALLINRANGE(-406.09, 371.66, 30)
	BUFFCHECK()
	MASSMOVE3(-360.72, 371.11)
	KILLALLINRANGE(-360.72, 371.11, 30)
	BUFFCHECK()
	MASSMOVE3(-328.34, 367.93)
	KILLALLINRANGE(-328.34, 367.93, 30)
	BUFFCHECK()
	MASSMOVE3(-295.16, 365.75)
	KILLALLINRANGE(-295.16, 365.75, 30)
	BUFFCHECK()
	MASSMOVE3(-265.91, 365.23)
	KILLALLINRANGE(-265.91, 365.23, 30)
	BUFFCHECK()
	MASSBUILDCHI(2000)
	SLEEP(1000)
	MASSMOVE3(-204.83, 365.85)
	KILLALLINRANGE(-204.83, 365.85, 20)
	BUFFCHECK()
	MASSMOVE3(-190.79, 345.97)
	KILLALLINRANGE(-190.79, 345.97, 20)
	BUFFCHECK()
	MASSMOVE3(-184.18, 322.88)
	KILLALLINRANGE(-184.18, 322.88, 20)
	BUFFCHECK()
	MASSMOVE3(-188.09, 300.24)
	KILLALLINRANGE(-188.09, 300.24, 20)
	BUFFCHECK()
	MASSMOVE3(-190.66, 280.99)
	MASSMOVE3(-190.87, 261.63)
	MASSMOVE3(-186.97, 234.38)
	BUFFCHECK()
	SLEEP(1000)
	$TARGET5 = GETNPCUNIQUEID("Drake Fling")
	IF $TARGET5 <> 0 THEN
		SELECTTARGET($TARGET5)
		$DRAKETIMER = TIMERINIT()
		WHILE GETNPCUNIQUEID("Drake Fling")
			IF TIMERDIFF($DRAKETIMER) > 90000 THEN EXITLOOP
			MASSATTACK()
			$TARGET5 = GETNPCUNIQUEID("Drake Fling")
			IF $TARGET5 <> 0 THEN
				SELECTTARGET($TARGET5)
				MASSATTACK()
			ENDIF
			SLEEP(100)
			IF NOT GETNPCUNIQUEID("Drake Fling") THEN EXITLOOP
		WEND
	ENDIF
	SLEEP(500)
	MOVE(-185.64, 238.83)
	MOVE(-182.2, 236.39)
	GATHERALLNONAME(40)
	SLEEP(1000)
	IF GETNPCUNIQUEID("Attendant") THEN
		IF ISQUESTAVAILABLE(26640) THEN
			BUFFCHECK()
			MASSGENIECHISKILL()
			TAKEQUEST("Attendant", 26640)
			WAITFORNPC("Vile: Drake Fling")
			$TARGET6 = GETNPCUNIQUEID("Vile: Drake Fling")
			IF $TARGET6 <> 0 THEN
				MASSTRIPLESPARK()
				SELECTTARGET($TARGET6)
				MASSATTACK()
			ENDIF
		ENDIF
	ENDIF
	GATHERALL("Essence of Defense", 100)
	STEALTHCHECK()
	SLEEP(2000)
	GATHERALL("Essence of Defense", 100)
	STEALTHCHECK()
	GATHERALL("Essence of Defense", 100)
	GATHERALLNONAME(40)
	GATHERALL("Essence of Defense", 100)
	SLEEP(1000)
ENDFUNC
FUNC STEALTHCHECK()
	$STEALTHTIMER = TIMERINIT()
	WHILE HASBUFF("Stealth Enter Stealth mode.", 149)
		IF TIMERDIFF($STEALTHTIMER) > 20000 THEN EXITLOOP
		SLEEP(1000)
	WEND
ENDFUNC
