FUNC MASSSPEEDPATH($CLIENTSINDEXES)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		SPEEDPATH()
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSGENIEENERGYCHECK($CLIENTSINDEXES, $ENERGYMINIMUM)
	$ALLALTSHAVEMINENERGY = TRUE
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF GENIEENERGY() < $ENERGYMINIMUM THEN
			$ALLALTSHAVEMINENERGY = FALSE
			EXITLOOP
		ENDIF
	NEXT
	SWITCHTO($MAIN)
	RETURN $ALLALTSHAVEMINENERGY
ENDFUNC
FUNC SPEEDPATH()
	CASTSKILL(1022, 1)
ENDFUNC
FUNC SMARTHOLYPATH()
	IF GENIEENERGY() > 75 AND NOT HASBUFF("Increased movement speed", 44) AND SKILLOFFCOOLDOWN(1022, 1) THEN
		CASTSKILL(1022, 1)
	ENDIF
ENDFUNC
