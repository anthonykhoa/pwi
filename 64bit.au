	ENDIF
	IF HASQUEST(39035) OR HASQUEST(39036) OR HASQUEST(39037) OR HASQUEST(39251) OR HASQUEST(39106) THEN
		CASTLEOFWONDROUSFATE()
	ENDIF
	IF HASQUEST(39038) OR HASQUEST(39039) OR HASQUEST(39040) THEN
		VERDANTSEA()
	ENDIF
	IF HASQUEST(39041) OR HASQUEST(39042) OR HASQUEST(39043) OR HASQUEST(39234) OR HASQUEST(39254) THEN
