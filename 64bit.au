			IF @ERROR OR NOT $ACALL[0] THEN RETURN SETERROR(@ERROR + 10, @EXTENDED, 0)
			LOCAL $ARET[2]
			LOCAL $ARES = DLLCALL("kernel32.dll", "dword", "ExpandEnvironmentStringsW", "wstr", $ACALL[2], "wstr", "", "dword", 4096)
			$ARET[0] = $ARES[2]
			$ARET[1] = $ACALL[4]
			RETURN $ARET
