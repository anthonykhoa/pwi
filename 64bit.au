	DIM $COORD9[22][2] = [[427, -344.12], [369.12, -381.93], [293.42, -416.04], [263.94, -425.18], [203.09, -439.2], [138.54, -448.69], [75.53, -449.47], [43.11, -450.19], [-14.28, -447.99], [-47.02, -448.37], [-83.12, -449.4], [-118.18, -447.28], [-150.4, -442.89], [-184.53, -438.13], [-216.76, -432.4], [-245.95, -425.22], [-277.05, -416.32], [-306.78, -407.87], [-335.5, -396.71], [-358.56, -378.96], [-378.87, -353.77], [-391.61, -328.69]]
	DIM $COORD10[12][2] = [[354.57, -162.81], [276.24, -58.94], [212.16, -24.33], [153.61, -6.83], [123.8, 8.49], [97.83, 24.78], [66.15, 29.56], [-46.34, 30.13], [-84.52, 28.81], [-201.73, -44.16], [-295.78, -112.98], [-339.39, -142.38]]
	DIM $COORD11[18][2] = [[367.43, 182.61], [356.63, 214.41], [298.46, 290.42], [263.92, 339.38], [234.58, 363.62], [202.81, 373.17], [136.37, 387.42], [101.63, 393.24], [65.45, 440.34], [39.61, 451.85], [-14.31, 459.32], [-41.52, 451.41], [-67.34, 436.75], [-94.87, 425.45], [-211.64, 387.83], [-253.68, 297.05], [-329.33, 266.04], [-385.16, 223.18]]
	IF $EVENT == 6 AND $TEAM == 1 THEN RETURN $COORD6RED
	IF $EVENT == 6 AND $TEAM == 2 THEN RETURN $COORD6BLUE
	IF $EVENT == 7 AND $TEAM == 1 THEN RETURN $COORD7RED
	IF $EVENT == 7 AND $TEAM == 2 THEN RETURN $COORD7BLUE
	IF $EVENT == 8 AND $TEAM == 1 THEN RETURN $COORD8RED
	IF $EVENT == 8 AND $TEAM == 2 THEN RETURN $COORD8BLUE
	IF $EVENT == 9 THEN RETURN $COORD9
	IF $EVENT == 10 THEN RETURN $COORD10
	IF $EVENT == 11 THEN RETURN $COORD11
	RETURN -1
ENDFUNC
FUNC NREVENTDESTINATION($TEAM, $EVENT)
	IF $EVENT < 0 OR $EVENT >= 12 THEN RETURN -1
	DIM $RESULT[3] = [0, 0]
	DIM $COORDS[6][2] = [[14, 220.89], [14, 76], [14, 194], [14, 220.9], [14, 427], [14, 113]]
	PRINT("Team - EVENT " & $TEAM & " - " & $EVENT)
	IF $EVENT <= 5 THEN
		$RESULT[0] = $COORDS[$EVENT][0]
		$RESULT[1] = $COORDS[$EVENT][1]
		RETURN $RESULT
	ELSEIF $EVENT <= 8 THEN
		RETURN NRCONVOYDEST($TEAM, $EVENT)
	ELSE
		RETURN NRCATADEST($TEAM, $EVENT)
	ENDIF
ENDFUNC
FUNC CANJOINNREVENT()
	$POINTS = NRPOINTS()
	IF $POINTS[0] > 50 THEN RETURN FALSE
	RETURN TRUE
ENDFUNC
FUNC ISTUNDRACAMPAIGNDAY()
	RETURN INSTANCEVALUE(101545) == 1
ENDFUNC
FUNC CHECKFORSCRAMBLE()
	$TEAM = NORTHERNREALMTEAM()
	IF $TEAM == 0 THEN RETURN
	$QUESTID = $TEAM == 1 ? 42021 : 42024
	IF NOT HASQUEST($QUESTID) AND NOT ISQUESTAVAILABLE($QUESTID) THEN RETURN
	IF INSTANCEVALUE(101681) + INSTANCEVALUE(101682) <> 0 THEN
		ARCTICSCRAMBLE()
	ENDIF
	RETURN
ENDFUNC
FUNC NRJOINEVENT()
	$TEAM = NORTHERNREALMTEAM()
	IF $TEAM == 0 THEN RETURN
	IF NOT CANJOINNREVENT() THEN RETURN
	SETSTATUS("Northern Realm Event")
	TRANSFERMAP($MAP_NORTHERNREALM)
	IF ISTUNDRACAMPAIGNDAY() THEN
		SETSTATUS("Northern Realm Event - Under Campaign Leaving...")
		TRANSFERMAP($MAP_MAIN)
		ENTERMYHOME()
		RETURN
	ENDIF
	$EVENT = NREVENTNUMBER()
	WHILE $EVENT == -1
		SETSTATUS("Northern Realm Event - Waiting...")
		SLEEP(20000)
		RESURRECTIFDEAD()
		$EVENT = NREVENTNUMBER()
		CHECKFORSCRAMBLE()
	WEND
	$TEAM = NORTHERNREALMTEAM()
	IF GETGLOBALSETTING("NR2100Points", FALSE) THEN
		SETSTATUS("Northern Realm Event - To Check Points > 2100")
		WHILE TRUE
			$EVENT = NREVENTNUMBER()
			IF(($EVENT >= 0 AND $EVENT < 6) OR($EVENT >= 9)) AND INSTANCEVALUE(101572 + $TEAM) > 2100 AND @MIN <= 15 AND @MIN >= 1 THEN EXITLOOP
			SLEEP(20000)
			RESURRECTIFDEAD()
			CHECKFORSCRAMBLE()
		WEND
	ENDIF
	IF GETGLOBALSETTING("NR1400Points", FALSE) AND NOT GETGLOBALSETTING("NR2100Points") THEN
		SETSTATUS("Northern Realm Event - To Check Points > 1400")
		WHILE TRUE
			$EVENT = NREVENTNUMBER()
			IF(($EVENT >= 0 AND $EVENT < 6) OR($EVENT >= 9)) AND INSTANCEVALUE(101572 + $TEAM) > 1400 AND @MIN <= 15 AND @MIN >= 10 THEN EXITLOOP
			SLEEP(20000)
			RESURRECTIFDEAD()
			CHECKFORSCRAMBLE()
		WEND
	ENDIF
	$HEIGHT = RANDOM(50, 75, 1)
	$EVENTTIMER = TIMERINIT()
	SELFBUFF()
	WHILE CANJOINNREVENT() AND NOT HASBUFF("Reward Token", 481) AND TIMERDIFF($EVENTTIMER) < 900000 AND NREVENTNUMBER() <> -1
		SETSTATUS("Northern Realm Event - Joining...")
		$DEST = NREVENTDESTINATION($TEAM, $EVENT)
		RESURRECTIFDEAD()
		STAGEIFATCAMP()
		RESURRECTIFDEAD()
		IF NOT ACTIONFLAG() THEN
			IF DISTANCE2D($DEST[0], $DEST[1]) > 5 THEN
				FLYUP()
				NOBLOCKFLY($DEST[0], $DEST[1], $HEIGHT, 1)
			ELSEIF $EVENT >= 6 THEN
				DROPDOWN()
				$DEST = NREVENTDESTINATION($TEAM, $EVENT)
				IF CANJOINNREVENT() AND NOT HASBUFF("Reward Token", 481) AND DISTANCE2D($DEST[0], $DEST[1]) > 10 THEN
					IF NOT RESURRECTIFDEAD() THEN MOVETO($DEST[0], $DEST[1])
				ENDIF
			ENDIF
		ENDIF
		SLEEP(1000)
	WEND
	SETSTATUS("Northern Realm Event - Waiting for end...")
	RETURNTOCAMP()
	WHILE HASBUFF("Reward Token", 481)
		SLEEP(10000)
	WEND
	TRANSFERMAP($MAP_MAIN, 0, 965.39, 3196.61)
	SETSTATUS("Northern Realm Event - done.")
	ENTERMYHOME()
ENDFUNC
FUNC NRJOINARCTICSCRAMBLE()
	$TEAM = NORTHERNREALMTEAM()
	IF $TEAM == 0 THEN RETURN
	SETSTATUS("Northern Realm - Weekly Flags")
	TRANSFERMAP($MAP_NORTHERNREALM)
	IF ISTUNDRACAMPAIGNDAY() THEN
		SETSTATUS("Northern Realm Event - Under Campaign Leaving...")
		TRANSFERMAP($MAP_MAIN)
		ENTERMYHOME()
		RETURN
	ENDIF
	CHECKFORSCRAMBLE()
	TRANSFERMAP($MAP_MAIN)
	ENTERMYHOME()
ENDFUNC
FUNC STAGEIFATCAMP()
	$TEAM = NORTHERNREALMTEAM()
	SLEEP(1000)
	IF $TEAM == 1 AND GETNPCUNIQUEID("Imperial Campsite Teleporter") THEN
		TAKEQUEST("Imperial Campsite Teleporter", 41937)
		WHILE GETNPCUNIQUEID("Imperial Campsite Teleporter")
			SLEEP(1000)
		WEND
	ELSEIF $TEAM == 2 AND GETNPCUNIQUEID("Divine Garrison Teleporter") THEN
		TAKEQUEST("Divine Garrison Teleporter", 41941)
		WHILE GETNPCUNIQUEID("Divine Garrison Teleporter")
			SLEEP(1000)
		WEND
	ENDIF
ENDFUNC
DIM $IMPERIALCAMPTELEPORTS[4][5] = [["Spirit Bastion Teleporter", 41934, 697, -405, 65], ["Arar Outpost Teleporter", 41934, 684, 184, 65], ["Citadel Outpost Teleporter", 41934, 244, 98, 65], ["Imperial Campsite Teleporter", 41934, 1378, -51, 65]]
DIM $DIVINECAMPTELEPORTS[4][5] = [["Oracle Village Teleporter", 41938, -623, 404, 65], ["Skai Outpost Teleporter", 41938, -702, -188, 65], ["Citadel Outpost Teleporter", 41938, -259, 63, 65], ["Divine Garrison Teleporter", 41938, -1394, -87, 65]]
FUNC RETURNTOCAMP()
	$TEAM = NORTHERNREALMTEAM()
	IF $TEAM == 1 THEN
		IF NOT GETNPCUNIQUEID("Imperial Campsite Teleporter") THEN
			TAKENEARESTQUEST($IMPERIALCAMPTELEPORTS, 41934)
			WAITFORNPC("Imperial Campsite Teleporter")
		ENDIF
		FLY(1378.28, -40.954)
	ELSEIF $TEAM == 2 THEN
		IF NOT GETNPCUNIQUEID("Divine Garrison Teleporter") THEN
			TAKENEARESTQUEST($DIVINECAMPTELEPORTS, 41938)
			WAITFORNPC("Divine Garrison Teleporter")
		ENDIF
		FLY(-1389.919, -77.724)
	ENDIF
ENDFUNC
FUNC NORTHERNREALMCARTQUEST()
	$TEAM = NORTHERNREALMTEAM()
	IF $TEAM == 0 THEN RETURN
	$QUESTID = $TEAM == 1 ? 41630 : 41629
	IF NOT HASQUEST($QUESTID) AND NOT ISQUESTAVAILABLE($QUESTID) THEN RETURN
	SETSTATUS("Northern Realm - Cart Quest")
	IF @WDAY == 3 THEN
		SETSTATUS("Cart quest not available on Tuesdays.")
		RETURN
	ENDIF
	$INSTANCE = INSTANCEID()
	IF $INSTANCE <> 93 THEN TRANSFERMAP($MAP_NORTHERNREALM)
	IF ISTUNDRACAMPAIGNDAY() THEN
		SETSTATUS("Cart quest not available on Tuesdays.")
		RETURN
	ENDIF
	IF $TEAM == 1 THEN
		IF NOT IMPERIALCARTQUEST() THEN
			SETSTATUS("Cart Quest Failed.")
		ELSE
			SETSTATUS("NR Cart Quest done.")
		ENDIF
	ENDIF
	IF $TEAM == 2 THEN
		IF NOT DIVINECARTQUEST() THEN
			SETSTATUS("Cart Quest Failed.")
		ELSE
			SETSTATUS("NR Cart Quest done.")
		ENDIF
	ENDIF
	IF GETGLOBALSETTING("AutoBankRepairSpotAlternate", TRUE) AND GETGLOBALSETTING("AutoBankRepairSpotAlternate2", TRUE) THEN
		SETSTATUS("Both Bamboo Village and Silver Pool setting selected. Make sure to only select one tick box please. Going to Silver Pool for now.")
		TRANSFERMAP($MAP_MAIN, 0, 490.75, 179.28)
	ELSEIF GETGLOBALSETTING("AutoBankRepairSpotAlternate", TRUE) THEN
		TRANSFERMAP($MAP_MAIN, 0, -305.77, -1992.67)
	ELSEIF GETGLOBALSETTING("AutoBankRepairSpotAlternate2", TRUE) THEN
		TRANSFERMAP($MAP_MAIN, 0, 490.75, 179.28)
	ELSE
		TRANSFERMAP($MAP_MAIN, 0, RANDOM(964, 974), RANDOM(3196, 3206))
	ENDIF
ENDFUNC
FUNC DIVINECARTQUEST()
	takequest("Divine Quartermaster Nikita", 41629, -1386, -65)
	If Not HasQuest(41629) Then Return False
	NRSelfBuff()
	setstatus("Northern Realm - Cart Quest")
	stageifatcamp()
	fly(734.29, -21.23, 70)
