			LOCAL $ACALL = DLLCALL("gdi32.dll", "handle", "CreateRoundRectRgn", "int", $ILEFTRECT, "int", $ITOPRECT, "int", $IRIGHTRECT, "int", $IBOTTOMRECT, "int", $IWIDTHELLIPSE, "int", $IHEIGHTELLIPSE)
			IF @ERROR THEN RETURN SETERROR(@ERROR, @EXTENDED, 0)
