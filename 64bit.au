	If NOT pvpmove(-400.4, -376.88) Then Return False
  SpeedPath()
    If NOT pvpmove(-400.45, -222.88) Then Return False
	If NOT pvpmove(-443.48, -155.17) Then Return False
  SpeedPath()
	If NOT pvpmove(-600.34, -170.82) Then Return False
	If NOT pvpmove(-666.36, -163.91) Then Return False
	turninquest("Divine Logistician", 41834)
	returntocamp()
	Return True
ENDFUNC
