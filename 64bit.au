	FUNC SUMMONPETWITHREVIVE($SLOT = 0)
		IF CLASS() <> 3 THEN RETURN
		STARTLISTENING()
		SUMMONPET($SLOT)
		SLEEP(350)
		IF SEETEXT("Pet is dead") THEN
			CASTSKILL(329)
			SLEEP(1100)
		ELSE
			RETURN
		ENDIF
		SUMMONPET($SLOT)
		SLEEP(350)
		IF SEETEXT("Pet is dead") THEN
			CASTSKILL(329)
			SLEEP(1100)
		ELSE
			RETURN
		ENDIF
		SUMMONPET($SLOT)
		SLEEP(350)
		IF SEETEXT("Pet is dead") THEN
			CASTSKILL(329)
			SLEEP(1100)
		ELSE
			RETURN
		ENDIF
	ENDFUNC
