FUNC ADVENTUREKINGDOMMAP()
	EXITHOME()
	$INSTANCE = INSTANCEID()
	IF $INSTANCE <> 191 THEN
		IF NOT ISADVENTUREKINGDOMOPEN() THEN RETURN
		SETSTATUS("Divination of Luck")
		TRANSFERMAP($MAP_ADVENTUREKINGDOM)
	ENDIF
ENDFUNC
