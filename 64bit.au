FUNC PICKUPEXTERMINATIONORDER()
	IF NOT HASQUEST(37124) AND NOT ISQUESTAVAILABLE(37124) AND ITEMCOUNT(53456) == 0 THEN RETURN
	SETSTATUS("Bounty Hunter - Picking Up Extermination Order")
	TRANSFERMAP($MAP_MAIN, 0, 495.15, 3236.29)
	TAKEQUEST("Head Hunter", 37124)
	WHILE HASQUEST(37124)
		SLEEP(200)
	WEND
	SLEEP(1000)
	RETURN TRUE
ENDFUNC
FUNC PICKUPMAZEKEYS()
	IF NOT ISQUESTAVAILABLE(32485) AND NOT ISQUESTAVAILABLE(42990) THEN RETURN
	SETSTATUS("Picking Up Maze Keys...")
	TRANSFERMAP($MAP_MAIN, 0, -1958.67, -2269.38)
	FLYUP()
	DROPDOWN()
	FLYUP(710)
	FLY(-2367.62, -2188.25, 70)
	TAKEQUEST("Starshower", 32485)
	TAKEQUEST("Thunderdrum", 42990)
	FLY(-1958.67, -2269.38, 70)
ENDFUNC
FUNC ENABLEDDAILY($NAME)
	RETURN ISCHECKED($DAILYOPTIONS.item($NAME))
ENDFUNC
FUNC ENABLEDGROUP($NAME)
	IF $FORCE_GROUP <> "" THEN RETURN $NAME == $FORCE_GROUP
	RETURN ENABLEDDAILY($NAME)
ENDFUNC
DIM $MISC_COMMANDS[0][5]
FUNC ADDMISCBUTTON($TITLE, $FUNC, $REGISTER = TRUE, $YCOORD = -1, $WIDTH_ADJUST = 0, $XOFFSET = -1, $HELP = "", $BACKGROUNDCOLOR = -1, $TEXTCOLOR = -1)
	$COLS = 2
	STATIC $YBUTTONOFFSET = 0
	STATIC $XBUTTONOFFSET = 0
	STATIC $X = 0
	STATIC $Y = 0
	IF $YCOORD <> -1 THEN
		$YBUTTONOFFSET = $YCOORD
		$X = 0
		$Y = 0
	ENDIF
	IF $XOFFSET <> -1 THEN
		$XBUTTONOFFSET = $XOFFSET
	ENDIF
	$CTRLID = GUICTRLCREATEBUTTON($TITLE, $X * 140 + 20 + $WIDTH_ADJUST * (1 - $X) + $XBUTTONOFFSET, $Y * 35 + 80 + $YBUTTONOFFSET, 130 - $WIDTH_ADJUST, 30)
	GUICTRLSETONEVENT(-1, $FUNC)
	$X = $X + 1
	IF $X == $COLS THEN
		GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKRIGHT + $GUI_DOCKHEIGHT)
		$X = 0
		$Y = $Y + 1
	ELSE
		GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKHEIGHT)
	ENDIF
	IF $BACKGROUNDCOLOR <> -1 THEN
		GUICTRLSETBKCOLOR($CTRLID, $BACKGROUNDCOLOR)
	ENDIF
	IF $TEXTCOLOR <> -1 THEN
		GUICTRLSETCOLOR($CTRLID, $TEXTCOLOR)
	ENDIF
	IF $REGISTER THEN
		REGISTERCOMMAND($TITLE, $FUNC, $HELP)
	ENDIF
	SETEXTENDED($CTRLID)
	RETURN($Y + ($X == 0 ? 0 : 1)) * 35 + 80 + $YBUTTONOFFSET
ENDFUNC
FUNC REGISTERCOMMAND($TITLE, $FUNC, $HELP = "")
	REDIM $MISC_COMMANDS[UBOUND($MISC_COMMANDS) + 1][5]
	$MISC_COMMANDS[UBOUND($MISC_COMMANDS) - 1][0] = $TITLE
	$MISC_COMMANDS[UBOUND($MISC_COMMANDS) - 1][1] = $FUNC
	$MISC_COMMANDS[UBOUND($MISC_COMMANDS) - 1][3] = $HELP
ENDFUNC
