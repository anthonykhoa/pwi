	MOVE(-333.5, 168.37)
	WHILE ITEMCOUNT(41409) < 1
		DIGITEM("Raccoon Alliance Pact")
		SLEEP(100)
	WEND
	FLY(-398.2, 130.87, 39)
	USETELEPORTMASTER("Teleport Master", 2)
	USEANCIENTGIFT()
	IF ISMAIN() THEN
		TURNINQUEST("Bamboo Raccoon Chief", 31028, -255, -441.7)
	ELSE
