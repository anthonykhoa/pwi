	$POS[0] = STRINGFORMAT("%.2f", _MEMORYREAD($PLAYER + 60, $GAME_PROCESS, "float"))
	$POS[1] = STRINGFORMAT("%.2f", _MEMORYREAD($PLAYER + 68, $GAME_PROCESS, "float"))
