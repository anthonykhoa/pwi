FUNC FARMLUNARBADGES()
	$SKIPALTS = FALSE
	FARMLUNAR($SKIPALTS)
ENDFUNC
FUNC FARMLUNAREOD()
	$SKIPALTS = TRUE
	FARMLUNAR($SKIPALTS)
ENDFUNC
FUNC FARMLUNAR($SKIPALTS = TRUE)
	$PARTY = PARTYARRAY()
	$INSTANCE = INSTANCEID()
	DIM $ALT_NAMES[5]
	WHILE $ALT_NAMES[0] == ""
		WHILE UBOUND($PARTY) < 2 OR UBOUND($PARTY) > 6
			SETSTATUS("Form a squad with between 2 to 6 characters. Make sure they are YOUR characters logged onto your computer!")
			SLEEP(5000)
			$PARTY = PARTYARRAY()
		WEND
		FOR $I = 0 TO UBOUND($CLIENTS) - 1
			IF $CLIENTS[$I][3] == $PARTY[1][0] THEN
				$ALT_NAMES[0] = $CLIENTS[$I][2]
				SETSTATUS("We have at least 1 alt. Good to go.")
				EXITLOOP
			ENDIF
		NEXT
		IF $ALT_NAMES[0] == "" THEN
			SETSTATUS("Can't find client for alt #1. Is it actually your alt?")
			SLEEP(1000)
		ENDIF
	WEND
	SWITCHTO($MAIN)
	SETSTATUS("Farm Lunar with " & PARTYCOUNT() & " characters.")
	$COUNT = 1
	SLEEP(1000)
	IF $INSTANCE <> 127 THEN TRANSFERMAP($MAP_MAIN, 0, 1762.42, 1151.86)
	$SEVENHOURTIMER = TIMERINIT()
	$MSINSEVENHOUR = 1000 * 60 * 60 * 7
	WHILE(PARTYCOUNT() > 1 AND PARTYCOUNT() < 7)
		IF TIMERDIFF($SEVENHOURTIMER) > $MSINSEVENHOUR THEN
			SETSTATUS("Farm Lunar: time farming exceeds 7 hours. Stopping to avoid hitting earning cap.")
			RETURN
		ENDIF
		$INSTANCE = INSTANCEID()
		WHILE $INSTANCE <> $MAP_MAIN AND $INSTANCE <> 127
			SLEEP(1000)
		WEND
		IF $INSTANCE <> 127 THEN
			IF NOT GETNPCUNIQUEID("Illusion Stone") THEN TRANSFERMAP($MAP_MAIN, 0, 1762.42, 1151.86)
		ENDIF
		SETSTATUS("Farm Lunar Run #" & $COUNT)
		SLEEP(2000)
		$CLIENTSINDEXES = GETSQUADALTS()
		IF GETNPCUNIQUEID("Illusion Stone") THEN
			GATHERALTSINSQUAD()
			SLEEP(2000)
			FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
				$INDEX = $CLIENTSINDEXES[$I]
				SWITCHTONUM($INDEX)
				IF $INSTANCE <> 127 THEN TAKEQUEST("Illusion Stone", 9522)
			NEXT
			SWITCHTO($MAIN)
		ENDIF
		IF $SKIPALTS THEN
			RUNLUNAR()
		ELSE
			RUNLUNAR2()
		ENDIF
		REFORMSQUAD()
		SLEEP(15000)
		WHILE INCOMBAT()
			SLEEP(1000)
		WEND
		MASSTELEPORTSTONETOEASTARCHSQUAD()
		$CLIENTSINDEXES = GETSQUADALTS()
		SWITCHTO($MAIN)
		SLEEP(10000)
		$COUNT += 1
	WEND
	SETSTATUS("Finished. We ran Lunar " & $COUNT & " times.")
ENDFUNC
FUNC KILLALLINRANGE($X, $Y, $DIST = 20, $TIMELIMITED = FALSE, $DURATION = 6000)
	$NPCARRAY = NPCARRAY()
	$DELAY = 200
	$MOBSNEARBY = FALSE
	IF UBOUND($NPCARRAY) THEN
		$MOBSNEARBY = TRUE
	ELSE
		RETURN
	ENDIF
	$FORBIDDENID = 0
	DIM $FORBIDDENIDS[12] = [38585, 37700, 37899, 37898, 64324, 64323, 64322, 64321, 48322, 48321, 37900, 64246]
	$TIMER = TIMERINIT()
	WHILE $MOBSNEARBY
		IF $TIMELIMITED THEN
			IF TIMERDIFF($TIMER) > $DURATION THEN
				EXITLOOP
			ENDIF
		ENDIF
		$MOBTOKILL = 0
		FOR $I = 0 TO UBOUND($NPCARRAY) - 1
			FOR $J = 0 TO UBOUND($FORBIDDENIDS) - 1
				IF $NPCARRAY[$I][1] == $FORBIDDENIDS[$J] THEN
					$FORBIDDENID = $NPCARRAY[$I][0]
					EXITLOOP
				ENDIF
			NEXT
			$MOBSNEARBY = FALSE
			IF $NPCARRAY[$I][0] == $FORBIDDENID THEN CONTINUELOOP
			IF DISTANCEBETWEEN($NPCARRAY[$I][4], $NPCARRAY[$I][5], $X, $Y) < $DIST THEN
				$MOBSNEARBY = TRUE
				$MOBTOKILL = $I
				EXITLOOP
			ENDIF
		NEXT
		IF $MOBSNEARBY THEN
			$TARGET = $NPCARRAY[$MOBTOKILL][0]
			IF $TARGET <> 0 THEN
				SELECTTARGET($TARGET)
				AOE()
			ENDIF
			SLEEP($DELAY)
			$NPCARRAY = NPCARRAY()
		ENDIF
	WEND
ENDFUNC
