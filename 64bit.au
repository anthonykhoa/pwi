		$PACKET &= _HEX($SKILLID)
		$PACKET &= _HEX($POSX, 8, "float")
		$PACKET &= _HEX($POSZ, 8, "float")
		$PACKET &= _HEX($POSY, 8, "float")
		$PACKET &= "1101"
		$PACKET &= _HEX($TARGETID)
		$PACKETSIZE = 24
		SENDPACKET($PACKET, $PACKETSIZE, $GAME_PID)
	ENDFUNC
