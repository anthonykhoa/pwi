FUNC SPEEDTNF()
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF $CLIENTS[$I][2] == $MAIN THEN CONTINUELOOP
		RUN("TheNightmareStuff.exe")
		$NAME = $CLIENTS[$I][2]
		$HANDLER = WINWAIT($NAME & " - TheNightmareStuff")
		SLEEP(1000)
		CONTROLCLICK($HANDLER, "Do TNF", "Button5")
		SLEEP(500)
	NEXT
	CONTROLCLICK($MAIN & " - TheNightmareStuff", "Do TNF", "Button5")
ENDFUNC
FUNC WEEKLYFLAGSJOINALLBOTS()
	$ADD = 0
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF $CLIENTS[$I][2] == $MAIN THEN CONTINUELOOP
		RUN("TheNightmareStuff.exe")
		$NAME = $CLIENTS[$I][2]
		$HANDLER = WINWAIT($NAME & " - TheNightmareStuff")
		$ADD += 300
		SLEEP($ADD)
		CONTROLCLICK($HANDLER, "Do Weekly Flags", "Button7")
		SLEEP($ADD)
	NEXT
	SWITCHTO($MAIN)
	SLEEP($ADD)
	CONTROLCLICK($MAIN & " - TheNightmareStuff", "Do Weekly Flags", "Button7")
ENDFUNC
