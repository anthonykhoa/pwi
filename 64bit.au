	$PROSPERITY = (HOMESTEADINFO())[7]
	WHILE $PROSPERITY == 0
		SLEEP(1000)
		$PROSPERITY = (HOMESTEADINFO())[7]
	WEND
	IF NOT HOMESTEADCHECKIFDIDCOLLECTIONQUEST() THEN
		SETSTATUS("Probably did homestead collection quest today already. Continuing dailies.")
		RETURN
	ENDIF
	IF $PROSPERITY > 7600 THEN
		$LEVELTOUSE = 10
		HOMECOLLECTIONQUEST($MASTERYTOUSE, $LEVELTOUSE)
	ELSEIF $PROSPERITY > 5400 AND $PROSPERITY < 7600 THEN
		$LEVELTOUSE = 8
		HOMECOLLECTIONQUEST($MASTERYTOUSE, $LEVELTOUSE)
	ELSEIF $PROSPERITY > 4050 AND $PROSPERITY < 5400 THEN
		$LEVELTOUSE = 7
		HOMECOLLECTIONQUEST($MASTERYTOUSE, $LEVELTOUSE)
	ELSEIF $PROSPERITY > 1349 AND $PROSPERITY < 4050 THEN
		SETSTATUS("Error: homestead prosperity is above 1349 and below 4050. No supported quests at this time for this prosperity range. Either increase prosperity above 4050 or lower it below 1349 to do a daily collection quest.")
	ENDIF
ENDFUNC
FUNC HOMECOLLECTIONQUEST($MASTERYTOUSE, $LEVELTOUSE = 10)
	SETSTATUS("HS - Collection Quest - 7600+ Prosperity - " & $MASTERYTOUSE)
	DIM $LVL10QUESTSFURNISHING[8][4] = [[35177, 8429, 1, 280], [35182, 8443, 1, 235], [35189, 8446, 1, 235], [35484, 8464, 1, 280], [35183, 8662, 1, 235], [35184, 8663, 1, 235], [35971, 9294, 1, 280], [35485, 8667, 1, 280]]
	DIM $LVL10QUESTSCONSTRUCTION[10][4] = [[35966, 9286, 1, 320], [35965, 9285, 1, 320], [35483, 8266, 1, 320], [35482, 8260, 1, 320], [35479, 8311, 1, 320], [35475, 8253, 1, 280], [35474, 8250, 1, 280], [35192, 8303, 1, 320], [35191, 8300, 1, 320], [35190, 8296, 1, 320]]
	DIM $LVL10QUESTSDECORATION[14][4] = [[35970, 9293, 1, 280], [35478, 8424, 1, 235], [35477, 8342, 1, 235], [35476, 8331, 1, 235], [35473, 8753, 1, 280], [35472, 8404, 1, 280], [35471, 8402, 1, 280], [35187, 8383, 1, 235], [35181, 8394, 1, 280], [35176, 8646, 1, 235], [35175, 8645, 1, 235], [35174, 8634, 1, 235], [35173, 8360, 1, 235], [35188, 8658, 1, 235]]
	DIM $LVL10QUESTSHANDCRAFT[8][4] = [[35969, 9318, 1, 280], [35968, 9317, 1, 280], [35967, 9316, 1, 235], [35470, 8512, 1, 280], [35469, 8510, 1, 280], [35180, 8533, 1, 280], [35179, 8544, 1, 280], [35178, 8529, 1, 280]]
	DIM $LVL10QUESTSALL[40][4] = [[35177, 8429, 1, 280], [35182, 8443, 1, 235], [35189, 8446, 1, 235], [35484, 8464, 1, 280], [35183, 8662, 1, 235], [35184, 8663, 1, 235], [35971, 9294, 1, 280], [35485, 8667, 1, 280], [35966, 9286, 1, 320], [35965, 9285, 1, 320], [35483, 8266, 1, 320], [35482, 8260, 1, 320], [35479, 8311, 1, 320], [35475, 8253, 1, 280], [35474, 8250, 1, 280], [35192, 8303, 1, 320], [35191, 8300, 1, 320], [35190, 8296, 1, 320], [35970, 9293, 1, 280], [35478, 8424, 1, 235], [35477, 8342, 1, 235], [35476, 8331, 1, 235], [35473, 8753, 1, 280], [35472, 8404, 1, 280], [35471, 8402, 1, 280], [35187, 8383, 1, 235], [35181, 8394, 1, 280], [35176, 8646, 1, 235], [35175, 8645, 1, 235], [35174, 8634, 1, 235], [35173, 8360, 1, 235], [35188, 8658, 1, 235], [35969, 9318, 1, 280], [35968, 9317, 1, 280], [35967, 9316, 1, 235], [35470, 8512, 1, 280], [35469, 8510, 1, 280], [35180, 8533, 1, 280], [35179, 8544, 1, 280], [35178, 8529, 1, 280]]
	DIM $LVL8QUESTSFURNISHING[4][4] = [[35151, 8444, 1, 135], [35149, 8671, 1, 160], [35144, 8442, 1, 135], [35140, 8426, 1, 160]]
	DIM $LVL8QUESTSCONSTRUCTION[8][4] = [[35829, 9210, 1, 180], [35454, 8264, 1, 180], [35451, 8270, 1, 180], [35447, 8307, 1, 180], [35446, 8298, 1, 180], [35445, 8293, 1, 180], [35152, 8292, 1, 180], [35148, 8310, 1, 180]]
	DIM $LVL8QUESTSDECORATION[13][4] = [[35963, 9292, 1, 160], [35453, 8334, 1, 160], [35452, 8326, 1, 160], [35449, 8413, 1, 160], [35147, 8385, 1, 135], [35143, 8419, 1, 135], [35142, 8416, 1, 135], [35139, 8656, 1, 135], [35138, 8655, 1, 135], [35137, 8377, 1, 135], [35136, 8374, 1, 135], [35135, 8352, 1, 135], [35133, 8347, 1, 135]]
	DIM $LVL8QUESTSHANDCRAFT[5][4] = [[35828, 9206, 1, 160], [35455, 8487, 1, 135], [35448, 8508, 1, 160], [35150, 8499, 1, 160], [35141, 8532, 1, 160]]
	DIM $LVL8QUESTSALL[30][4] = [[35151, 8444, 1, 135], [35149, 8671, 1, 160], [35144, 8442, 1, 135], [35140, 8426, 1, 160], [35829, 9210, 1, 180], [35454, 8264, 1, 180], [35451, 8270, 1, 180], [35447, 8307, 1, 180], [35446, 8298, 1, 180], [35445, 8293, 1, 180], [35152, 8292, 1, 180], [35148, 8310, 1, 180], [35963, 9292, 1, 160], [35453, 8334, 1, 160], [35452, 8326, 1, 160], [35449, 8413, 1, 160], [35147, 8385, 1, 135], [35143, 8419, 1, 135], [35142, 8416, 1, 135], [35139, 8656, 1, 135], [35138, 8655, 1, 135], [35137, 8377, 1, 135], [35136, 8374, 1, 135], [35135, 8352, 1, 135], [35133, 8347, 1, 135], [35828, 9206, 1, 160], [35455, 8487, 1, 135], [35448, 8508, 1, 160], [35150, 8499, 1, 160], [35141, 8532, 1, 160]]
	DIM $LVL7QUESTSFURNISHING[9][4] = [[35124, 8436, 2, 100], [35126, 8670, 2, 120], [35437, 8466, 2, 120], [35438, 8472, 2, 120], [35440, 8453, 2, 120], [35441, 8456, 2, 120], [35442, 8665, 2, 120], [35824, 9212, 2, 120], [35825, 9213, 2, 120]]
	DIM $LVL7QUESTSCONSTRUCTION[8][4] = [[35127, 8290, 2, 135], [35128, 8291, 2, 135], [35129, 8297, 2, 135], [35130, 8632, 2, 135], [35429, 8248, 2, 120], [35430, 8251, 2, 120], [35435, 8258, 2, 135], [35436, 8263, 2, 135]]
	DIM $LVL7QUESTSDECORATION[11][4] = [[35113, 8344, 2, 100], [35125, 8421, 2, 100], [35114, 8346, 2, 100], [35427, 8410, 2, 120], [35115, 8349, 2, 100], [35116, 8356, 2, 100], [35117, 8369, 2, 100], [35118, 8637, 2, 100], [35119, 8643, 2, 100], [35120, 8653, 2, 100], [35121, 8654, 2, 100]]
	DIM $LVL7QUESTSHANDCRAFT[7][4] = [[35122, 8542, 2, 120], [35123, 8531, 2, 120], [35131, 8507, 2, 120], [35432, 8554, 2, 120], [35439, 8486, 2, 120], [35826, 9207, 2, 120], [35827, 9208, 2, 120]]
	DIM $LVL7QUESTSALL[35][4] = [[35124, 8436, 2, 100], [35126, 8670, 2, 120], [35437, 8466, 2, 120], [35438, 8472, 2, 120], [35440, 8453, 2, 120], [35441, 8456, 2, 120], [35442, 8665, 2, 120], [35824, 9212, 2, 120], [35825, 9213, 2, 120], [35127, 8290, 2, 135], [35128, 8291, 2, 135], [35129, 8297, 2, 135], [35130, 8632, 2, 135], [35429, 8248, 2, 120], [35430, 8251, 2, 120], [35435, 8258, 2, 135], [35436, 8263, 2, 135], [35113, 8344, 2, 100], [35125, 8421, 2, 100], [35114, 8346, 2, 100], [35427, 8410, 2, 120], [35115, 8349, 2, 100], [35116, 8356, 2, 100], [35117, 8369, 2, 100], [35118, 8637, 2, 100], [35119, 8643, 2, 100], [35120, 8653, 2, 100], [35121, 8654, 2, 100], [35122, 8542, 2, 120], [35123, 8531, 2, 120], [35131, 8507, 2, 120], [35432, 8554, 2, 120], [35439, 8486, 2, 120], [35826, 9207, 2, 120], [35827, 9208, 2, 120]]
	$MINENERGY = 0
	$MAXENERGY = 0
	$HOMESTEADINFO = HOMESTEADINFO()
	$ENERGYBEFORE = $HOMESTEADINFO[6]
	DIM $HOME_QUESTS[0][0] = [[]]
	IF $MASTERYTOUSE == "Furnishing" THEN
		IF $LEVELTOUSE == 10 THEN
			$HOME_QUESTS = $LVL10QUESTSFURNISHING
			$MINENERGYNEEDED = 235
			$MAXENERGYNEEDED = 280
		ELSEIF $LEVELTOUSE == 8 THEN
			$HOME_QUESTS = $LVL8QUESTSFURNISHING
			$MINENERGYNEEDED = 135
			$MAXENERGYNEEDED = 160
		ELSEIF $LEVELTOUSE == 7 THEN
			$HOME_QUESTS = $LVL7QUESTSFURNISHING
			$MINENERGYNEEDED = 200
			$MAXENERGYNEEDED = 240
		ENDIF
	ELSEIF $MASTERYTOUSE == "Construction" THEN
		IF $LEVELTOUSE == 10 THEN
			$HOME_QUESTS = $LVL10QUESTSCONSTRUCTION
			$MINENERGYNEEDED = 280
			$MAXENERGYNEEDED = 320
		ELSEIF $LEVELTOUSE == 8 THEN
			$HOME_QUESTS = $LVL8QUESTSCONSTRUCTION
			$MINENERGYNEEDED = 180
			$MAXENERGYNEEDED = 180
		ELSEIF $LEVELTOUSE == 7 THEN
			$HOME_QUESTS = $LVL7QUESTSCONSTRUCTION
			$MINENERGYNEEDED = 240
			$MAXENERGYNEEDED = 270
		ENDIF
	ELSEIF $MASTERYTOUSE == "Decoration" THEN
		IF $LEVELTOUSE == 10 THEN
			$HOME_QUESTS = $LVL10QUESTSDECORATION
			$MINENERGYNEEDED = 235
			$MAXENERGYNEEDED = 280
		ELSEIF $LEVELTOUSE == 8 THEN
			$HOME_QUESTS = $LVL8QUESTSDECORATION
			$MINENERGYNEEDED = 135
			$MAXENERGYNEEDED = 160
		ELSEIF $LEVELTOUSE == 7 THEN
			$HOME_QUESTS = $LVL7QUESTSDECORATION
			$MINENERGYNEEDED = 200
			$MAXENERGYNEEDED = 240
		ENDIF
	ELSEIF $MASTERYTOUSE == "Handcraft" THEN
		IF $LEVELTOUSE == 10 THEN
			$HOME_QUESTS = $LVL10QUESTSHANDCRAFT
			$MINENERGYNEEDED = 235
			$MAXENERGYNEEDED = 280
		ELSEIF $LEVELTOUSE == 8 THEN
			$HOME_QUESTS = $LVL8QUESTSHANDCRAFT
			$MINENERGYNEEDED = 135
			$MAXENERGYNEEDED = 160
		ELSEIF $LEVELTOUSE == 7 THEN
			$HOME_QUESTS = $LVL7QUESTSHANDCRAFT
			$MINENERGYNEEDED = 200
			$MAXENERGYNEEDED = 240
		ENDIF
	ENDIF
	FOR $J = 0 TO UBOUND($HOME_QUESTS) - 1
		IF HASQUEST($HOME_QUESTS[$J][0]) THEN
			TURNINHOMEQUEST($HOME_QUESTS[$J][0])
			SLEEP(1000)
			IF NOT HASQUEST($HOME_QUESTS[$J][0]) THEN
				SETSTATUS("Homestead - Collection Quest (7600+ Prosperity) -- turned in quest from previous day. Items were already crafted.")
			ENDIF
		ENDIF
	NEXT
	IF NOT HOMESTEADENERGYCHECK($MINENERGYNEEDED, $MAXENERGYNEEDED) THEN
		RETURN
	ENDIF
	FOR $J = 0 TO UBOUND($HOME_QUESTS) - 1
		IF HASQUEST($HOME_QUESTS[$J][0]) THEN
			$QUEST = $J
			IF NOT HOMESTEADENERGYCHECK($MINENERGYNEEDED, $MAXENERGYNEEDED) THEN
				RETURN
			ENDIF
			$HOMESTEADINFO = HOMESTEADINFO()
			$ENERGYBEFORE = $HOMESTEADINFO[6]
			$ENERGYREQUIRED = $HOME_QUESTS[$QUEST][2] * $HOME_QUESTS[$QUEST][3]
			IF $ENERGYBEFORE < $ENERGYREQUIRED THEN
				SETSTATUS("Homestead Collection quest - skipped already-had quest due to insufficient energy.")
				SLEEP(500)
				CONTINUELOOP
			ENDIF
			CRAFTHOMEITEM($HOME_QUESTS[$QUEST][1], $HOME_QUESTS[$QUEST][2], $HOME_QUESTS[$QUEST][3])
			SLEEP(1500)
			$HOMESTEADINFONEW = HOMESTEADINFO()
			$ENERGYAFTER = $HOMESTEADINFONEW[6]
			$ENERGYDIFFERENCE = $ENERGYBEFORE - $ENERGYAFTER
			IF $ENERGYDIFFERENCE == $ENERGYREQUIRED THEN
				TURNINHOMEQUEST($HOME_QUESTS[$J][0])
				SETSTATUS("Homestead - Collection Quest - crafted items and turned in quest from previous day.")
			ENDIF
			SLEEP(1500)
		ENDIF
	NEXT
	$QUEST = -1
	$ATTEMPT = 0
	WHILE $QUEST == -1 AND $ATTEMPT < 6
		IF $ATTEMPT < 5 THEN
			FOR $J = 0 TO UBOUND($HOME_QUESTS) - 1
				IF HASQUEST($HOME_QUESTS[$J][0]) THEN CONTINUELOOP
				TAKEHOMEQUEST($HOME_QUESTS[$J][0])
				SLEEP(1500)
				IF HASQUEST($HOME_QUESTS[$J][0]) THEN
					$QUEST = $J
					EXITLOOP
				ENDIF
			NEXT
			SLEEP(1000)
			IF $QUEST == -1 THEN
				$ATTEMPT = $ATTEMPT + 1
				SENDPACKET("C20001", 3, $GAME_PID)
				SLEEP(1000)
			ENDIF
		ELSEIF $ATTEMPT == 5 THEN
			FOR $J = 0 TO UBOUND($HOME_QUESTS) - 1
				IF HASQUEST($HOME_QUESTS[$J][0]) THEN CONTINUELOOP
				TAKEHOMEQUEST($HOME_QUESTS[$J][0])
				SLEEP(1500)
				IF HASQUEST($HOME_QUESTS[$J][0]) THEN
					$QUEST = $J
					EXITLOOP
				ENDIF
			NEXT
			SLEEP(1000)
			IF $QUEST == -1 THEN
				IF $LEVELTOUSE == 7 THEN
					$HOME_QUESTS = $LVL7QUESTSALL
				ELSEIF $LEVELTOUSE == 8 THEN
					$HOME_QUESTS = $LVL8QUESTSALL
				ELSEIF $LEVELTOUSE == 10 THEN
					$HOME_QUESTS = $LVL10QUESTSALL
				ENDIF
				SLEEP(1000)
				FOR $J = 0 TO UBOUND($HOME_QUESTS) - 1
					IF HASQUEST($HOME_QUESTS[$J][0]) THEN CONTINUELOOP
					TAKEHOMEQUEST($HOME_QUESTS[$J][0])
					SLEEP(1500)
					IF HASQUEST($HOME_QUESTS[$J][0]) THEN
						$QUEST = $J
						EXITLOOP
					ENDIF
				NEXT
			ENDIF
			$ATTEMPT = $ATTEMPT + 1
		ENDIF
	WEND
	IF $QUEST > -1 THEN
		$QUEST = $J
		IF NOT HOMESTEADENERGYCHECK($MINENERGYNEEDED, $MAXENERGYNEEDED) THEN
			RETURN
		ENDIF
		$HOMESTEADINFO = HOMESTEADINFO()
		$ENERGYBEFORE = $HOMESTEADINFO[6]
		$ENERGYREQUIRED = $HOME_QUESTS[$QUEST][2] * $HOME_QUESTS[$QUEST][3]
		IF $ENERGYBEFORE < $ENERGYREQUIRED THEN
			SETSTATUS("Homestead Collection Quest - not enough energy to make items for today's quest.")
			RETURN
		ENDIF
		CRAFTHOMEITEM($HOME_QUESTS[$QUEST][1], $HOME_QUESTS[$QUEST][2], $HOME_QUESTS[$QUEST][3])
		SLEEP(1500)
		$HOMESTEADINFONEW = HOMESTEADINFO()
		$ENERGYAFTER = $HOMESTEADINFONEW[6]
		$ENERGYDIFFERENCE = $ENERGYBEFORE - $ENERGYAFTER
		IF $ENERGYDIFFERENCE == $ENERGYREQUIRED THEN
			TURNINHOMEQUEST($HOME_QUESTS[$J][0])
			SETSTATUS("Homestead Collection Quest - crafted items and turned in quest picked up today. Refreshed " & $ATTEMPT - 1 & " times. Remaining energy = " & $ENERGYAFTER)
		ELSE
			SETSTATUS("Homestead Collection Quest - couldn't turn in today's quest. Probably missing recipe. Refreshed " & $ATTEMPT - 1 & " times. Remaining energy = " & $ENERGYAFTER)
		ENDIF
	ELSE
		$HOMESTEADINFONEW = HOMESTEADINFO()
		$ENERGYAFTER = $HOMESTEADINFONEW[6]
		SETSTATUS("Homestead Collection Quest - no suitable quest found today. Better luck tomorrow!. Refreshed " & $ATTEMPT - 1 & " times. Remaining energy = " & $ENERGYAFTER)
	ENDIF
	SLEEP(2000)
	WHILE ITEMCOUNT(50427) > 0 OR ITEMCOUNT(50427) > 0 OR ITEMCOUNT(50425) > 0
		USEITEMID(50427)
		SLEEP(200)
		USEITEMID(50426)
		SLEEP(200)
		USEITEMID(50425)
		SLEEP(2000)
	WEND
ENDFUNC
FUNC HOMESTEADENERGYCHECK($MINENERGYNEEDED, $MAXENERGYNEEDED)
	$HOMESTEADINFO = HOMESTEADINFO()
	$CURRENTENERGY = $HOMESTEADINFO[6]
	IF $CURRENTENERGY >= $MAXENERGYNEEDED THEN
		SETSTATUS("Current energy: " & $CURRENTENERGY & "Energy range: Min = " & $MINENERGYNEEDED & ", Max = " & $MAXENERGYNEEDED & ". Good to craft any item.")
		RETURN 2
	ELSEIF $CURRENTENERGY < $MAXENERGYNEEDED AND $CURRENTENERGY >= $MINENERGYNEEDED THEN
		SETSTATUS("Current energy: " & $CURRENTENERGY & "Energy range: Min = " & $MINENERGYNEEDED & ", Max = " & $MAXENERGYNEEDED & ". May be unable to craft some items.")
		RETURN 1
	ELSE
		SETSTATUS("Current energy: " & $CURRENTENERGY & "Energy range: Min = " & $MINENERGYNEEDED & ", Max = " & $MAXENERGYNEEDED & ". Not enough energy to craft any items now. Exiting.")
		RETURN 0
	ENDIF
ENDFUNC
FUNC HOMESTEADCHECKIFDIDCOLLECTIONQUEST()
	$HOMESTEADINFO = HOMESTEADINFO()
	$CLEANNESSBEFORE = $HOMESTEADINFO[8]
	RECHARGECLEANNESS()
	SLEEP(1000)
	$HOMESTEADINFOAFTER = HOMESTEADINFO()
	$CLEANNESSAFTER = $HOMESTEADINFOAFTER[8]
	IF $CLEANNESSBEFORE <> $CLEANNESSAFTER THEN
		RETURN FALSE
	ELSE
		RETURN TRUE
	ENDIF
ENDFUNC
FUNC HOMESTEADCHECKIFENERGYISFULL()
	$HOMESTEADINFO = HOMESTEADINFO()
	$MAXENERGY = $HOMESTEADINFO[14]
	$CURRENTENERGY = $HOMESTEADINFO[6]
	SETSTATUS("$maxenergy = " & $MAXENERGY & " and current energy = " & $CURRENTENERGY)
ENDFUNC
Func LOWLEVELHOMECOLLECTIONQUEST ( )
	SETSTATUS ( "Homestead - Collection Quest (Low Prosperity)" )
	ENTERMYHOME ( )
	$PROSPERITY = ( HOMESTEADINFO ( ) ) [ 7 ]
	While $PROSPERITY == 0
		Sleep ( 1000 )
		$PROSPERITY = ( HOMESTEADINFO ( ) ) [ 7 ]
	WEnd
	If $PROSPERITY >= 1350 Then
		SETSTATUS ( "Homestead - Prosperity too high: " & $PROSPERITY )
		Return
	EndIf
	Dim $HOME_QUESTS [ 4 ] [ 7 ] = [ [ 34997 , 8570 , 8577 , 253 , 28 , 0 , 0 ] , [ 35000 , 8567 , 8751 , 220 , 532 , 0 , 0 ] , [ 35001 , 8573 , 8574 , 288 , 345 , 0 , 0 ] , [ 35002 , 8572 , 8575 , 274 , 16 , 0 , 0 ] ]
	$ARRAY = HOMEITEMS ( )
	For $J = 0 To UBound ( $HOME_QUESTS ) + -1
		If HASQUEST ( $HOME_QUESTS [ $J ] [ 0 ] ) Then
			$I = 1
			While $HOME_QUESTS [ $J ] [ $I ] > 0
				$DATA = _ARRAYSEARCH ( $ARRAY , $HOME_QUESTS [ $J ] [ $I + 2 ] )
				If $DATA == "-1" And $HOME_QUESTS [ $J ] [ $I + 2 ] <> 0 Then
					CRAFTHOMEITEM ( $HOME_QUESTS [ $J ] [ $I ] , 3 )
					Sleep ( 100 )
				Else
					If $HOME_QUESTS [ $J ] [ $I + 2 ] == $ARRAY [ $DATA ] [ 0 ] And $HOME_QUESTS [ $J ] [ $I + 2 ] <> 0 Then
						If $ARRAY [ $DATA ] [ 1 ] <= 3 And $ARRAY [ $DATA ] [ 2 ] <= 1 Then CRAFTHOMEITEM ( $HOME_QUESTS [ $J ] [ $I ] , ( 3 - $ARRAY [ $DATA ] [ 1 ] ) )
						If $ARRAY [ $DATA ] [ 1 ] <= 3 And $ARRAY [ $DATA ] [ 2 ] >= 1 Then CRAFTHOMEITEM ( $HOME_QUESTS [ $J ] [ $I ] , ( 4 - $ARRAY [ $DATA ] [ 1 ] ) )
						Sleep ( 100 )
					EndIf
				EndIf
				$I += 1
			WEnd
			Sleep ( 1000 )
			TURNINHOMEQUEST ( $HOME_QUESTS [ $J ] [ 0 ] )
		EndIf
		Sleep ( 1000 )
	Next
	$QUEST = -1
	$ATTEMPT = 0
	While $QUEST == -1 And $ATTEMPT < 5
		For $J = 0 To UBound ( $HOME_QUESTS ) + -1
			Sleep ( 1000 )
			If QUESTAVAILABLE ( $HOME_QUESTS [ $J ] [ 0 ] ) == 0 And Not HASQUEST ( $HOME_QUESTS [ $J ] [ 0 ] ) Then
				TAKEHOMEQUEST ( $HOME_QUESTS [ $J ] [ 0 ] )
				$QUEST = $J
				ExitLoop
			EndIf
		Next
		Sleep ( 1000 )
		For $J = 0 To UBound ( $HOME_QUESTS ) -1
			If HASQUEST ( $HOME_QUESTS [ $J ] [ 0 ] ) And $QUEST == -1 Then
				$QUEST = $J
				ExitLoop
			EndIf
		Next
		If $QUEST == -1 Then
			If ( HOMESTEADINFO ( ) ) [ 7 ] == 0 Then ExitLoop
			$ATTEMPT = $ATTEMPT + 1
			SENDPACKET ( "C20001" , 3 , $GAME_PID )
			Sleep ( 1000 )
		EndIf
	WEnd
	If $QUEST > -1 Then
		$I = 1
		While $HOME_QUESTS [ $QUEST ] [ $I ] > 0
			$DATA = _ARRAYSEARCH ( $ARRAY , $HOME_QUESTS [ $QUEST ] [ $I + 2 ] )
			If $DATA == "-1" And $HOME_QUESTS [ $QUEST ] [ $I + 2 ] <> 0 Then
				CRAFTHOMEITEM ( $HOME_QUESTS [ $QUEST ] [ $I ] , 3 )
				Sleep ( 100 )
			Else
				If $HOME_QUESTS [ $QUEST ] [ $I + 2 ] == $ARRAY [ $DATA ] [ 0 ] And $HOME_QUESTS [ $QUEST ] [ $I + 2 ] <> 0 Then
					If $ARRAY [ $DATA ] [ 1 ] <= 3 And $ARRAY [ $DATA ] [ 2 ] <= 1 Then CRAFTHOMEITEM ( $HOME_QUESTS [ $QUEST ] [ $I ] , ( 3 - $ARRAY [ $DATA ] [ 1 ] ) )
					If $ARRAY [ $DATA ] [ 1 ] <= 3 And $ARRAY [ $DATA ] [ 2 ] >= 1 Then CRAFTHOMEITEM ( $HOME_QUESTS [ $QUEST ] [ $I ] , ( 4 - $ARRAY [ $DATA ] [ 1 ] ) )
					Sleep ( 100 )
				EndIf
			EndIf
			$I += 1
		WEnd
		Sleep ( 1000 )
		TURNINHOMEQUEST ( $HOME_QUESTS [ $QUEST ] [ 0 ] )
	EndIf
EndFunc
