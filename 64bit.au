FUNC KILLSKYMOB()
	SETSTATUS("Finding Sky Mob Item")
	FOR $I = 0 TO 10
		$ARRAY = INVARRAY()
		FOR $ITEMID = 74858 TO 74864
			$INDEX = SEARCHITEMID($ARRAY, $ITEMID)
			SLEEP(200)
			IF $INDEX <> -1 THEN
				KILLSPAWNINGSKYMOB($ARRAY[$INDEX][0], $ARRAY[$INDEX][1])
				RETURN
			ENDIF
		NEXT
	NEXT
ENDFUNC
FUNC KILLSPAWNINGSKYMOB($INDEX, $ITEMTYPE)
	SETSTATUS("Killing Sky Mob")
	$PLAYERLOCATION = INSTANCEID()
	IF $PLAYERLOCATION <> $MAP_PRIMAL AND $PLAYERLOCATION <> $MAP_STORY AND $PLAYERLOCATION <> $MAP_NEVERFALL THEN
		TRANSFERMAP($MAP_PRIMAL, 0)
	ENDIF
	FLYUP()
	DESELECTTARGET()
	USEITEM($INDEX, $ITEMTYPE)
	SLEEP(1000)
	WHILE NOT PLAYERTARGET()
		SLEEP(200)
	WEND
	WHILE GETHPMP()[0] > 0 AND PLAYERTARGET()
		EXECUTEMACRO(0)
	WEND
	RESURRECTIFDEAD()
ENDFUNC
FUNC SACREDSPIRITTICKET()
	$TICKET = 0
	IF ITEMCOUNT(74866) THEN
		SLEEP(3000)
	ENDIF
	FOR $I = 74852 TO 74865
		IF ITEMCOUNT($I) THEN
			$TICKET = $I
			EXITLOOP
		ENDIF
	NEXT
	IF $TICKET == 0 THEN RETURN
	SETSTATUS("Sacred Spirit Ticket")
	$MAP = INSTANCEID()
	IF $MAP <> $MAP_NEVERFALL AND $MAP <> $MAP_PRIMAL THEN
		TRANSFERMAP($MAP_NEVERFALL, 0)
	ENDIF
	FLYUP(RANDOM(10, 30) + ALTITUDE())
	WHILE ITEMCOUNT($TICKET)
		IF NOT HASQUEST($TICKET - 74864 + 47550) THEN
			USEITEMID($TICKET)
		ENDIF
		SLEEP(1000)
	WEND
	WHILE NOT OWNEDNPC()
		SLEEP(1000)
	WEND
	$TARGET = OWNEDNPC()
	WHILE $TARGET
		KILL($TARGET, 100, 0)
		SLEEP(100)
		$TARGET = OWNEDNPC()
	WEND
ENDFUNC
FUNC VITAEMOBITEM()
	SLEEP(7000)
	SETSTATUS("Checking if vitae mob item in inventory...")
	$TARGET = 0
	$TARGETID = 0
	$VITAEITEMID = 0
	$COUNT = 0
	$NAME = ""
	$SHIFTING = ITEMCOUNT(74859)
	$TWILIGHT = ITEMCOUNT(74860)
	$ROYAL = ITEMCOUNT(74861)
	$PIOUS = ITEMCOUNT(74862)
	$APEX = ITEMCOUNT(74863)
	$RISING = ITEMCOUNT(74864)
	$SEALING = ITEMCOUNT(74865)
	SLEEP(250)
	$TIMER = TIMERINIT()
	IF $SHIFTING > 0 THEN
		$COUNT = $SHIFTING
		SETSTATUS($COUNT & " shifting sky item found.")
		$VITAEITEMID = 74859
		$TARGETID = 74852
		$NAME = "Sacred Spirit Leader Shifting Sky"
	ELSEIF $TWILIGHT > 0 THEN
		$COUNT = $TWILIGHT
		SETSTATUS($COUNT & " twilight sky item found.")
		$VITAEITEMID = 74860
		$TARGETID = 74853
		$NAME = "Sacred Spirit Leader Twilight Sky"
	ELSEIF $ROYAL > 0 THEN
		$COUNT = $ROYAL
		SETSTATUS($COUNT & " royal sky item found.")
		$VITAEITEMID = 74861
		$TARGETID = 74854
		$NAME = "Sacred Spirit Leader Royal Sky"
	ELSEIF $PIOUS > 0 THEN
		$COUNT = $PIOUS
		SETSTATUS($COUNT & " pious sky item found.")
		$VITAEITEMID = 74862
		$TARGETID = 74855
		$NAME = "Sacred Spirit Leader Pious Sky"
	ELSEIF $APEX > 0 THEN
		$COUNT = $APEX
		SETSTATUS($COUNT & " apex sky item found.")
		$VITAEITEMID = 74863
		$TARGETID = 74856
		$NAME = "Sacred Spirit Leader Apex Sky"
	ELSEIF $RISING > 0 THEN
		$COUNT = $RISING
		SETSTATUS($COUNT & " rising sky item found.")
		$VITAEITEMID = 74864
		$TARGETID = 74857
		$NAME = "Sacred Spirit Leader Rising Sky"
	ELSEIF $SEALING > 0 THEN
		$COUNT = $SEALING
		SETSTATUS($COUNT & " sealing sky item found.")
		$VITAEITEMID = 74865
		$TARGETID = 74858
		$NAME = "Sacred Spirit Leader Seal Sky"
	ELSE
		SETSTATUS("No vitae mob item found. Continuing dailies")
		RETURN
	ENDIF
	USEITEMID(38408)
	$MAP = INSTANCEID()
	IF $MAP <> $MAP_NEVERFALL AND $MAP <> $MAP_PRIMAL THEN
		TRANSFERMAP($MAP_NEVERFALL, 0)
	ENDIF
	USEANCIENTGIFT()
	$POS_INITIAL = PLAYERPOS()
	$GROUNDHEIGHT = $POS_INITIAL[2]
	$HPMP = GETHPMP()
	$SEED = $HPMP[0]
	SRANDOM($SEED)
	$FLYHEIGHT = RANDOM(0, 20)
	GENIECHISKILL()
	SWITCHTOHUMANFORM()
	FLYUP()
	FLYUP($POS_INITIAL[2] + $FLYHEIGHT + 10)
	$POS = PLAYERPOS()
	SELFBUFF()
	CLEARTARGET()
	SLEEP(1000)
	WHILE INCOMBAT() AND PLAYERTARGET() > 0
		EXECUTEMACRO(0)
	WEND
	DESELECTTARGET()
	SLEEP(1000)
	FOR $I = 1 TO $COUNT
		USEITEMID($VITAEITEMID)
		IF CHI() > 300 THEN
			SLEEP(1000)
			TRIPLESPARK()
		ENDIF
		$WAITFORMOBTIMER = TIMERINIT()
		WHILE TIMERDIFF($WAITFORMOBTIMER) < 30000 AND PLAYERTARGET() == 0
			SLEEP(100)
		WEND
		$NPCARRAY = NPCARRAY()
		$CURRENTTARGET = PLAYERTARGET()
		$TARGET = FINDCLOSEST($NPCARRAY, $TARGETID, 1)
		$REALTARGET = 0
		IF $CURRENTTARGET == $TARGET THEN
			$REALTARGET = $CURRENTTARGET
			QUICKSELECT($REALTARGET)
		ENDIF
		IF NOT $CURRENTTARGET > 0 THEN
			$TARGET = FINDCLOSEST($NPCARRAY, $TARGETID, 1)
			SLEEP(1000)
			IF $TARGET > 0 THEN QUICKSELECT($TARGET)
			SLEEP(100)
			$REALTARGET = PLAYERTARGET()
			IF NOT $REALTARGET > 0 THEN
				SETSTATUS("Something went wrong. Couldn't find spawned mob.")
			ENDIF
			CONTINUELOOP
		ENDIF
		$SPARKTIMER = TIMERINIT()
		$KILLTIMER = TIMERINIT()
		WHILE PLAYERTARGET() > 0 AND TIMERDIFF($KILLTIMER) < 120000
			IF TIMERDIFF($KILLTIMER) > 120000 THEN
				SETSTATUS("Vitae mob item: time exceeded 2 minutes. Continuing with dailies.")
				RETURN
			ENDIF
			IF TIMERDIFF($SPARKTIMER) > 15000 AND CHI() > 300 THEN
				TRIPLESPARK()
				$SPARKTIMER = TIMERINIT()
			ENDIF
			SETSTATUS("Killing vitae mob.")
			EXECUTEMACRO(0)
			IF(GETHPMP())[0] == 0 THEN
				SETSTATUS("Died while trying to kill vitae mob. Be less squish. Continuing dailies.")
				GOTOTOWNAFTERDEATH()
				USEITEMID(38408)
				SELFBUFF()
				FLY($POS_INITIAL[0], $POS_INITIAL[1])
				$NPCARRAY = NPCARRAY()
				$CURRENTTARGET = PLAYERTARGET()
				$TARGET = FINDCLOSEST($NPCARRAY, $TARGETID, 1)
				$REALTARGET = 0
				IF $CURRENTTARGET == $TARGET THEN
					$REALTARGET = $CURRENTTARGET
					QUICKSELECT($REALTARGET)
				ENDIF
				IF NOT $CURRENTTARGET > 0 THEN
					$TARGET = FINDCLOSEST($NPCARRAY, $TARGETID, 1)
					SLEEP(1000)
					IF $TARGET > 0 THEN QUICKSELECT($TARGET)
					SLEEP(100)
					$REALTARGET = PLAYERTARGET()
					IF NOT $REALTARGET > 0 THEN
						SETSTATUS("Something went wrong. Couldn't find spawned mob.")
						RETURN
					ENDIF
				ENDIF
				SLEEP(100)
			ENDIF
		WEND
	NEXT
ENDFUNC
FUNC SECRETPRINCESS()
	IF NOT HASQUEST(33633) AND NOT ISQUESTAVAILABLE(33633) THEN RETURN
	SETSTATUS("Primal World - Secret Princess")
	TRANSFERMAP($MAP_PRIMAL, 3, 478.65, -670.42)
	MOVE(506.72, -654.58)
	IF NOT GETNPCUNIQUEID("Cursed Merman") THEN
		FLY(489.71, -636.14, 40)
	ENDIF
	TAKEQUEST("Cursed Merman", 33633)
	MOVE(492.78, -643.42, 281.95, 1)
	$QUEST = 0
	IF HASQUEST(33634) THEN
		$QUEST = 33634
		MOVE(273.41, -521.37, 269.38, 1)
		MOVE(260.64, -512.3, 247.35, 1)
		WHILE ITEMCOUNT(47409, 1) < 5
			DIGITEM("Little Coral")
		WEND
		MOVE(273.41, -521.37, 269.38, 1)
	ELSEIF HASQUEST(33635) THEN
		$QUEST = 33635
		MOVE(788.78, -295.83)
		MOVE(790.94, -294.54, 235.09, 1)
		WHILE ITEMCOUNT(47411, 1) < 5
			DIGITEM("Shell")
		WEND
		MOVE(804.68, -285.16, 274.18, 1)
	ELSEIF HASQUEST(33636) THEN
		$QUEST = 33636
		MOVE(403.63, -887.5, 280.03, 1)
		MOVE(403.52, -887.68, 216.91, 1)
		WHILE ITEMCOUNT(47412, 1) < 5
			DIGITEM("Little Coral")
		WEND
		MOVE(403.63, -887.5, 280.03, 1)
	ELSEIF HASQUEST(33637) THEN
		$QUEST = 33637
		MOVE(446.1, -278.31)
		MOVE(452.06, -276.41, 195.49, 1)
		WHILE ITEMCOUNT(47413, 1) < 5
			DIGITEM("Little Coral")
		WEND
		MOVE(470.07, -311.6, 280.79, 1)
	ENDIF
	MOVE(453.34, -640.13)
	TALKTONPC("Mermaid")
	IF ISMAIN() THEN
		USEANCIENTGIFT()
		TURNINQUEST("Mermaid", $QUEST, 0, 0, 0, 0)
	ELSE
		USEANCIENTGIFT()
		TURNINQUEST("Mermaid", $QUEST, 0, 0, 0, 1)
	ENDIF
	USEANCIENTGIFT()
	MOVE(458.68, -655.68, 235.84, 1)
ENDFUNC
FUNC LIUSOO()
	IF NOT HASQUEST(30309) AND NOT ISQUESTAVAILABLE(30309) THEN RETURN
	SETSTATUS("Primal World - Liu Soo")
	TRANSFERMAP($MAP_STORY, 1, -644.05, 174.95)
	WAITFORNPC("Queen Liu Soo")
	MOVE(-644.05, 174.95)
	TAKEQUEST("Queen Liu Soo", 30309, -644.05, 174.95)
	TIMEDSELFBUFF()
	USEACTIVEPOINTS(30309)
	FLY(-629.82, 80.5, 39)
	DIM $OBSTACLES[5][3] = [[-712.52, 39.71, 4], [-755.05, 23.09, 10], [-663.71, 5.85, 1], [-657.11, 19.02, 3], [-614.41, -11.36, 27]]
	DIM $WAYPOINTS[11][3] = [[-694.7, -9.54, 0], [-661.96, -13.8, 0], [-615.34, 40.33, 0], [-650.94, 56.74, 0], [-684.3, 63.54, 0], [-698.66, 31.61, 0], [-648.66, 72.25, 0], [-683.41, 29.08, 0], [-673.28, 29.7, 0], [-727.74, 18.29, 0], [-715.75, -6.61, 0]]
	$CURPOS = 0
	$KILLMODE = 0
	$LASTWAYPOINT = -1
	$CURWAYPOINT = -1
	WHILE ITEMCOUNT(41444) < 8
		FOR $I = 0 TO UBOUND($OBSTACLES) - 1
			AVOIDPLACE($OBSTACLES[$I][0], $OBSTACLES[$I][1], $OBSTACLES[$I][2], $OBSTACLES[$I][2] + 2)
		NEXT
		IF NOT CIRCLEAVOID("Ren Dao", 35, 52, -685.9, 39.5, 54.8, 2, 20, FALSE) THEN
			$MOBS = NPCARRAY()
			$CURPOS = PLAYERPOS()
			IF COUNTMOBSINAREA($CURPOS[0], $CURPOS[1], 30, "Maternity Nectar Spirit", 2, $MOBS) > 2 THEN
				BUFFEREDSELECT(GETNPCUNIQUEID("Maternity Nectar Spirit"))
				SLEEP(100)
				$TARGETPOS = TARGETPOS()
				IF UBOUND($TARGETPOS) AND COUNTMOBSINAREA($TARGETPOS[0], $TARGETPOS[1], 5, "Maternity Nectar Spirit") > 1 THEN
					AOE()
				ELSE
					KILL("Maternity Nectar Spirit", 200, 2, 1)
				ENDIF
				CONTINUELOOP
			ELSEIF COUNTMOBSINAREA($CURPOS[0], $CURPOS[1], 20, "Disciple of Ren Dao", 2, $MOBS) > 7 OR $KILLMODE AND COUNTMOBSINAREA($CURPOS[0], $CURPOS[1], 20, "Disciple of Ren Dao", 2, $MOBS) > 2 THEN
				$CURRTARGET = PLAYERTARGET()
				$INDEX = FINDCLOSEST($MOBS, $CURRTARGET, 0)
				IF $INDEX == -1 OR $MOBS[$INDEX][2] <> "Disciple of Ren Dao" OR NOT INCOMBAT() OR DISTANCE2D($MOBS[$INDEX][4], $MOBS[$INDEX][5]) > 20 THEN
					$INDEX = FINDCLOSEST($MOBS, "Disciple of Ren Dao")
				ENDIF
				IF $INDEX <> -1 THEN
					$KILLMODE = 1
					BUFFEREDSELECT($MOBS[$INDEX][0])
					SLEEP(100)
					AOE()
				ENDIF
				CONTINUELOOP
			ELSEIF COUNTMOBSINAREA($CURPOS[0], $CURPOS[1], 30, "Maternity Nectar Spirit", 2, $MOBS) > 0 THEN
				KILL("Maternity Nectar Spirit", 200, 2, 1)
				CONTINUELOOP
			ELSEIF COUNTMOBSINAREA($CURPOS[0], $CURPOS[1], 7, "Disciple of Ren Dao", 2, $MOBS) <= 2 THEN
				$KILLMODE = 0
			ELSEIF $KILLMODE THEN
				KILL("Disciple of Ren Dao", 200, 2, 0)
				CONTINUELOOP
			ENDIF
			$POS = GETNPCPOSITION("Ren Dao")
			DO
				FOR $I = 0 TO UBOUND($WAYPOINTS) - 1
					$WAYPOINTS[$I][2] = COUNTMOBSINAREA($WAYPOINTS[$I][0], $WAYPOINTS[$I][1], 25, "Disciple of Ren Dao", 2, $MOBS)
					DIM $CHECK[2] = [$WAYPOINTS[$I][0], $WAYPOINTS[$I][1]]
					IF ISCROWDED($CHECK, 30, 1) OR $I == $LASTWAYPOINT OR $I == $CURWAYPOINT THEN
						$WAYPOINTS[$I][2] = -1
					ENDIF
				NEXT
				_ARRAYSORT($WAYPOINTS, 1, 0, 0, 2)
				FOR $NEXTPOS = 0 TO UBOUND($WAYPOINTS) - 1
					IF RANDOM(0, 2, 1) == 0 AND DISTANCE2D($WAYPOINTS[$NEXTPOS][0], $WAYPOINTS[$NEXTPOS][1]) > 25 OR $NEXTPOS == UBOUND($WAYPOINTS) - 1 THEN
						EXITLOOP
					ENDIF
				NEXT
				PRINT("Nextpost " & $NEXTPOS)
				DIM $DEST[2] = [$WAYPOINTS[$NEXTPOS][0], $WAYPOINTS[$NEXTPOS][1]]
			UNTIL UBOUND($POS) == 0 OR CHECKPATHSAFE($POS, 30, $DEST)
			IF ACTIONFLAG() == 0 THEN
				MOVETO($DEST[0], $DEST[1])
				$LASTWAYPOINT = $CURWAYPOINT
				$CURWAYPOINT = $NEXTPOS
			ENDIF
		ENDIF
		SLEEP(50)
	WEND
	USEANCIENTGIFT()
	TURNINQUEST("Queen Liu Soo", 30309, -644.05, 174.95, 45)
ENDFUNC
FUNC SEARCHFORENERGY()
	IF NOT HASQUEST(30674) AND NOT ISQUESTAVAILABLE(30673) THEN RETURN
	SETSTATUS("Primal World - Search For Energy")
	TRANSFERMAP($MAP_STORY, 0, -755.37, -223.9)
	TAKEQUEST("Mu Hoffen", 30673, -755.37, -223.9)
	TIMEDSELFBUFF()
	FLY(-754.5, -248.9)
	WHILE ITEMCOUNT(41484) < 1
		KILL("Lord Tyrant's Scout", 200, 2, 1)
		SLEEP(300)
	WEND
	FLY(-722.69, -76.74)
	WHILE HASQUEST(30675)
		SELECTTARGET(GETNPCUNIQUEID("Vitality"))
		IF NPCDISTANCE("Vitality") > 15 THEN MOVETONPC("Vitality")
		SLEEP(200)
		USEITEMID(41484, 1)
		WAITSTOP()
	WEND
	USEANCIENTGIFT()
	TURNINQUEST("Mu Hoffen", 31031, -755.37, -223.9)
ENDFUNC
