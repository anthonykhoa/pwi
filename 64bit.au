FUNC TRIAL()
	INVITEALTS()
	SLEEP(2000)
	MASSTELETOBASE()
	SLEEP(12000)
	MOVE(-38.8, 687.77)
	MASSMOVE()
	SLEEP(2000)
	MASSFOLLOWCOMMAND()
	MOVE(-100.01, 703.07)
	MASSMOVE()
	SLEEP(2000)
	$POS = PLAYERPOS()
	$CURRENT_MAP = INITIALMAP()
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($I)
		IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
		TRANSFERMAP($CURRENT_MAP, 0, $POS[0], $POS[1])
		WAITTOFINISH()
	NEXT
	SWITCHTO($MAIN)
	DYNAMICHELPER()
	MOVE(-98.275, 715.63)
	MASSMOVE()
	SLEEP(2000)
	DYNAMICHELPER()
	SLEEP(2000)
	MOVE(74.05, -1237.19)
	MASSMOVE()
	SLEEP(1000)
	MASSFOLLOWCOMMAND()
	MOVE(110.19, -1186.04)
ENDFUNC
