FUNC GEARSWAPCONTROLS()
	REGISTERCOMMAND("Toggle Gear", "ToggleGear", "Toggle between saved gear sets.")
	$Y = $YOFFSET + 10
	$WIDTH = 50
	GUICTRLCREATELABEL("Swap fast between gear sets. Char-specific. Very OP.", 20, $Y, 240, 20)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKHEIGHT + $GUI_DOCKRIGHT)
	GUICTRLSETTIP(-1, "Almost a little... too OP? Consider not using this in PvP out of respect for fair play.")
	$Y += 25
	FOR $I = 0 TO $GEAR_SWAP_SET_COUNT - 1
		$GEAR_SET_LABELS[$I] = GUICTRLCREATELABEL("Unset", 30, $Y + 20, 80, 20)
		GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
		GUICTRLCREATEGROUP("Gear Set #" & $I + 1, 20, $Y, 270, 46)
		GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKHEIGHT)
		$X = 270 + 20 - ($WIDTH + 3) * 3
		GUICTRLCREATEBUTTON("Save", $X, $Y + 10, $WIDTH, 30)
		GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKRIGHT + $GUI_DOCKSIZE)
		GUICTRLSETONEVENT(-1, "SetGear" & $I)
		$X += $WIDTH + 3
		GUICTRLCREATEBUTTON("Remove", $X, $Y + 10, $WIDTH, 30)
		GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKRIGHT + $GUI_DOCKSIZE)
		GUICTRLSETONEVENT(-1, "UnsetGear" & $I)
		$X += $WIDTH + 3
		GUICTRLCREATEBUTTON("Swap", $X, $Y + 10, $WIDTH, 30)
		GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKRIGHT + $GUI_DOCKSIZE)
		GUICTRLSETONEVENT(-1, "SwapGear" & $I)
		$Y += 50
		REGISTERCOMMAND("Gear Swap #" & $I + 1, "SwapGear" & $I, "Switch to gear set #" & $I + 1 & ".")
	NEXT
	$Y += 5
	GUICTRLCREATELABEL("Bot gear-swap is much stronger than other solutions provided by placing 2 full gear sets onto your skillbar because:" & @CRLF & "1) bot gear swap can swap warsoul repository set bonuses" & @CRLF & "2) no risk of accidentally taking gear off instead of equipping it" & @CRLF & "3) gear doesn't need to be on skillbar (save skillbar space)", 20, $Y, 270, 75)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKHEIGHT)
	ADDHELPCONTROL("Typical use case with 2 gear sets:" & @CRLF & @CRLF & "1) high damage gear set" & @CRLF & "2) tanky gear set" & @CRLF & @CRLF & "Set a hotkey for each gear set you want to quickly swap to." & @CRLF & "Place some parts of each gear set on your character's skillbar in-game to visually confirm which gearset you have equipped.", 280, $YOFFSET + 5)
ENDFUNC
FUNC MAKESETTINGSCONTROLS()
    SettingSCheckBox("Use Sin to glitch DHJ boss instead of cleric", "UseSinToGlitchDhjBoss", "false")
	SETTINGSCHECKBOX("NOTE: Settings listed here are not character specific!", "none", TRUE, FALSE, TRUE, "")
	SETTINGSCHECKBOX("NOTE2: Settings changes take effect immediately, even", "none", TRUE, FALSE, TRUE, "")
	SETTINGSCHECKBOX("if bot is active, but changes only save to settings.ini", "none", TRUE, FALSE, TRUE, "")
	SETTINGSCHECKBOX("if you tick/untick setting while TheNightmareStuff is idle.", "none", TRUE, FALSE, TRUE, "")
	SETTINGSCHECKBOX("", "none", TRUE, FALSE, TRUE, "")
	SETTINGSCHECKBOX("Bot Behavior Settings", "none", TRUE, FALSE, TRUE, "A few settings for changing how TheNightmareStuff itself works.")
	SETTINGSCHECKBOX("Enable notifications", "notifications", "False")
	GUICTRLSETTIP(-1, "Sends notification messages from bot to the Windows notifications panel on Windows 10 or higher. Interesting but probably not needed!.")
