	WHILE HASQUEST(39140)
		MOVE($PRETTYCOORDS[$I][0], $PRETTYCOORDS[$I][1], $PRETTYCOORDS[$I][2], 1)
		IF GETNPCUNIQUEID("Pretty Tiger") THEN
			TALKTONPC("Pretty Tiger")
			TURNINQUEST("Pretty Tiger", 39140)
			SLEEP(2000)
