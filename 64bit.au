	RETURN _MEMORYREAD($PLAYER + $PLAYERBOUNDARY_OFFSET, $GAME_PROCESS, "byte")
ENDFUNC
FUNC CLEARDRUNK()
	$WASDRUNK = _MEMORYREAD(PLAYERADDRESS() + $PLAYERDRUNK_OFFSET, $GAME_PROCESS, "byte")
	_MEMORYWRITE(PLAYERADDRESS() + $PLAYERDRUNK_OFFSET, $GAME_PROCESS, 0, "byte")
	RETURN $WASDRUNK
ENDFUNC
FUNC PARTYCOUNT()
	$PLAYER = PLAYERADDRESS()
	RETURN _MEMORYREAD(_MEMORYREAD($PLAYER + $PLAYERPARTY_OFFSET, $GAME_PROCESS) + $PARTYCOUNT_OFFSET, $GAME_PROCESS)
ENDFUNC
FUNC PARTYARRAY()
	$PLAYER = PLAYERADDRESS()
	$PARTY = _MEMORYREAD($PLAYER + $PLAYERPARTY_OFFSET, $GAME_PROCESS)
	$COUNT = _MEMORYREAD($PARTY + $PARTYCOUNT_OFFSET, $GAME_PROCESS)
	$PARTYLIST = _MEMORYREAD($PARTY + $PARTYCOUNT_OFFSET + 4294967292, $GAME_PROCESS)
	DIM $ARRAY[$COUNT][2]
	FOR $I = 0 TO $COUNT - 1
		$MEMBER = _MEMORYREAD($PARTYLIST + $I * 4, $GAME_PROCESS)
		$ARRAY[$I][0] = _MEMORYREAD($MEMBER + 12, $GAME_PROCESS)
		$ARRAY[$I][1] = BUFFARRAY($MEMBER)
	NEXT
	RETURN $ARRAY
ENDFUNC
FUNC WARSOULREPOSITORY()
	$BASE = _MEMORYREAD(_MEMORYREAD($ADDRESS_WARSOUL_REPOSITORY, $GAME_PROCESS) + 4, $GAME_PROCESS) + 20
	DIM $ARRAY[12]
	FOR $I = 0 TO 11
		$ARRAY[$I] = _MEMORYREAD($BASE + 4 * $I, $GAME_PROCESS)
	NEXT
	RETURN $ARRAY
ENDFUNC
