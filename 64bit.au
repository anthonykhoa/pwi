	GUICTRLSETTIP(-1, "Navigates character to the inside of Heavenfall Temple," & @CRLF & "and grabs the weekly quest inside if available.")
	ADDHELPCONTROL("Basic instructions:" & @CRLF & @CRLF & '1) Click "Enter Heavenfall Temple"' & @CRLF & '2) craft "Chaotic Essence" and use it' & @CRLF & "3) Enter into a Heavenfall Temple room" & @CRLF & '4) click "Run Tower"' & @CRLF & @CRLF & "If character gets stuck, pause the bot from system tray, " & @CRLF & "complete the room manually, then unpause.")
ENDFUNC
FUNC REFRESHTOWERSETTINGS()
