	ELSEIF HASQUEST(39061) THEN
		ADVENTUREKINGDOMTHRILL()
	ELSEIF HASQUEST(39049) THEN
		TIGERROMANCE()
	ELSEIF HASQUEST(39044) THEN
		CELEBRATIONOFFLOWERS()
	ELSEIF HASQUEST(39032) OR HASQUEST(39033) OR HASQUEST(39034) THEN
		MANDALAPALACE()
	ELSEIF HASQUEST(39035) OR HASQUEST(39036) OR HASQUEST(39037) THEN
		CASTLEOFWONDROUSFATE()
	ELSEIF HASQUEST(39038) OR HASQUEST(39039) OR HASQUEST(39040) THEN
		VERDANTSEA()
	ELSEIF HASQUEST(39041) OR HASQUEST(39042) OR HASQUEST(39043) THEN
		FROSTMARCH()
	ENDIF
ENDFUNC
