	FUNC SENDMAKEFROMITEMLIST($ITEMID, $LISTSLOTS)
		IF UBOUND($LISTSLOTS) < 2 THEN RETURN
		$PACKET = "6D000001" & _HEX($LISTSLOTS[0], 4) & _HEX($ITEMID) & _HEX($ITEMID) & _HEX(UBOUND($LISTSLOTS) - 1)
		FOR $I = 1 TO UBOUND($LISTSLOTS) - 1
			$PACKET = $PACKET & _HEX($LISTSLOTS[$I])
		NEXT
		SENDPACKET($PACKET, 18 + 4 * UBOUND($LISTSLOTS) - 4, $GAME_PID)
	ENDFUNC
