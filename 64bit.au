	SWITCHTO($MAIN)
	LOCAL CONST $PLAYER_COUNT = 10
	LOCAL $PLAYERCOORDS[$PLAYER_COUNT][2] = [[-330.07, -1520.09], [-296.83, -1480.11], [-296.83, -1480.11], [-328.88, -1447.89], [-328.88, -1447.89], [-328.88, -1447.89], [-365.16, -1481.82], [-365.16, -1481.82], [-365.16, -1481.82], [-365.16, -1481.82]]
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		IF $I >= $PLAYER_COUNT THEN EXITLOOP
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		LOCAL $X = $PLAYERCOORDS[$I][0]
		LOCAL $Y = $PLAYERCOORDS[$I][1]
		MOVETO($X, $Y)
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC WESTANTICLOCKWISE()
	LOCAL $CLIENTSINDEXES = GETSQUADALTS()
	SWITCHTO($MAIN)
	LOCAL CONST $PLAYER_COUNT = 10
	LOCAL $PLAYERCOORDS[$PLAYER_COUNT][2] = [[-365.16, -1481.82], [-330.07, -1520.09], [-330.07, -1520.09], [-296.83, -1480.11], [-296.83, -1480.11], [-296.83, -1480.11], [-328.88, -1447.89], [-328.88, -1447.89], [-328.88, -1447.89], [-328.88, -1447.89]]
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		IF $I >= $PLAYER_COUNT THEN EXITLOOP
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		LOCAL $X = $PLAYERCOORDS[$I][0]
		LOCAL $Y = $PLAYERCOORDS[$I][1]
		MOVETO($X, $Y)
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
#region DHJ

Func WaitClientsInstance(ByRef $ClientsIndexes, $Instance)
  $flag = 1
  While $flag
  $flag = 0
    FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
      SWITCHTONUM($CLIENTSINDEXES[$I])
      IF INSTANCEID() <> $Instance THEN $flag = 1
    NEXT
  WEnd
EndFunc

func TeleportAndWait($ID, $NpcName)
  If TeleportStoneTo($ID) Then
    WaitForNpc($NpcName)
  EndIf
EndFunc

Func TeleportToDhjNpc()
  if GetNpcUniqueId("Lieutenant Bennett") Then Return
  TeleportAndWait(9044, "Illusion Stone")
  TakeQuest("Illusion Stone", 37947, 1759.930, 1155.825)
  WaitForNpc("Lieutenant Bennett")
  Sleep(2000)
EndFunc

Func TeleportClientsToDhj(ByRef $ClientsIndexes)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SwitchToNum($CLIENTSINDEXES[$I])
    If InstanceId() == 186 Or GetNpcUniqueId("Lieutenant Bennett") Then ContinueLoop
    SetStatus("Teleporting To Illusion Stone")
    TeleportStoneTo(9044)
  Next
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SwitchToNum($CLIENTSINDEXES[$I])
    If InstanceId() == 186 Or GetNpcUniqueId("Lieutenant Bennett") Then ContinueLoop
    SetStatus("Waiting For ILlusion Stone")
    WaitForNpc("Illusion Stone")
  Next
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SwitchToNum($CLIENTSINDEXES[$I])
    If InstanceId() == 186 Or GetNpcUniqueId("Lieutenant Bennett") Then ContinueLoop
    SetStatus("Taking Illusion Stone quest")
    TakeQuest("Illusion Stone", 37947, 1753.525, 1153.224)
  Next
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SwitchToNum($CLIENTSINDEXES[$I])
    If InstanceId() == 186 Or GetNpcUniqueId("Lieutenant Bennett") Then ContinueLoop
    SetStatus("Waiting Lietenant Bernand")
    WaitForNpc("Lieutenant Bennett")
  Next
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SwitchToNum($CLIENTSINDEXES[$I])
    If InstanceId() == 186 Then ContinueLoop
    SetStatus("Taking Quest From Leutenant")
    TakeQuest("Lieutenant Bennett", 37848, 931.96, -940.34)
  Next
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SwitchToNum($CLIENTSINDEXES[$I])
    If InstanceId() == 186 Then ContinueLoop
    SetStatus("Waiting For Archmage Conrad")
    WaitForNpc("Archmage Conrad")
  Next
  SwitchTo($Main)
EndFunc

FUNC FARMDHJ()
  SETSTATUS("Starting DHJ farming.")
  $ClientsIndexes = GETSQUADALTS()
  $Count = UBOUND($ClientsIndexes)
  WHILE $Count < 2
    SETSTATUS("Form a squad with 2 or more characters. Make sure to include cleric for glitching." & @CRLF & "Move character for 1s to cancel FarmDHJ.")
    SLEEP(1000)
    $ClientsIndexes = GETSQUADALTS()
    $Count = UBOUND($ClientsIndexes)
    IF MOVEKEY() <> 0 THEN
      SETSTATUS("Farm DHJ cancelled by moving character.")
      RETURN
    ENDIF
  WEND
  SETSTATUS("Farm DHJ with " & $Count & " characters.")
  If SkillOffCooldown(4638, 4) And InstanceId() <> 186 Then
    TeleportToDhjNpc()
    CASTSKILL(4638, 4)
    SLEEP(10000)
    MASSSQUADSIGNETACCEPT()
    SLEEP(12000)
  Else
    TeleportClientsToDhj($ClientsIndexes)
  EndIf
  SquadLeaveFix($ClientsIndexes)
  While True
    RunDhj($ClientsIndexes)
  WEND
ENDFUNC

Func SquadLeaveFix(ByRef $ClientsIndexes)
  While UBound(GetSquadAlts()) < UBound($ClientsIndexes)
    $MainId = PLAYERID()
    FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
      INVITESQUAD(SQUADIDNUM($ClientsIndexes[$I]))
    Next
    Sleep(2000)
    FOR $I = 0 TO UBOUND($ClientsIndexes) - 1
      SWITCHTONUM($ClientsIndexes[$I])
      ACCEPTSQUADID($MAINID)
    Next
  WEnd
  SwitchTo($Main)
EndFunc

Func WaitToFindTarget($Target, $TimeLimit = 0, $Field = 1)
  $Timer = TIMERINIT()
  $Mobs = NpcArray()
  $Index = FindClosest($Mobs, $Target, $Field)
  While $Index == -1
    If $TimeLimit > 0 And TimerDiff($Timer) > $TimeLimit Then Return -1
    $Mobs = NpcArray()
    $Index = FindClosest($Mobs, $Target, $Field)
  WEnd
  Return $Mobs[$Index][0]
EndFunc

Func WaitToFindTarget2($Target, $TimeLimit = 0, $Field = 1)
  SwitchTo($MAIN)
  $Timer = TIMERINIT()
  $Mobs = NpcArray()
  $Index = FindClosest($Mobs, $Target, $Field)
  While $Index == -1
    If $TimeLimit > 0 And TimerDiff($Timer) > $TimeLimit Then Return -1
    $Mobs = NpcArray()
    $Index = FindClosest($Mobs, $Target, $Field)
  WEnd
  Return $Mobs[$Index][0]

EndFunc

Func TargetEachother(ByRef $ClientsIndexes)
  SwitchToNum($ClientsIndexes[0])
  $Target = PlayerId()
  For $i = 1 To UBound($ClientsIndexes) - 1
    SwitchToNum($ClientsIndexes[$i])
    SelectTarget($Target)
  Next
  $Target = PlayerId()
  SwitchToNum($ClientsIndexes[0])
  SelectTarget($Target)
  SwitchTo($Main)
EndFunc

Func KillTargetClients($Target, ByRef $ClientsIndexes, $Field = 0, $Range = 0)
  $Mobs = NpcArray()
  $Index = FindClosest($Mobs, $Target, $Field)
  $MacroNumber = 3
  If $Range > 10 Then $MacroNumber = 5
	While $Index <> -1
		For $i = 0 To UBound($clientsIndexes) - 1
			switchtonum($clientsIndexes[$i])
      QuickSelect($Mobs[$Index][0])
      If $Range > 0 Then
        $Destination = NewPositionBetweenVectors($Range)
        If $Destination <> 0 Then
          WaitClientsToFinish($ClientsIndexes)
          ClientsMoveAndWait($Destination[0], $Destination[1], $ClientsIndexes)
        EndIf
      EndIf
      $skills = macroarray($MacroNumber)
      ExecuteSkills($skills)
		Next
    $Mobs = NpcArray()
    $Index = FindClosest($Mobs, $Target, $Field)
    Sleep(100)
	WEnd
  SwitchTo($Main)
EndFunc

Func KillTargetClientsUpdatedForDHJ($Target, ByRef $ClientsIndexes, $Field = 0, $Range = 0)
    Local $StartTime = TimerInit()
    Local $HPCheckDone = False
    $Mobs = NpcArray()
    $Index = FindClosest($Mobs, $Target, $Field)
    $MacroNumber = 3
    If $Range > 10 Then $MacroNumber = 5

    While $Index <> -1
        ; Check if 30 seconds have passed since start
        If TimerDiff($StartTime) > 30000 And Not $HPCheckDone Then
            Local $TargetHP = TargetHPPercent()
            If $TargetHP > 95 Then
                ClientsMoveAndWait(128.77, 39.35, $ClientsIndexes, 186)
                ClientsMoveAndWait(115.15, 37.56, $ClientsIndexes, 186)
                ClientsMoveAndWait(103.250, 13.298, $ClientsIndexes, 186)
                ; Restart the function
                Return RUNDHJ($ClientsIndexes)
            EndIf

            Local $AnyDead = False
            For $i = 0 To UBound($ClientsIndexes) - 1
                SwitchToNum($ClientsIndexes[$i])

                ; Check if HP is zero
                Local $HPMP = GETHPMP()
                If $HPMP[0] == 0 Then
                    $AnyDead = True
                    MASSRESTOTOWN() ; Resurrect the character
                EndIf
            Next

            If $AnyDead Then
                ; Move the living characters back to the initial coordinates
                For $i = 0 To UBound($ClientsIndexes) - 1
                    Local $HPMP = GETHPMP()
                    If $HPMP[0] > 0 Then
                        SwitchToNum($ClientsIndexes[$i])
                        ClientsMoveAndWait(128.77, 39.35, $ClientsIndexes, 186)
                        ClientsMoveAndWait(115.15, 37.56, $ClientsIndexes, 186)
                        ClientsMoveAndWait(103.250, 13.298, $ClientsIndexes, 186)
                    EndIf
                Next
                
                ; Restart the function
                Return RUNDHJ($ClientsIndexes)
            EndIf
            
            $HPCheckDone = True ; Ensure this check only runs once
        EndIf

        For $i = 0 To UBound($ClientsIndexes) - 1
            SwitchToNum($ClientsIndexes[$i])
            QuickSelect($Mobs[$Index][0])
            If $Range > 0 Then
                $Destination = NewPositionBetweenVectors($Range)
                If $Destination <> 0 Then
                    WaitClientsToFinish($ClientsIndexes)
                    ClientsMoveAndWait($Destination[0], $Destination[1], $ClientsIndexes)
                EndIf
            EndIf
            $Skills = MacroArray($MacroNumber)
            ExecuteSkills($Skills)
        Next
        $Mobs = NpcArray()
        $Index = FindClosest($Mobs, $Target, $Field)
        Sleep(100)
    WEnd
    SwitchTo($Main)
EndFunc

Func KillTargetClients2(ByRef $ClientsIndexes, $Field = 0, $Range = 0)
  $MacroNumber = 3
  If $Range > 10 Then $MacroNumber = 5
	For $i = 0 To UBound($ClientsIndexes) - 1
		switchtonum($ClientsIndexes[$i])
    If $Range > 0 Then
      $Destination = NewPositionBetweenVectors($Range)
      If $Destination <> 0 Then
        WaitClientsToFinish($ClientsIndexes)
        ClientsMoveAndWait($Destination[0], $Destination[1], $ClientsIndexes)
      EndIf
    EndIf
    $skills = macroarray($MacroNumber)
    ExecuteSkills($skills)
	Next
  SwitchTo($Main)
EndFunc

Func KillTargetClients3(ByRef $ClientsIndexes)
    ; Get the initial target's unique ID
    SwitchTo($MAIN)
    $InitialUniqueID = GetTarget()
    $CurrentUniqueID = GetTarget()
    If $CurrentUniqueID <> $InitialUniqueID Then
        Return  ; Exit the function if the unique ID changes
    EndIf
    executemacro(5)  ; Replace 3576 with the specific skill ID if needed
    Sleep(100)

    SwitchTo($Main)
EndFunc



; Main function for mass nuking the final boss
FUNC MASSNUKEFINALBOSSTTR($MobName, $CHECKING = True, $GENIECHI = FALSE, $FOLLOW = TRUE, $RANGEDONLY = FALSE, $RETURNTOSTARTINGPOSITION = FALSE, $CHI = 400, $USESPARK = TRUE, $ENDWITHTARGETDEATH = TRUE, $BMDOESNOTTRIPLESPARK = FALSE, $UPDBMDOESNOTTRIPLESPARK = FALSE, $FAIRYBOSSNUKEDHJ = FALSE, $UPDNUKE = FALSE, $WeakestClient = $WeakestClient, $OTHERCLIENTSINDEXES = $OTHERCLIENTSINDEXES)
    Dim $Mobs, $Index, $Target, $InitialUniqueID, $CurrentUniqueID
    Dim $StartTime = TimerInit()
    Dim $InitialBossHP, $CurrentBossHP
    Dim $HP70Reached = FALSE, $HP45Reached = FALSE, $HP25Reached = FALSE
    SWITCHTO($MAIN)
    ; Main client execution - this will set the target for all clients
    $Mobs = NPCARRAY()
    $Index = -1

    ; Loop to find the target with a timeout mechanism
    While TimerDiff($StartTime) < 20000 ; 2 second timeout (2000 ms)
        $Index = FindClosest($Mobs, $MobName, 2, 0, True, 20, 300)
        If $Index <> -1 Then ExitLoop
        Sleep(100) ; Small delay before retrying to find the target
    Wend

    If $Index = -1 Then
        ; If no target is found within the timeout, return
        SetStatus("Timeout reached: Could not find target " & $MobName)
        Return
    EndIf

    $Target = $Mobs[$Index][0]
    QuickSelect($Target)

    ; Get the initial target's unique ID and initial HP
    $InitialUniqueID = GetTarget()
    $InitialBossHP = TARGETHPPERCENT() ; Store initial boss HP

    ; Ensure the target is valid
    If $InitialUniqueID == 0 Then
        SetStatus("Failed to acquire target: " & $MobName)
        Return
    EndIf

    SETSTATUS("----------------------------------- MASS NUKING ----------------------------------")
    $CLIENTSINDEXES = GETNEARBYALTS()
    $USELIFEHUNTERSPAM = GETGLOBALSETTING("useLifeHunterSpamInMassNuke100_10")

    If $USESPARK Then
        For $I = 0 To UBOUND($OTHERCLIENTSINDEXES) - 1
            $INDEX = $OTHERCLIENTSINDEXES[$I]
            SWITCHTONUM($INDEX)
            If CLASS() == 0 Then
                If INSTANCEID() == 176 And $UPDBMDOESNOTTRIPLESPARK And Not GETGLOBALSETTING("bmDoubleSparkInstead") Then
                    CONTINUELOOP
                ElseIf $BMDOESNOTTRIPLESPARK And Not GETGLOBALSETTING("bmDoubleSparkInstead") Then
                    CONTINUELOOP
                ElseIf GETGLOBALSETTING("bmDoubleSparkInstead") Then
                    CASTSKILL(227)
                EndIf
            EndIf
            TRIPLESPARK()
        Next
    EndIf

    SLEEP(350)
    If $GENIECHI Then MASSGENIECHISKILL($CHI, TRUE)
    SLEEP(350)
    SWITCHTO($MAIN)

    MASSSELECT2()
    $SEEKEREQUIPATTACK = TRUE
    $SEEKEREQUIPDEF = TRUE
    $SEEKERATTACKGEARTIMER = 0
    $SINTIMER = TIMERINIT()
    $GENIESKILLTIMER = TIMERINIT()
    $CASTFRENZYALREADY = FALSE

    Dim $SINKNIFETHROWSKILLIDS[6] = [3802, 3799, 3800, 3801, 3803, 3804]
    Dim $BMHFIDS[7] = [413, 3931, 3932, 3933, 3934, 3935, 3936]
    Dim $BARBRANGEDSKILLIDS[9] = [3864, 4408, 502, 3853, 3854, 3855, 3856, 3857, 3858]
    $CHECKDISTANCETOTARGETTIMER = 0

    ; Initialize movement timer
    $MovementTimer = TimerInit()
    $MoveDirection = 1  ; 1 for X, 2 for Y, alternates

    While MOVEKEY() == 0
        SWITCHTO($MAIN)

        ; Update current target ID and HP
        $CurrentUniqueID = GetTarget()
        $CurrentBossHP = TARGETHPPERCENT()

        ; Check if the target has changed (indicating the boss might be dead)
        If $ENDWITHTARGETDEATH And $CurrentUniqueID <> $InitialUniqueID Then
            SETSTATUS("------------------------------- Mass Nuke cancelled: Target dead ------------------------------")

            EXITLOOP
        EndIf

        For $I = 0 To UBOUND($OTHERCLIENTSINDEXES) - 1
            $INDEX = $OTHERCLIENTSINDEXES[$I]
            If CLIENTINGROUP($CLIENTS[$INDEX][2], "ignore") Then CONTINUELOOP
            If CLIENTINGROUP($CLIENTS[$INDEX][2], "main") Then
                If GETGLOBALSETTING("MassNukeUseFrenzyOnMain") And TIMERDIFF($GENIESKILLTIMER) > 5000 And Not $CASTFRENZYALREADY Then
                    USEGENIESKILL(978, PLAYERID())
                    $CASTFRENZYALREADY = TRUE
                EndIf
            EndIf
            If Not CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") Then CONTINUELOOP
            SWITCHTONUM($INDEX)
        Next

        ; Instead of executing macro individually, call MASSMACRO5 to execute it for all clients
        MASSMACRO5()

        If TIMERDIFF($CHECKDISTANCETOTARGETTIMER) > 1000 Or $CHECKDISTANCETOTARGETTIMER == 0 Then
            $CHECKDISTANCETOTARGETTIMER = TIMERINIT()
        EndIf
        SLEEP(100)
        SWITCHTO($MAIN)
    Wend

    $ALREADYUSINGSKILLSENDER = FALSE
    SWITCHTO($MAIN)
    If $FOLLOW Then MASSFOLLOW($OTHERCLIENTSINDEXES)
    SETSTATUS("------------------------------- Mass Nuke cancelled ------------------------------ ")
ENDFUNC


FUNC PLAYERPOS1()
    $PLAYER = PLAYERADDRESS()
    DIM $POS[2]
    $POS[0] = _MEMORYREAD($PLAYER + 60, $GAME_PROCESS, "float") ; X coordinate
    $POS[1] = _MEMORYREAD($PLAYER + 68, $GAME_PROCESS, "float") ; Y coordinate
    RETURN $POS
ENDFUNC


FUNC MASSNUKEBOSSTTR($MobName, $GENIECHI = FALSE, $FOLLOW = TRUE, $RANGEDONLY = FALSE, $RETURNTOSTARTINGPOSITION = FALSE, $CHI = 400, $USESPARK = TRUE, $ENDWITHTARGETDEATH = FALSE, $BMDOESNOTTRIPLESPARK = FALSE, $UPDBMDOESNOTTRIPLESPARK = FALSE, $FAIRYBOSSNUKEDHJ = FALSE, $UPDNUKE = FALSE)
    Dim $Mobs, $Index, $Target, $InitialUniqueID, $CurrentUniqueID
    Dim $StartTime = TimerInit()
    SWITCHTO($MAIN)
    ; Main client execution - this will set the target for all clients
    $Mobs = NPCARRAY()
    $Index = -1

    ; Loop to find the target with a timeout mechanism
    While TimerDiff($StartTime) < 2000 ; 2 second timeout (3000 ms)
        $Index = FindClosest($Mobs, $MobName, 2, 0, True, 20, 300)
        If $Index <> -1 Then ExitLoop
        Sleep(100) ; Small delay before retrying to find the target
    Wend

    If $Index = -1 Then
        ; If no target is found within the timeout, return
        SetStatus("Timeout reached: Could not find target " & $MobName)
        Return
    EndIf

    $Target = $Mobs[$Index][0]
    QuickSelect($Target)

    ; Get the initial target's unique ID
    $InitialUniqueID = GetTarget()

    ; Ensure the target is valid
    If $InitialUniqueID == 0 Then
        SetStatus("Failed to acquire target: " & $MobName)
        Return
    EndIf

    SETSTATUS("----------------------------------- MASS NUKING ----------------------------------")
    $CLIENTSINDEXES = GETNEARBYALTS()
    $USELIFEHUNTERSPAM = GETGLOBALSETTING("useLifeHunterSpamInMassNuke100_10")

    If $USESPARK Then
        For $I = 0 To UBOUND($CLIENTSINDEXES) - 1
            $INDEX = $CLIENTSINDEXES[$I]
            SWITCHTONUM($INDEX)
            If CLASS() == 0 Then
                If INSTANCEID() == 176 And $UPDBMDOESNOTTRIPLESPARK And Not GETGLOBALSETTING("bmDoubleSparkInstead") Then
                    CONTINUELOOP
                ElseIf $BMDOESNOTTRIPLESPARK And Not GETGLOBALSETTING("bmDoubleSparkInstead") Then
                    CONTINUELOOP
                ElseIf GETGLOBALSETTING("bmDoubleSparkInstead") Then
                    CASTSKILL(227)
                EndIf
            EndIf
            TRIPLESPARK()
        Next
    EndIf

    SLEEP(350)
    If $GENIECHI Then MASSGENIECHISKILL($CHI, TRUE)
    SLEEP(350)
    SWITCHTO($MAIN)

    MASSSELECT2()
    $SEEKEREQUIPATTACK = TRUE
    $SEEKEREQUIPDEF = TRUE
    $SEEKERATTACKGEARTIMER = 0
    $SINTIMER = TIMERINIT()
    $GENIESKILLTIMER = TIMERINIT()
    $CASTFRENZYALREADY = FALSE

    Dim $SINKNIFETHROWSKILLIDS[6] = [3802, 3799, 3800, 3801, 3803, 3804]
    Dim $BMHFIDS[7] = [413, 3931, 3932, 3933, 3934, 3935, 3936]
    Dim $BARBRANGEDSKILLIDS[9] = [3864, 4408, 502, 3853, 3854, 3855, 3856, 3857, 3858]
    $CHECKDISTANCETOTARGETTIMER = 0

    While MOVEKEY() == 0
        SWITCHTO($MAIN)
        
        If $UPDNUKE And TIMERDIFF($MAXTIMEALLOWEDFORNUKE) > 180000 Then
            SETSTATUS("More than 180s passed on boss nuke. Something likely went wrong. Exiting.")
            EXITLOOP
        EndIf

        ; Update current target ID
        $CurrentUniqueID = GetTarget()

        ; Check if the target has changed (indicating the boss might be dead)
        If $ENDWITHTARGETDEATH And $CurrentUniqueID <> $InitialUniqueID Then
            SETSTATUS("------------------------------- Mass Nuke cancelled: Target dead ------------------------------")
            EXITLOOP
        EndIf

        ; New Check: Ensure the boss is still in the mob array
        $Mobs = NPCARRAY()
        $Index = FindClosest($Mobs, $MobName, 2, 0, True, 20, 300)
        If $Index = -1 Then
            SETSTATUS("------------------------------- Mass Nuke cancelled: Boss no longer found ------------------------------")
            EXITLOOP
        EndIf
            

        ; Instead of executing macro individually, call MASSMACRO5 to execute it for all clients
        MASSMACRO5()

        If TIMERDIFF($CHECKDISTANCETOTARGETTIMER) > 1000 Or $CHECKDISTANCETOTARGETTIMER == 0 Then
            $CHECKDISTANCETOTARGETTIMER = TIMERINIT()
        EndIf
        SLEEP(100)
        SWITCHTO($MAIN)
    Wend

    $ALREADYUSINGSKILLSENDER = FALSE
    SWITCHTO($MAIN)
    If $FOLLOW Then MASSFOLLOW($CLIENTSINDEXES)
    SETSTATUS("------------------------------- Mass Nuke cancelled ------------------------------ ")
ENDFUNC







Func TargetSpecificMobKillStopSoulForceSort($ClientIndexes, $MobName, $ExecuteMacroNumber, $Alts = False)
    ; Define variables for reusability
    Dim $Mobs, $Index, $Target, $InitialUniqueID, $CurrentUniqueID, $skills
    Dim $HPMP, $MAXHPOFBESTSIN, $INDEXLOCATIONOFBESTSIN
    Dim $CHECKDISTANCETOTARGETTIMER = TIMERINIT(), $GENIESKILLTIMER = TIMERINIT()
    Dim $SEEKEREQUIPATTACK = True, $SEEKEREQUIPDEF = True, $SEEKERATTACKGEARTIMER = 0
    Dim $StartTime = TimerInit() ; Initialize the timeout timer

    DIM $SINKNIFETHROWSKILLIDS[6] = [3802, 3799, 3800, 3801, 3803, 3804]
    DIM $BMHFIDS[7] = [413, 3931, 3932, 3933, 3934, 3935, 3936]
    DIM $BARBRANGEDSKILLIDS[9] = [3864, 4408, 502, 3853, 3854, 3855, 3856, 3857, 3858]

    ; Main client execution - this will set the target for all clients
    $Mobs = NPCARRAY()
    $Index = -1

    ; Loop to find the target with a timeout mechanism
    While TimerDiff($StartTime) < 10000 ; 10 second timeout (10000 ms)
        $Index = FindClosest($Mobs, $MobName, 2, 0, True, 20, 300)
        If $Index <> -1 Then ExitLoop
        Sleep(100) ; Small delay before retrying to find the target
    Wend

    If $Index = -1 Then
        ; If no target is found within the timeout, return
        SetStatus("Timeout reached: Could not find target " & $MobName)
        Return
    EndIf

    $Target = $Mobs[$Index][0]
    QuickSelect($Target)

    ; Get the initial target's unique ID
    $InitialUniqueID = GetTarget()
    $CurrentUniqueID = GetTarget()

    If $CurrentUniqueID = $InitialUniqueID Then
        ; If Alts is True, loop through the top client indexes and synchronize them
        If $Alts Then
            ; Synchronize all clients with the main target
            For $i = 0 To UBound($ClientIndexes) - 1
                SwitchToNum($ClientIndexes[$i])
                Sleep(100) ; Ensure the client has switched
                QuickSelect($Target) ; Set the same target on the alt
            Next
        EndIf

        ; Execute the routine for each client
        While PLAYERTARGET()
            ; Main client actions
            $skills = macroarray($ExecuteMacroNumber)
            ExecuteSkills($skills)
            Sleep(100)

            If $Alts Then
                For $i = 0 To UBound($ClientIndexes) - 1
                    SwitchToNum($ClientIndexes[$i])
                    Sleep(100) ; Ensure the client has switched

                    ; Retrieve the health and other status of the alt
                    $HPMP = GETHPMP()

                    ; Execute specific class logic
                    Select
                        Case CLASS() == 5 ; Sin
                            If SKILLOFFCOOLDOWN(3248) Then
                                CASTSKILL(3248)
                            Else
                                CASTFIRSTSKILL($SINKNIFETHROWSKILLIDS)
                            EndIf

                        Case CLASS() == 4 ; Barbarian
                            If $Target <> 0 Then
                                USEFIRSTSKILL($BARBRANGEDSKILLIDS, $Target)
                            EndIf

                        Case CLASS() == 8 ; Seeker
                            If NOT HASBUFF("Attack Level increased", 135) Then
                                If TIMERDIFF($SEEKERATTACKGEARTIMER) > 29000 Or $SEEKERATTACKGEARTIMER = 0 Then
                                    $SEEKEREQUIPDEF = True
                                    $SEEKERATTACKGEARTIMER = TIMERINIT()
                                EndIf
                                If $SEEKEREQUIPDEF Then
                                    SWAPGEAR(2)
                                    $SEEKEREQUIPDEF = False
                                    $SEEKEREQUIPATTACK = True
                                EndIf
                            ElseIf HASBUFF("Attack Level increased", 135) And $SEEKEREQUIPATTACK Then
                                SWAPGEAR(0)
                                $SEEKEREQUIPATTACK = False
                                $SEEKERATTACKGEARTIMER = TIMERINIT()
                            EndIf

                        Case CLASS() == 7
                            If NOT HASBUFF("Focus Accelerated channeling", 37) And CURRENTSKILL() <> 566 Then
                                USESKILL(566, PLAYERID())
                            EndIf
                            If HASBUFF("Specific skill's damage is increased.", 366) Or CURRENTSKILL() == 6920 Then
                                USESKILL(921, $Target)
                            EndIf

                        Case CLASS() == 0 ; Blademaster
                            If CHI() > 200 And GETGLOBALSETTING("forceBMToUseHF") Then
                                $SKILLID = CHECKIFBMHFREADY($BMHFIDS)
                                If $SKILLID <> 0 Then USESKILL($SKILLID, $Target)
                            EndIf
                    EndSelect

                    ; Execute general skills
                    EXECUTEMACRO($ExecuteMacroNumber, False)
                    Sleep(100)
                Next
            EndIf
        WEnd
    EndIf

    ; Switch back to the main client
    SwitchTo($Main)
EndFunc





Func TargetSpecificMobKillStop($MobName, $ExecuteMacroNumber, $Alts = False)
    ; Define variables for reusability
    Dim $Mobs, $Index, $Target, $InitialUniqueID, $CurrentUniqueID, $skills
    Dim $CLIENTSINDEXES, $HPMP, $MAXHPOFBESTSIN, $INDEXLOCATIONOFBESTSIN
    Dim $CHECKDISTANCETOTARGETTIMER = TIMERINIT(), $GENIESKILLTIMER = TIMERINIT()
    Dim $SEEKEREQUIPATTACK = True, $SEEKEREQUIPDEF = True, $SEEKERATTACKGEARTIMER = 0
    Dim $StartTime = TimerInit() ; Initialize the timeout timer

    DIM $SINKNIFETHROWSKILLIDS[6] = [3802, 3799, 3800, 3801, 3803, 3804]
    DIM $BMHFIDS[7] = [413, 3931, 3932, 3933, 3934, 3935, 3936]
    DIM $BARBRANGEDSKILLIDS[9] = [3864, 4408, 502, 3853, 3854, 3855, 3856, 3857, 3858]

    ; Main client execution - this will set the target for all clients
    $Mobs = NPCARRAY()
    $Index = -1

    ; Loop to find the target with a timeout mechanism
    While TimerDiff($StartTime) < 10000 ; 10 second timeout (10000 ms)
        $Index = FindClosest($Mobs, $MobName, 2, 0, True, 20, 300)
        If $Index <> -1 Then ExitLoop
        Sleep(100) ; Small delay before retrying to find the target
    Wend

    If $Index = -1 Then
        ; If no target is found within the timeout, return
        SetStatus("Timeout reached: Could not find target " & $MobName)
        Return
    EndIf

    $Target = $Mobs[$Index][0]
    QuickSelect($Target)

    ; Get the initial target's unique ID
    $InitialUniqueID = GetTarget()
    $CurrentUniqueID = GetTarget()

    If $CurrentUniqueID = $InitialUniqueID Then
        ; If Alts is True, loop through each client and synchronize them
        If $Alts Then
            $CLIENTSINDEXES = GetSquadAlts()

            ; Synchronize all clients with the main target
            For $i = 0 To UBound($CLIENTSINDEXES) - 1
                SwitchToNum($CLIENTSINDEXES[$i])
                Sleep(100) ; Ensure the client has switched
                QuickSelect($Target) ; Set the same target on the alt
            Next
        EndIf

        ; Execute the routine for each client
        While PLAYERTARGET()
            ; Main client actions
            $skills = macroarray($ExecuteMacroNumber)
            ExecuteSkills($skills)
            Sleep(100)

            If $Alts Then
                For $i = 0 To UBound($CLIENTSINDEXES) - 1
                    SwitchToNum($CLIENTSINDEXES[$i])
                    Sleep(100) ; Ensure the client has switched

                    ; Retrieve the health and other status of the alt
                    $HPMP = GETHPMP()

                    ; Execute specific class logic
                    Select
                        Case CLASS() == 5 ; Sin
                            If SKILLOFFCOOLDOWN(3248) Then
                                CASTSKILL(3248)
                            Else
                                CASTFIRSTSKILL($SINKNIFETHROWSKILLIDS)
                            EndIf

                        Case CLASS() == 4 ; Barbarian
                            If $Target <> 0 Then
                                USEFIRSTSKILL($BARBRANGEDSKILLIDS, $Target)
                            EndIf

                        Case CLASS() == 8 ; Seeker
                            If NOT HASBUFF("Attack Level increased", 135) Then
                                If TIMERDIFF($SEEKERATTACKGEARTIMER) > 29000 Or $SEEKERATTACKGEARTIMER = 0 Then
                                    $SEEKEREQUIPDEF = True
                                    $SEEKERATTACKGEARTIMER = TIMERINIT()
                                EndIf
                                If $SEEKEREQUIPDEF Then
                                    SWAPGEAR(2)
                                    $SEEKEREQUIPDEF = False
                                    $SEEKEREQUIPATTACK = True
                                EndIf
                            ElseIf HASBUFF("Attack Level increased", 135) And $SEEKEREQUIPATTACK Then
                                SWAPGEAR(0)
                                $SEEKEREQUIPATTACK = False
                                $SEEKERATTACKGEARTIMER = TIMERINIT()
                            EndIf

                        Case CLASS() == 7
                            If NOT HASBUFF("Focus Accelerated channeling", 37) And CURRENTSKILL() <> 566 Then
                                USESKILL(566, PLAYERID())
                            EndIf
                            If HASBUFF("Specific skill's damage is increased.", 366) Or CURRENTSKILL() == 6920 Then
                                USESKILL(921, $Target)
                            EndIf

                        Case CLASS() == 0 ; Blademaster
                            If CHI() > 200 And GETGLOBALSETTING("forceBMToUseHF") Then
                                $SKILLID = CHECKIFBMHFREADY($BMHFIDS)
                                If $SKILLID <> 0 Then USESKILL($SKILLID, $Target)
                            EndIf
                    EndSelect

                    ; Execute general skills
                    EXECUTEMACRO($ExecuteMacroNumber, False)
                    Sleep(100)
                Next
            EndIf
        WEnd
    EndIf

    ; Switch back to the main client
    SwitchTo($Main)
EndFunc





Func AutoAttackTargetClients($Target, ByRef $ClientsIndexes, $Field = 0)
  $Mobs = NpcArray()
  $Index = FindClosest($Mobs, $Target, $Field)
	While $Index <> -1
		For $i = 0 To UBound($clientsIndexes) - 1
			SwitchToNum($clientsIndexes[$i])
      QuickSelect($Mobs[$Index][0])
      ExecuteRegularAttack()
		Next
    $Mobs = NpcArray()
    $Index = FindClosest($Mobs, $Target, $Field)
    Sleep(500)
	WEnd
  SwitchTo($Main)
EndFunc

Func MoveToRangeClients($Range, $TargetX, $TargetY)
    $PlayerPos = PlayerPos()
    $PlayerX = $PlayerPos[0]
    $PlayerY = $PlayerPos[1]
EndFunc

Func GetAnyTarget()
  $Mobs = NpcArray()
  While UBound($Mobs) == 0
    $Mobs = NpcArray()
    Sleep(100)
  WEnd
  If UBound($Mobs) > 0 Then Return $Mobs[0][0]
  Return 0
EndFunc

Func MoveAndWait($x, $y, $Instance = 0)
    If $Instance <> 0 And $Instance <> InstanceId() Then Return
		MoveTo($X, $Y)
    WaitToFinish()
EndFunc

Func FindQuidProQuo()
    Dim $QuidProQuoSkills[5] = [1363, 1694, 1695, 2252, 2253]
    For $i = 0 To UBound($QuidProQuoSkills) - 1
        If SkillOffCooldown($QuidProQuoSkills[$i]) Then Return $QuidProQuoSkills[$i]
    Next
EndFunc

Func FindSacSlash()
    Dim $SacSlashSkills[2] = [1847, 2251]
    For $i = 0 To UBound($SacSlashSkills) - 1
        If SkillOffCooldown($SacSlashSkills[$i]) Then Return $SacSlashSkills[$i]
    Next
EndFunc

Func KillDhjBoss(ByRef $ClientsIndexes)
	$Members = partyarray()

    $LeaderId = $Members[0][0]
    $AltId = 0
    $AltIndex = 0

    $AltClass = 7
    $AltSkill = 3588
    if GETGLOBALSETTING("UseSinToGlitchDhjBoss") Then
        $AltClass = 5
        $AltSkill = 3811
    EndIf

	For $i = 0 To UBound($ClientsIndexes) - 1
		SwitchToNum($ClientsIndexes[$i])
        If CLASS() <> $AltClass Then ContinueLoop

        $AltId = PlayerId()
        $AltIndex = $i

        LeaveSquad()
        Sleep(1000)
        QuickSelect($LeaderId)

        Sleep(6000)
        While SkillOffCooldown($AltSkill)
            UseSkill($AltSkill, $LeaderId)
            Sleep(100)
        WEnd
        ExitLoop
	Next
    SwitchTo($Main)
    invitesquad($AltId)
    CastSkill(FindSacSlash())
    Sleep(500)
    SwitchToNum($AltIndex)
    AcceptSquadId($LeaderId)

    SwitchTo($Main)
    $Target = WaitToFindTarget(53500)
    UseSkill(FindQuidProQuo(), $Target)
    KillTargetClients($Target, $ClientsIndexes, 0, 34)
EndFunc



Func WaitToFindClassMatch($ClientsIndexes = $ClientsIndexes)
    Local $TargetClass = 8
    $TargetID = 0
    Local $i

    For $i = 0 To UBound($ClientsIndexes) - 1
        SwitchToNum($ClientsIndexes[$i])
        If CLASS() = $TargetClass Then
            $TargetID = PlayerId()
        EndIf
    Next
    SwitchTo($MAIN)
    Return $TargetID
EndFunc

FUNC HPDownCheck($Target, $MacroNumber = 5)
    $CounterForHP = 3
    QuickSelect($Target)
    WHILE TargetHpPercent <> 0 AND $CounterForHP <> 0 
        EXECUTEMACRO($MacroNumber)
        $CounterForHP = $CounterForHP - 1
        Sleep(1000)
    WEND
ENDFUNC

FUNC DoubleJumpAndMove($x, $y, $FirstDelay = 200, $SecondDelay = 200)
	TrueJump() ; alrdy done
	Sleep($FirstDelay) ; alrdy done
	JumpMoveAndWait($x, $y, $SecondDelay) 
	WaitToFinish()
ENDFUNC


FUNC JUMPMOVEANDWAIT($x, $y, $Delay = 700)
	TrueJump() ; alrdy done
	Sleep($Delay)
	MOVE($x, $y)
	WaitToFinish() ; alrdy done
ENDFUNC

Func OtherClientsMoveAndWait($x, $y, ByRef $ClientsIndexes, $classnumber, $instance = 0)
    FOR $I = 0 TO UBOUND($ClientsIndexes) - 1
        SwitchToNum($ClientsIndexes[$i])
        If Class() = $classnumber Then ContinueLoop
        If $Instance <> 0 And InstanceId() <> $Instance Then ContinueLoop
        CancelAction()
        MoveTo2($x, $y)
    NEXT
    SwitchTo($Main)
    WaitClientsToFinish($ClientsIndexes)
EndFunc

FUNC FindTargettingForBoss($MobName)
	Dim $StartTime = TimerInit()
	; Main client execution - this will set the target for all clients
    	$Mobs = NPCARRAY()
    	$Index = -1

    	; Loop to find the target with a timeout mechanism
    	While TimerDiff($StartTime) < 10000 ; 10 second timeout (10000 ms)
        	$Index = FindClosest($Mobs, $MobName, 2, 0, True, 20, 300)
        	If $Index <> -1 Then ExitLoop
        	Sleep(100) ; Small delay before retrying to find the target
    	Wend

    	If $Index = -1 Then
        	; If no target is found within the timeout, return
        	SetStatus("Timeout reached: Could not find target " & $MobName)
        	Return
    	EndIf

    	$Target = $Mobs[$Index][0]
    	QuickSelect($Target)
ENDFUNC


