			$HDC = _WINAPI_GETDC(0)
			LOCAL CONST $__WINAPICONSTANT_LOGPIXELSY = 90
			$ITWIPSPERPIXELY = 1440 / _WINAPI_GETDEVICECAPS($HDC, $__WINAPICONSTANT_LOGPIXELSY)
			_WINAPI_RELEASEDC(0, $HDC)
			RETURN $ITWIPSPERPIXELY
		ENDFUNC
