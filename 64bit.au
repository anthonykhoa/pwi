	ENDFUNC
	FUNC USESKILL2($SKILL_ID, $TARGET)
		$TYPE = 0
		$SKILL = SKILLOFFCOOLDOWN($SKILL_ID, $TYPE)
		$SKILL_ID = @EXTENDED
		IF $SKILL == 0 THEN RETURN 0
		$CONDITION = SKILLCASTCONDITION($SKILL)
		IF SKILLCASTCONDITION($SKILL) <> 0 THEN
			RETURN SETEXTENDED($CONDITION, 0)
		ENDIF
		USESKILL($SKILL_ID, $TARGET)
		RETURN 1
	ENDFUNC
