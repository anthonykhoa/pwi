FUNC SAVECOORDS()
	$PLAYERPOS = PLAYERPOS()
	$PLAYERPOS[0] = ROUND($PLAYERPOS[0], 3)
	$PLAYERPOS[1] = ROUND($PLAYERPOS[1], 3)
	LOCAL $TEXT[2] = ["If Not pvpmove(", ") Then Return False"]
	FILEWRITE("pos.txt", $TEXT[0] & $PLAYERPOS[0] & ", " & $PLAYERPOS[1] & $TEXT[1] & @CRLF)
ENDFUNC
FUNC DISPLAYQUESTS2()
	FOR $I = 35515 TO 50000
		IF ISQUESTAVAILABLE($I) THEN
			SETSTATUS($I & "is available")
		ENDIF
	NEXT
ENDFUNC
FUNC DISPLAYBUFFS()
	$BUFFARRAY = BUFFARRAY()
	$STRING = ""
	FOR $I = 0 TO UBOUND($BUFFARRAY) - 1
		$STRING &= $BUFFARRAY[$I][0] & " : " & $BUFFARRAY[$I][1] & @CRLF
	NEXT
	MSGBOX(0, "Buffs", $STRING)
ENDFUNC
FUNC PETSUMMONEDTESTER()
	$STRING = ""
	FOR $I = 2000 TO 4000
		PRINT($I & " : " & PETSUMMONED2($I))
	NEXT
ENDFUNC

Func Test()
EndFunc

FUNC DISPLAYDYNAMICNPCFILE1()
ENDFUNC

FUNC DISPLAYDYNAMICNPCFILE2()
ENDFUNC

FUNC DISPLAYINSTANCEVALUES()
	$STRING = ""
	$ID = INSTANCEID()
	$INSTANCEVALUES = INSTANCEVALUETABLE()
	$STRING &= "Instance is " & $ID & @CRLF
	FOR $I = 0 TO UBOUND($INSTANCEVALUES) - 1
		$STRING &= $INSTANCEVALUES[$I][0] & " : " & $INSTANCEVALUES[$I][1] & @CRLF
	NEXT
	MSGBOX(0, "Values", $STRING)
ENDFUNC
FUNC DISPLAYWMBOSSNAME()
	IF INSTANCEID() <> 215 THEN
		MSGBOX(0, "Warning", "You are not in WM, please Enter WM before trying to check boss name :v")
		RETURN
	ENDIF
	LOCAL $BOSSNAME = "Flag (yay!)"
	$INSTANCEVALUES = INSTANCEVALUETABLE()
	FOR $I = 0 TO UBOUND($INSTANCEVALUES) - 1
		$VALUE = $INSTANCEVALUES[$I][0]
		IF $VALUE == 101853 THEN
			$BOSSNAME = "Maze boss (eh)"
		ELSEIF $VALUE >= 101825 AND $VALUE <= 101834 THEN
			$BOSSNAME = "Sword (eww)"
		ENDIF
	NEXT
	MSGBOX(0, "Boss Name", $BOSSNAME)
ENDFUNC
FUNC LOGTWBIDS()
	SETSTATUS("Logging TW bids")
	$STARTID = 0
	WHILE TRUE
		$MESSAGE = FINDFIRSTMESSAGE("System Message: A Faction  has declared war on", $STARTID)
		IF $MESSAGE[1] <> "" THEN
			$LAND = _STRINGBETWEEN($MESSAGE[1], "territory of ", "!")[0]
			FILEWRITE("bidding-log.txt", $LAND & @CRLF)
		ENDIF
		$STARTID = $MESSAGE[0] + 1
		SLEEP(2000)
	WEND
ENDFUNC
FUNC FINDFIRSTMESSAGE($STRING, $STARTID = 0)
	$CHAT = CHATARRAY()
	LOCAL $MESSAGE[2] = [$CHAT[UBOUND($CHAT) - 1][0], ""]
	FOR $I = 0 TO UBOUND($CHAT) - 1
		IF $CHAT[$I][0] < $STARTID THEN CONTINUELOOP
		IF STRINGINSTR($CHAT[$I][1], $STRING) THEN
			$MESSAGE[0] = $CHAT[$I][0]
			$MESSAGE[1] = $CHAT[$I][1]
			EXITLOOP
		ENDIF
	NEXT
	RETURN $MESSAGE
ENDFUNC
FUNC DISPLAYNPCS()
	$ARRAY = NPCARRAY()
	$STRING = ""
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		$STRING &= "ID: " & $ARRAY[$I][1] & ",	Name: " & $ARRAY[$I][2] & @CRLF
	NEXT
	$STRING &= "FakeID: " & FAKENPCID()
	MSGBOX(0, "Npcs", $STRING)
ENDFUNC
FUNC DISPLAYCHAT()
	$STRING = ""
	$ARRAY = CHATARRAY()
	FOR $J = 0 TO 50
		$I = UBOUND($ARRAY) - $J - 1
		IF $I < 0 THEN EXITLOOP
		$STRING &= "ID: " & $ARRAY[$I][0] & ",	Msg: " & $ARRAY[$I][1] & @CRLF
	NEXT
	MSGBOX(0, "Array", $STRING)
ENDFUNC
FUNC DISPLAYQUESTS()
	$STRING = ""
	$ARRAY = QUESTARRAY()
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		$STRING &= $ARRAY[$I][0] & "," & $ARRAY[$I][1] & "," & $ARRAY[$I][2] & "," & $ARRAY[$I][3] & @CRLF
	NEXT
	MSGBOX(0, "Array", $STRING)
ENDFUNC
GLOBAL $AUTOPOTENABLED = OBJCREATE("Scripting.Dictionary")
GLOBAL $AUTOPOTVALUE = OBJCREATE("Scripting.Dictionary")
GLOBAL $AUTOPOTVALUELABEL = OBJCREATE("Scripting.Dictionary")
GUIREGISTERMSG($WM_NOTIFY, "WM_NOTIFY")
FUNC WM_NOTIFY($HWND, $MSG, $WPARAM, $LPARAM)
	$CTRLID = _WINAPI_LOWORD($WPARAM)
	IF $CTRLID == $HTABS THEN
		ONTABCHANGE()
	ELSEIF GUICTRLREAD($HTABS) == 6 THEN
		FOR $KEY IN $AUTOPOTVALUE
			IF $AUTOPOTVALUE.item($KEY) == $CTRLID THEN
				GUICTRLSETDATA($AUTOPOTVALUELABEL.item($KEY), GUICTRLREAD($AUTOPOTVALUE.item($KEY)) & "%")
				EXITLOOP
			ENDIF
		NEXT
	ENDIF
	RETURN $GUI_RUNDEFMSG
ENDFUNC
GUIREGISTERMSG($WM_KEYDOWN, "WM_KEYDOWN")
FUNC WM_KEYDOWN($HWND, $IMSG, $WPARAM, $LPARAM)
	#forceref $HWND, $IMSG, $WPARAM
	CONSOLEWRITE(_WINAPI_GETKEYNAMETEXT($LPARAM) & @CRLF)
	RETURN $GUI_RUNDEFMSG
ENDFUNC
GUIREGISTERMSG($WM_SIZE, "WM_SIZE")
FUNC WM_SIZE($HWND, $IMSG, $IWPARAM, $ILPARAM)
	IF $HWND == $HGUI THEN
		RESIZEALL()
	ENDIF
	RETURN $GUI_RUNDEFMSG
ENDFUNC
GUIREGISTERMSG($WM_GETMINMAXINFO, "WM_GETMINMAXINFO")
FUNC WM_GETMINMAXINFO($HWND, $MSG, $WPARAM, $LPARAM)
	$TAGMAXINFO = DLLSTRUCTCREATE("int;int;int;int;int;int;int;int;int;int", $LPARAM)
	DLLSTRUCTSETDATA($TAGMAXINFO, 7, 359)
	DLLSTRUCTSETDATA($TAGMAXINFO, 8, 359)
	RETURN 0
ENDFUNC
GUIREGISTERMSG($WM_CLOSE, "WM_CLOSE")
GUIREGISTERMSG($WM_NCLBUTTONDOWN, "WM_NCLBUTTONDOWN")
FUNC WM_CLOSE($HWND, $IMSG, $WPARAM, $LPARAM)
	LOCAL $TNMHDR = DLLSTRUCTCREATE($TAGNMITEMACTIVATE, $LPARAM)
	LOCAL $IDFROM = DLLSTRUCTGETDATA($TNMHDR, "IDFrom")
	LOCAL $INDEX = DLLSTRUCTGETDATA($TNMHDR, "Index")
	LOCAL $CODE = DLLSTRUCTGETDATA($TNMHDR, "Code")
	CONSOLEWRITE($IDFROM & @TAB & $INDEX & @TAB & $CODE & @CRLF)
	RETURN $GUI_RUNDEFMSG
ENDFUNC
FUNC WM_NCLBUTTONDOWN($HWND, $IMSG, $IWPARAM, $ILPARAM)
	IF $IWPARAM = 20 THEN
		_EXIT()
		EXIT
	ENDIF
	RETURN $GUI_RUNDEFMSG
ENDFUNC
FUNC AUTOPOTCONTROL($TEXT, $TOOLTIP, $INITY = 0)
	STATIC $Y = 47 + $YOFFSET
	IF $INITY <> 0 THEN $Y = $INITY
	$CHECKBOX = GUICTRLCREATECHECKBOX($TEXT, 30, $Y, 60, 20, $BS_AUTOCHECKBOX)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, $TOOLTIP)
	$AUTOPOTENABLED.add($TEXT, $CHECKBOX)
	$LABEL = GUICTRLCREATELABEL("", 92, $Y + 3, 27, 20, $SS_RIGHT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$AUTOPOTVALUELABEL.add($TEXT, $LABEL)
	GLOBAL $SLIDER = GUICTRLCREATESLIDER(120, $Y, 160, 30)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKHEIGHT + $GUI_DOCKRIGHT)
	GUICTRLSETLIMIT(-1, 100, 0)
	GUICTRLSETBKCOLOR(-1, $COLOR_WHITE)
	$AUTOPOTVALUE.add($TEXT, $SLIDER)
	$Y += 30
	RETURN $Y
ENDFUNC
FUNC ENABLEDAUTOPOT($NAME)
	RETURN ISCHECKED($AUTOPOTENABLED.item($NAME))
ENDFUNC
FUNC VALUEAUTOPOT($NAME)
	IF ENABLEDAUTOPOT($NAME) THEN
		RETURN GUICTRLREAD($AUTOPOTVALUE.item($NAME))
	ELSE
		RETURN -1 * GUICTRLREAD($AUTOPOTVALUE.item($NAME)) - 1
	ENDIF
ENDFUNC
