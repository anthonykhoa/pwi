	FUNC UPDNAVIGATETOAGENTOFUNITY()
		$ARRIVED = FALSE
		IF NOT MOVE5(-396.97, -267.48, -1, 0, FALSE, FALSE, 30000) THEN RETURN $ARRIVED
		SpeedPATH()
		IF NOT MOVE5(-378.73, -226.1, -1, 0, FALSE, FALSE, 30000) THEN RETURN $ARRIVED
		IF NOT MOVE5(-359.36, -187.37, -1, 0, FALSE, FALSE, 30000) THEN RETURN $ARRIVED
		SpeedPATH()
		IF NOT MOVE5(-353.93, -178.75, -1, 0, FALSE, FALSE, 30000) THEN RETURN $ARRIVED
		SpeedPATH()
		IF NOT MOVE5(-318.47, -104.03, -1, 0, FALSE, FALSE, 30000) THEN RETURN $ARRIVED
		IF NOT MOVE5(-347.81, -71.06, -1, 0, FALSE, FALSE, 30000) THEN RETURN $ARRIVED
		IF NOT MOVE5(-329.23, -53.39, -1, 0, FALSE, FALSE, 30000) THEN RETURN $ARRIVED
		SpeedPATH()
		IF NOT MOVE5(-292.03, -56.52, -1, 0, FALSE, FALSE, 30000) THEN RETURN $ARRIVED
		IF NOT MOVE5(-295.3, -60.62, -1, 0, FALSE, FALSE, 30000) THEN RETURN $ARRIVED
		$ARRIVED = TRUE
		RETURN $ARRIVED
	ENDFUNC
	FUNC UPDMASSNAVIGATETOCOORD(ByRef $CLIENTSINDEXES, $X, $Y, $INDEX = -1)
		SETSTATUS("UPD: Mass Navigating to " & $X & ", " & $Y)
		DIM $UPDCOORDS[20][2] = [[-396.97, -267.48], [-378.73, -226.1], [-359.36, -187.37], [-353.93, -178.75], [-318.47, -104.03], [-374.81, -71.06], [-329.23, -53.39], [-292.03, -56.52], [-295.3, -60.02], [283.14, -305.15], [286.91, -355.66], [135.54, 361.59], [117.38, 406.68], [-51.38, -331.41], [-83.29, -334.49], [-137.62, 327.55], [-173.27, 327.26], [-200.66, 325.07], [-221.98, 324.49], [-308.22, 328.74]]
		$CLOSESTINDEX = 0
		IF $INDEX <> -1 THEN
			$CLOSESTINDEX = $INDEX
		ELSE
			$CLOSESTINDEX = FINDCLOSESTCOORDINATE2($UPDCOORDS, $X, $Y)
		ENDIF
		SETSTATUS("closestindex = " & $CLOSESTINDEX)
		SQUADLEAVEGLITCHFIX($CLIENTSINDEXES, 10)
		IF NOT CHECKALLCHARINSIDEINSTANCE(176, $CLIENTSINDEXES) THEN SLEEP(25000)
		SQUADLEAVEGLITCHFIX($CLIENTSINDEXES, 10)
		$ARRIVED = FALSE
		IF INSTANCEID() <> 176 THEN
			SETSTATUS("Not inside UPD. Cannot move to requested coordinates.")
			RETURN $ARRIVED
		ENDIF
		IF $CLOSESTINDEX == 0 THEN
			IF NOT MASSMOVETOCOORDENHANCED(-396.97, -267.48, $CLIENTSINDEXES, 10, 176, 60000) THEN RETURN $ARRIVED
			IF NOT MASSMOVETOCOORDENHANCED($X, $Y, $CLIENTSINDEXES, 10, 176, 60000) THEN RETURN $ARRIVED
			$ARRIVED = TRUE
		ELSEIF $CLOSESTINDEX == 1 THEN
			IF NOT MASSMOVETOCOORDENHANCED(-396.97, -267.48, $CLIENTSINDEXES, 10, 176, 60000) THEN RETURN $ARRIVED
			IF MASSGENIEENERGYCHECK($CLIENTSINDEXES, 75) THEN MASSSpeedPATH($CLIENTSINDEXES)
			IF NOT MASSMOVETOCOORDENHANCED(-378.73, -226.1, $CLIENTSINDEXES) THEN RETURN $ARRIVED
			IF NOT MASSMOVETOCOORDENHANCED($X, $Y, $CLIENTSINDEXES, 10, 176, 60000) THEN RETURN $ARRIVED
			$ARRIVED = TRUE
		ELSEIF $CLOSESTINDEX == 2 THEN
			IF NOT MASSMOVETOCOORDENHANCED(-396.97, -267.48, $CLIENTSINDEXES, 10, 176, 60000) THEN RETURN $ARRIVED
