FUNC HOMELANDRENEWAL()
	DIM $QUESTS[5] = [36258, 36259, 36260, 36261, 36262]
	IF NOT HASANYQUEST($QUESTS) AND NOT ISQUESTAVAILABLE(36258) THEN RETURN
	SETSTATUS("Primal World - Homeland Renewal")
	TRANSFERMAP($MAP_PRIMAL, 0, -204.46, -832.14)
	TAKEQUEST("Resistance Force Leader", 36258)
	TIMEDSELFBUFF()
	FLY(-271.46, -849.82, 32)
	IF HASQUEST(36259) THEN
		USETELEPORTMASTER("Image of Althea", 1)
		FLY(-276.74, -366.02)
		WHILE QUESTKILLCOUNT(36259) < 5
			KILL("Tyrant Army Remnant", 200, 2, 1)
		WEND
