FUNC COMBATCONTROLS()
	$HCOMBATGUI = GUICREATE("", 270, 320 + $WINDOW_EXTRA_HEIGHT, 15, $YOFFSET, $WS_POPUP, $WS_EX_MDICHILD, $HGUI)
	GUISETBKCOLOR($COLOR_WHITE, $HCOMBATGUI)
	$Y = $YOFFSET
	GUICTRLSETTIP(-1, "Utility functions for COMBAT; e.g, buffing, moving, nuking, etc, with your alts.")
	ADDHELPCONTROL("This page intended for users who prefer button-clicks to hotkey presses. All buttons here are hotkeyable." & @CRLF & "REMEMBER: ONLY HOTKEYS CAN INTERRUPT CURRENTLY-RUNNING BOT ACTIONS! MANY OF THE BELOW FUNCTIONS WORK BETTER AS HOTKEYS!", 245, $Y - 75)
	GUICTRLCREATELABEL("Most-commonly used functions are highest on list.", 10, $Y - 70, 230, 20)
	GUICTRLSETTIP(-1, 'For more utility functions, please see Misc > "Utility" tab.')
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKHEIGHT)
	ADDMISCBUTTON("MASS MOVE", "MassMove", TRUE, -55, 0, -20, "Tell all nearby alts to come to your location." & @CRLF & "Veno auto put into fox form and " & @CRLF & "alts over 30m use move speed skills to come.")
	GUICTRLSETTIP(-1, "Tell all nearby alts to come to your location." & @CRLF & "Veno auto put into fox form and " & @CRLF & "alts over 30m use move speed skills to come, or holy path if you have that setting ticked.")
	ADDMISCBUTTON("Mass Move 2", "MassMove2", TRUE, -1, 0, -1, "Tell all nearby alts to come to your location. " & @CRLF & "No fox form, no movement speed skills.")
	GUICTRLSETTIP(-1, "Tell all nearby alts to come to your location. " & @CRLF & "No fox form, no movement speed skills.")
	ADDMISCBUTTON("Mass Follow", "MassFollowCommand", TRUE, -1, 0, -1, "Tells all alts to cancel what they are doing and follow your character." & @CRLF & "The cancel part doesn't always work. Try mass move, *then* mass follow.")
	GUICTRLSETTIP(-1, "Tells all alts to cancel what they are doing and follow your character." & @CRLF & "The cancel part doesn't always work. Try mass move, *then* mass follow.")
	ADDMISCBUTTON("Full Buff", "FullBuff", TRUE, -1, 0, -1, "All nearby characters use buff skills from macro(4). Veno will summon the pet from first slot." & @CRLF & "Buffs will not repeat. If skill on cooldown it will be skipped" & @CRLF & "If you have mystic, they gain 1 spark of chi before buffing." & @CRLF & "Hint: put pet revive in macro (4)")
	GUICTRLSETTIP(-1, "All nearby characters use buff skills from macro(4). Veno will summon the pet from first slot." & @CRLF & "Buffs will not repeat. If skill on cooldown it will be skipped" & @CRLF & "If you have mystic, they gain 1 spark of chi before buffing." & @CRLF & "Hint: put pet revive in macro (4)")
	ADDMISCBUTTON("Mass Buff Check", "MassBuffCheck", TRUE, -1, 0, -1, "Checks if specific buffs are missing, such as chill of deep or summer sprint on all alts. Useful to use this instead of doing a full rebuff.")
	GUICTRLSETTIP(-1, "Checks if specific buffs are missing, such as chill of deep or summer sprint on all alts. Useful to use this instead of doing a full rebuff.")
	ADDMISCBUTTON("Mass Spread10", "MSpreadCommand10", TRUE, -1, 0, -1, "Causes alts to uniformly spread around you in a perfect circle. Very useful in some situations.")
	GUICTRLSETTIP(-1, "Causes alts to uniformly spread around you in a perfect circle. Very useful in some situations.")
	ADDMISCBUTTON("Mass Holy Path", "MassSpeedPathCommand", TRUE, -1, 0, -1, "Casts holy path on all chars nearby.")
	GUICTRLSETTIP(-1, "Casts holy path on all chars nearby.")
	ADDMISCBUTTON("Mass Absolute Domain", "MassAbsoluteDomainCommand", TRUE, -1, 0, -1, "Casts absolute domain on all chars nearby. Incredible for surviving boss mechanics.")
