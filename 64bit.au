	PRINT("Hmm3")
	WAITSTOP(5)
	IF NOT JUMPUPTHENMOVEAK(-134.81, -122.7, 33) THEN RETURN FALSE
	WAITSTOP(5)
	IF NOT JUMPUPTHENMOVEAK(-131.59, -118.87, 36) THEN RETURN FALSE
	WHILE DISTANCE2D(-58.35, -118) > 8
		SLEEP(1000)
		IF DISTANCE2D(-133.46, -118) < 3 THEN
			IF DISTANCE2D(-133.46, -118) > 1 AND ACTIONFLAG() == 0 THEN
				MOVETO(-133.46, -118)
			ENDIF
		ENDIF
	WEND
	WHILE ACTIONFLAG()
		SLEEP(100)
	WEND
	WAITSTOPMOVE()
	IF FALLOFFPILLARS() THEN RETURN FALSE
	MOVE(-53.57, -118.07)
	GRABTIGERBUFF(9)
	RETURN TRUE
ENDFUNC
FUNC JUMPACROSSPILLARS2()
	STATIC $HTIMER = 0
	IF $HTIMER == 0 THEN
		$HTIMER = TIMERINIT()
	ELSEIF TIMERDIFF($HTIMER) > 500000 THEN
		SLEEP(MOD(36000 - MOD(TIMERDIFF($HTIMER), 36000), 36000))
		$HTIMER = TIMERINIT()
	ELSE
		SLEEP(MOD(18000 + 36000 - MOD(TIMERDIFF($HTIMER), 36000), 36000))
		$HTIMER = TIMERINIT()
	ENDIF
	MOVEWHILEJUMPING(-58.24, -98.97, 45, 6)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	SLEEP(4000 - TIMERDIFF($HTIMER))
	MOVEWHILEJUMPING(-61.99, -80.35, 45, 6)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	SLEEP(8000 - TIMERDIFF($HTIMER))
	MOVEWHILEJUMPING(-65.91, -60.87, 45, 6)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	SLEEP(12000 - TIMERDIFF($HTIMER))
	MOVEWHILEJUMPING(-70.08, -40.16, 45, 6)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	MOVEWHILEJUMPING(-73.53, -23.01, 45, 6)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	GRABTIGERBUFF(10)
	SLEEP(36000 - TIMERDIFF($HTIMER))
	MOVEWHILEJUMPING(-77.18, -4.04, 45, 6)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	SLEEP(40000 - TIMERDIFF($HTIMER))
	MOVEWHILEJUMPING(-86.29, 12.83, 45, 6)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	SLEEP(44000 - TIMERDIFF($HTIMER))
	MOVEWHILEJUMPING(-96.75, 29.21, 45, 6)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	SLEEP(48000 - TIMERDIFF($HTIMER))
	MOVEWHILEJUMPING(-103.81, 45, 45, 6)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	MOVEWHILEJUMPING(-112.76, 61.66, 45, 6)
	IF FALLOFFPILLARS() THEN RETURN FALSE
	GRABTIGERBUFF(11)
	RETURN TRUE
ENDFUNC
FUNC OPENGST()
	WHILE ITEMCOUNTTOTAL(21049) >= 100
		AUTOPATH(1283.2, 1102.39, 22, 0)
		WAITSTOP()
		STARTNPCDIALOGUE(GETNPCUNIQUEID("Mysterious Merchant"))
		SLEEP(200)
		WHILE FREEINVSLOTS() > 1 AND ITEMCOUNTTOTAL(21049) >= 100
			ACCEPTQUEST(21457)
			WHILE NOT HASQUEST(21457)
				SLEEP(10)
			WEND
			HANDINQUEST(21457, 0)
			WHILE HASQUEST(21457)
				SLEEP(10)
			WEND
		WEND
		CLOSENPCWINDOW()
		AUTOPATH(1212.7, 798.38, 22, 0)
		WAITSTOP()
		STARTNPCDIALOGUE(GETNPCUNIQUEID("General Summer"))
		SLEEP(200)
		$COUNT = ROUND(ITEMCOUNTTOTAL(19277) / 9999)
		IF $COUNT > 0 THEN MANUFACTURE(4772, $COUNT)
		WHILE ITEMCOUNTTOTAL(19277) > 9999
			SLEEP(1000)
		WEND
		WAITSTOP()
		CLOSENPCWINDOW()
	WEND
ENDFUNC
FUNC NPCTOKENS()
	WHILE ITEMCOUNTTOTAL(24721) >= 10
		MOVE(1282.46, 1008.73)
		STARTNPCDIALOGUE(GETNPCUNIQUEID("PW Boutique Agent"))
		SLEEP(200)
		$COUNT = ROUND(ITEMCOUNTTOTAL(24721) / 1000)
		IF $COUNT > FREEINVSLOTS() THEN
			$COUNT = FREEINVSLOTS()
		ENDIF
		WHILE FREEINVSLOTS() > 3 AND ITEMCOUNTTOTAL(24721) >= 10
			MANUFACTURE(4133, $COUNT)
		WEND
		CLOSENPCWINDOW()
		AUTOPATH(1212.7, 798.38, 22, 0)
		WAITSTOP()
		STARTNPCDIALOGUE(GETNPCUNIQUEID("General Summer"))
		SLEEP(200)
		$COUNT = ROUND(ITEMCOUNTTOTAL(19277) / 9999)
		IF $COUNT > 0 THEN MANUFACTURE(4772, $COUNT)
		WHILE ITEMCOUNTTOTAL(19277) > 9999
			SLEEP(1000)
		WEND
		WAITSTOP(1)
		CLOSENPCWINDOW()
	WEND
ENDFUNC
