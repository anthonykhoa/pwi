		FUNC _WINAPI_GETTHREADDESKTOP($ITHREADID)
			LOCAL $ACALL = DLLCALL("user32.dll", "handle", "GetThreadDesktop", "dword", $ITHREADID)
			IF @ERROR THEN RETURN SETERROR(@ERROR, @EXTENDED, 0)
			RETURN $ACALL[0]
		ENDFUNC
