FUNC SETTINGSCHECKBOX($TITLE, $FIELD, $DEFAULT, $PATCH = FALSE, $LABELONLY = FALSE, $EXPLANATION = "")
	STATIC $Y = 0
	IF $LABELONLY == FALSE THEN
		$CBSETTING = GUICTRLCREATECHECKBOX($TITLE, 1, $Y, 260, 20, $BS_AUTOCHECKBOX)
		GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
		PRINT("Settings " & $FIELD & " " & $CBSETTING)
		IF INIREAD("settings.ini", "settings", $FIELD, $DEFAULT) == "True" THEN
			GUICTRLSETSTATE(-1, $GUI_CHECKED)
		ENDIF
		GUICTRLSETONEVENT(-1, $PATCH ? "SettingsPatch" : "SaveSettings")
		$GLOBAL_SETTINGS_OPTIONS.add($FIELD, $CBSETTING)
	ELSE
		IF $EXPLANATION = "" THEN
			GUICTRLCREATELABEL($TITLE, 1, $Y, 280, 15)
			GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
		ELSE
			GUICTRLCREATELABEL($TITLE, 18, $Y, 280, 15)
			GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
			GUICTRLSETTIP(-1, $EXPLANATION)
		ENDIF
	ENDIF
	IF $TITLE == "" THEN
		$Y += 10
	ELSE
		$Y += 20
	ENDIF
	RETURN $Y
ENDFUNC
FUNC SETTINGSPATCH()
	APPLYPATCHES()
	SAVESETTINGS()
ENDFUNC
FUNC SAVESETTINGS()
	FOR $KEY IN $GLOBAL_SETTINGS_OPTIONS
		INIWRITE("settings.ini", "settings", $KEY, ISCHECKED($GLOBAL_SETTINGS_OPTIONS.item($KEY)))
	NEXT
ENDFUNC
FUNC APPLYPATCHESFORALL()
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($I)
		APPLYPATCHES()
	NEXT
ENDFUNC
FUNC APPLYPATCHES()
	$ACCELERATION = GETGLOBALSETTING("instantacceleration")
	APPLYPATCH($ADDRESS_FAST_FLY_PATCH, "short", 37008, 886, $ACCELERATION)
	APPLYPATCH($ADDRESS_SKIP_FLY_ANIMATION1_PATCH, "dword", 0, 420, $ACCELERATION)
	APPLYPATCH($ADDRESS_SKIP_FLY_ANIMATION2_PATCH, "dword", 0, 1400, $ACCELERATION)
	;APPLYPATCH($ADDRESS_AIR_STRAFE1_PATCH, "byte", 9, 1, $ACCELERATION)
	;APPLYPATCH($ADDRESS_AIR_STRAFE2_PATCH, "byte", 9, 2, $ACCELERATION)
	;APPLYPATCH($ADDRESS_AIR_STRAFE3_PATCH, "byte", 9, 1, $ACCELERATION)
	;APPLYPATCH($ADDRESS_AIR_STRAFE4_PATCH, "byte", 9, 2, $ACCELERATION)
	APPLYPATCH($ADDRESS_BUILTIN_AUTOPOT, "short", 432, 49202, GETGLOBALSETTING("builtinautopot", TRUE))
ENDFUNC
FUNC APPLYPATCH($ADDRESS, $TYPE, $PATCH, $ORIG, $USEPATCH)
	$CURR = _MEMORYREAD($ADDRESS, $GAME_PROCESS, $TYPE)
	IF $CURR <> ($USEPATCH ? $PATCH : $ORIG) THEN
		_MEMORYWRITE($ADDRESS, $GAME_PROCESS, $USEPATCH ? $PATCH : $ORIG, $TYPE)
	ENDIF
ENDFUNC
FUNC APPLYPATCHES2()
	$ACCELERATION = FALSE
	$CURR = _MEMORYREAD($ADDRESS_FAST_FLY_PATCH, $GAME_PROCESS, "short")
	IF $CURR == 886 THEN
		$ACCELERATION = TRUE
	ELSE
		$ACCELERATION = FALSE
	ENDIF
	APPLYPATCH($ADDRESS_FAST_FLY_PATCH, "short", 37008, 886, $ACCELERATION)
	APPLYPATCH($ADDRESS_SKIP_FLY_ANIMATION1_PATCH, "dword", 0, 420, $ACCELERATION)
	APPLYPATCH($ADDRESS_SKIP_FLY_ANIMATION2_PATCH, "dword", 0, 1400, $ACCELERATION)
	APPLYPATCH($ADDRESS_AIR_STRAFE1_PATCH, "byte", 9, 1, $ACCELERATION)
	APPLYPATCH($ADDRESS_AIR_STRAFE2_PATCH, "byte", 9, 2, $ACCELERATION)
	APPLYPATCH($ADDRESS_AIR_STRAFE3_PATCH, "byte", 9, 1, $ACCELERATION)
	APPLYPATCH($ADDRESS_AIR_STRAFE4_PATCH, "byte", 9, 2, $ACCELERATION)
	APPLYPATCH($ADDRESS_BUILTIN_AUTOPOT, "short", 432, 49202, GETGLOBALSETTING("builtinautopot", TRUE))
ENDFUNC
FUNC MARRIAGEQUEST()
	GLOBAL $SPOUSE_NAME = ""
	$PARTY = PARTYARRAY()
	SETSTATUS("Marriage Quest")
	WHILE UBOUND($PARTY) <> 2
		SETSTATUS("Invite your spouse to your squad")
		SLEEP(1000)
		$PARTY = PARTYARRAY()
	WEND
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF $CLIENTS[$I][3] == $PARTY[1][0] THEN
			$SPOUSE_NAME = $CLIENTS[$I][2]
			EXITLOOP
		ENDIF
	NEXT
	IF $SPOUSE_NAME == "" THEN
		SETSTATUS("Spouse client not found, assuming squad member is spouse.")
	ENDIF
	IF $SPOUSE_NAME <> "" THEN
		SWITCHTO($SPOUSE_NAME)
		TRANSFERMAP($MAP_MAIN, 0, 1233.22, 1056.55)
	ENDIF
	SWITCHTO($MAIN)
	TRANSFERMAP($MAP_MAIN, 0, 1233.22, 1056.55)
	COUPLEFLY(1233.22, 1056.55)
	DIM $QUESTS[7] = [36688, 36720, 36819, 36931, 36936, 36941, 36946]
	$IDX = @WDAY - 2
	$MQUEST = 0
	IF $PARTY[0][0] == PLAYERID() THEN
		WHILE TRUE
			QUICKSELECT($PARTY[1][0])
			SLEEP(2000)
			$POS = TARGETPOS()
			IF UBOUND($POS) == 3 AND DISTANCE($POS[0], $POS[1], $POS[2]) < 10 THEN
				EXITLOOP
			ENDIF
			SETSTATUS("Waiting for spouse to be near.")
		WEND
		FOR $I = 0 TO 6
			$MQUEST = $QUESTS[MOD($IDX + 7 - $I, 7)]
			TAKEQUEST("Matchmaker Servant", $MQUEST)
			SLEEP(1000)
			IF HASQUEST($MQUEST) THEN
				EXITLOOP
			ENDIF
		NEXT
		IF NOT HASQUEST($MQUEST) THEN
			SETSTATUS("Can't pick Marriage Quest.")
			RETURN
		ENDIF
	ENDIF
	WHILE TRUE
		IF HASQUEST(36688) THEN
			SETSTATUS("MQ: Sholar Hsu and Lady White")
			SCHOLARHSUANDLADYWHITE()
		ELSEIF HASQUEST(36720) THEN
			SETSTATUS("MQ: The West Room")
			THEWESTROOM()
		ELSEIF HASQUEST(36819) THEN
			SETSTATUS("MQ: Jean Mon")
			JEANMON()
		ELSEIF HASQUEST(36931) THEN
			SETSTATUS("MQ: Celestial and Mortal")
			CELESTIALANDMORTAL()
		ELSEIF HASQUEST(36936) THEN
			SETSTATUS("MQ: Butterflys Wish")
			BUTTERFLYSWISH()
		ELSEIF HASQUEST(36941) THEN
			SETSTATUS("MQ: Solaris Phoenix")
			SOLARISPHOENIX()
		ELSEIF HASQUEST(36946) THEN
			SETSTATUS("MQ: Peacoks Fly Southeast")
			PEACOKSFLYSOUTHEAST()
		ELSE
			SETSTATUS("Waiting for Marriage Quest")
			SLEEP(1000)
			CONTINUELOOP
		ENDIF
		EXITLOOP
	WEND
	FLYUP()
	COUPLEFLY(1500, 1200)
	IF STRINGLEN($SPOUSE_NAME) > 0 THEN
		SWITCHTO($SPOUSE_NAME)
		ENTERHOME(PLAYERID())
	ENDIF
	SWITCHTO($MAIN)
	SETSTATUS("Finished.")
ENDFUNC
FUNC COUPLEDIG($NAME, $ITEM, $QUEST)
	WHILE ITEMCOUNT($ITEM, 1) == 0 AND HASQUEST($QUEST)
		DIGITEM($NAME)
	WEND
	IF STRINGLEN($SPOUSE_NAME) > 0 THEN
		SWITCHTO($SPOUSE_NAME)
		WHILE ITEMCOUNT($ITEM, 1) == 0 AND HASQUEST($QUEST)
			DIGITEM($NAME)
		WEND
	ENDIF
	SWITCHTO($MAIN)
ENDFUNC
FUNC COUPLEFLY($X, $Y, $HEIGHT = 55)
	GROUPFUNC("couple", "FlyUp")
	GROUPFLY("couple", $X, $Y, $HEIGHT, FALSE)
ENDFUNC
FUNC DOUBLEKILLQUEST($NAME, $QUEST, $COUNT)
	WHILE HASQUEST($QUEST) AND QUESTKILLCOUNT($QUEST) < $COUNT
		IF STRINGLEN($SPOUSE_NAME) > 0 THEN
			SWITCHTO($SPOUSE_NAME)
			KILL($NAME, 200, 2, 0)
		ENDIF
		SWITCHTO($MAIN)
		KILL($NAME, 200, 2, 0)
	WEND
	IF STRINGLEN($SPOUSE_NAME) > 0 THEN
		SWITCHTO($SPOUSE_NAME)
		WHILE HASQUEST($QUEST) AND QUESTKILLCOUNT($QUEST) < $COUNT
			KILL($NAME, 200, 2, 0)
		WEND
	ENDIF
	SWITCHTO($MAIN)
ENDFUNC
FUNC DOUBLEREGATTACK($NAME)
	$TARGET = GETNPCUNIQUEID($NAME)
	IF STRINGLEN($SPOUSE_NAME) > 0 THEN
		SWITCHTO($SPOUSE_NAME)
		QUICKSELECT($TARGET)
		REGATTACK($TARGET)
	ENDIF
	SWITCHTO($MAIN)
	QUICKSELECT($TARGET)
	REGATTACK($TARGET)
	SLEEP(2000)
ENDFUNC
