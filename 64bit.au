			REGATTACK($TARGET)
			REGATTACK($TARGET)
			REGATTACK($TARGET)
			REGATTACK($TARGET)
			EXITLOOP
		ENDIF
	WEND
	SETSTATUS("Chest detected and attacked. Attempting to pick drops with all nearby char.")
	MASSGATHERALL()
	$CLIENTSINDEXES = GETNEARBYALTS(10)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		SETSTATUS("# big notes = " & ITEMCOUNT(21652))
	NEXT
	SETSTATUS("Done.")
ENDFUNC
FUNC SAROKKANCHESTTESTER()
	$X = 0
	WHILE TRUE
		$MOBS = NPCARRAY()
		$TARGET = GETNPCUNIQUEID("Wraith Commander Scorch")
		IF $TARGET > 0 THEN
			PLAYERTARGET($TARGET)
			SELECTTARGET($TARGET)
			REGATTACK($TARGET)
			REGATTACK($TARGET)
			REGATTACK($TARGET)
			REGATTACK($TARGET)
			REGATTACK($TARGET)
			REGATTACK($TARGET)
			EXITLOOP
		ENDIF
		$X += 1
		SETSTATUS($X)
	WEND
ENDFUNC
FUNC MASTERAPPRENTICEINSTANCE()
	STATIC $RESETTIMER = 0
	IF $RESETTIMER <> 0 AND TIMERDIFF($RESETTIMER) < (30 * 60 * 1000) THEN
		SETSTATUS("Waiting 30 minutes for instance to reset")
		SLEEP(30 * 60 * 1000 - TIMERDIFF($RESETTIMER))
	ENDIF
	SETSTATUS("M/A Instance")
	$COUNT = SETHOSTPARTY()
	IF $COUNT < 2 OR $COUNT > 4 THEN
		SETSTATUS("M/A: Form party with your apprentices first")
		SLEEP(2000)
		RETURN FALSE
	ENDIF
	IF NOT ENTERMAINSTANCE() THEN
		SETSTATUS("M/A Instance could not be opened")
		RETURN
	ENDIF
	IF HASQUEST(40875) OR ISQUESTAVAILABLE(40875) THEN
		GROUPTAKEQUEST("team", "Seasons Teleporter", 40875, TRUE, TRUE)
		MASTERAPPRENTICEINSTANCEAUTUMNEVENT()
	ELSEIF HASQUEST(40606) OR ISQUESTAVAILABLE(40606) THEN
		GROUPTAKEQUEST("team", "Seasons Teleporter", 40606, TRUE, TRUE)
		MASTERAPPRENTICEINSTANCESUMMEREVENT()
	ELSEIF HASQUEST(40395) OR ISQUESTAVAILABLE(40395) THEN
		GROUPTAKEQUEST("team", "Seasons Teleporter", 40395, TRUE, TRUE)
		MASTERAPPRENTICEINSTANCESPRINGEVENT()
	ENDIF
	WAITFORNPC("Illusion Stone")
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF CLIENTINGROUP($CLIENTS[$I][2], "team") THEN
			SWITCHTONUM($I)
			ENTERMYHOME()
		ENDIF
	NEXT
	SWITCHTO($MAIN)
	$RESETTIMER = TIMERINIT()
	SETSTATUS("Done.")
ENDFUNC
FUNC MAKECOMBATSTATCONTROLS()
	$Y = 34
	$XA = 10
	$XB = 170
	$SPACE = 60
	$XC = $XA
	$NUMWIDTH = $XB - $XA - $SPACE - 10
	GUICTRLCREATELABEL("Combat Time:", $XA, $Y, 100, 12)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GLOBAL $HCOMBATTIME = GUICTRLCREATELABEL("00:00:00", $XA + $SPACE, $Y, $NUMWIDTH, 15, $SS_RIGHT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLCREATEBUTTON("Reset", $XB, $Y - 5, 60, 20)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETONEVENT(-1, "ResetCombatStats")
	$Y += 30
	GUICTRLCREATELABEL("Kills: ", $XA, $Y, 60, 30)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GLOBAL $HKILLS = GUICTRLCREATELABEL("0", $XA + $SPACE, $Y, $NUMWIDTH, 20, $SS_RIGHT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$Y += 15
	GUICTRLCREATELABEL("Dam Dealt:", $XA, $Y, 60, 30)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GLOBAL $HDEALT = GUICTRLCREATELABEL("0", $XA + $SPACE, $Y, $NUMWIDTH, 20, $SS_RIGHT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$Y += 15
	GUICTRLCREATELABEL("Max Dealt:", $XA, $Y, 60, 30)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GLOBAL $HMAXDEALT = GUICTRLCREATELABEL("0", $XA + $SPACE, $Y, $NUMWIDTH, 20, $SS_RIGHT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$Y += 15
	GUICTRLCREATELABEL("Ave Dealt:", $XA, $Y, 60, 30)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GLOBAL $HAVEDEALT = GUICTRLCREATELABEL("0", $XA + $SPACE, $Y, $NUMWIDTH, 20, $SS_RIGHT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$Y += 15
	GUICTRLCREATELABEL("# attacks :", $XA, $Y, 60, 30)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GLOBAL $HCOUNTDAMAGEDEALT = GUICTRLCREATELABEL("0", $XA + $SPACE, $Y, $NUMWIDTH, 20, $SS_RIGHT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$Y += 15
	GUICTRLCREATELABEL("DPS:", $XA, $Y, 60, 30)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GLOBAL $HDPS = GUICTRLCREATELABEL("0", $XA + $SPACE, $Y, $NUMWIDTH, 20, $SS_RIGHT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$Y += 15
	$Y += 15
	GUICTRLCREATELABEL("Deaths:", $XC, $Y, 60, 30)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GLOBAL $HDEATHS = GUICTRLCREATELABEL("0", $XC + $SPACE, $Y, $NUMWIDTH, 20, $SS_RIGHT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$Y += 15
	GUICTRLCREATELABEL("Dam Taken:", $XC, $Y, 60, 30)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GLOBAL $HTAKEN = GUICTRLCREATELABEL("0", $XC + $SPACE, $Y, $NUMWIDTH, 20, $SS_RIGHT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$Y += 15
	GUICTRLCREATELABEL("Max Taken:", $XC, $Y, 60, 30)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GLOBAL $HMAXTAKEN = GUICTRLCREATELABEL("0", $XC + $SPACE, $Y, $NUMWIDTH, 20, $SS_RIGHT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$Y += 15
	GUICTRLCREATELABEL("Ave Taken:", $XC, $Y, 60, 30)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GLOBAL $HAVETAKEN = GUICTRLCREATELABEL("0", $XC + $SPACE, $Y, $NUMWIDTH, 20, $SS_RIGHT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$Y += 15
	ADDHELPCONTROL("A fun little damage log to track your damage done and received." & @CRLF & "Starts tracking from the moment you open the Combat window & enter combat mode." & @CRLF & 'Click "Reset" button to start calculating from 0 seconds again.', 250, 30)
ENDFUNC
FUNC GETTIMESTRING($TICKS)
	LOCAL $G_IHOUR, $G_IMINS, $G_ISECS
	_TICKSTOTIME($TICKS, $G_IHOUR, $G_IMINS, $G_ISECS)
	RETURN STRINGFORMAT("%02i:%02i:%02i", $G_IHOUR, $G_IMINS, $G_ISECS)
ENDFUNC
FUNC ADDCOMMA($STR)
	$SCOMMA = $STR
	IF STRINGISDIGIT($STR) AND STRINGLEN($STR) > 3 THEN
		$SCOMMA = STRINGLEFT($STR, STRINGLEN($STR) - 3) & "," & STRINGRIGHT($STR, 3)
		DO
			IF NOT STRINGINSTR(STRINGLEFT($SCOMMA, 4), ",") THEN
				$SCOMMA = STRINGLEFT($SCOMMA, STRINGINSTR($SCOMMA, ",") - 4) & "," & STRINGRIGHT($SCOMMA, STRINGLEN($SCOMMA) - STRINGINSTR($SCOMMA, ",") + 4)
			ENDIF
		UNTIL STRINGINSTR(STRINGLEFT($SCOMMA, 4), ",")
	ENDIF
	RETURN $SCOMMA
ENDFUNC
FUNC UPDATENUMLABEL($CONTROL, $NUM)
	$TEXT = ADDCOMMA("" & ROUND($NUM))
	IF GUICTRLREAD($CONTROL) <> $TEXT THEN
		GUICTRLSETDATA($CONTROL, $TEXT)
	ENDIF
ENDFUNC
FUNC RESETCOMBATSTATS()
	UPDATEINFOCOMBATCONTROLS(TRUE)
ENDFUNC
FUNC UPDATEINFOCOMBATCONTROLS($RESET = FALSE)
	STATIC $CURRENTMESSAGE = -1
	STATIC $KILLCOUNT = 0
	STATIC $DEATHCOUNT = 0
	STATIC $TOTALDAMAGEDEALT = 0
	STATIC $MAXDAMAGEDEALT = 0
	STATIC $COUNTDAMAGEDEALT = 0
	STATIC $TOTALDAMAGETAKEN = 0
	STATIC $MAXDAMAGETAKEN = 0
	STATIC $COUNTDAMAGETAKEN = 0
	STATIC $COMBATTIMER = TIMERINIT()
	STATIC $INCOMBATTIMER = 0
	STATIC $COMBATTIME = 0
	STATIC $DAMLOG = OBJCREATE("Scripting.Dictionary")
	STATIC $DPSLOG[30][2]
	STATIC $EMPTYLOG[30][2]
	STATIC $DPSCURIDX = 0
	IF $RESET THEN
		$KILLCOUNT = 0
		$DEATHCOUNT = 0
		$TOTALDAMAGEDEALT = 0
		$MAXDAMAGEDEALT = 0
		$COUNTDAMAGEDEALT = 0
		$TOTALDAMAGETAKEN = 0
		$MAXDAMAGETAKEN = 0
		$COUNTDAMAGETAKEN = 0
		$COMBATTIMER = TIMERINIT()
		$INCOMBATTIMER = 0
		$COMBATTIME = 0
		$DPSCURIDX = 0
		$DPSLOG = $EMPTYLOG
	ENDIF
	$DPSLOG[$DPSCURIDX][1] = 0
	IF INCOMBAT() THEN
		IF $INCOMBATTIMER == 0 THEN
			$INCOMBATTIMER = TIMERINIT()
		ENDIF
	ELSEIF $INCOMBATTIMER THEN
		$COMBATTIME += TIMERDIFF($INCOMBATTIMER)
		$INCOMBATTIMER = 0
		$DPSCURIDX = 0
		$DPSLOG = $EMPTYLOG
	ENDIF
	IF $INCOMBATTIMER <> 0 THEN
		$DPSLOG[$DPSCURIDX][0] = TIMERDIFF($INCOMBATTIMER)
	ENDIF
	$CHATS = CHATARRAY()
	$MOBNAME = ""
	$TOTALDAMAGE = 0
	$COUNT = 0
	$MAX = 0
	IF $CURRENTMESSAGE == -1 AND UBOUND($CHATS) THEN
		$CURRENTMESSAGE = $CHATS[UBOUND($CHATS) - 1][0]
	ENDIF
	FOR $I = UBOUND($CHATS) - 1 TO 0 STEP -1
		IF $CHATS[$I][0] <= $CURRENTMESSAGE THEN
			EXITLOOP
		ENDIF
		$MATCH = STRINGREGEXP($CHATS[$I][1], "\^C0C0C0(.+) takes ([0-9]+) damage", $STR_REGEXPARRAYMATCH)
		IF @ERROR == 0 THEN
			$NAME = $MATCH[0]
			$DAMAGE = NUMBER($MATCH[1])
			$TOTALDAMAGEDEALT += $DAMAGE
			IF $DAMAGE > $MAXDAMAGEDEALT THEN
				$MAXDAMAGEDEALT = $DAMAGE
			ENDIF
			$COUNTDAMAGEDEALT += 1
			$DPSLOG[$DPSCURIDX][1] += $DAMAGE
		ENDIF
		$MATCH = STRINGREGEXP($CHATS[$I][1], "\^C0C0C0(.+) deals ([0-9]+) damage", $STR_REGEXPARRAYMATCH)
		IF @ERROR == 0 THEN
			$NAME = $MATCH[0]
			$DAMAGE = NUMBER($MATCH[1])
			$TOTALDAMAGETAKEN += $DAMAGE
			IF $DAMAGE > $MAXDAMAGETAKEN THEN
				$MAXDAMAGETAKEN = $DAMAGE
			ENDIF
			$COUNTDAMAGETAKEN += 1
		ENDIF
		$MATCH = STRINGREGEXP($CHATS[$I][1], "\^BED293You killed (.+)!", $STR_REGEXPARRAYMATCH)
		IF @ERROR == 0 THEN
			$KILLCOUNT += 1
		ENDIF
		$MATCH = STRINGREGEXP($CHATS[$I][1], "\^BED293You were killed by (.+)", $STR_REGEXPARRAYMATCH)
		IF @ERROR == 0 THEN
			$DEATHCOUNT += 1
		ENDIF
	NEXT
	IF UBOUND($CHATS) THEN $CURRENTMESSAGE = $CHATS[UBOUND($CHATS) - 1][0]
	$TIMEDELTA = $INCOMBATTIMER ? $COMBATTIME + TIMERDIFF($INCOMBATTIMER) : $COMBATTIME
	$DPSTOTAL = 0
	$DPSSTOP = $DPSLOG[$DPSCURIDX][0]
	$DPSSTART = $DPSSTOP
	FOR $I = 0 TO UBOUND($DPSLOG) - 1
		$IDX = $I
		PRINT($DPSCURIDX & " - " & $IDX & "   #   " & $DPSLOG[$IDX][0] & " , " & $DPSLOG[$IDX][1])
		$DPSTOTAL += $DPSLOG[$IDX][1]
		IF $DPSLOG[$IDX][0] > 0 THEN $DPSSTART = _MIN($DPSSTART, $DPSLOG[$IDX][0])
	NEXT
	PRINT($DPSTOTAL & "  " & $DPSSTART & "  " & $DPSSTOP)
	$TEXT = GETTIMESTRING($TIMEDELTA)
	IF $TEXT <> GUICTRLREAD($HCOMBATTIME) THEN GUICTRLSETDATA($HCOMBATTIME, $TEXT)
	UPDATENUMLABEL($HKILLS, $KILLCOUNT)
	UPDATENUMLABEL($HDEATHS, $DEATHCOUNT)
	UPDATENUMLABEL($HDEALT, $TOTALDAMAGEDEALT)
	UPDATENUMLABEL($HCOUNTDAMAGEDEALT, $COUNTDAMAGEDEALT)
	UPDATENUMLABEL($HTAKEN, $TOTALDAMAGETAKEN)
	UPDATENUMLABEL($HMAXDEALT, $MAXDAMAGEDEALT)
	UPDATENUMLABEL($HMAXTAKEN, $MAXDAMAGETAKEN)
	UPDATENUMLABEL($HAVEDEALT, $COUNTDAMAGEDEALT ? $TOTALDAMAGEDEALT / $COUNTDAMAGEDEALT : 0)
	UPDATENUMLABEL($HAVETAKEN, $COUNTDAMAGETAKEN ? $TOTALDAMAGETAKEN / $COUNTDAMAGETAKEN : 0)
	UPDATENUMLABEL($HDPS, $DPSSTART ? $DPSTOTAL * 1000 / _MAX($DPSSTOP - $DPSSTART, 1000) : 0)
	IF $INCOMBATTIMER <> 0 THEN $DPSCURIDX = MOD($DPSCURIDX + 1, UBOUND($DPSLOG))
	RETURN
ENDFUNC
GLOBAL $HGUI
GLOBAL $YOFFSET
DIM $INFOSTATCONTROL[0][3]
GLOBAL $HINFOLOGBOX
GLOBAL $HINFOGUI
GLOBAL $HSETTINGSGUI
GLOBAL $HINFOTABS
GLOBAL ENUM $TAB_INFO_LOG, $TAB_INFO_RADAR, $TAB_INFO_STAT, $TAB_INFO_COMBAT, $TAB_INFO_SETTINGS, $TAB_INFO_ABOUT
FUNC ADDINFOSTATCONTROL($LABEL, $FUNC, $MOD = "s", $FORCEY = -1)
	STATIC $X = 10
	STATIC $Y = 34
	REDIM $INFOSTATCONTROL[UBOUND($INFOSTATCONTROL) + 1][3]
	GUICTRLCREATELABEL($LABEL & ":", $X, $Y, 62, 30)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$INFOSTATCONTROL[UBOUND($INFOSTATCONTROL) - 1][0] = GUICTRLCREATELABEL("0", $X + 62, $Y, 120, 30)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$INFOSTATCONTROL[UBOUND($INFOSTATCONTROL) - 1][1] = $FUNC
	$INFOSTATCONTROL[UBOUND($INFOSTATCONTROL) - 1][2] = $MOD
	$Y += 18
	IF $Y > 425 THEN
		$Y = 34
		$X = 190
	ENDIF
	PRINT("Added " & $LABEL & " - " & UBOUND($INFOSTATCONTROL))
ENDFUNC
FUNC HPLABEL()
	$HPMP = GETHPMP()
	RETURN $HPMP[0] & "/" & $HPMP[1]
ENDFUNC
FUNC MPLABEL()
	$HPMP = GETHPMP()
	RETURN $HPMP[2] & "/" & $HPMP[3]
ENDFUNC
FUNC TARGETID()
	$ID = 0
	$TARGET = PLAYERTARGET()
	IF BITAND($TARGET, -2147483648) THEN
		$ARRAY = NPCARRAY()
		FOR $I = 0 TO UBOUND($ARRAY) - 1
			IF($ARRAY[$I][0] == $TARGET) THEN
				$ID = $ARRAY[$I][1]
				EXITLOOP
			ENDIF
		NEXT
	ELSE
		$ARRAY = PLAYERARRAY()
		FOR $I = 0 TO UBOUND($ARRAY) - 1
			IF($ARRAY[$I][0] == $TARGET) THEN
				$ID = $ARRAY[$I][0]
				EXITLOOP
			ENDIF
		NEXT
	ENDIF
	RETURN $ID
ENDFUNC
FUNC TARGETUID()
	$UID = 0
	$ARRAY = NPCARRAY()
	$TARGET = PLAYERTARGET()
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		IF($ARRAY[$I][0] == $TARGET) THEN
			$UID = $ARRAY[$I][0]
			EXITLOOP
		ENDIF
	NEXT
	RETURN $UID
ENDFUNC
FUNC TARGETNAME()
	$TARGET = PLAYERTARGET()
	$TARGETNAME = ""
	IF BITAND($TARGET, -2147483648) THEN
		$ARRAY = NPCARRAY()
		FOR $I = 0 TO UBOUND($ARRAY) - 1
			IF($ARRAY[$I][0] == $TARGET) THEN
				$TARGETNAME = $ARRAY[$I][2]
				EXITLOOP
			ENDIF
		NEXT
	ELSE
		$ARRAY = PLAYERARRAY()
		FOR $I = 0 TO UBOUND($ARRAY) - 1
			IF($ARRAY[$I][0] == $TARGET) THEN
				$TARGETNAME = $ARRAY[$I][2]
				EXITLOOP
			ENDIF
		NEXT
	ENDIF
	RETURN $TARGETNAME
ENDFUNC
FUNC TARGETFACTIONID()
	$TARGET = PLAYERTARGET()
	$FACTIONID = 0
	$ARRAY = PLAYERARRAY()
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		IF($ARRAY[$I][0] == $TARGET) THEN
			$FACTIONID = $ARRAY[$I][7]
			EXITLOOP
		ENDIF
	NEXT
	RETURN $FACTIONID
ENDFUNC
FUNC TARGETHPPERCENT()
	$ID = 0
	$ARRAY = NPCARRAY()
	$TARGET = PLAYERTARGET()
	$HPPERCENT = 0
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		IF($ARRAY[$I][0] == $TARGET) THEN
			$HPPERCENT = $ARRAY[$I][7] / $ARRAY[$I][8]
			RETURN $HPPERCENT * 100
		ENDIF
	NEXT
	RETURN $HPPERCENT * 100
ENDFUNC
