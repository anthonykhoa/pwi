FUNC LOGACTIONS($TEXT)
	STATIC $LASTACTION = 0
	IF $TEXT == $LASTACTION THEN RETURN
	$LOGENTRY = STRINGFORMAT("[%s] %s: %s", STRINGFORMAT("%02i:%02i:%02i", @HOUR, @MIN, @SEC), PLAYERNAME(), $TEXT)
	$CURRENTTEXT = GUICTRLREAD($HINFOLOGBOX)
	$CURRENTTEXT = $CURRENTTEXT ? $CURRENTTEXT & @CRLF : ""
	GUICTRLSETDATA($HINFOLOGBOX, $CURRENTTEXT & $LOGENTRY)
	$LASTACTION = $TEXT
	SCROLLLOGTOBOTTOM()
ENDFUNC
FUNC SCROLLLOGTOBOTTOM()
	SCROLLBOXTOBOTTOM($HINFOLOGBOX)
ENDFUNC
FUNC SCROLLBOXTOBOTTOM($BOX)
	$ILEN = _GUICTRLEDIT_GETTEXTLEN($BOX)
	_GUICTRLEDIT_SETSEL($BOX, $ILEN, $ILEN)
	_GUICTRLEDIT_SCROLL($BOX, $SB_SCROLLCARET)
ENDFUNC
FUNC INFOCONTROLS2()
	$HINFOGUI = GUICREATE("", 282, 330 + $WINDOW_EXTRA_HEIGHT, 10, $YOFFSET, $WS_POPUP, $WS_EX_MDICHILD, $HGUI)
	REGISTERGUI($HINFOGUI)
	$HINFOTABS = GUICTRLCREATETAB(0, 0, 282, 330 + $WINDOW_EXTRA_HEIGHT, $TCS_MULTILINE)
	GUICTRLSETBKCOLOR(-1, $COLOR_WHITE)
	GUICTRLSETRESIZING(-1, $GUI_DOCKBORDERS)
	GUICTRLSETONEVENT(-1, "OnTabChange")
	GUICTRLCREATETABITEM("Log")
	GUICTRLSETTIP(-1, "A log of all feedback TheNightmareStuff gives during it's operation.")
	ADDHELPCONTROL("A log of all status messages TheNightmareStuff produces during its operation." & @CRLF & "This log of messages is incredibly useful when troubleshooting" & @CRLF & "problems that arise with operation of TheNightmareStuff. Include the text" & @CRLF & "from this log along with the x,y, and z coordinates of your character" & @CRLF & "when submitting a problem you encountered running TheNightmareStuff.")
	$HINFOLOGBOX = GUICTRLCREATEEDIT("", 1, 20, 278, 308 + $WINDOW_EXTRA_HEIGHT, BITOR($ES_AUTOVSCROLL, $ES_WANTRETURN, $WS_VSCROLL, $ES_READONLY))
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKBOTTOM)
	GUICTRLSETBKCOLOR(-1, $COLOR_WHITE)
	ADDHELPCONTROL("A log of all status messages TheNightmareStuff produces during its operation." & @CRLF & "This log of messages is incredibly useful when troubleshooting" & @CRLF & "problems that arise with operation of TheNightmareStuff. Include the text" & @CRLF & "from this log along with the x,y, and z coordinates of your character" & @CRLF & "when submitting a problem you encountered running TheNightmareStuff.")
	GUICTRLCREATETABITEM("Radar")
	GUICTRLSETTIP(-1, "A visual representation of your char and nearby players, mobs, and mineables.")
	MAKERADAR()
	GUISWITCH($HINFOGUI)
	GUICTRLCREATETABITEM("Stats")
	GUICTRLSETTIP(-1, "A fun and useful list of various character stats and variables TheNightmareStuff uses.")
	MAKEINFOSTATCONTROLS()
	GUICTRLCREATETABITEM("Combat")
	GUICTRLSETTIP(-1, "A fun combat calculator to measure your character's damage output & more.")
	MAKECOMBATSTATCONTROLS()
	GUICTRLCREATETABITEM("Settings")
	GUICTRLSETTIP(-1, "All settings that can modify how TheNightmareStuff works for you are located here.")
	$HSETTINGSGUI = GUICREATE("", 278 - 20, 330 + $WINDOW_EXTRA_HEIGHT - $YOFFSET, 20, $YOFFSET + 40, $WS_POPUP, $WS_EX_MDICHILD, $HGUI)
	GUISETBKCOLOR($COLOR_WHITE, $HSETTINGSGUI)
	$H = MAKESETTINGSCONTROLS()
	REGISTERGUI($HSETTINGSGUI, $H)
	GUISWITCH($HINFOGUI)
	GUICTRLCREATETABITEM("")
	GUISWITCH($HGUI)
ENDFUNC
FUNC UPDATEINFOSTATCONTROLS()
	FOR $I = 0 TO UBOUND($INFOSTATCONTROL) - 1
		$DATA = CALL($INFOSTATCONTROL[$I][1])
		SWITCH $INFOSTATCONTROL[$I][2]
			CASE "s"
				$DATA = STRING($DATA)
			CASE "x"
				$DATA = HEX($DATA, 8)
			CASE ",2"
				$DATA = ROUND($DATA[0], 2) & "," & ROUND($DATA[1], 2) & "," & ROUND($DATA[2], 2)
			CASE "c"
				$DATA = STRING(UBOUND($DATA))
		ENDSWITCH
		IF $DATA <> GUICTRLREAD($INFOSTATCONTROL[$I][0]) THEN
			GUICTRLSETDATA($INFOSTATCONTROL[$I][0], $DATA)
		ENDIF
	NEXT
ENDFUNC
FUNC INFOCONTROLS()
	$Y = $YOFFSET + 2
	$X = 20
	GUICTRLCREATELABEL("Name: ", $X, $Y, 45, 20)
	GLOBAL $NAMELABEL = GUICTRLCREATELABEL("", $X + 40, $Y, 75, 20)
	$X += 120
	GUICTRLCREATELABEL("Map: ", $X, $Y, 45, 20)
	GLOBAL $MAPLABEL = GUICTRLCREATELABEL("", $X + 50, $Y, 75, 20)
	$X -= 120
	$Y += 17
	GUICTRLCREATELABEL("HP: ", $X, $Y, 45, 20)
	GLOBAL $HPLABEL = GUICTRLCREATELABEL("", $X + 40, $Y, 75, 20)
	$X += 120
	GUICTRLCREATELABEL("MP: ", $X, $Y, 45, 20)
	GLOBAL $MPLABEL = GUICTRLCREATELABEL("", $X + 50, $Y, 75, 20)
	$X -= 120
	$Y += 17
	GUICTRLCREATELABEL("Chi: ", $X, $Y, 45, 20)
	GLOBAL $CHILABEL = GUICTRLCREATELABEL("", $X + 40, $Y, 75, 20)
	$X += 120
	GUICTRLCREATELABEL("Location: ", $X, $Y, 45, 20)
	GLOBAL $POSLABEL = GUICTRLCREATELABEL("", $X + 50, $Y, 100, 20)
	MAKERADAR()
ENDFUNC
FUNC UPDATEINFOCONTROLS()
	$HPMP = GETHPMP()
	GUICTRLSETDATA($NAMELABEL, PLAYERNAME())
	GUICTRLSETDATA($MAPLABEL, INSTANCEID())
	GUICTRLSETDATA($HPLABEL, $HPMP[0] & "/" & $HPMP[1])
	GUICTRLSETDATA($MPLABEL, $HPMP[2] & "/" & $HPMP[3])
	GUICTRLSETDATA($CHILABEL, CHI())
	$POS = PLAYERPOS()
	$LABEL = STRINGFORMAT("%.1f, %.1f (%.1f)", ($POS[0] + 4000) / 10, ($POS[1] + 5500) / 10, ($POS[2]) / 10)
	GUICTRLSETDATA($POSLABEL, $LABEL)
	DRAWWORLD()
ENDFUNC
FUNC MAKERADAR()
	GLOBAL $HRADARGUI = GUICREATE("", 270, 270, 15, 132, $WS_POPUP, $WS_EX_MDICHILD, $HGUI)
	REGISTERGUI($HRADARGUI)
	_GDIPLUS_STARTUP()
	GLOBAL $GRAPHICS = _GDIPLUS_GRAPHICSCREATEFROMHWND($HRADARGUI)
	GLOBAL $RADAR_WIDTH = 270
	GLOBAL $RADAR_HEIGHT = 270
	GLOBAL $BITMAP = _GDIPLUS_BITMAPCREATEFROMGRAPHICS($RADAR_WIDTH, $RADAR_HEIGHT, $GRAPHICS)
	GLOBAL $BACKBUFFER = _GDIPLUS_IMAGEGETGRAPHICSCONTEXT($BITMAP)
	GUISWITCH($HRADARGUI)
	DRAWWORLD()
	ADDHELPCONTROL('The main practical use of Radar is to pick a good spot to start the "Farm Herbs/Mines" function.' & @CRLF & @CRLF & "Black dot at center = your character." & @CRLF & "Black Circle = 60 meters (limit of what you can tab to)" & @CRLF & @CRLF & "Bright red dot = your character's target" & @CRLF & "Green arrow/triangle = pointer towards your target." & @CRLF & @CRLF & "Dark red dots = NPCS (and mobs)" & @CRLF & "Bright green dots = players." & @CRLF & "Blue dots = mineable items (note: quest-only mineables show up too unfortunately)", 250, 10)
	GUISWITCH($HGUI)
ENDFUNC
FUNC CLEARRADAR()
	_GDIPLUS_GRAPHICSCLEAR($BACKBUFFER, -1)
	_GDIPLUS_GRAPHICSDRAWIMAGERECT($GRAPHICS, $BITMAP, 0, 0, $RADAR_WIDTH, $RADAR_HEIGHT)
ENDFUNC
DIM $DIGSPOT[0]
GLOBAL $HERB_RADIUS = 200
FUNC DRAWWORLD()
	STATIC $PEN = _GDIPLUS_PENCREATE()
	STATIC $BRUSH = _GDIPLUS_BRUSHCREATESOLID()
	_GDIPLUS_GRAPHICSCLEAR($BACKBUFFER, -328966)
	$ZOOM = 210
	$SIZE = 4
	$POS = PLAYERPOS()
	$INSTANCE = INSTANCEID()
	_GDIPLUS_PENSETCOLOR($PEN, -16724992)
	IF UBOUND($DIGSPOT) == 0 THEN
		_GDIPLUS_GRAPHICSDRAWELLIPSE($BACKBUFFER, $RADAR_WIDTH / 2 - $HERB_RADIUS * $RADAR_WIDTH / $ZOOM, $RADAR_HEIGHT / 2 - $HERB_RADIUS * $RADAR_WIDTH / $ZOOM, $HERB_RADIUS * $RADAR_WIDTH / $ZOOM * 2, $HERB_RADIUS * $RADAR_WIDTH / $ZOOM * 2, $PEN)
	ELSE
		DIM $RELPOS[3] = [$DIGSPOT[0] - $POS[0], $DIGSPOT[1] - $POS[1], $DIGSPOT[2] - $POS[2]]
		_GDIPLUS_GRAPHICSDRAWELLIPSE($BACKBUFFER, $RELPOS[0] / $ZOOM * $RADAR_WIDTH + $RADAR_WIDTH / 2 - $HERB_RADIUS * $RADAR_WIDTH / $ZOOM, -1 * $RELPOS[1] / $ZOOM * $RADAR_HEIGHT + $RADAR_HEIGHT / 2 - $HERB_RADIUS * $RADAR_WIDTH / $ZOOM, $HERB_RADIUS * $RADAR_WIDTH / $ZOOM * 2, $HERB_RADIUS * $RADAR_WIDTH / $ZOOM * 2, $PEN)
	ENDIF
	_GDIPLUS_PENSETCOLOR($PEN, -3355444)
	_GDIPLUS_GRAPHICSDRAWELLIPSE($BACKBUFFER, $RADAR_WIDTH / 2 - 35.5 * $RADAR_WIDTH / $ZOOM, $RADAR_HEIGHT / 2 - 35.5 * $RADAR_WIDTH / $ZOOM, 35.5 * $RADAR_WIDTH / $ZOOM * 2, 35.5 * $RADAR_WIDTH / $ZOOM * 2, $PEN)
	_GDIPLUS_GRAPHICSDRAWELLIPSE($BACKBUFFER, $RADAR_WIDTH / 2 - 5 * $RADAR_WIDTH / $ZOOM, $RADAR_HEIGHT / 2 - 5 * $RADAR_WIDTH / $ZOOM, 5 * $RADAR_WIDTH / $ZOOM * 2, 5 * $RADAR_WIDTH / $ZOOM * 2, $PEN)
	$DIR = PLAYERDIR()
	$ARRAY = NPCARRAY()
	_GDIPLUS_BRUSHSETSOLIDCOLOR($BRUSH, -7864320)
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		DIM $RELPOS[3] = [$ARRAY[$I][4] - $POS[0], $ARRAY[$I][5] - $POS[1], $ARRAY[$I][6] - $POS[2]]
		_GDIPLUS_GRAPHICSFILLRECT($BACKBUFFER, $RELPOS[0] * $RADAR_WIDTH / $ZOOM + $RADAR_WIDTH / 2 - $SIZE / 2, -1 * $RELPOS[1] * $RADAR_HEIGHT / $ZOOM + $RADAR_HEIGHT / 2 - $SIZE / 2, $SIZE, $SIZE, $BRUSH)
	NEXT
	$ARRAY = PLAYERARRAY()
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		DIM $RELPOS[3] = [$ARRAY[$I][4] - $POS[0], $ARRAY[$I][5] - $POS[1], $ARRAY[$I][6] - $POS[2]]
		_GDIPLUS_BRUSHSETSOLIDCOLOR($BRUSH, -16724992)
		IF $INSTANCE <> 177 OR($RELPOS[2] < 22 AND $RELPOS[2] > -22) THEN
			_GDIPLUS_GRAPHICSFILLRECT($BACKBUFFER, $RELPOS[0] / $ZOOM * $RADAR_WIDTH + $RADAR_WIDTH / 2 - $SIZE / 2, -1 * $RELPOS[1] / $ZOOM * $RADAR_HEIGHT + $RADAR_HEIGHT / 2 - $SIZE / 2, $SIZE, $SIZE, $BRUSH)
		ENDIF
	NEXT
	$ARRAY = ITEMSARRAY()
	_GDIPLUS_BRUSHSETSOLIDCOLOR($BRUSH, -16777012)
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		DIM $RELPOS[3] = [$ARRAY[$I][4] - $POS[0], $ARRAY[$I][5] - $POS[1], $ARRAY[$I][6] - $POS[2]]
		_GDIPLUS_GRAPHICSFILLRECT($BACKBUFFER, $RELPOS[0] / $ZOOM * $RADAR_WIDTH + $RADAR_WIDTH / 2 - $SIZE / 2, -1 * $RELPOS[1] / $ZOOM * $RADAR_HEIGHT + $RADAR_HEIGHT / 2 - $SIZE / 2, $SIZE, $SIZE, $BRUSH)
	NEXT
	IF PLAYERTARGET() THEN
		$TARPOS = TARGETPOS()
		IF $TARPOS <> 0 THEN
			$DIST = DISTANCEBETWEEN3D($TARPOS, $POS)
			DIM $RELPOS[3] = [$TARPOS[0] - $POS[0], $TARPOS[1] - $POS[1], $TARPOS[2] - $POS[2]]
			_GDIPLUS_BRUSHSETSOLIDCOLOR($BRUSH, -65536)
			_GDIPLUS_GRAPHICSFILLRECT($BACKBUFFER, $RELPOS[0] / $ZOOM * $RADAR_WIDTH + $RADAR_WIDTH / 2 - $SIZE / 2, -1 * $RELPOS[1] / $ZOOM * $RADAR_HEIGHT + $RADAR_HEIGHT / 2 - $SIZE / 2, $SIZE, $SIZE, $BRUSH)
			IF $DIST < 59.9 THEN
				DIM $POSA[2] = [$TARPOS[0] + ($TARPOS[1] - $POS[1]) * 0.6 - $POS[0], $TARPOS[1] - ($TARPOS[0] - $POS[0]) * 0.707 - $POS[1]]
				DIM $POSB[2] = [$TARPOS[0] - ($TARPOS[1] - $POS[1]) * 0.6 - $POS[0], $TARPOS[1] + ($TARPOS[0] - $POS[0]) * 0.707 - $POS[1]]
				_GDIPLUS_GRAPHICSDRAWELLIPSE($BACKBUFFER, $RELPOS[0] / $ZOOM * $RADAR_WIDTH + $RADAR_WIDTH / 2 - 12 * $RADAR_WIDTH / $ZOOM, -1 * $RELPOS[1] / $ZOOM * $RADAR_HEIGHT + $RADAR_HEIGHT / 2 - 12 * $RADAR_WIDTH / $ZOOM, 12 * $RADAR_WIDTH / $ZOOM * 2, 12 * $RADAR_WIDTH / $ZOOM * 2, $PEN)
				_GDIPLUS_PENSETCOLOR($PEN, -13391190)
				_GDIPLUS_PENSETWIDTH($PEN, 1)
				_GDIPLUS_GRAPHICSDRAWLINE($BACKBUFFER, $RADAR_WIDTH / 2, $RADAR_HEIGHT / 2, $RADAR_WIDTH / 2 + $POSA[0] / $ZOOM * $RADAR_WIDTH, $RADAR_HEIGHT / 2 - $POSA[1] / $ZOOM * $RADAR_WIDTH, $PEN)
				_GDIPLUS_GRAPHICSDRAWLINE($BACKBUFFER, $RADAR_WIDTH / 2, $RADAR_HEIGHT / 2, $RADAR_WIDTH / 2 + $POSB[0] / $ZOOM * $RADAR_WIDTH, $RADAR_HEIGHT / 2 - $POSB[1] / $ZOOM * $RADAR_WIDTH, $PEN)
				_GDIPLUS_GRAPHICSDRAWLINE($BACKBUFFER, $RADAR_WIDTH / 2 + $POSA[0] / $ZOOM * $RADAR_WIDTH, $RADAR_HEIGHT / 2 - $POSA[1] / $ZOOM * $RADAR_WIDTH, $RADAR_WIDTH / 2 + $POSB[0] / $ZOOM * $RADAR_WIDTH, $RADAR_HEIGHT / 2 - $POSB[1] / $ZOOM * $RADAR_WIDTH, $PEN)
			ENDIF
			IF $DIST < 18 THEN
				DIM $TARDIR = [($TARPOS[0] - $POS[0]) / $DIST, ($TARPOS[1] - $POS[1]) / $DIST]
				DIM $POSA[2] = [$TARDIR[0] * 25, $TARDIR[1] * 25]
				_GDIPLUS_PENSETCOLOR($PEN, -16733696)
				_GDIPLUS_GRAPHICSDRAWLINE($BACKBUFFER, $RADAR_WIDTH / 2 - 2 * $TARDIR[1] * $RADAR_WIDTH / $ZOOM, $RADAR_HEIGHT / 2 - 2 * $TARDIR[0] * $RADAR_HEIGHT / $ZOOM, $RADAR_WIDTH / 2 - 2 * $TARDIR[1] * $RADAR_WIDTH / $ZOOM + 25 * $TARDIR[0] / $ZOOM * $RADAR_WIDTH, $RADAR_HEIGHT / 2 - 2 * $TARDIR[0] * $RADAR_HEIGHT / $ZOOM - 25 * $TARDIR[1] / $ZOOM * $RADAR_HEIGHT, $PEN)
				_GDIPLUS_GRAPHICSDRAWLINE($BACKBUFFER, $RADAR_WIDTH / 2 + 2 * $TARDIR[1] * $RADAR_WIDTH / $ZOOM, $RADAR_HEIGHT / 2 + 2 * $TARDIR[0] * $RADAR_HEIGHT / $ZOOM, $RADAR_WIDTH / 2 + 2 * $TARDIR[1] * $RADAR_WIDTH / $ZOOM + 25 * $TARDIR[0] / $ZOOM * $RADAR_WIDTH, $RADAR_HEIGHT / 2 + 2 * $TARDIR[0] * $RADAR_HEIGHT / $ZOOM - 25 * $TARDIR[1] / $ZOOM * $RADAR_HEIGHT, $PEN)
				_GDIPLUS_GRAPHICSDRAWLINE($BACKBUFFER, $RADAR_WIDTH / 2 - 2 * $TARDIR[1] * $RADAR_WIDTH / $ZOOM, $RADAR_HEIGHT / 2 - 2 * $TARDIR[0] * $RADAR_HEIGHT / $ZOOM, $RADAR_WIDTH / 2 + 2 * $TARDIR[1] * $RADAR_WIDTH / $ZOOM, $RADAR_HEIGHT / 2 + 2 * $TARDIR[0] * $RADAR_HEIGHT / $ZOOM, $PEN)
				_GDIPLUS_GRAPHICSDRAWLINE($BACKBUFFER, $RADAR_WIDTH / 2 - 2 * $TARDIR[1] * $RADAR_WIDTH / $ZOOM + 25 * $TARDIR[0] / $ZOOM * $RADAR_WIDTH, $RADAR_HEIGHT / 2 - 2 * $TARDIR[0] * $RADAR_HEIGHT / $ZOOM - 25 * $TARDIR[1] / $ZOOM * $RADAR_HEIGHT, $RADAR_WIDTH / 2 + 2 * $TARDIR[1] * $RADAR_WIDTH / $ZOOM + 25 * $TARDIR[0] / $ZOOM * $RADAR_WIDTH, $RADAR_HEIGHT / 2 + 2 * $TARDIR[0] * $RADAR_HEIGHT / $ZOOM - 25 * $TARDIR[1] / $ZOOM * $RADAR_HEIGHT, $PEN)
			ENDIF
		ENDIF
	ENDIF
	_GDIPLUS_BRUSHSETSOLIDCOLOR($BRUSH, -16777216)
	_GDIPLUS_GRAPHICSFILLELLIPSE($BACKBUFFER, $RADAR_WIDTH / 2 - $SIZE, $RADAR_HEIGHT / 2 - $SIZE, $SIZE * 2, $SIZE * 2, $BRUSH)
	$DIR = PLAYERDIR()
	_GDIPLUS_PENSETCOLOR($PEN, -16777216)
	_GDIPLUS_PENSETWIDTH($PEN, $SIZE)
	_GDIPLUS_GRAPHICSDRAWLINE($BACKBUFFER, $RADAR_WIDTH / 2, $RADAR_WIDTH / 2, $RADAR_WIDTH / 2 + $SIZE * 2 * $DIR[0], $RADAR_WIDTH / 2 + $SIZE * 2 * $DIR[1] * -1, $PEN)
	_GDIPLUS_PENSETWIDTH($PEN, 1)
	_GDIPLUS_GRAPHICSDRAWIMAGERECT($GRAPHICS, $BITMAP, 0, 0, $RADAR_WIDTH, $RADAR_HEIGHT)
	RETURN
ENDFUNC
GLOBAL $CURRENTROUTENAME = ""
GLOBAL $CURRENTROUTESTRING = ""
FUNC ROUTESGUIDE()
	MSGBOX(-1, "How to Use Routes", "Objective: Create or Edit a Route" & @CRLF & @CRLF & '1) Click "ADD NEW ROUTE" and select a unique name for the new route' & @CRLF & '1b) Click "Rename Route" if you want to change name you give route' & @CRLF & '1c) Click "Delete Route" to remove the route entirely.' & @CRLF & "2) Move your character in-game to desired starting coordinates" & @CRLF & '3) Click the "Add" button next to the word "Walk"' & @CRLF & "4) Move your character to the next desired coordinate" & @CRLF & '5) Click one or more of buttons under the "Add Route Actions" interface:' & @CRLF & '5a) Add "Dig" (use dropdown menu to select what you are digging) or' & @CRLF & '5b) Add "Walk" (default movement to next coordinate in your route) or' & @CRLF & '5c) Add "Wait" (fill in the box to indicate how many seconds to wait) or' & @CRLF & '5d) Add "Move Jump" (character(s) do a forward jump) or' & @CRLF & '5e) Add "Speed" (character(s) use holy path on genie to run really fast) or' & @CRLF & '5f) Add "Jump Move" (character(s) jump straight up then forward) or' & @CRLF & '5g) Add "Pause" (bot waits for you to press one of the three' & @CRLF & '    "Execute" buttons before continuing with rest of route.' & @CRLF & "6) Repeat steps 4 and 5 until your desired route is mapped out." & @CRLF & '7a) Click "Remove Last Coord" if you need to redo a coordinate, or.' & @CRLF & '7b) Click "Clear ALL Coords" if you want to completely start over, or.' & @CRLF & @CRLF & "Objective: Execute a Route" & @CRLF & @CRLF & '1) Click one of the three possible "Execute" options;' & @CRLF & '1a) "Execute (self)" causes only your main character to do the route.' & @CRLF & '1b) "Execute (SQUAD)" causes all char in squad to do the route.' & @CRLF & '1c) "Execute (Alts)" causes all char in squad except main to do route.' & @CRLF & '2) Bot executes route until a "Pause" is encountered.' & @CRLF & "3) Repeat steps 1-2 until route is completed.")
ENDFUNC
FUNC ROUTESCONTROLS()
	$Y = 10 + $YOFFSET
	GUICTRLCREATELABEL("Route:", 20, $Y, 50, 30)
	GUICTRLSETTIP(-1, "Current route name. If blank, you haven't created any routes yet." & @CRLF & "Use the dropdown menu to select route you want." & @CRLF & "Otherwise, use the buttons to the right to add, rename, or delete a route.")
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GLOBAL $HROUTECOMBO = GUICTRLCREATECOMBO("", 70, $Y - 3, 90, 30, BITOR($CBS_DROPDOWNLIST, $WS_VSCROLL))
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKHEIGHT)
	GUICTRLSETONEVENT(-1, "UpdateRoute")
	GLOBAL $HROUTEREPEAT = GUICTRLCREATECHECKBOX("Auto Repeat", 170, $Y, 80, 20, $BS_AUTOCHECKBOX)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKRIGHT + $GUI_DOCKSIZE)
	GUICTRLSETONEVENT(-1, "ToggleRepeat")
	GUICTRLSETTIP(-1, 'Use "Auto Repeat" to do the selected route over and over, e.g., when mining herbs.')
	$Y += 25
	GLOBAL $HROUTEBOX = GUICTRLCREATEEDIT("", 20, $Y, 140, 160, BITOR($ES_AUTOVSCROLL, $ES_WANTRETURN, $WS_VSCROLL, $ES_READONLY))
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKBOTTOM)
	$ADDROUTEBUTTON = GUICTRLCREATEBUTTON("ADD NEW ROUTE", 170, $Y, 115, 30)
	GUICTRLSETBKCOLOR($ADDROUTEBUTTON, 11195366)
	GUICTRLSETCOLOR($ADDROUTEBUTTON, 139)
	GUICTRLSETONEVENT(-1, "AddNewRoute")
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKRIGHT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Add a new route. Give a unique route name when prompted.")
	$Y += 35
	GUICTRLCREATEBUTTON("Rename Route", 170, $Y, 115, 30)
	GUICTRLSETONEVENT(-1, "RenameRoute")
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKRIGHT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Rename an existing route. Give a unique route name when prompted.")
	$Y += 35
	GUICTRLCREATEBUTTON("Delete Route", 170, $Y, 115, 30)
	GUICTRLSETONEVENT(-1, "DeleteRoute")
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKRIGHT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Delete an existing route. You'll be prompted to confirm your decision first.")
	$Y += 45
	GUICTRLCREATEBUTTON("Remove Last Coord", 170, $Y, 115, 30)
	GUICTRLSETONEVENT(-1, "RemoveLast")
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKRIGHT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Deletes the most recent coordinate in the current route." & @CRLF & "Can click multiple times to keep removing coordinates.")
	$Y += 35
	GUICTRLCREATEBUTTON("Clear ALL Coords", 170, $Y, 115, 30)
	GUICTRLSETONEVENT(-1, "ClearRoute")
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKRIGHT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Deletes all coordinates in the current route. You'll be prompted to confirm your decision first.")
	$Y += 50
	GUICTRLCREATEBUTTON("GUIDE", 170, $Y, 115, 30)
	GUICTRLSETONEVENT(-1, "RoutesGuide")
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKRIGHT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Click to read the full guide on how to use this Routes page.")
	$Y -= 30
	GUICTRLCREATELABEL("Coords: ", 40, $Y, 79, 20)
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Current coordinates of your character. These are coordinates that will be used when a Route Action is added below.")
	GLOBAL $HROUTECORDS = GUICTRLCREATELABEL("0,0", 90, $Y, 79, 20)
	GUICTRLSETTIP(-1, "Current coordinates of your character. These are coordinates that will be used when a Route Action is added below.")
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$Y += 20
	GUICTRLCREATEGROUP("Add Route Actions", 20, $Y, 270, 100)
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKHEIGHT)
	$ADDACTIONSLABEL = GUICTRLCREATELABEL("", 20, $Y, 60, 20)
	GUICTRLSETBKCOLOR($ADDACTIONSLABEL, $GUI_BKCOLOR_TRANSPARENT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKHEIGHT)
	GUICTRLSETTIP(-1, "Here you can add all the different actions you can take in your route." & @CRLF & "Possible actions include dig, walk, wait, move jump, holy path, jump move, and Pause." & @CRLF & @CRLF & "The actions you select show up in the box above.")
	$Y += 20
	GUICTRLCREATEBUTTON("Add", 30, $Y - 3, 30, 20)
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, 'Add "Dig" (an herb or other mineable) at current coordinate.')
	GUICTRLSETONEVENT(-1, "AddRouteCollect")
	GUICTRLCREATELABEL("Dig", 65, $Y, 35, 20)
	GUICTRLSETTIP(-1, 'Add "Dig" (an herb or other mineable) at current coordinate.' & @CRLF & "Use dropdown menu on right to select a mineable item.")
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GLOBAL $HROUTECOLLECT = GUICTRLCREATECOMBO("", 100, $Y - 3, 120, 15, $CBS_DROPDOWNLIST)
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKHEIGHT)
	GUICTRLCREATEBUTTON("Find", 230, $Y - 3, 50, 20)
	GUICTRLSETTIP(-1, "Moves your character to the nearest herb/mineable you selected from dropdown menu." & @CRLF & 'In other words, this "Find" button just helps you find the coordinates' & @CRLF & 'you need to use a "Dig" action at.')
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKRIGHT + $GUI_DOCKSIZE)
	GUICTRLSETONEVENT(-1, "MoveToSelected")
	$Y += 25
	GUICTRLCREATEBUTTON("Add", 30, $Y - 3, 30, 20)
	GUICTRLSETTIP(-1, "Adds a command in route to move character(s) to current coordinates." & @CRLF & 'If you are on ground, command will be "Walk".' & @CRLF & 'If you are flying, command will be "Fly".' & @CRLF & 'If you are swimming, command will be "Swim".')
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETONEVENT(-1, "AddRouteMove")
	GLOBAL $HROUTEMOVENAME = GUICTRLCREATELABEL("Fly", 65, $Y, 25, 20)
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Adds a command in route to move character(s) to current coordinates." & @CRLF & 'If you are on ground, command will be "Walk".' & @CRLF & 'If you are flying, command will be "Fly".' & @CRLF & 'If you are swimming, command will be "Swim".')
	$XCOL = 100
	GUICTRLCREATEBUTTON("Add", 30 + $XCOL, $Y - 3, 30, 20)
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETONEVENT(-1, "AddRouteMoveJump")
	GUICTRLSETTIP(-1, "Adds a command to route for character(s) to jump while moving to current location." & @CRLF & "Useful for clearing bumpy ground without getting stuck.")
	GUICTRLCREATELABEL("Move Jump", 65 + $XCOL, $Y, 60, 20)
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Adds a command to route for character(s) to jump while moving to current location." & @CRLF & "Useful for clearing bumpy ground without getting stuck.")
	$XCOL += 100
	GUICTRLCREATEBUTTON("Add", 30 + $XCOL, $Y - 3, 30, 20)
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Adds a command to route for character(s) to jump straight up then move to current location." & @CRLF & "Useful for clearing hard obstacles like logs/etc on ground.")
	GUICTRLSETONEVENT(-1, "AddRouteJumpMove")
	GUICTRLCREATELABEL("Jump Move", 65 + $XCOL, $Y, 60, 20)
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Adds a command to route for character(s) to jump straight up then move to current location." & @CRLF & "Useful for clearing hard obstacles like logs/etc on ground.")
	$Y += 25
	GUICTRLCREATEBUTTON("Add", 30, $Y - 3, 30, 20)
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETONEVENT(-1, "AddRouteWait")
	GUICTRLSETTIP(-1, "Adds a command to route for character(s) to do nothing for some time." & @CRLF & "Use input box to right to indicate how many seconds.")
	GUICTRLCREATELABEL("Wait", 65, $Y, 30, 20)
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GLOBAL $HROUTEWAIT = GUICTRLCREATEINPUT("1", 90, $Y - 3, 30, 20, BITOR($GUI_SS_DEFAULT_INPUT, $ES_CENTER, $ES_NUMBER))
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Set time to wait in seconds")
	GUICTRLCREATEBUTTON("Add", 130, $Y - 3, 30, 20)
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Adds a command to route for character(s) to use holy path on genie to run at max speed of 15m/s.")
	GUICTRLSETONEVENT(-1, "AddRouteSpeed")
	GUICTRLCREATELABEL("Speed", 165, $Y, 30, 20)
	GUICTRLSETTIP(-1, "Adds a command to route for character(s) to use holy path on genie to run at max speed of 15m/s.")
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLCREATEBUTTON("Add", 30 + $XCOL, $Y - 3, 30, 20)
	GUICTRLSETTIP(-1, 'Adds a command to route for route execution to stop until one of the 3 "Execute" buttons below is pressed.' & @CRLF & 'A logical way to use this is to have route "Pause" when your characters arrive at a boss.')
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETONEVENT(-1, "AddRoutePause")
	GUICTRLCREATELABEL("Pause", 65 + $XCOL, $Y, 30, 20)
	GUICTRLSETTIP(-1, 'Adds a command to route for route execution to stop until one of the 3 "Execute" buttons below is pressed.' & @CRLF & 'A logical way to use this is to have route "Pause" when your characters arrive at a boss.')
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	$Y += 40
	GUICTRLCREATEBUTTON("EXECUTE (self)", 20, $Y, 90, 30)
	GUICTRLSETONEVENT(-1, "ExecuteRouteMain")
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, 'Executes current route with just your current character bot is set to (the "Main").' & @CRLF & "Can be hotkeyed.")
	GUICTRLCREATEBUTTON("EXECUTE (Squad)", 120, $Y, 90, 30)
	GUICTRLSETONEVENT(-1, "ExecuteRouteSquad")
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Execute Current Route for the whole squad including main character." & @CRLF & "Useful when you want to move entire squad somewhere without having to watch screen." & @CRLF & "Can be hotkeyed.")
	GUICTRLCREATEBUTTON("EXECUTE (Alts)", 190, $Y, 90, 30)
	GUICTRLSETONEVENT(-1, "ExecuteRouteAlts")
	GUICTRLSETRESIZING(-1, $GUI_DOCKBOTTOM + $GUI_DOCKRIGHT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Execute Current Route for the alts in squad (excludes the main character)." & @CRLF & "Useful when you want to run ahead with main character killing monsters while alts follow behind more slowly." & @CRLF & "Can be hotkeyed.")
	ADDHELPCONTROL("Routes has two main use cases:" & @CRLF & @CRLF & "1) plot a route for an alt to dig herbs/mines endlessly, and" & @CRLF & "2) plot a route for characters to navigate a farming instance" & @CRLF & @CRLF & 'Please click "Guide" button to learn how to use this feature fully.')
	REGISTERCOMMAND("Execute Route", "ExecuteRouteMain", "Execute Current route on main. Can be hotkeyed.")
	REGISTERCOMMAND("Execute Route Squad", "ExecuteRouteSquad", "Execute Current Route for the whole squad. Can be hotkeyed.")
	REGISTERCOMMAND("Execute Route Alts", "ExecuteRouteAlts", "Execute Current Route Alts in Squad without Main character")
	REGISTERCOMMAND("Execute All Routes", "ExecuteAllRoutes", "Execute Routes on all currently open Speed Bots")
ENDFUNC
FUNC ADDNEWROUTE()
	GUISETSTATE(@SW_DISABLE, $HGUI)
	$NAME = INPUTBOX("Route Name", "Enter new route name")
	IF $NAME == "" OR ROUTEALREADYEXIST($NAME) THEN
		MSGBOX($MB_OK, "Name Exist", "You already have Route with that name")
	ELSE
		INIWRITE("settings.ini", "routes", $NAME, "")
		SELECTROUTE($NAME)
		REFRESHROUTESBOX()
	ENDIF
	GUISETSTATE(@SW_ENABLE, $HGUI)
	WINACTIVATE($HGUI)
ENDFUNC
FUNC ROUTEALREADYEXIST($NAME)
	$ROUTES = INIREADSECTION("settings.ini", "routes")
	FOR $I = 1 TO UBOUND($ROUTES) - 1
		IF $ROUTES[$I][0] == $NAME THEN
			RETURN TRUE
		ENDIF
	NEXT
	RETURN FALSE
ENDFUNC
FUNC RENAMEROUTE()
	GUISETSTATE(@SW_DISABLE, $HGUI)
	$NAME = INPUTBOX("Renaming Route " & $CURRENTROUTENAME, "Enter new route name")
	IF $NAME == "" THEN
		GUISETSTATE(@SW_ENABLE, $HGUI)
		WINACTIVATE($HGUI)
		RETURN
	ENDIF
	$DATA = INIREAD("settings.ini", "routes", $CURRENTROUTENAME, "")
	INIDELETE("settings.ini", "routes", $CURRENTROUTENAME)
	INIWRITE("settings.ini", "routes", $NAME, $DATA)
	SELECTROUTE($NAME)
	REFRESHROUTESBOX()
	GUISETSTATE(@SW_ENABLE, $HGUI)
	WINACTIVATE($HGUI)
ENDFUNC
FUNC REMOVELAST()
	IF STRINGINSTR($CURRENTROUTESTRING, ";") THEN
		$CURRENTROUTESTRING = (STRINGREGEXP($CURRENTROUTESTRING, "(.*?);([^;]+$)", 1))[0]
	ELSE
		$CURRENTROUTESTRING = ""
	ENDIF
	INIWRITE("settings.ini", "routes", $CURRENTROUTENAME, $CURRENTROUTESTRING)
	FILLROUTEBOX()
ENDFUNC
FUNC CLEARROUTE()
	IF ACTIONCONFIRMED("Are you sure you want to clear " & $CURRENTROUTENAME & "?") THEN
		$CURRENTROUTESTRING = ""
		INIWRITE("settings.ini", "routes", $CURRENTROUTENAME, "")
		FILLROUTEBOX()
	ENDIF
ENDFUNC
FUNC DELETEROUTE()
	IF ACTIONCONFIRMED("Are you sure you want to delete " & $CURRENTROUTENAME & "?") THEN
		INIDELETE("settings.ini", "routes", $CURRENTROUTENAME)
		INIDELETE("settings-" & NORMALIZEDNAME() & ".ini", "route", "current")
		REFRESHROUTESBOX()
	ENDIF
ENDFUNC
FUNC ACTIONCONFIRMED($MESSAGE)
	GUISETSTATE(@SW_DISABLE, $HGUI)
	$CONFIRMED = FALSE
	$INPUT = MSGBOX($MB_YESNO, "Confirmation", $MESSAGE)
	IF $INPUT == $IDYES THEN
		$CONFIRMED = TRUE
	ENDIF
	GUISETSTATE(@SW_ENABLE, $HGUI)
	WINACTIVATE($HGUI)
	RETURN $CONFIRMED
ENDFUNC
FUNC FILLROUTEBOX()
	$NICESTRING = STRINGREPLACE($CURRENTROUTESTRING, ";", @CRLF)
	$NICESTRING = STRINGREPLACE($NICESTRING, "|", " ")
	$NICESTRING = STRINGREGEXPREPLACE($NICESTRING, "\.[0-9]+", "")
	GUICTRLSETDATA($HROUTEBOX, $NICESTRING)
	SCROLLBOXTOBOTTOM($HROUTEBOX)
ENDFUNC
FUNC UPDATEROUTE()
	$CURRENTROUTENAME = GUICTRLREAD($HROUTECOMBO)
	SELECTROUTE($CURRENTROUTENAME)
ENDFUNC
FUNC SELECTROUTE($ROUTENAME)
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "route", "current", $ROUTENAME)
	$CURRENTROUTENAME = $ROUTENAME
	$CURRENTROUTESTRING = INIREAD("settings.ini", "routes", $ROUTENAME, "")
	FILLROUTEBOX()
ENDFUNC
FUNC REFRESHROUTESBOX()
	GUICTRLSETDATA($HROUTECOMBO, "", "")
	DIM $ROUTES = INIREADSECTION("settings.ini", "routes")
	IF UBOUND($ROUTES) <= 1 THEN RETURN
	$COMBOSTRING = $ROUTES[1][0]
	FOR $I = 2 TO UBOUND($ROUTES) - 1
		$COMBOSTRING = $COMBOSTRING & "|" & $ROUTES[$I][0]
	NEXT
	$CURRENTROUTE = INIREAD("settings-" & NORMALIZEDNAME() & ".ini", "route", "current", $ROUTES[1][0])
	LOADCHARCHECKBOX("route", "repeat", $HROUTEREPEAT)
	GUICTRLSETDATA($HROUTECOMBO, $COMBOSTRING, $CURRENTROUTE)
	SELECTROUTE($CURRENTROUTE)
ENDFUNC
FUNC ISHERBID($ID)
	RETURN($ID >= 3074 AND $ID <= 3103) OR($ID >= 3535 AND $ID <= 3553)
ENDFUNC
FUNC ISHERB($ARRAY, $I)
	$ID = $ARRAY[$I][1]
	RETURN ISHERBID($ID) AND DISTANCEBETWEEN($ARRAY[$I][4], $ARRAY[$I][5], $DIGSPOT[0], $DIGSPOT[1]) < $HERB_RADIUS
ENDFUNC
FUNC DIGSPOT()
	SELFBUFF()
	FLYUP()
	$BUFFTIMER = TIMERINIT()
	$DIGSPOT = PLAYERPOS()
	$LABEL = STRINGFORMAT("%.0f, %.0f (%.0f)", ($DIGSPOT[0] + 4000) / 10, ($DIGSPOT[1] + 5500) / 10, ($DIGSPOT[2]) / 10)
	SETSTATUS("Digging herbs/mines at " & $LABEL)
	$INSTANCE = INSTANCEID()
	$STUCKTIMER = TIMERINIT()
	$POS = PLAYERPOS()
	WHILE MOVEKEY() == 0 AND GETHPMP()[0] <> 0 AND INSTANCEID() == $INSTANCE
		IF TIMERDIFF($BUFFTIMER) > 600000 THEN
			SELFBUFF()
			$BUFFTIMER = TIMERINIT()
		ENDIF
		IF AREWESTUCK($STUCKTIMER, $POS[0], $POS[1], 30000) THEN
			$GETUNSTUCKTIMER = TIMERINIT()
			WHILE TIMERDIFF($GETUNSTUCKTIMER) < 10000
				CANCELACTION()
				SLEEP(500)
				MOVERANDOMIFSTUCK($DIGSPOT[0], $DIGSPOT[1])
			WEND
		ENDIF
		IF TRANSPORTMODE() == 0 AND NOT MOUNTSUMMONED() THEN SWITCHTOSECONDFORM()
		IF NOT DIGITEM("FUNC:IsHerb", 1, 1, $HERB_RADIUS * 2) THEN
			WHILE PLAYERTARGET() AND INCOMBAT()
				EXECUTEMACRO(0)
				SLEEP(100)
			WEND
			IF NOT INCOMBAT AND NOT DIGITEM("FUNC:IsHerb", 1, 1, $HERB_RADIUS * 2) AND DISTANCE2D($DIGSPOT[0], $DIGSPOT[1]) > 5 THEN
				FLY($DIGSPOT[0], $DIGSPOT[1])
				SETSTATUS("Digging herbs/mines at " & $LABEL & ". No nearby herbs spotted. Returning to initial dig spot.")
				FLYUP()
			ENDIF
			SLEEP(1000)
		ENDIF
	WEND
	SETSTATUS("Left digging area. Finished.")
	DIM $DIGSPOT[0]
ENDFUNC
FUNC ADDROUTEINSTRUCTION($COMMAND, $PARAMS = "")
	$JOIN = $CURRENTROUTESTRING == "" ? "" : ";"
	$PARAMJOIN = $PARAMS == "" ? "" : "|"
	$CURRENTROUTESTRING = $CURRENTROUTESTRING & $JOIN & $COMMAND & $PARAMJOIN & $PARAMS
	INIWRITE("settings.ini", "routes", $CURRENTROUTENAME, $CURRENTROUTESTRING)
	FILLROUTEBOX()
ENDFUNC
FUNC ADDROUTESPEED()
	ADDROUTEINSTRUCTION("SPEED", GETPLAYERSTRINGPOSITION())
ENDFUNC
FUNC ADDROUTEWAIT()
	ADDROUTEINSTRUCTION("WAIT", GUICTRLREAD($HROUTEWAIT))
ENDFUNC
FUNC ADDROUTEMOVEJUMP()
	ADDROUTEINSTRUCTION("MOVEJUMP", GETPLAYERSTRINGPOSITION())
ENDFUNC
FUNC ADDROUTEJUMPMOVE()
	ADDROUTEINSTRUCTION("JUMPMOVE", GETPLAYERSTRINGPOSITION())
ENDFUNC
FUNC ADDROUTEPAUSE()
	ADDROUTEINSTRUCTION("PAUSE")
ENDFUNC
FUNC ADDROUTECOLLECT()
	$COLLECT = GUICTRLREAD($HROUTECOLLECT)
	IF $COLLECT == "" THEN RETURN
	ADDROUTEINSTRUCTION("DIG", $COLLECT)
ENDFUNC
FUNC MOVETOSELECTED()
	$COLLECT = GUICTRLREAD($HROUTECOLLECT)
	$ITEMS = ITEMSARRAY()
	$IDX = FINDCLOSEST($ITEMS, $COLLECT, 2)
	IF $IDX == -1 THEN RETURN
	MOVETO($ITEMS[$IDX][4], $ITEMS[$IDX][5])
ENDFUNC
FUNC ADDROUTEMOVE()
	IF GUICTRLREAD($HROUTEMOVENAME) == "Fly" THEN
		ADDROUTEINSTRUCTION("FLY", GETPLAYERSTRINGPOSITION() & "," & ROUND((PLAYERPOS())[2] / 10, 0))
	ELSEIF GUICTRLREAD($HROUTEMOVENAME) == "Swim" THEN
		ADDROUTEINSTRUCTION("SWIM", GETPLAYERSTRINGPOSITION() & "," & ROUND((PLAYERPOS())[2] / 10, 3))
	ELSE
		ADDROUTEINSTRUCTION("WALK", GETPLAYERSTRINGPOSITION())
	ENDIF
ENDFUNC
FUNC GETPLAYERSTRINGPOSITION($PRECISION = 3)
	$POS = PLAYERPOS()
	RETURN ROUND(($POS[0] + 4000) / 10, $PRECISION) & "," & ROUND(($POS[1] + 5500) / 10, $PRECISION)
ENDFUNC
FUNC DROPDOWNIFNEEDED($COLLECT)
	$ITEMS = ITEMSARRAY()
	$IDX = FINDCLOSEST($ITEMS, $COLLECT, 2)
	IF $IDX == -1 THEN RETURN
	$POS = PLAYERPOS()
	IF $POS[2] - $ITEMS[$IDX][6] > 20 THEN
		DROPDOWN()
	ENDIF
ENDFUNC
FUNC TOGGLEREPEAT()
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "route", "repeat", ISCHECKED($HROUTEREPEAT))
ENDFUNC
FUNC EXECUTEALLROUTES()
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF $CLIENTS[$I][2] == $MAIN THEN CONTINUELOOP
		$TITLE = $CLIENTS[$I][2] & " - TheNitemare"
		CONTROLCLICK($TITLE, "Execute", "Button76")
		SLEEP(200)
	NEXT
	CONTROLCLICK($MAIN & " - TheNightmareStuff", "Execute", "Button76")
ENDFUNC
FUNC EXECUTEROUTESQUAD()
	$PARTY = PARTYARRAY()
	IF UBOUND($PARTY) == 0 THEN RETURN
	$LEADER = PARTYARRAY()[0][0]
	EXECUTEROUTE(GETSQUADCLIENTSINDEXES($LEADER))
ENDFUNC
FUNC EXECUTEROUTEMAIN()
	LOCAL $CLIENTSINDEXES[1] = [GETMAINCLIENTINDEX()]
	EXECUTEROUTE($CLIENTSINDEXES)
ENDFUNC
FUNC EXECUTEROUTEALTS()
	$PARTY = PARTYARRAY()
	IF UBOUND($PARTY) == 0 THEN RETURN
	$LEADER = PARTYARRAY()[0][0]
	EXECUTEROUTE(GETSQUADCLIENTSINDEXESNOMAIN($LEADER))
ENDFUNC
FUNC EXECUTEROUTE($CLIENTSINDEXES)
	$ROUTESTRING = $CURRENTROUTESTRING
	$ARRAY = STRINGSPLIT($ROUTESTRING, ";")
	IF $ARRAY[0] == 0 THEN RETURN
	$COUNT = 1
	STATIC $PAUSEDLOCATION = 0
	STATIC $PAUSEDROUTENAME = ""
	STATIC $PAUSEDROUTECOUNT = 0
	DO
		$START = 1
		IF $PAUSEDROUTENAME <> "" AND $PAUSEDROUTENAME == $CURRENTROUTENAME THEN
			$START = $PAUSEDLOCATION
			$COUNT = $PAUSEDROUTECOUNT
			SETSTATUS("Continuing " & $CURRENTROUTENAME & " #" & $COUNT)
		ELSE
			SETSTATUS("Executing Route " & $CURRENTROUTENAME & " #" & $COUNT)
		ENDIF
		IF $START <= $ARRAY[0] AND $START >= 1 THEN
			FOR $I = $START TO $ARRAY[0]
				$COMMANDARRAY = STRINGSPLIT($ARRAY[$I], "|")
				IF $COMMANDARRAY[0] == 0 THEN CONTINUELOOP
				$COMMAND = $COMMANDARRAY[1]
				$PARAMS = $COMMANDARRAY[0] == 1 ? "" : $COMMANDARRAY[2]
				$PAUSE = ROUTEINSTRUCTIONS($COMMAND, $PARAMS, $CLIENTSINDEXES)
				IF $PAUSE THEN
					$PAUSEDLOCATION = $I + 1
					$PAUSEDROUTENAME = $CURRENTROUTENAME
					$PAUSEDROUTECOUNT = $COUNT
					SETSTATUS("Route Paused, use an Execute option to continue to continue.")
					RETURN
				ENDIF
			NEXT
		ENDIF
		$COUNT += 1
	UNTIL ISCHECKED($HROUTEREPEAT) == FALSE
	$PAUSEDROUTENAME = ""
	SETSTATUS("Finished Route.")
ENDFUNC
FUNC ROUTEINSTRUCTIONS($COMMAND, $PARAMS, $CLIENTSINDEXES)
	SWITCH($COMMAND)
		CASE "PAUSE"
			RETURN TRUE
		CASE "WALK"
			MOVESTRINGXYZ($PARAMS, $CLIENTSINDEXES)
		CASE "SPEED"
			MOVESTRINGXYZ($PARAMS, $CLIENTSINDEXES)
			MASSSPEEDPATH($CLIENTSINDEXES)
		CASE "MOVEJUMP"
			JUMPSTRINGXYZ($PARAMS, $CLIENTSINDEXES)
		CASE "JUMPMOVE"
			JUMPTHENMOVESTRINGXYZ($PARAMS, $CLIENTSINDEXES)
		CASE "WAIT"
			SLEEP(INT($PARAMS) * 1000)
		CASE "FLY"
			FLYSTRINGXYZ($PARAMS, $CLIENTSINDEXES)
		CASE "LAND"
			ROUTEDROPDOWN($CLIENTSINDEXES)
		CASE "SWIM"
			SWIMSTRINGXYZ($PARAMS, $CLIENTSINDEXES)
		CASE "DIG"
			DROPDOWNIFNEEDED($PARAMS)
			WHILE DIGITEM($PARAMS, 1, 2, 60)
				SLEEP(100)
			WEND
	ENDSWITCH
	RETURN FALSE
ENDFUNC
FUNC FLYSTRINGXYZ($PARAMS, $CLIENTSINDEXES)
	$ARRAY = STRINGSPLIT($PARAMS, ",", $STR_NOCOUNT)
	$X = NUMBER($ARRAY[0], 3) * 10 - 4000
	$Y = NUMBER($ARRAY[1], 3) * 10 - 5500
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		USEITEM(12, GETEQUIPID(12), 1)
	NEXT
	SLEEP(3000)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		AUTOPATH($X, $Y, INT($ARRAY[2]), 0)
	NEXT
	WAITCLIENTSTOFINISH($CLIENTSINDEXES)
	SWITCHTO($MAIN)
ENDFUNC
FUNC SWIMSTRINGXYZ($PARAMS, $CLIENTSINDEXES)
	$ARRAY = STRINGSPLIT($PARAMS, ",", $STR_NOCOUNT)
	$X = NUMBER($ARRAY[0]) * 10 - 4000
	$Y = NUMBER($ARRAY[1]) * 10 - 5500
	$Z = NUMBER($ARRAY[2])
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		IF TRANSPORTMODE() == 0 THEN
			MOVETO($X, $Y)
		ELSE
			AUTOPATH($X, $Y, $Z, 0)
		ENDIF
	NEXT
	WAITCLIENTSTOFINISH($CLIENTSINDEXES)
	SWITCHTO($MAIN)
ENDFUNC
FUNC MOVESTRINGXYZ2($X, $Y)
	$DEST_X = $X * 10 - 4000
	$DEST_Y = $Y * 10 - 5500
	MOVETO2($DEST_X, $DEST_Y)
ENDFUNC
FUNC MOVESTRINGXYZ($PARAMS, $CLIENTSINDEXES)
	$ARRAY = STRINGSPLIT($PARAMS, ",", $STR_NOCOUNT)
	$X = NUMBER($ARRAY[0]) * 10 - 4000
	$Y = NUMBER($ARRAY[1]) * 10 - 5500
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		MOVETO($X, $Y, -1, 0, TRUE)
	NEXT
	WAITCLIENTSTOFINISH($CLIENTSINDEXES)
	SWITCHTO($MAIN)
ENDFUNC
FUNC JUMPSTRINGXYZ($PARAMS, $CLIENTSINDEXES)
	$ARRAY = STRINGSPLIT($PARAMS, ",", $STR_NOCOUNT)
	$X = NUMBER($ARRAY[0]) * 10 - 4000
	$Y = NUMBER($ARRAY[1]) * 10 - 5500
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		MOVETO($X, $Y, -1, 0, TRUE)
		TRUEJUMP()
	NEXT
	SLEEP(200)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		TRUEJUMP()
	NEXT
	WAITCLIENTSTOFINISH($CLIENTSINDEXES)
	SWITCHTO($MAIN)
ENDFUNC
FUNC JUMPTHENMOVESTRINGXYZ($PARAMS, $CLIENTSINDEXES)
	$ARRAY = STRINGSPLIT($PARAMS, ",", $STR_NOCOUNT)
	$X = NUMBER($ARRAY[0]) * 10 - 4000
	$Y = NUMBER($ARRAY[1]) * 10 - 5500
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		TRUEJUMP()
	NEXT
	SLEEP(1000)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		TRUEJUMP()
	NEXT
	SLEEP(1000)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		MOVETO($X, $Y, -1, 0, TRUE)
	NEXT
	WAITCLIENTSTOFINISH($CLIENTSINDEXES)
	SWITCHTO($MAIN)
ENDFUNC
FUNC ROUTEDROPDOWN($CLIENTSINDEXES)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		USEITEM(12, GETEQUIPID(12), 1)
	NEXT
	SLEEP(3000)
	WAITCLIENTSTOFINISH($CLIENTSINDEXES)
	SWITCHTO($MAIN)
ENDFUNC
FUNC UPDATEFARMPOS()
	$POS = PLAYERPOS()
	IF UBOUND($POS) THEN
		$STR = TRANSPORTMODE() == 0 ? "Walk" : TRANSPORTMODE() == 1 ? "Swim" : "Fly"
		IF $STR <> GUICTRLREAD($HROUTEMOVENAME) THEN GUICTRLSETDATA($HROUTEMOVENAME, $STR)
		$STR = GETPLAYERSTRINGPOSITION(0) & " (" & ROUND($POS[2] / 10) & ")"
		IF $STR <> GUICTRLREAD($HROUTECORDS) THEN GUICTRLSETDATA($HROUTECORDS, $STR)
	ENDIF
ENDFUNC
FUNC REFRESHROUTECONTROLS()
	$CURR = GUICTRLREAD($HROUTECOLLECT)
	$ITEMSARRAY = ITEMSARRAY()
	IF UBOUND($ITEMSARRAY) THEN
		$HERBSTR = ""
		$HERBFIRST = ""
		FOR $I = 0 TO UBOUND($ITEMSARRAY) - 1
			IF ISHERBID($ITEMSARRAY[$I][1]) AND NOT STRINGINSTR($HERBSTR, $ITEMSARRAY[$I][2]) THEN
				IF $HERBFIRST == "" THEN $HERBFIRST = $ITEMSARRAY[$I][2]
				$HERBSTR = $HERBSTR & "|" & $ITEMSARRAY[$I][2]
			ENDIF
		NEXT
		IF $CURR <> "" AND STRINGINSTR($HERBSTR, $CURR) THEN $HERBFIRST = $CURR
		STATIC $LASTCOMBOSTR = ""
		IF $HERBSTR <> $LASTCOMBOSTR THEN
			GUICTRLSETDATA($HROUTECOLLECT, $HERBSTR, $HERBFIRST)
			$LASTCOMBOSTR = $HERBSTR
		ENDIF
	ENDIF
ENDFUNC
DIM $OPPONENT_MINION_TEAM[6][2]
DIM $MY_MINION_TEAM[3][2]
FUNC MINIONINFO()
	MSGBOX(-1, "Minion Information", "Minions: a mini-game of sorts set within your character's Homestead." & @CRLF & 'Fight with your "Minions" up to 200 times per month against minions' & @CRLF & "from other players. Winning fights increases your points and grants" & @CRLF & "Minion pouches that contain more minion eggs (which grow your minion" & @CRLF & "strength and help win more battles). Higher score leads to more" & @CRLF & "rewards you can collect from Elysian Arena each month, such as" & @CRLF & "various Star Chart and War Avatar materials. TheNightmareStuff keeps a record" & @CRLF & "of past battles in the minionlog.ini file to help it pick the minions" & @CRLF & "you have that give BEST chance of winning each minion battle, and it" & @CRLF & "can automatically complete all 200 battles for you!")
ENDFUNC
