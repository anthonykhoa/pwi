		FUNC _WINAPI_GETGVALUE($IRGB)
			RETURN BITSHIFT(BITAND(__RGB($IRGB), 65280), 8)
		ENDFUNC
		FUNC _WINAPI_GETMAPMODE($HDC)
			LOCAL $ACALL = DLLCALL("gdi32.dll", "int", "GetMapMode", "handle", $HDC)
			IF @ERROR THEN RETURN SETERROR(@ERROR, @EXTENDED, 0)
