FUNC MASSTAKEEXTERMINATIONORDER($CLIENTSINDEXES)
	SWITCHTO($MAIN)
	SETSTATUS("Picking Extermination Order for all nearby alts.")
	$HEADHUNTERUID = GETNPCUNIQUEID("Head Hunter")
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		IF HASQUEST(37124) THEN CONTINUELOOP
		DROPDOWN()
		IF TRANSPORTMODE() == 1 OR INSTANCEID() == 176 THEN SWITCHTOHUMANFORM()
		IF NOT ISQUESTAVAILABLE(37124) THEN CONTINUELOOP
		STARTNPCDIALOGUE($HEADHUNTERUID)
	NEXT
	SLEEP(300)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		IF NOT ISQUESTAVAILABLE(37124) THEN CONTINUELOOP
		ACCEPTQUEST(37124)
	NEXT
ENDFUNC
FUNC MASSTAKEBH($CLIENTSINDEXES, $QUESTID)
	SWITCHTO($MAIN)
	SETSTATUS("Picking BH for all nearby alts.")
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		IF HASQUEST($QUESTID) THEN CONTINUELOOP
		IF NOT ISQUESTAVAILABLE($QUESTID) THEN CONTINUELOOP
		STARTNPCDIALOGUE($QUESTID)
	NEXT
	SLEEP(300)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		IF NOT ISQUESTAVAILABLE($QUESTID) THEN CONTINUELOOP
		IF HASQUEST($QUESTID) THEN CONTINUELOOP
		ACCEPTQUEST($QUESTID)
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSBH_4_1()
	$CLIENTSINDEXES = GETNEARBYALTS()
	MASSTAKEEXTERMINATIONORDER($CLIENTSINDEXES)
	SLEEP(4000)
	MASSTAKEBH($CLIENTSINDEXES, 37120)
	MASSCLOSENPCWINDOW()
ENDFUNC
