FUNC USEFIRSTINDICT($INV, $DICT)
	FOR $I = 0 TO UBOUND($INV) - 1
		IF $DICT.exists(INT($INV[$I][1], 1)) THEN
			USEITEMID($INV[$I][1])
			EXITLOOP
		ENDIF
	NEXT
ENDFUNC
FUNC DOAUTOPOTACTION($HP, $MP, $ELIX, $APOTH_IMMUNE, $APOTH_FULLHP, $PDEFCHARM, $MDEFCHARM, $AD, $TREE, $MAC)
	$INV = 0
	$HPMP = GETHPMP()
	IF $HPMP[0] == 0 THEN
		RETURN
	ENDIF
	$STATUS = GETDEFENSECHARMSTATUS()
	$HPPERCENT = $HPMP[0] * 100 / $HPMP[1]
	$MPPERCENT = $HPMP[2] * 100 / $HPMP[3]
	IF $HP > -1 AND $HPMP[4] == 0 AND $HPPERCENT < $HP AND $CLIENTS[$CURRENT_CLIENT][2] == $MAIN THEN
		IF UBOUND($INV) == 0 THEN $INV = INVARRAY()
		USEFIRSTINDICT($INV, $HPPOTS)
	ENDIF
	IF $MP > -1 AND $HPMP[5] == 0 AND $MPPERCENT < $MP AND $CLIENTS[$CURRENT_CLIENT][2] == $MAIN THEN
		IF UBOUND($INV) == 0 THEN $INV = INVARRAY()
		USEFIRSTINDICT($INV, $MPPOTS)
	ENDIF
	IF $ELIX > -1 AND $HPMP[6] == 0 AND $HPPERCENT < $ELIX AND $CLIENTS[$CURRENT_CLIENT][2] == $MAIN THEN
		IF UBOUND($INV) == 0 THEN $INV = INVARRAY()
		USEFIRSTINDICT($INV, $ELIXPOTS)
	ENDIF
	IF $APOTH_IMMUNE > -1 AND $HPPERCENT < $APOTH_IMMUNE AND $CLIENTS[$CURRENT_CLIENT][2] == $MAIN THEN
		IMMUNEAPOTH()
		SLEEP(100)
	ENDIF
	IF $APOTH_FULLHP > -1 AND $HPPERCENT < $APOTH_FULLHP AND $CLIENTS[$CURRENT_CLIENT][2] == $MAIN THEN
		FULLHPAPOTH()
		SLEEP(100)
	ENDIF
	IF $PDEFCHARM AND $STATUS[0] == 0 AND NOT $STATUS[1] AND $CLIENTS[$CURRENT_CLIENT][2] == $MAIN THEN
		IF UBOUND($INV) == 0 THEN $INV = INVARRAY()
		USEFIRSTINDICT($INV, $PHYSDEFCHARMS)
	ENDIF
	IF $MDEFCHARM AND $STATUS[0] == 0 AND NOT $STATUS[2] AND $CLIENTS[$CURRENT_CLIENT][2] == $MAIN THEN
		IF UBOUND($INV) == 0 THEN $INV = INVARRAY()
		USEFIRSTINDICT($INV, $MAGDEFCHARMS)
	ENDIF
	IF $AD > -1 AND $HPPERCENT < $AD AND SKILLOFFCOOLDOWN(1039, 1) AND GENIEENERGY() > 135 AND $CLIENTS[$CURRENT_CLIENT][2] == $MAIN THEN
		ABSOLUTEDOMAIN()
		SLEEP(100)
	ENDIF
	IF $TREE > -1 AND $HPPERCENT < $TREE AND SKILLOFFCOOLDOWN(1006, 1) AND GENIEENERGY() > 115 AND $CLIENTS[$CURRENT_CLIENT][2] == $MAIN THEN
		CASTSKILL(1006, 1)
		SLEEP(100)
	ENDIF
	IF $MAC > -1 AND $HPPERCENT < $MAC AND $CLIENTS[$CURRENT_CLIENT][2] == $MAIN THEN
		EXECUTEMACRO(2)
	ENDIF
ENDFUNC
FUNC HANDLEDEFENSECHARMS($PRIORITY)
	$STATUS = GETDEFENSECHARMSTATUS()
	IF $STATUS[0] == 0 AND $STATUS[1 + $PRIORITY] == FALSE THEN
		USEITEMID(47233 + $PRIORITY)
		SLEEP(140)
	ELSEIF $STATUS[0] == 0 AND $STATUS[1 + (1 - $PRIORITY)] == FALSE THEN
		USEITEMID(47233 + (1 - $PRIORITY))
		SLEEP(140)
	ENDIF
ENDFUNC
FUNC QUEST($STARTNPC, $QUESTID, $START_X, $START_Y, $TARGET, $TARGET_X, $TARGET_Y, $TARGET_TYPE, $OBJ_ITEM, $OBJ_COUNT)
	DIM $ARRAY[10] = [$STARTNPC, $QUESTID, $START_X, $START_Y, $TARGET, $TARGET_X, $TARGET_Y, $TARGET_TYPE, $OBJ_ITEM, $OBJ_COUNT]
	RETURN $ARRAY
ENDFUNC
