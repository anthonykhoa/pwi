	FUNC HANDINQUEST($QUESTID, $OPTIONINDEX)
		LOCAL $PACKET, $PACKETSIZE
		$PACKET = "2500"
		$PACKET &= "06000000"
		$PACKET &= "08000000"
		$PACKET &= _HEX($QUESTID)
		$PACKET &= _HEX($OPTIONINDEX)
		$PACKETSIZE = 18
		SENDPACKET($PACKET, $PACKETSIZE, $GAME_PID)
	ENDFUNC
	FUNC HANDINQUEST2($QUESTID, $OPTIONINDEX)
		LOCAL $PACKET, $PACKETSIZE
		$PACKET = "2500"
		$PACKET &= "06000000"
		$PACKET &= "08000000"
		$PACKET &= _HEX($QUESTID)
		$PACKET &= _HEX($OPTIONINDEX)
		FOR $PACKETSIZE = 18 TO 30
			SETSTATUS("packet size of " & $PACKETSIZE)
			SENDPACKET($PACKET, $PACKETSIZE, $GAME_PID)
			SLEEP(1000)
		NEXT
	ENDFUNC
