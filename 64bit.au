			IF @ERROR OR NOT $ACALL[0] THEN RETURN SETERROR(@ERROR, @EXTENDED, 0)
			IF NOT $BCOLORREF THEN
				$ACALL[2] = INT(BINARYMID($ACALL[2], 3, 1) & BINARYMID($ACALL[2], 2, 1) & BINARYMID($ACALL[2], 1, 1))
			ENDIF
			$ITRANSCOLOR = $ACALL[2]
			$ITRANSGUI = $ACALL[3]
			RETURN $ACALL[4]
		ENDFUNC
