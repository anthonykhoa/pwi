	FUNC REFINEGLYPH($MIDDLE, $GLYPH1, $GLYPH2, $GLYPH3, $GLYPH4, $GLYPH5)
		$PACKET = "CA0002000000" & _HEX(6) & _HEX(0) & _HEX($MIDDLE) & _HEX(0) & _HEX($GLYPH1) & _HEX(0) & _HEX($GLYPH2) & _HEX(0) & _HEX($GLYPH3) & _HEX(0) & _HEX($GLYPH4) & _HEX(0) & _HEX($GLYPH5)
		SENDPACKET($PACKET, 58, $GAME_PID)
