FUNC FLYTOCOORDS1($DISPLAY_X, $DISPLAY_Y, $DISPLAY_Z = -1)
	$X = $DISPLAY_X * 10 - 4000
	$Y = $DISPLAY_Y * 10 - 5500
	$Z = -1
	IF $DISPLAY_Z <> -1 THEN $Z = $DISPLAY_Z * 10
	FLY($X, $Y)
	IF $Z <> -1 THEN MOVETO($X, $Y, $Z)
ENDFUNC
FUNC FLYTOCOORDS($DISPLAY_X, $DISPLAY_Y, $DISPLAY_Z = -1)
	$X = $DISPLAY_X * 10 - 4000
	$Y = $DISPLAY_Y * 10 - 5500
	FLY($X, $Y, 135)
ENDFUNC
