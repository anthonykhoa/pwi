	IF NOT ISQUESTAVAILABLE(20758) THEN RETURN
	SETSTATUS("Main Map - Nirvana Palace Keys")
	TRANSFERMAP($MAP_MAIN, 0, 507, 3234)
	TAKEQUEST("Mysterious Old Man", 20758)
