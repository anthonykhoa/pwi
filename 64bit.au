FUNC DOPLOWSHARES()
	DIM $QUESTS[5] = [37207, 37209, 37210, 37211, 37212]
	IF NOT HASANYQUEST($QUESTS) AND NOT ISQUESTAVAILABLE(37207) THEN RETURN
	SETSTATUS("Neverfall - Plow Shares")
	TRANSFERMAP($MAP_NEVERFALL, 0, -604.92, -714.17, 25)
	TAKEQUEST("Wenham Granary Manager", 37207)
	SLEEP(2000)
	USEANCIENTGIFT()
	IF HASQUEST(37209) THEN
		TURNINQUEST("Wenham Granary Manager", 37691)
		FLYUP(110)
		DOVEHICLEQUEST(37207, "Broken Fertilizer", 4174, "Withered Sprout", 0)
	ELSEIF HASQUEST(37210) THEN
		TURNINQUEST("Wenham Granary Manager", 37693)
		WHILE NOT INCOMBAT()
			SLEEP(1000)
		WEND
		WHILE INCOMBAT()
			SLEEP(1000)
		WEND
		MOVE(-612.23, -658.63)
		DOVEHICLEQUEST(37207, "Weed Eradicator", 4197, "Persistent Weed", 1, 4200)
	ELSEIF HASQUEST(37211) THEN
		MOVE(-597.14, -780.57)
		DOVEHICLEQUEST(37207, "Insect Annihilator", 4196, "Annoying Pest", 0)
	ELSEIF HASQUEST(37212) THEN
		TURNINQUEST("Wenham Granary Manager", 37695)
		WHILE NOT INCOMBAT()
			SLEEP(1000)
		WEND
		WHILE INCOMBAT()
			SLEEP(1000)
		WEND
		MOVE(-608.7, -721.83)
		MOVE(-641.87, -722.13)
		DOVEHICLEQUEST(37207, "Vermin Exterminator", 4199, "Ripe Wheat", 1, 4200)
	ENDIF
	FLY(-828.2, -579.02, 15)
ENDFUNC
FUNC DOVEHICLEQUEST($PARENTQUEST, $VEHICLENAME, $VEHICLEWEAPID, $TARGETNAME, $MOVES, $VEHICLESECONDSKILL = -1)
	SETSTATUS("Neverfall - Plow Shares: " & $VEHICLENAME)
	PRINT($PARENTQUEST & " " & $VEHICLENAME & " " & $VEHICLEWEAPID & " " & $TARGETNAME & " " & $MOVES)
	WHILE HASQUEST($PARENTQUEST)
		DESELECTTARGET()
		$VEHICLE = GETNPCUNIQUEID($VEHICLENAME)
		PRINT("Hmmm " & $VEHICLE & " " & $VEHICLENAME & " " & GETNPCUNIQUEID($VEHICLENAME))
		WHILE NPCALIVE($VEHICLE, 0)
			MOVETONPC($VEHICLE, 1, 0, 5)
			IF PLAYERTARGET() THEN
				FLYUP(200)
				WHILE PLAYERTARGET()
					DESELECTTARGET()
					SLEEP(3000)
				WEND
				MOVETONPC($VEHICLE, 1, 0, 5)
				WAITSTOP(1)
			ENDIF
			IF NPCDISTANCE($VEHICLE, 0) < 40 THEN
				ENTERVEHICLE($VEHICLE)
				SLEEP(1000)
				EXITLOOP
			ENDIF
		WEND
		$TIMER = TIMERINIT()
		WHILE INVEHICLE() AND HASQUEST($PARENTQUEST)
			IF $MOVES THEN
				MOVETONPC($TARGETNAME, FALSE, 2, 2.9)
			ENDIF
			SHOOTWEAP($VEHICLEWEAPID, $TARGETNAME)
			IF TIMERDIFF($TIMER) > 16000 AND $VEHICLESECONDSKILL <> -1 THEN
				SHOOTWEAP($VEHICLESECONDSKILL, 0)
				$TIMER = TIMERINIT()
			ENDIF
		WEND
	WEND
ENDFUNC
FUNC ENTERVEHICLE($TARGET)
	SWITCHTOHUMANFORM()
	SENDPACKET("CD0000000000" & _HEX($TARGET) & "FFFFFFFF", 14, $GAME_PID)
ENDFUNC
FUNC SHOOTWEAP($WEAP, $TARGETNAME)
	$TARGET = GETNPCUNIQUEID($TARGETNAME)
	SELECTTARGET($TARGET)
	SLEEP(200)
	SENDPACKET("2900" & _HEX($WEAP) & "0B01" & _HEX($TARGET), 12, $GAME_PID)
	SLEEP(200)
	SENDPACKET("09000043", 4, $GAME_PID)
ENDFUNC
FUNC CRISISMOB($ARRAY, $I)
	RETURN $ARRAY[$I][1] >= 53718 AND $ARRAY[$I][1] <= 53722 AND NOT BITAND($ARRAY[$I][3], $NPCSTATUSBITDEAD)
ENDFUNC
FUNC DODARKNESSOFMAGNIER()
	IF NOT HASQUEST(37710) AND NOT ISQUESTAVAILABLE(37710) THEN RETURN
	SETSTATUS("Neverfall - Darkness Of Magnier")
	DIM $WEREWOLF_SPOTS[4][2] = [[782.99, 219.53], [828.36, 162.15], [836.75, 347.81], [823.75, 319.7]]
	DIM $CRISIS_SPOTS[6][2] = [[894.45, 334.93], [887.56, 256.08], [877.18, 169.5], [833.5, 164.58], [741.32, 133.93], [694.39, 342.18]]
	DIM $VAMPIRE_SPOTS[6][2] = [[775.31, 216.43], [815.78, 168.13], [706.69, 251.17], [869.63, 243.55], [842.83, 355.27], [754.29, 339.13]]
	TRANSFERMAP($MAP_NEVERFALL, 0, 782.61, 431.1, 55)
	TIMEDSELFBUFF()
	FLYUP()
	TAKEQUEST("Veteran Roberts", 37710)
	SETSTATUS("Neverfall - Doing Magnier Quest")
	SLEEP(1000)
	IF HASQUEST(37711) THEN
		USEITEMID(38408)
		SLEEP(1000)
		IF NOT WAITTILNIGHT(0) THEN RETURN
		SETSTATUS("Neverfall - Magnier Quest: Werewolves")
		USEANCIENTGIFT()
		FLYUP()
		FLY(831.5, 160)
		FLYRANDOM($WEREWOLF_SPOTS, 16)
		$POS = PLAYERPOS()
		$MOBTIMER = TIMERINIT()
		WHILE HASQUEST(37711)
			IF NOT WAITTILNIGHT(0) THEN RETURN
			IF NOT GETNPCUNIQUEID("Lurking Werewolf") AND NOT HASBUFF("Super Sight", 150) AND NOT HASQUEST(37846) THEN
				FLY($POS[0], $POS[1])
				IF ITEMCOUNT(54905) > 0 THEN
					SETSTATUS("Neverfall - Magnier Quest: Werewolves - using detection item")
					USEITEMID(54905)
					SLEEP(1000)
				ELSEIF ITEMCOUNT(32228) > 0 THEN
					SETSTATUS("Neverfall - Magnier Quest: Werewolves - using espionage potion")
					USEITEMID(32228)
					SLEEP(1000)
				ELSE
					SETSTATUS("Neverfall - Magnier Quest: Werewolves - no more stealth detection items. Failed.")
					EXITLOOP
				ENDIF
				SLEEP(1000)
			ENDIF
			$MOBS = NPCARRAY()
			$CURRTARGET = PLAYERTARGET()
			$INDEX = FINDCLOSEST($MOBS, $CURRTARGET, 0)
			IF $INDEX == -1 OR $MOBS[$INDEX][2] <> "Lurking Werewolf" OR NOT INCOMBAT() OR DISTANCE2D($MOBS[$INDEX][4], $MOBS[$INDEX][5]) > 40 THEN
				$INDEX = FINDCLOSEST($MOBS, "Lurking Werewolf")
			ENDIF
			IF $INDEX <> -1 THEN
				IF CHI() > 300 THEN TRIPLESPARK()
				KILL($MOBS[$INDEX][0], 200, 0, 0)
			ENDIF
		WEND
	ELSEIF HASQUEST(37712) THEN
		IF NOT WAITTILNIGHT(1) THEN RETURN
		SETSTATUS("Neverfall - Magnier Quest: Crisis")
		USEANCIENTGIFT()
		FLYUP()
		FLYRANDOM($CRISIS_SPOTS, 16)
		$POS = PLAYERPOS()
		WHILE HASQUEST(37712)
			IF NOT WAITTILNIGHT(1) THEN RETURN
			IF NOT GETNPCUNIQUEID("FUNC:CrisisMob") THEN FLY($POS[0], $POS[1])
			IF CHI() > 300 THEN TRIPLESPARK()
			KILL("FUNC:CrisisMob", 200, 2, 1)
		WEND
	ELSEIF HASQUEST(37784) THEN
		SETSTATUS("Neverfall - Magnier Quest: Statues")
		FLYUP(106)
		MOVETONPC("Stone Statue")
		TURNINQUEST("Stone Statue", 37786)
		SLEEP(6000)
		MOVE(847.32, 318.17, 130, 1)
		TURNINQUEST("Stone Statue", 37787)
		SLEEP(6000)
		MOVE(846.54, 298.59, 130.78, 1)
		MOVE(824.69, 181.28, 109.64, 1)
		TURNINQUEST("Stone Statue", 37822)
		SLEEP(6000)
		MOVE(750.73, 231.02, 114.97, 1)
		MOVE(715.32, 261.17, 109.16, 1)
		USEANCIENTGIFT()
		TURNINQUEST("Stone Statue", 37823)
		SLEEP(5000)
		FLYUP(130)
	ELSEIF HASQUEST(37785) THEN
		IF NOT WAITTILNIGHT(1) THEN RETURN
		SETSTATUS("Neverfall - Magnier Quest: Vampires")
		FLYUP()
		FLYRANDOM($VAMPIRE_SPOTS, 16)
		$POS = PLAYERPOS()
		USEANCIENTGIFT()
		WHILE HASQUEST(37785)
			IF NOT WAITTILNIGHT(1) THEN RETURN
			$MOBS = NPCARRAY()
			$CURRTARGET = PLAYERTARGET()
			$INDEX = FINDCLOSEST($MOBS, $CURRTARGET, 0)
			IF $INDEX == -1 OR $MOBS[$INDEX][2] <> "Suspicious Vampire" OR NOT INCOMBAT() THEN
				$INDEX = FINDCLOSEST($MOBS, "Suspicious Vampire")
			ENDIF
			IF $INDEX == -1 THEN
				SLEEP(1000)
			ELSEIF $MOBS[$INDEX][8] == 0 THEN
				BUFFEREDSELECT($MOBS[$INDEX][0])
			ELSEIF $MOBS[$INDEX][7] > 0.5 * $MOBS[$INDEX][8] OR NPCTARGET($MOBS[$INDEX][10]) <> PLAYERID() THEN
				BUFFEREDSELECT($MOBS[$INDEX][0])
				IF CHI() > 300 THEN TRIPLESPARK()
				$SKILL = EXECUTEMACRO(0)
				IF $SKILL == -1 THEN
					DO
						SLEEP(250)
						CANCELACTION()
						SLEEP(300)
					UNTIL ACTIONFLAG() = 0
				ENDIF
			ELSEIF $MOBS[$INDEX][7] < 0.5 * $MOBS[$INDEX][8] THEN
				DO
					CANCELACTION()
					SLEEP(250)
				UNTIL ACTIONFLAG() = 0
				BUFFEREDSELECT($MOBS[$INDEX][0])
				USEITEMID(54585, 1)
			ENDIF
			SLEEP(1000)
		WEND
		SETSTATUS("Neverfall - Magnier Quest: Finished")
	ENDIF
	FLYUP()
	WHILE HASQUEST(37710)
		TURNINQUEST("Veteran Roberts", 37710, 782.61, 431.1, 55)
		SLEEP(2000)
	WEND
	FLYUP(130)
	IF ISQUESTAVAILABLE(37710) THEN
		SETSTATUS("Neverfall - Checking Magnier again")
		DODARKNESSOFMAGNIER()
	ELSE
		MOVE(RANDOM(747, 762), RANDOM(325, 358))
	ENDIF
ENDFUNC
FUNC WAITTILNIGHT($ISNIGHT)
	$MOVED = FALSE
	WHILE($ISNIGHT AND(GETNPCUNIQUEID("Common Vampire") == 0)) OR(($ISNIGHT == 0) AND GETNPCUNIQUEID("Common Vampire"))
		IF GETGLOBALSETTING("skipmagnierwait") AND NOT $DAILY_SINGLE_CALL THEN
			SETSTATUS("Neverfall - Skipping Magnier")
			RETURN FALSE
		ENDIF
		SETSTATUS("Neverfall - Waiting for Magnier Quest")
		SLEEP(10000)
		IF NOT $MOVED THEN
			FLY(RANDOM(747, 762), RANDOM(325, 358))
			$MOVED = TRUE
		ENDIF
		ENTERHOME(PLAYERID())
		WHILE @MIN <> 1
			SLEEP(30000)
		WEND
		SLEEP(RANDOM(60000, 240000))
		EXITHOME()
		WAITFORNPC("Stone Statue")
	WEND
	RETURN TRUE
ENDFUNC
FUNC VENGEANCEMOB($ARRAY, $I)
	RETURN($ARRAY[$I][1] == 59290 OR $ARRAY[$I][1] == 59291 OR $ARRAY[$I][1] == 59292 OR $ARRAY[$I][1] == 59293 OR $ARRAY[$I][1] == 59295) AND NOT BITAND($ARRAY[$I][3], $NPCSTATUSBITDEAD)
ENDFUNC
FUNC FLAMEOFVENGEANCE()
	IF NOT HASQUEST(40039) AND NOT ISQUESTAVAILABLE(40039) THEN RETURN
	SETSTATUS("Neverfall - Flame of Vengeance")
	$MAP = INSTANCEID()
	IF CLASS() == 12 AND $MAP <> $MAP_NEVERFALL THEN TELEPORTSTONETOETHERBLADE()
	TRANSFERMAP($MAP_NEVERFALL, 0, -512, 950.07, 30)
	TAKEQUEST("Light Empress Althea", 40039)
	SELFBUFF()
	DIM $SPOTS[7][2] = [[-739.71, 1217.8], [-739.71, 1217.8], [-597.42, 1046.13], [-512.83, 1016.64], [-425.53, 1032.91], [-418.52, 957.82], [-354.85, 1127.85]]
	FLYRANDOM($SPOTS, 15)
	USEANCIENTGIFT()
	WHILE HASQUEST(40039)
		IF CHI() > 300 THEN TRIPLESPARK()
		KILL("FUNC:VengeanceMob", 200, 2, 0)
	WEND
	FLYUP(130)
ENDFUNC
FUNC REBORNINFIRE()
	DIM $QUESTS[5] = [40040, 40041, 40042, 40043, 40044]
	IF NOT HASANYQUEST($QUESTS) AND NOT ISQUESTAVAILABLE(40040) THEN RETURN
	SETSTATUS("Neverfall - Reborn In Fire")
	TRANSFERMAP($MAP_NEVERFALL, 0, 705, 1517, 30)
	TAKEQUEST("Flametail Worshiper", 40040)
	TIMEDSELFBUFF()
	SLEEP(1000)
	IF HASQUEST(40041) THEN
		DIM $SPOTS[4][2] = [[449.37, 1652.81], [510.53, 1678.17], [527.44, 1672.47], [433.98, 1671.93]]
		FLYRANDOM($SPOTS, 15)
		WHILE QUESTKILLCOUNT(40041) < 5
			IF CHI() > 300 THEN TRIPLESPARK()
			KILL("Contorted Sheren", 200, 2, 0)
		WEND
		TURNINQUESTFAKENPC(40041)
	ENDIF
	IF HASQUEST(40042) THEN
		DIM $SPOTSAGAIN[5][2] = [[601.32, 1743.72], [645.73, 1786.99], [717.41, 1794.33], [616.07, 1679.44], [771.76, 1797.49]]
		FLYRANDOM($SPOTSAGAIN, 20)
		WHILE QUESTKILLCOUNT(40042) < 5
			KILL("Dallagher Flame", 200, 2, 0)
		WEND
		TURNINQUESTFAKENPC(40042)
	ENDIF
	IF HASQUEST(40043) THEN
		FLY(849.55, 1693.56, 19)
		WHILE ITEMCOUNT(59427) < 1
			DIGITEM("Flame of the Divine Mountain")
		WEND
		TURNINQUESTFAKENPC(40043)
		SLEEP(4000)
	ENDIF
	USEANCIENTGIFT()
	$OPTION = GETGLOBALSETTING("fireblood") ? 1 : 0
	TURNINQUESTFAKENPC(40044, $OPTION)
ENDFUNC
FUNC BATTLEOFSURVIVAL()
	DIM $QUESTS[2] = [41069, 41070]
	IF NOT HASANYQUEST($QUESTS) AND NOT ANYQUESTAVAILABLE($QUESTS) THEN RETURN
	SETSTATUS("Neverfall - Battle of Survival")
	TRANSFERMAP($MAP_NEVERFALL, 0, RANDOM(1362.41, 1366.33), RANDOM(1568.21, 1573.96), 30)
	TAKEQUEST("Recruit Officer Taylor", 41069)
	WHILE HASQUEST(41069)
		SLEEP(1000)
	WEND
	IF ITEMCOUNT(62056) THEN
		TAKEQUEST("Recruit Officer Taylor", 41070)
		WHILE DISTANCE2D(-570, -827) > 100
			SLEEP(10000)
		WEND
		WHILE HASQUEST(41071)
			SLEEP(10000)
		WEND
		WAITFORNPC("Recruit Officer Taylor")
		SLEEP(RANDOM(10000, 30000, 1))
		TALKTONPC("Recruit Officer Taylor")
		TAKEQUEST("Recruit Officer Taylor", 41072)
	ENDIF
	WAITFORNPC("Polydeux Major")
	WHILE HASQUEST(41070)
		TRASHQUEST(41070)
		SLEEP(1000)
	WEND
ENDFUNC
FUNC DOCLOUDTOPDRAGONROUTE()
	STATIC $ATTEMPTCOUNT = 0
	STATIC $SUCCESSCOUNT[8] = [0, 0, 0, 0, 0, 0, 0, 0]
	$ATTEMPTCOUNT += 1
	WHILE DISTANCE2D(1511, 367) > 2
		SLEEP(250)
	WEND
	SLEEP(2000)
	MOVEWHILEJUMPING(1508.15, 357.91, 111)
	MOVEWHILEJUMPING(1463.97, 354.26, 111, 5)
	WHILE HASQUEST(41894) AND ALTITUDE() > 111
		MOVEWHILEJUMPINGANDLAND(1463.97, 354.26, 111)
		SLEEP(1000)
	WEND
	$SUCCESSCOUNT[0] += ALTITUDE() > 111
	MOVEWHILEJUMPING(1470.19, 349.3, 111)
	MOVEWHILEJUMPING(1470.19, 331, 111)
	MOVEWHILEJUMPING(1473.52, 320, 111, 7)
	MOVEWHILEJUMPING(1473.52, 306, 111, -1)
	$USEADPOS = PLAYERPOS()
	IF DISTANCE2D(1473.52, 306) < 5 THEN ABSOLUTEDOMAIN()
	JUMPUPTHENMOVE(1473.52, 295.11, 1473.52, 306, 111)
	WHILE HASQUEST(41895) AND ALTITUDE() > 111
		MOVEWHILEJUMPINGANDLAND(1473.52, 295.11, 111, 5)
		SLEEP(1000)
	WEND
	$SUCCESSCOUNT[1] += ALTITUDE() > 111
	MOVEWHILEJUMPING(1462.25, 293.8, 111)
	MOVEWHILEJUMPING(1402.37, 294.75, 111, -1)
	WHILE HASQUEST(41896) AND ALTITUDE() > 111
		MOVEWHILEJUMPINGANDLAND(1399.59, 295.6, 111, -1)
		SLEEP(100)
	WEND
	$SUCCESSCOUNT[2] += ALTITUDE() > 111
	MOVEWHILEJUMPINGANDLAND(1401.96, 313.17, 111, 1)
	MOVEWHILEJUMPING(1402.06, 344.19, 111, 2)
	MOVEWHILEJUMPING(1399.01, 351.67, 111, -1)
	MOVEWHILEJUMPING(1399.08, 356.67, 111, -1)
	$POS = PLAYERPOS()
	IF DISTANCE2D(1399.08, 359.2) < 10 AND $POS[2] > 116 THEN IMMUNEAPOTH()
	MOVEWHILEJUMPING(1399.23, 392.63, 111, -1)
	SLEEP(500)
	JUMPUPTHENMOVE(1399.4, 402.78, 1399.06, 392.76, 111)
	WHILE HASQUEST(41897) AND ALTITUDE() > 111
		MOVEWHILEJUMPINGANDLAND(1399.4, 402.78, 111, 5)
		SLEEP(1000)
	WEND
	$SUCCESSCOUNT[3] += ALTITUDE() > 111
	MOVEWHILEJUMPING(1402, 410.8, 111)
	MOVEWHILEJUMPINGANDLAND(1398.2, 410.8, 111)
	MOVEWHILEJUMPING(1390.33, 427.39, 111)
	WHILE ALTITUDE() > 111
		MOVEWHILEJUMPINGANDLAND(1378.17, 427.39, 111)
		MOVEWHILEJUMPINGANDLAND(1367.19, 423.1, 111)
		SLEEP(2000)
		IF NOT HASQUEST(41898) THEN EXITLOOP
	WEND
	$SUCCESSCOUNT[4] += ALTITUDE() > 111
	MOVEWHILEJUMPING(1367.13, 406.3, 111)
	MOVEWHILEJUMPING(1367.19, 260.12, 117)
	MOVEWHILEJUMPING(1362.76, 249.12, 111, -1)
	WHILE HASQUEST(41899) AND ALTITUDE() > 111
		MOVEWHILEJUMPING(1362.76, 249.12, 111)
		SLEEP(1000)
	WEND
	$SUCCESSCOUNT[5] += ALTITUDE() > 111
	MOVEWHILEJUMPING(1370.91, 248.34, 111, -1)
	MOVEWHILEJUMPING(1374.3, 253.39, 111)
	MOVEWHILEJUMPING(1453.69, 253.33, 117)
	MOVEWHILEJUMPINGANDLAND(1467.81, 248.99, 111)
	WHILE HASQUEST(41900) AND ALTITUDE() > 111
		MOVEWHILEJUMPINGANDLAND(1467.81, 248.99, 111)
		SLEEP(1000)
	WEND
	IF ALTITUDE() > 111 THEN USEANCIENTGIFT()
	$SUCCESSCOUNT[6] += ALTITUDE() > 111
	MOVEWHILEJUMPING(1501.66, 266.37, 111)
	MOVEWHILEJUMPING(1501.76, 287.9, 111)
	MOVEWHILEJUMPING(1499.73, 293.86, 111)
	MOVEWHILEJUMPING(1499.17, 305.61, 111)
	$SUCCESSCOUNT[7] += ALTITUDE() > 111
	MOVEWHILEJUMPING(1509.32, 316.26, 111, -1)
	WHILE HASQUEST(41901) AND ALTITUDE() > 111
		MOVEWHILEJUMPING(1509.32, 316.26, 111, -1)
		SLEEP(1000)
	WEND
	RETURN ALTITUDE() > 111
ENDFUNC
FUNC CLOUDTOPDRAGON()
	IF NOT HASQUEST(41893) AND NOT ISQUESTAVAILABLE(41893) THEN RETURN
	SETSTATUS("Neverfall - Cloud Top Dragon")
	WHILE HASQUEST(41893)
		TRASHQUEST(41893)
		SLEEP(1000)
	WEND
	TRANSFERMAP($MAP_NEVERFALL, 0, 1440.33, 340.13)
	WHILE ISQUESTAVAILABLE(41893)
		TAKEQUEST("Kolorte", 41893, 1440.33, 340.13)
		IF NOT DOCLOUDTOPDRAGONROUTE() THEN
			WHILE HASQUEST(41893)
				TRASHQUEST(41893)
				SLEEP(1000)
			WEND
		ENDIF
	WEND
ENDFUNC
FUNC MEMORIESGOTOPHOTO($I)
	WHILE HASQUEST(44019 + $I)
		SLEEP(500)
	WEND
	WHILE ITEMCOUNT(69086 + $I)
		USEITEMID(69086 + $I)
		SLEEP(1000)
	WEND
	LOCAL $POSITIONS[20][2] = [[-499, 512], [-852, 446], [-165, 368], [150, -170], [768.5, 878.5], [-180.5, -298.5], [1876.5, 1875.5], [950, 1300], [1965.5, 1552.5], [1500, -550], [185, 1406], [-239.8, 1433], [-837.5, 1514], [515.5, -598], [-333, -848], [412, 509.5], [251, 1778.5], [-811, 852.5], [470, -294], [1903, 170.5]]
	$DESTX = $POSITIONS[$I][0]
	$DESTY = $POSITIONS[$I][1]
	MOVE2(1885.88, -446.03)
	IF HASQUEST(44039) THEN
		USEANCIENTGIFT()
		FLY(-484, 494)
		DROPDOWN()
		WAITSTOP(1)
	ENDIF
	WHILE HASQUEST(44039 + $I)
		USEANCIENTGIFT()
		FLY($DESTX, $DESTY, 40)
		COMPLETEQUEST2(44039 + $I)
	WEND
	IF $I == 6 THEN FLYUP(330)
	SLEEP(3000)
ENDFUNC
FUNC MEMORIESOFTHEPAST()
	IF NOT HASQUEST(43976) AND NOT ISQUESTAVAILABLE(43976) THEN RETURN
	SETSTATUS("Neverfall - Memories of the Past")
	TRANSFERMAP($MAP_NEVERFALL, 0, 1860, -444, 70)
	TAKEQUEST("Sacred Spirit", 43976)
	FOR $I = 43999 TO 44018
		IF HASQUEST($I) THEN
			MEMORIESGOTOPHOTO($I - 43999)
			EXITLOOP
		ENDIF
		SLEEP(100)
	NEXT
	$WHILETIMER = TIMERINIT()
	WHILE INCOMBAT() AND TIMERDIFF($WHILETIMER) < 120000
		EXECUTEMACRO(0)
	WEND
ENDFUNC
