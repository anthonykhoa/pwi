FUNC TNF()
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($I)
		TRANSFERMAP(1, 0, 1333.337, 831.325)
	NEXT
	SWITCHTO($MAIN)
	WHILE NOT GETNPCUNIQUEID("Thursday Night Fights Agent")
		SLEEP(30000)
	WEND
	SLEEP(10000)
	WHILE NOT ISQUESTAVAILABLE(34156)
		SLEEP(5000)
	WEND
	SLEEP(5000)
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($I)
		TAKEQUEST("Thursday Night Fights Agent", 34156, 1331.337, 831.325)
		SLEEP(5000)
	NEXT
	SLEEP(10000)
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($I)
		TAKEQUEST("Tournament Registrar", 34155, 380.545, -906.054)
		SLEEP(5000)
	NEXT
	SLEEP(10000)
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($I)
		$ARRAY = INVARRAY()
		$INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
		USETELESTONE($ARRAY[$INDEX][1], $ARRAY[$INDEX][0], 2101)
		SLEEP(5000)
	NEXT
ENDFUNC
FUNC TNF3()
	SWITCHTO($MAIN)
	SETSTATUS("Doing TNF for weekly credit on all char.")
	MASSTELEPORTSTONETOARCHOSAURWESTALL()
	SLEEP(10000)
	$CLIENTSINDEXES = GETNEARBYALTS()
	MASSMOVETOCOORD(1269.8, 1123.5, $CLIENTSINDEXES, FALSE)
	MASSMOVETOCOORD(1271.17, 871.57, $CLIENTSINDEXES, FALSE)
	MASSMOVETOCOORD(1329.64, 826.02, $CLIENTSINDEXES, FALSE)
	SWITCHTO($MAIN)
	WHILE NOT GETNPCUNIQUEID("Thursday Night Fights Agent")
		SLEEP(30000)
	WEND
	WHILE NOT ISQUESTAVAILABLE(34156)
		SLEEP(5000)
	WEND
	TAKECLIENTSQUEST("Thursday Night Fights Agent", 34156, 1331.337, 831.325, $CLIENTSINDEXES)
	SLEEP(10000)
	WHILE NOT GETNPCUNIQUEID("Tournament Registrar")
		SLEEP(1000)
	WEND
	SLEEP(10000)
	MASSMOVETOCOORD(380.545, -906.054)
	TAKECLIENTSQUEST("Tournament Registrar", 34155, 380.545, -906.054, $CLIENTSINDEXES)
	SLEEP(10000)
	WHILE NOT GETNPCUNIQUEID("Exit Manager")
		SLEEP(1000)
	WEND
	IF GETGLOBALSETTING("AutoBankRepairSpotAlternate") THEN
		MASSTELEPORTSTONETOBAMBOOVILLAGEALL()
	ELSEIF GETGLOBALSETTING("AutoBankRepairSpotAlternate2") THEN
		MASSTELEPORTSTONETOETHERBLADEALL()
	ELSE
		MASSTELEPORTSTONETOHHVILLAGEALL()
	ENDIF
	SETSTATUS("TNF weekly done.")
ENDFUNC
