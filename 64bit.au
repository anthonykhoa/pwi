		WHILE ITEMCOUNT(51659) > 0
			USEITEMID(51659)
			SLEEP(1000)
		WEND
		SLEEP(10 * 60 * 1000)
		WHILE HASQUEST(36268) AND NOT ITEMCOUNT(51614, 1)
			DIGITEM("Ripe Pumpkin")
			SLEEP(100)
		WEND
		USEANCIENTGIFT()
		TURNINQUEST("Tree Raccoon Chief", 36268, -466.14, 123.72, 37)
		TURNINQUEST("Tree Raccoon Chief", 36260, -466.14, 123.72, 37)
		USETELEPORTMASTER("Teleport Master", 0)
	ELSEIF HASQUEST(36261) THEN
		USETELEPORTMASTER("Image of Althea", 4)
		USETELEPORTMASTER("Teleporter Kinai", 0)
		MOVE(242.88, 763.49)
		MOVE(276.24, 767.06)
		WHILE HASQUEST(36261) AND QUESTKILLCOUNT(36261) < 1
			TRIPLESPARK()
			KILL("Giant Stone Golem", 200, 2, 3)
			SLEEP(100)
		WEND
		MOVE(276.24, 767.06)
		MOVE(229.45, 765.72)
		MOVE(89.77, 802.26)
		USEANCIENTGIFT()
		TURNINQUEST("Inkstone Chief", 36261, 98.1, 691.31, 36)
		MOVE(96.98, 806.24)
		USETELEPORTMASTER("Teleporter Cobaltite", 0)
		USETELEPORTMASTER("Teleporter Kinai", 2)
	ELSEIF HASQUEST(36262) THEN
		USETELEPORTMASTER("Image of Althea", 5)
		MOVE(463.51, -653.77, 242.23, 1)
		MOVE(302.16, -477.72, 285, 1)
		WHILE ITEMCOUNT(51615, 1) < 5
			DIGITEM("Suspicious Bubble")
			SLEEP(100)
		WEND
		MOVE(289.48, -464.3, 250.18, 1)
		MOVE(275.48, -440.3, 247.18, 1)
		USEANCIENTGIFT()
		TURNINQUEST("Seaward Chief Wavelance", 36262)
		MOVE(288.53, -468.71, 255.66, 1)
		MOVE(463.51, -653.77, 242.23, 1)
		MOVE(474.14, -661.16, 230.2, 1)
		USETELEPORTMASTER("Teleport Master Aquas", 0)
	ENDIF
ENDFUNC
