			LOCAL $ACALL = DLLCALL("gdi32.dll", "dword", "GetPixel", "handle", $HDC, "int", $IX, "int", $IY)
			IF @ERROR OR($ACALL[0] = 4294967295) THEN RETURN SETERROR(@ERROR, @EXTENDED, -1)
			RETURN __RGB($ACALL[0])
		ENDFUNC
