	SETSTATUS("Main Map - Pick Up Divine Quests")
	TRANSFERMAP($MAP_MAIN, 0, 1506.5, 846.63)
	TALKTONPC("Divine Emissary of Void")
	OPENNPCQUESTINTERFACE()
	DIM $QUESTS[8] = [22875, 22876, 22877, 22878, 22879, 22880, 31476, 31478]
	FOR $I = 0 TO UBOUND($QUESTS) - 1
		ACCEPTVOIDQUEST($QUESTS[$I], 3)
		SLEEP(100)
