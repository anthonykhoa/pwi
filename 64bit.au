			ENDIF
		ELSEIF GETGLOBALSETTING("waitUpTo1MinutesForUPDReset") THEN
			IF SQUADCOMBATMODECHECK($SQUADLIST, -299.15, -185.71, 45, 60000) THEN
				$FASTRESETTIMING = TRUE
			ENDIF
		ENDIF
		SWITCHTO($MAIN)
		DIM $TELEPORTSTONEARRAY[UBOUND($SQUADLIST)][2]
		FOR $I = 0 TO UBOUND($SQUADLIST) - 1
			$INDEX = $SQUADLIST[$I]
			SWITCHTONUM($INDEX)
			$ARRAY = INVARRAY()
			$INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
			$ITEMID = -1
			$ITEMPOS = -1
			IF $INDEX == -1 THEN
				SETSTATUS("Out of teleport stones. Fix this for future runs.")
			ELSE
				$ITEMID = $ARRAY[$INDEX][1]
				$ITEMPOS = $ARRAY[$INDEX][0]
			ENDIF
			$TELEPORTSTONEARRAY[$I][0] = $ITEMID
