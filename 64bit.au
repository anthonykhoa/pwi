FUNC ECDAILY()
	DOTELEPORTROUTE(478.76, 3248.16, 258.91)
	WAITFORNPC("Teleport Master Yao")
	TALKTONPC("Teleport Master Yao")
	SLEEP(5000)
	ACCEPTQUEST(50268)
	SLEEP(5000)
	CLOSENPCWINDOW()
	FLYTOCOORDS(184, 404, 69)
	SLEEP(5000)
	TALKTONPC("Holy Ritualmaster")
