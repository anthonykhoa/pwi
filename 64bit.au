	FUNC UPDMASSNAVIGATETOAGENTOFUNITY(ByRef $CLIENTSINDEXES)
		$ARRIVED = FALSE
		SETSTATUS("unity 0")
		IF NOT MASSMOVETOCOORDENHANCED(-396.97, -267.48, $CLIENTSINDEXES, 10, 176, 60000) THEN RETURN $ARRIVED
		SETSTATUS("unity 1")
		IF MASSGENIEENERGYCHECK($CLIENTSINDEXES, 75) THEN MASSSPEEDPATH($CLIENTSINDEXES)
		IF NOT MASSMOVETOCOORDENHANCED(-378.73, -226.1, $CLIENTSINDEXES, 10, 176, 60000) THEN RETURN $ARRIVED
		IF NOT MASSMOVETOCOORDENHANCED(-359.36, -187.37, $CLIENTSINDEXES, 10, 176, 60000) THEN RETURN $ARRIVED
		IF MASSGENIEENERGYCHECK($CLIENTSINDEXES, 75) THEN MASSSPEEDPATH($CLIENTSINDEXES)
		IF NOT MASSMOVETOCOORDENHANCED(-353.93, -178.75, $CLIENTSINDEXES, 10, 176, 60000) THEN RETURN $ARRIVED
		IF MASSGENIEENERGYCHECK($CLIENTSINDEXES, 75) THEN MASSSPEEDPATH($CLIENTSINDEXES)
		IF NOT MASSMOVETOCOORDENHANCED(-318.47, -104.03, $CLIENTSINDEXES, 10, 176, 60000) THEN RETURN $ARRIVED
		IF NOT MASSMOVETOCOORDENHANCED(-347.81, -71.06, $CLIENTSINDEXES, 10, 176, 60000) THEN RETURN $ARRIVED
		IF NOT MASSMOVETOCOORDENHANCED(-329.23, -53.39, $CLIENTSINDEXES, 10, 176, 60000) THEN RETURN $ARRIVED
		IF MASSGENIEENERGYCHECK($CLIENTSINDEXES, 75) THEN MASSSPEEDPATH($CLIENTSINDEXES)
		IF NOT MASSMOVETOCOORDENHANCED(-292.03, -56.52, $CLIENTSINDEXES, 10, 176, 60000) THEN RETURN $ARRIVED
		IF NOT MASSMOVETOCOORDENHANCED(-295.3, -60.62, $CLIENTSINDEXES, 10, 176, 60000) THEN RETURN $ARRIVED
		$ARRIVED = TRUE
		RETURN $ARRIVED
	ENDFUNC
	FUNC UPDCHECKERBOARDHELPER2()
		$MEMBERS = PARTYARRAY2()
		$SQUADCLIENTS = GETSQUADALTS()
		UPDCHECKERBOARDHELPER($MEMBERS, $SQUADCLIENTS)
	ENDFUNC
	FUNC UPDCHECKERBOARDHELPER($MEMBERS, $SQUADCLIENTS)
		SETSTATUS("UPD: Prior to Checkerboard.")
		$CHECKERBOARDSUCCESS = FALSE
		$DIEDSOUSINGSLOWERTIMING = FALSE
		$CANCELCHECKERBOARD = FALSE
		$CLIENTSINDEXESALL = GETNEARBYALTS()
		$EXPECTEDCOUNT = UBOUND($SQUADCLIENTS)
		$FAILCOUNT = 0
		MASSCLOSENPCWINDOW()
		WHILE NOT $CHECKERBOARDSUCCESS
			IF $CANCELCHECKERBOARD THEN
				$FAILCOUNT += 1
				SETSTATUS("Something went wrong. Restarting checkerboard from start.")
				$DIEDSOUSINGSLOWERTIMING = TRUE
				MASSJUMPTOCOORD(-382.73, -229.86, $SQUADCLIENTS, TRUE, 176)
				SETSTATUS("Jump done.")
				MASSRESTOTOWN()
				SETSTATUS("Mass res done")
				SLEEP(3000)
				SQUADLEAVEGLITCHFIX($MEMBERS, 10)
				SETSTATUS("Squad leave glitch check done.")
				CHECKALLCHARINSIDEINSTANCE(176, $SQUADCLIENTS)
				CHECKALLCHARINSIDEINSTANCE(176, $SQUADCLIENTS)
				SETSTATUS("Check all char inside done.")
				MASSMOVETOCOORDENHANCED(-382.73, -229.86, $SQUADCLIENTS, 10, 176)
				SETSTATUS("Mass move to -382.73, -229.86 done.")
				IF $FAILCOUNT > 3 THEN
					MASSCLOSENPCWINDOW()
					SWITCHTO($MAIN)
					MASSTELEPORTINCENSE()
					REFORMSQUAD()
					SLEEP(1000)
					SQUADLEAVEGLITCHFIX($MEMBERS, 10)
					SLEEP(1000)
					FOR $I = 0 TO UBOUND($SQUADCLIENTS) - 1
						MOVE5(-400.78, -293.64)
					NEXT
					SLEEP(10000)
					MASSMOVETOCOORD(934.63, -942.33, $SQUADCLIENTS)
					TAKECLIENTSQUEST("Swordsman Zenray", 34438, 931.96, -940.34, $SQUADCLIENTS)
					SLEEP(25000)
					SQUADLEAVEGLITCHFIX($MEMBERS, 10)
					CHECKALLCHARINSIDEINSTANCE(176, $SQUADCLIENTS)
					CHECKALLCHARINSIDEINSTANCE(176, $SQUADCLIENTS)
				ENDIF
			ENDIF
			MASSCLOSENPCWINDOW()
			$CANCELCHECKERBOARD = FALSE
			$CURRENTMEMBERS = GETNEARBYALTS(65)
			$CURRENTMEMBERCOUNT = UBOUND($CURRENTMEMBERS)
			IF $CURRENTMEMBERCOUNT < 10 THEN
				SETSTATUS("Less than 10 players. Unable to do UPD checkerboard. Will try to fix...")
				WHILE $CURRENTMEMBERCOUNT < 10
					SQUADLEAVEGLITCHFIX($MEMBERS, 10)
					CHECKALLCHARINSIDEINSTANCE(176, $SQUADCLIENTS)
					$CURRENTMEMBERS = GETNEARBYALTS(65)
					$CURRENTMEMBERCOUNT = UBOUND($CURRENTMEMBERS)
				WEND
			ENDIF
			$INSTANCE = INSTANCEID()
			IF $INSTANCE <> 176 THEN
				SETSTATUS("Not inside UPD. Cannot do UPD checkerboard.")
				RETURN
			ENDIF
			$CLIENTSINDEXES = GETNEARBYALTS(30)
			$CLIENTSINDEXES5 = GETNEARBYALTS(5)
			$NUMBEROFCHAR = UBOUND($CLIENTSINDEXES)
			$NUMBEROFCHAR5 = UBOUND($CLIENTSINDEXES5)
			IF DISTANCE2D(-359.36, -187.37) < 5 AND $NUMBEROFCHAR5 == 10 THEN
				$CHECKERBOARDSUCCESS = TRUE
				EXITLOOP
			ENDIF
			MASSSWITCHTOHUMANFORM()
			SWITCHTO($MAIN)
			IF $NUMBEROFCHAR == 10 AND DISTANCE2D(-382.73, -229.86) < 10 THEN
				SETSTATUS("UPD Checkerboard, starting near the board already.")
				MASSMOVETOCOORDENHANCED(-382.73, -229.86, $SQUADCLIENTS, 10, 176, 20000)
				CHECKALLCHARINSIDEINSTANCE(176, $SQUADCLIENTS)
				MASSMOVETOCOORDENHANCED(-382.73, -229.86, $SQUADCLIENTS, 10, 176, 20000)
			ELSEIF $NUMBEROFCHAR < 10 AND DISTANCE2D(-382.73, -229.86) < 10 THEN
				SETSTATUS("UPD Checkerboard, char appears to be missing. Fixing...")
				CHECKALLCHARINSIDEINSTANCE(176, $SQUADCLIENTS)
				CHECKALLCHARINSIDEINSTANCE(176, $SQUADCLIENTS)
				MASSSPEEDPATH($SQUADCLIENTS)
				MASSMOVETOCOORDENHANCED(-382.73, -229.86, $SQUADCLIENTS, 10, 176, 20000)
				CHECKALLCHARINSIDEINSTANCE(176, $SQUADCLIENTS)
				MASSMOVETOCOORDENHANCED(-382.73, -229.86, $SQUADCLIENTS, 10, 176, 20000)
			ELSEIF $NUMBEROFCHAR == 10 THEN
				SETSTATUS("UPD checkerboard, starting from instance entrance.")
				MASSSPEEDPATH($SQUADCLIENTS)
				MASSMOVETOCOORDENHANCED(-382.73, -229.86, $SQUADCLIENTS, 10, 176, 20000)
				CHECKALLCHARINSIDEINSTANCE(176, $SQUADCLIENTS)
				MASSMOVETOCOORDENHANCED(-382.73, -229.86, $SQUADCLIENTS, 10, 176, 20000)
			ENDIF
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			SETSTATUS("UPD-Checkboard starting.")
			DIM $PLAYERCOORDS[10][21][2] = [[[-388.35, -219.15], [-387.51, -216.3], [-387.51, -216.3], [-387.51, -216.3], [-383.55, -214.63], [-385.17, -210.88], [-385.17, -210.88], [-385.17, -210.88], [-381.1, -209.07], _
			[-382.78, -205.23], [-382.78, -205.23], [-382.78, -205.23], [-378.86, -203.47], [-380.45, -199.56], [-380.45, -199.56], [-380.45, -199.56], [-376.43, -198.15], [-378.03, -194.2], [-378.03, -194.2], [-378.03, -194.2], _
			[-374.09, -192.76]], [[-383.06, -221.75], [-381.83, -218.72], [-381.83, -218.72], [-381.83, -218.72], [-378.03, -217.18], [-379.65, -213.21], [-379.65, -213.21], [-379.65, -213.21], [-375.73, -211.34], _
			[-377.25, -207.59], [-377.25, -207.59], [-377.25, -207.59], [-373.37, -205.93], [-374.86, -202.18], [-374.86, -202.18], [-374.86, -202.18], [-370.93, -200.52], [-372.59, -196.18], [-372.59, -196.18], _
			[-372.59, -196.18], [-368.61, -194.67]], [[-377.63, -223.45], [-376.49, -221.05], [-376.49, -221.05], [-376.49, -221.05], [-372.41, -219.27], [-373.97, -215.34], [-373.97, -215.34], [-373.97, -215.34], _
			[-369.98, -213.47], [-371.8, -209.63], [-371.8, -209.63], [-371.8, -209.63], [-367.82, -208.14], [-369.35, -204.29], [-369.35, -204.29], [-369.35, -204.29], [-365.48, -202.8], [-367.05, -198.65], [-367.05, -198.65], _
			[-367.05, -198.65], [-363.06, -197.44]], [[-372.17, -226.04], [-370.86, -223.08], [-370.86, -223.08], [-370.86, -223.08], [-366.81, -221.81], [-368.54, -217.89], [-368.54, -217.89], [-368.54, -217.89], _
			[-364.55, -216.07], [-366.18, -212.03], [-366.18, -212.03], [-366.18, -212.03], [-362.39, -210.48], [-363.78, -206.61], [-363.78, -206.61], [-363.78, -206.61], [-359.83, -205.05], [-361.51, -201.22], [-361.51, -201.22], [-361.51, -201.22], [-357.56, -199.62]], _
			[[-366.45, -228.15], [-365.37, -225.55], [-365.37, -225.55], [-365.37, -225.55], [-361.59, -224.01], [-362.92, -219.75], [-362.92, -219.75], [-362.92, -219.75], [-359.09, -218.4], [-360.57, -214.25], [-360.57, -214.25], [-360.57, -214.25], [-356.8, -212.86], [-358.33, -208.98], [-358.33, -208.98], [-358.33, -208.98], [-354.42, -207.44], [-355.96, -203.43], [-355.96, -203.43], [-355.96, -203.43], [-351.81, -201.94]], _
			[[-388.35, -219.15], [-388.35, -219.15], [-387.51, -216.3], [-383.55, -214.63], [-383.55, -214.63], [-383.55, -214.63], [-385.17, -210.88], [-381.1, -209.07], [-381.1, -209.07], [-381.1, -209.07], [-382.78, -205.23], [-378.86, -203.47], [-378.86, -203.47], [-378.86, -203.47], [-380.45, -199.56], [-376.43, -198.15], [-376.43, -198.15], [-376.43, -198.15], [-378.03, -194.2], [-374.09, -192.76], [-374.09, -192.76]], _
			[[-383.06, -221.75], [-383.06, -221.75], [-381.83, -218.72], [-378.03, -217.18], [-378.03, -217.18], [-378.03, -217.18], [-379.65, -213.21], [-375.73, -211.34], [-375.73, -211.34], [-375.73, -211.34], [-377.25, -207.59], [-373.37, -205.93], [-373.37, -205.93], [-373.37, -205.93], [-374.86, -202.18], [-370.93, -200.52], [-370.93, -200.52], [-370.93, -200.52], [-372.59, -196.18], [-368.61, -194.67], [-368.61, -194.67]], _
			[[-377.63, -223.45], [-377.63, -223.45], [-376.49, -221.05], [-372.41, -219.27], [-372.41, -219.27], [-372.41, -219.27], [-373.97, -215.34], [-369.98, -213.47], [-369.98, -213.47], [-369.98, -213.47], [-371.8, -209.63], [-367.82, -208.14], [-367.82, -208.14], [-367.82, -208.14], [-369.35, -204.29], [-365.48, -202.8], [-365.48, -202.8], [-365.48, -202.8], [-367.05, -198.65], [-363.06, -197.44], [-363.06, -197.44]], _
			[[-372.17, -226.04], [-372.17, -226.04], [-370.86, -223.08], [-366.81, -221.81], [-366.81, -221.81], [-366.81, -221.81], [-368.54, -217.89], [-364.55, -216.07], [-364.55, -216.07], [-364.55, -216.07], [-366.18, -212.03], [-362.39, -210.48], [-362.39, -210.48], [-362.39, -210.48], [-363.78, -206.61], [-359.83, -205.05], [-359.83, -205.05], [-359.83, -205.05], [-361.51, -201.22], [-357.56, -199.62], [-357.56, -199.62]], _
			[[-366.45, -228.15], [-366.45, -228.15], [-365.37, -225.55], [-361.59, -224.01], [-361.59, -224.01], [-361.59, -224.01], [-362.92, -219.75], [-359.09, -218.4], [-359.09, -218.4], [-359.09, -218.4], [-360.57, -214.25], [-356.8, -212.86], [-356.8, -212.86], [-356.8, -212.86], [-358.33, -208.98], [-354.42, -207.44], [-354.42, -207.44], [-354.42, -207.44], [-355.96, -203.43], [-351.81, -201.94], [-351.81, -201.94]]]
			$COORDSCOUNT = UBOUND($PLAYERCOORDS, 2)
			SWITCHTO($MAIN)
			SLEEP(250)
			FOR $COORDINATE = 0 TO $COORDSCOUNT - 1
				IF $CANCELCHECKERBOARD THEN EXITLOOP
				$HPMP = GETHPMP()
				IF $HPMP[0] == 0 OR $HPMP[2] == 0 OR MOVEKEY() THEN
					$CANCELCHECKERBOARD = TRUE
					EXITLOOP
				ENDIF
				FOR $I = 0 TO UBOUND($SQUADCLIENTS) - 1
					$INDEX = $SQUADCLIENTS[$I]
					SWITCHTONUM($INDEX)
					IF $CLIENTS[$INDEX][2] == $MAIN THEN
						SQUADLEAVEGLITCHFIX($MEMBERS, 10)
						IF NOT CHECKALLCHARINSIDEINSTANCE(176, $SQUADCLIENTS) THEN
							$CANCELCHECKERBOARD = TRUE
							EXITLOOP
						ENDIF
						$CURRENTNUMOFCLIENTS = GETNEARBYALTS(30)
						IF UBOUND($CURRENTNUMOFCLIENTS) <> 10 THEN
							$CANCELCHECKERBOARD = TRUE
							EXITLOOP
						ENDIF
					ENDIF
					IF $CANCELCHECKERBOARD THEN EXITLOOP
					$HPMP = GETHPMP()
					IF $HPMP[0] == 0 OR $HPMP[2] == 0 OR MOVEKEY() THEN
						$CANCELCHECKERBOARD = TRUE
						EXITLOOP
					ENDIF
					WAITSTOP2(1, -1, 5000)
					IF CLASS() <> 7 THEN SWITCHTOHUMANFORM()
					$X = $PLAYERCOORDS[$I][$COORDINATE][0]
					$Y = $PLAYERCOORDS[$I][$COORDINATE][1]
					IF INSTANCEID() == 176 THEN
						IF DISTANCE2D($X, $Y) > 1 THEN MOVETO2($X, $Y)
					ENDIF
				NEXT
				SLEEP(1000)
				FOR $I = 0 TO UBOUND($SQUADCLIENTS) - 1
					IF $CANCELCHECKERBOARD THEN EXITLOOP
					$INDEX = $SQUADCLIENTS[$I]
					SWITCHTONUM($INDEX)
					$X = $PLAYERCOORDS[$I][$COORDINATE][0]
					$Y = $PLAYERCOORDS[$I][$COORDINATE][1]
					IF INSTANCEID() == 176 THEN
						MOVE5($X, $Y, -1, 0, FALSE, FALSE, 5000, 2, TRUE, 176, 5000)
					ELSE
						SETSTATUS("UPD checkerboard: something went wrong moving to specified position. Exiting.")
						$CANCELCHECKERBOARD = TRUE
						EXITLOOP
					ENDIF
				NEXT
				IF $CANCELCHECKERBOARD THEN EXITLOOP
				IF MOD($COORDINATE, 2) == 0 THEN
					SLEEP(100)
				ELSEIF GETGLOBALSETTING("updCheckerboardSlower") OR $DIEDSOUSINGSLOWERTIMING THEN
					SLEEP(8500)
				ELSE
					SLEEP(7000)
				ENDIF
			NEXT
			IF $CANCELCHECKERBOARD THEN CONTINUELOOP
			SWITCHTO($MAIN)
			MASSMOVETOCOORDENHANCED(-359.36, -187.37, $SQUADCLIENTS, 10, 176)
			SWITCHTO($MAIN)
			SLEEP(250)
			$CLIENTSINDEXES5 = GETNEARBYALTS(5)
			$NUMBEROFCHAR5 = UBOUND($CLIENTSINDEXES5)
			IF DISTANCE2D(-359.36, -187.37) < 5 AND $NUMBEROFCHAR5 == 10 THEN
				$CHECKERBOARDSUCCESS = TRUE
				EXITLOOP
			ENDIF
		WEND
		SWITCHTO($MAIN)
		SETSTATUS("Checkerboard done.")
	ENDFUNC
	FUNC UPDPILLARSTESTER()
		$CLIENTSINDEXES = GETSQUADALTS()
		UPDPILLARS($CLIENTSINDEXES)
	ENDFUNC
	FUNC UPDPILLARS(ByRef $CLIENTSINDEXES)
		SETSTATUS("UPD: Pillars starting.")
		SWITCHTO($MAIN)
		FULLBUFF()
		DESELECTTARGET()
		$MOBS = NPCARRAY()
		DIM $PILLARNAMES[5] = ["Gilded Metal Pillar", "Gigantic Wood Pillar", "Flooding Water Pillar", "Blazing Fire Pillar", "Steady Earth Pillar"]
		FOR $I = 0 TO UBOUND($PILLARNAMES) - 1
			SWITCHTO($MAIN)
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, $PILLARNAMES[$I])
			IF $INDEX <> -1 THEN
				$TARGET = $MOBS[$INDEX][0]
			ENDIF
			IF $TARGET THEN
				SELECTTARGET($TARGET)
				MASSSELECT2()
				MASSMACRO(0, $CLIENTSINDEXES, FALSE, TRUE)
				WHILE NPCALIVE($TARGET, 0)
					MASSMACRO(0, $CLIENTSINDEXES, FALSE, TRUE)
					SLEEP(100)
					$MOBS = NPCARRAY()
				WEND
			ENDIF
		NEXT
		SLEEP(100)
		SETSTATUS("UPD: Pillars done.")
		SWITCHTO($MAIN)
	ENDFUNC
	FUNC UPDPATHKEEPERBAJANTESTER()
		$CLIENTSINDEXES = GETSQUADALTS()
		UPDPATHKEEPERBAJAN($CLIENTSINDEXES)
	ENDFUNC
	FUNC UPDPATHKEEPERBAJAN(ByRef $CLIENTSINDEXES)
		SETSTATUS("UPD: Pathkeeper Bajan starting.")
		SWITCHTO($MAIN)
		IF GETNPCUNIQUEID("Agent of Unity") AND DISTANCE2D(-318.47, -104.03) < 10 THEN
			SWITCHTOHUMANFORM()
			SLEEP(1000)
			IF ISQUESTAVAILABLE(35648) THEN
				SETSTATUS("UPD: got Calligraphy. Boo.")
				RETURN
			ELSEIF ISQUESTAVAILABLE(35643) THEN
				SETSTATUS("UPD: got Painting. Boo.")
				RETURN
			ELSEIF ISQUESTAVAILABLE(35645) THEN
				SETSTATUS("UPD: got Wine already available. Proceeding.")
				RETURN
			ELSEIF ISQUESTAVAILABLE(35646) THEN
				SETSTATUS("UPD: got Music already available. Proceeding.")
				RETURN
			ELSEIF ISQUESTAVAILABLE(35647) THEN
				SETSTATUS("UPD: got Strategy already available. Proceeding.")
				RETURN
			ENDIF
		ELSE
			MASSMOVETOCOORDENHANCED(-353.93, -178.75, $CLIENTSINDEXES, 10, 176)
			MASSSPEEDPATH($CLIENTSINDEXES)
			MASSMOVETOCOORDENHANCED(-318.47, -104.03, $CLIENTSINDEXES, 10, 176)
		ENDIF
		$TARGET = -1
		$MOBS = NPCARRAY()
		$INDEX = FINDCLOSEST($MOBS, "Pathkeeper Bajan")
		IF $INDEX <> -1 THEN
			$TARGET = $MOBS[$INDEX][0]
		ENDIF
		IF $TARGET THEN
			SELECTTARGET($TARGET)
			SLEEP(100)
			MASSSELECT2()
			SLEEP(250)
			MASSSELECT2()
			SLEEP(250)
			MASSSELECT2()
			PREPAREALTSFORNUKE($CLIENTSINDEXES)
			MASSMOVETOCOORDENHANCED(-319.45, -105.63, $CLIENTSINDEXES, 10, 176)
			UPDSINTANKSBOSSAWAYFROMSQUAD($CLIENTSINDEXES, $TARGET, -317.31, -101.63)
			SWITCHTO($MAIN)
			MASSNUKEBOSSTTR("Pathkeeper Bajan",True, True, False, False, 400, True, True, True)
			
		ENDIF
		SLEEP(100)
		MASSRES3($CLIENTSINDEXES, -318.47, -104.03, 10, 176)
		SLEEP(1000)
		SWITCHTO($MAIN)
		$TARGET = 0
		$MOBS = NPCARRAY()
		$INDEX = FINDCLOSEST($MOBS, "Rare Uncharted Treasure")
		SETSTATUS("Looking for chest.")
		IF $INDEX <> -1 THEN
			$TARGET = $MOBS[$INDEX][0]
			IF $TARGET THEN SELECTTARGET($TARGET)
			SLEEP(100)
			MASSSELECT2()
		ELSE
			$LOOKFORCHESTTIMER = TIMERINIT()
			WHILE $INDEX == -1
				SWITCHTO($MAIN)
				$ARRAY = ITEMSARRAY()
				$DROPSCOUNT = UBOUND($ARRAY)
				IF $DROPSCOUNT > 50 THEN
					SETSTATUS("See drops already. Must have killed chest with aoes.")
					EXITLOOP
				ENDIF
				$TARGET = 0
				$MOBS = NPCARRAY()
				$INDEX = FINDCLOSEST($MOBS, "Ultimate Uncharted Treasure")
				SLEEP(100)
				IF TIMERDIFF($LOOKFORCHESTTIMER) > 30000 THEN
					SETSTATUS("Couldn't find chest after 30s of looking. Resuming farming.")
					EXITLOOP
				ENDIF
			WEND
		ENDIF
		SWITCHTO($MAIN)
		SETSTATUS("Selecting chest.")
		MASSRES3($CLIENTSINDEXES, -318.47, -104.03, 10, 176)
		SWITCHTO($MAIN)
		$MOBS = NPCARRAY()
		$INDEX = FINDCLOSEST($MOBS, "Rare Uncharted Treasure")
		IF $INDEX <> -1 THEN
			$TARGET = $MOBS[$INDEX][0]
		ENDIF
		IF $TARGET THEN
			SELECTTARGET($TARGET)
			MASSSELECT2()
			WHILE NPCALIVE($TARGET, 0)
				SELECTTARGET($TARGET)
				MASSAUTOATTACK()
				SLEEP(100)
			WEND
		ENDIF
		SWITCHTO($MAIN)
		IF GETGLOBALSETTING("UsePickupAll") THEN
			MASSPICKUPALL()
		ELSE
			MASSGATHERALL()
		ENDIF
		MASSSWITCHTOHUMANFORM()
		SLEEP(1000)
		SWITCHTO($MAIN)
		SETSTATUS("UPD: Pathkeeper Bajan done.")
	ENDFUNC
	FUNC UPDCLIMBRAMPAFTERPATHKEEPER(ByRef $CLIENTSINDEXES)
		MASSMOVETOCOORDENHANCED(-347.81, -71.06, $CLIENTSINDEXES, 10, 176)
		IF MASSGENIEENERGYCHECK($CLIENTSINDEXES, 75) THEN MASSSPEEDPATH($CLIENTSINDEXES)
		MASSMOVETOCOORDENHANCED(-329.23, -53.39, $CLIENTSINDEXES, 10, 176)
		MASSMOVETOCOORDENHANCED(-292.03, -56.52, $CLIENTSINDEXES, 10, 176)
		MASSMOVETOCOORDENHANCED(-295.3, -60.62, $CLIENTSINDEXES, 10, 176)
	ENDFUNC
	FUNC UPDMIDDLEBOSSTESTER()
		$CLIENTSINDEXES = GETSQUADALTS()
		UPDMIDDLEBOSS($CLIENTSINDEXES)
	ENDFUNC
	FUNC UPDMIDDLEBOSS(ByRef $CLIENTSINDEXES)
		SWITCHTO($MAIN)
		SWITCHTOHUMANFORM()
		SLEEP(1000)
		IF ISQUESTAVAILABLE(35645) THEN
			UPDWINE($CLIENTSINDEXES)
		ELSEIF ISQUESTAVAILABLE(35646) THEN
			UPDMUSIC($CLIENTSINDEXES)
		ELSEIF ISQUESTAVAILABLE(35647) THEN
			UPDSTRATEGY($CLIENTSINDEXES)
		ELSEIF ISQUESTAVAILABLE(35643) THEN
			SETSTATUS("UPD: Got painting. Boo! Suggest using UPD Instance Reset I.")
		ELSEIF ISQUESTAVAILABLE(35648) THEN
			SETSTATUS("UPD: Got calligraphy. Boo! Suggest using UPD Instance Reset I.")
		ENDIF
	ENDFUNC
	FUNC COUNTDEADCHARACTERS(ByRef $CLIENTSINDEXES)
		$COUNT = 0
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($I)
			$HPMP = GETHPMP()
			IF $HPMP[0] == 0 OR $HPMP[2] == 0 THEN
				$COUNT += 1
			ENDIF
		NEXT
		RETURN $COUNT
	ENDFUNC
	FUNC UPDWINETESTER()
		$CLIENTSINDEXES = GETSQUADALTS()
		UPDWINE($CLIENTSINDEXES)
	ENDFUNC
	FUNC UPDWINE(ByRef $CLIENTSINDEXES)
		SETSTATUS("UPD: Wine boss room starting.")
		SWITCHTO($MAIN)
		DIM $WINETRASHMOBNAMES[4] = ["Wine Elemental", "Millet Wine Drunkard", "Frontier Spirit Drunkard", "Southern Brew Drunkard"]
		IF GETNPCUNIQUEID("Agent of Unity") THEN
			UPDCLIMBRAMPAFTERPATHKEEPER($CLIENTSINDEXES)
			TAKECLIENTSQUEST("Agent of Unity", 35645, -292.87, -61.84, $CLIENTSINDEXES, TRUE, 15000)
			SLEEP(26000)
		ENDIF
		SWITCHTO($MAIN)
		SQUADLEAVEGLITCHFIX($CLIENTSINDEXES, 10)
		CHECKALLCHARINSIDEINSTANCE(176, $CLIENTSINDEXES)
		$WINEELEMENTALLOOPCOUNTER = 0
		$TARGET = PLAYERTARGET()
		$MOBS = NPCARRAY()
		$INDEX = FINDCLOSEST($MOBS, "Wine Elemental")
		MASSMOVETOCOORD(332.57, -289.5)
		WHILE $INDEX <> -1
			$NEARBYCHARS = GETNEARBYALTS()
			$TOTALCHARCOUNT = UBOUND($NEARBYCHARS)
			$TOTALDEADCHARCOUNT = COUNTDEADCHARACTERS($NEARBYCHARS)
			IF $TOTALCHARCOUNT == $TOTALDEADCHARCOUNT THEN
				SETSTATUS("UPD Wine: something went super wrong and squad wiped. Initiating recovery sequence.")
				SQUADLEAVEGLITCHFIX($CLIENTSINDEXES, 10)
				CHECKALLCHARINSIDEINSTANCE(176, $CLIENTSINDEXES)
				MASSRESTOTOWN()
				SWITCHTO($MAIN)
				SLEEP(7000)
				CLERICHEAL($CLIENTSINDEXES)
				FULLBUFF()
				UPDMASSNAVIGATETOCOORD($CLIENTSINDEXES, 332.57, -289.5, 9)
			ENDIF
			VENOSWITCHTOFOXFORM()
			SLEEP(200)
			SWITCHTO($MAIN)
			$KILLELEMENTALSTIMER = TIMERINIT()
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Wine Elemental")
			WHILE $INDEX <> -1
				SWITCHTO($MAIN)
				IF TIMERDIFF($KILLELEMENTALSTIMER) > 120000 THEN EXITLOOP
				$TARGET = $MOBS[$INDEX][0]
				IF $TARGET THEN SELECTTARGET($TARGET)
				MASSSELECT2()
				IF $TARGET THEN SELECTTARGET($TARGET)
				MASSSELECT2()
				MASSMACRO(1, $CLIENTSINDEXES, FALSE, TRUE, FALSE, TRUE)
				$MOBS = NPCARRAY()
				$INDEX = FINDCLOSEST($MOBS, "Wine Elemental")
			WEND
		WEND
		VENOSWITCHTOHUMANFORM()
		SLEEP(200)
		SWITCHTO($MAIN)
		FOR $I = 0 TO UBOUND($WINETRASHMOBNAMES) - 1
			$TARGET = PLAYERTARGET()
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, $WINETRASHMOBNAMES[$I])
			WHILE $INDEX <> -1
				$TARGET = PLAYERTARGET()
				IF NOT $TARGET THEN
					$TARGET = $MOBS[$INDEX][0]
				ENDIF
				IF $TARGET THEN SELECTTARGET($TARGET)
				IF $WINETRASHMOBNAMES[$I] == "Wine Elemental" THEN
					MASSMACROUPD(1, $CLIENTSINDEXES, $WINETRASHMOBNAMES, FALSE, TRUE, FALSE, 0, TRUE)
				ELSE
					MASSMACRO(0, $CLIENTSINDEXES, FALSE, TRUE)
				ENDIF
				SLEEP(100)
				$MOBS = NPCARRAY()
				$INDEX = FINDCLOSEST($MOBS, $WINETRASHMOBNAMES[$I])
			WEND
		NEXT
		SLEEP(250)
		MASSMOVETOCOORDENHANCED(283.14, -305.15, $CLIENTSINDEXES, 10, 176)
		SLEEP(250)
		MASSMOVETOCOORDENHANCED(283.14, -305.15, $CLIENTSINDEXES, 10, 176)
		FULLBUFF()
		SWITCHTO($MAIN)
		WHILE NOT ISQUESTAVAILABLE(35649)
			SWITCHTOHUMANFORM()
			SLEEP(1000)
			IF ISQUESTAVAILABLE(35649) THEN EXITLOOP
			$MOBS = NPCARRAY()
			$TARGET = -1
			$FINDBOSSTIMER = TIMERINIT()
			DO
				$INDEX = FINDCLOSEST($MOBS, "Lame Drinker Weist")
				IF $INDEX <> -1 THEN
					$TARGET = $MOBS[$INDEX][0]
				ENDIF
				IF $TARGET THEN SELECTTARGET($TARGET)
				SLEEP(100)
			UNTIL $TARGET <> -1
			MASSSELECT2()
			SLEEP(100)
			MASSSELECT2()
			SLEEP(250)
			MASSSELECT2()
			IF GETGLOBALSETTING("UPDWaitForMysticRezWineBoss") THEN
				IF CHECKFORMYSTIC($CLIENTSINDEXES) AND NOT CHECKFORMYSTICREZ($CLIENTSINDEXES) THEN MYSTICAOEREVIVE($CLIENTSINDEXES)
			ENDIF
			PREPAREALTSFORNUKE($CLIENTSINDEXES)
			SLEEP(1000)
			SWITCHTO($MAIN)
			IF GETGLOBALSETTING("UPDBMDoesNotTripleSpark") THEN
				MASSNUKE(TRUE, FALSE, FALSE, FALSE, 400, TRUE, TRUE, TRUE, TRUE, FALSE, TRUE)
			ELSE
				MASSNUKE(TRUE, FALSE, FALSE, FALSE, 400, TRUE, TRUE, FALSE, FALSE, FALSE, TRUE)
			ENDIF
			SLEEP(1000)
			MASSMACRO(0, $CLIENTSINDEXES, FALSE, TRUE)
			MASSRES3($CLIENTSINDEXES, 283.14, -305.15, 10, 176)
			SLEEP(250)
			SWITCHTO($MAIN)
			IF GETGLOBALSETTING("UsePickupAll") THEN
				MASSPICKUPALL()
			ELSE
				MASSGATHERALL()
			ENDIF
			SLEEP(250)
			MASSRES3($CLIENTSINDEXES, 283.14, -305.15, 10, 176)
			SWITCHTO($MAIN)
			$TARGET = 0
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Epic Uncharted Treasure")
			IF $INDEX <> -1 THEN
				$TARGET = $MOBS[$INDEX][0]
			ENDIF
			IF $TARGET THEN SELECTTARGET($TARGET)
			MASSSELECT2()
			MASSRES3($CLIENTSINDEXES, 283.14, -305.15, 10, 176)
			IF $TARGET THEN
				WHILE NPCALIVE($TARGET, 0)
					SELECTTARGET($TARGET)
					MASSMACRO(0, $CLIENTSINDEXES, FALSE, TRUE)
					SLEEP(100)
				WEND
			ENDIF
			$TARGET = 0
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Ocean Pillar Iron")
			IF $INDEX <> -1 THEN
				$TARGET = $MOBS[$INDEX][0]
			ENDIF
			SELECTTARGET($TARGET)
			MASSSELECT2()
			MASSRES3($CLIENTSINDEXES, 283.14, -305.15, 10, 176)
			IF $TARGET THEN
				WHILE NPCALIVE($TARGET, 0)
					SELECTTARGET($TARGET)
					MASSMACRO(0, $CLIENTSINDEXES, FALSE, TRUE)
					SLEEP(100)
				WEND
			ENDIF
			SLEEP(250)
			$TARGET = 0
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Epic Uncharted Treasure")
			IF $INDEX <> -1 THEN
				$TARGET = $MOBS[$INDEX][0]
			ENDIF
			IF $TARGET THEN SELECTTARGET($TARGET)
			IF $TARGET THEN
				WHILE NPCALIVE($TARGET, 0)
					SELECTTARGET($TARGET)
					MASSMACRO(0, $CLIENTSINDEXES, FALSE, TRUE)
					SLEEP(100)
				WEND
			ENDIF
			MASSRES3($CLIENTSINDEXES, 283.14, -305.15, 10, 176)
			SLEEP(250)
			SWITCHTO($MAIN)
			IF GETGLOBALSETTING("UsePickupAll") THEN
				MASSPICKUPALL()
			ELSE
				MASSGATHERALL()
			ENDIF
			SLEEP(250)
			MASSRES3($CLIENTSINDEXES, 283.14, -305.15, 10, 176)
			SWITCHTO($MAIN)
			SWITCHTOHUMANFORM()
			SLEEP(1000)
			IF ISQUESTAVAILABLE(35649) THEN
				EXITLOOP
			ENDIF
		WEND
		SETSTATUS("UPD: Wine boss done. Porting to Reflection room now.")
		UPDWINETOREFLECTION($CLIENTSINDEXES)
	ENDFUNC
	FUNC UPDWINETOREFLECTION(ByRef $CLIENTSINDEXES)
		MASSMOVETOCOORDENHANCED(286.91, -355.66, $CLIENTSINDEXES, 10, 176)
		MASSSWITCHTOHUMANFORM()
		SLEEP(1000)
		TAKECLIENTSQUEST("Agent of Wine", 35649, 286.91, -355.66, $CLIENTSINDEXES, TRUE, 15000)
		SLEEP(26000)
	ENDFUNC
	FUNC UPDMUSICTESTER()
		$CLIENTSINDEXES = GETSQUADALTS()
		UPDMUSIC($CLIENTSINDEXES)
	ENDFUNC
	FUNC UPDMUSIC($CLIENTSINDEXES)
		SETSTATUS("UPD: Music boss starting.")
		SWITCHTO($MAIN)
		IF GETNPCUNIQUEID("Agent of Unity") THEN
			UPDCLIMBRAMPAFTERPATHKEEPER($CLIENTSINDEXES)
			TAKECLIENTSQUEST("Agent of Unity", 35646, -292.87, -61.84, $CLIENTSINDEXES, TRUE, 15000)
			SLEEP(26000)
		ENDIF
		SWITCHTO($MAIN)
		$TARGET = -1
		$MOBS = NPCARRAY()
		$INDEX = FINDCLOSEST($MOBS, "Unfettered Lady")
		IF $INDEX <> -1 THEN
			$TARGET = $MOBS[$INDEX][0]
		ENDIF
		$TIMER = TIMERINIT()
		WHILE $INDEX == -1
			IF TIMERDIFF($TIMER) > 20000 THEN EXITLOOP
			SLEEP(1000)
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Unfettered Lady")
			IF $INDEX <> -1 THEN
				$TARGET = $MOBS[$INDEX][0]
			ENDIF
		WEND
		IF $TARGET THEN SELECTTARGET($TARGET)
		MASSSPEEDPATH($CLIENTSINDEXES)
		MASSMOVETOCOORDENHANCED(135.54, 361.59, $CLIENTSINDEXES, 10, 176)
		FULLBUFF()
		SLEEP(100)
		MASSMOVETOCOORDENHANCED(135.54, 361.59, $CLIENTSINDEXES, 10, 176)
		SLEEP(100)
		SWITCHTO($MAIN)
		WHILE NOT ISQUESTAVAILABLE(35649)
			MASSSELECT2()
			SLEEP(100)
			MASSSELECT2()
			SLEEP(250)
			MASSSELECT2()
			IF GETGLOBALSETTING("UPDWaitForMysticRezMusicBoss") THEN
				IF CHECKFORMYSTIC($CLIENTSINDEXES) AND NOT CHECKFORMYSTICREZ($CLIENTSINDEXES) THEN MYSTICAOEREVIVE($CLIENTSINDEXES)
			ENDIF
			IF GETGLOBALSETTING("UPDKeepSbUltiForMusicBoss") THEN
				SBULTI($CLIENTSINDEXES, TRUE, FALSE, $TARGET)
			ENDIF
			PREPAREALTSFORNUKE($CLIENTSINDEXES)
			CLERICSOG($CLIENTSINDEXES)
			IF GETGLOBALSETTING("UPDKeepSbUltiForMusicBoss") THEN
				SBULTI($CLIENTSINDEXES, FALSE, TRUE, $TARGET)
			ENDIF
			SWITCHTO($MAIN)
			IF GETGLOBALSETTING("UPDSparkTiming") THEN
				SETSTATUS("Sparking later for better timings on fast computers.")
				SLEEP(5900)
			ELSE
				SETSTATUS("Sparking earlier for better timing on laggy computers.")
				SLEEP(4500)
			ENDIF
			IF GETGLOBALSETTING("UPDBMDoesNotTripleSpark") THEN
				MASSNUKE(TRUE, FALSE, FALSE, FALSE, 400, TRUE, TRUE, TRUE, TRUE, FALSE, TRUE)
			ELSE
				MASSNUKE(TRUE, FALSE, FALSE, FALSE, 400, TRUE, TRUE, FALSE, FALSE, FALSE, TRUE)
			ENDIF
			SLEEP(1000)
			SWITCHTO($MAIN)
			$TARGET = PLAYERTARGET()
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Epic Uncharted Treasure")
			IF $INDEX <> -1 THEN
				$TARGET = $MOBS[$INDEX][0]
			ENDIF
			IF $TARGET THEN SELECTTARGET($TARGET)
			WHILE NPCALIVE($TARGET, 0)
				SELECTTARGET($TARGET)
				MASSAUTOATTACK()
				SLEEP(100)
			WEND
			SWITCHTO($MAIN)
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Ocean Pillar Iron")
			IF $INDEX <> -1 THEN
				$TARGET = $MOBS[$INDEX][0]
			ENDIF
			IF $TARGET THEN SELECTTARGET($TARGET)
			MASSSELECT2()
			WHILE NPCALIVE($TARGET, 0)
				SELECTTARGET($TARGET)
				MASSAUTOATTACK()
				SLEEP(100)
			WEND
			SLEEP(250)
			SWITCHTO($MAIN)
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Epic Uncharted Treasure")
			IF $INDEX <> -1 THEN
				$TARGET = $MOBS[$INDEX][0]
			ENDIF
			IF $TARGET THEN SELECTTARGET($TARGET)
			WHILE NPCALIVE($TARGET, 0)
				SELECTTARGET($TARGET)
				MASSAUTOATTACK()
				SLEEP(100)
			WEND
			SLEEP(250)
			SWITCHTO($MAIN)
			IF GETGLOBALSETTING("UsePickupAll") THEN
				MASSPICKUPALL()
			ELSE
				MASSGATHERALL()
			ENDIF
			MASSSWITCHTOHUMANFORM()
			SLEEP(1000)
		WEND
		SWITCHTO($MAIN)
		SETSTATUS("UPD: Music boss done. Porting to Reflection room now.")
		UPDMUSICTOREFLECTION($CLIENTSINDEXES)
	ENDFUNC
	FUNC UPDMUSICTOREFLECTION($CLIENTSINDEXES)
		MASSSWITCHTOHUMANFORM()
		SLEEP(1000)
		MASSSPEEDPATH($CLIENTSINDEXES)
		MASSMOVETOCOORDENHANCED(117.38, 406.68, $CLIENTSINDEXES, 10, 176)
		TAKECLIENTSQUEST("Agent of Music", 35649, 117.15, 407.42, $CLIENTSINDEXES, TRUE, 15000)
		SLEEP(26000)
	ENDFUNC
	FUNC UPDSTRATEGYTESTER()
		$CLIENTSINDEXES = GETSQUADALTS()
		UPDSTRATEGY($CLIENTSINDEXES)
	ENDFUNC
	FUNC UPDSTRATEGY($CLIENTSINDEXES)
		SWITCHTO($MAIN)
		SETSTATUS("UPD: Strategy boss starting.")
		IF GETNPCUNIQUEID("Agent of Unity") THEN
			UPDCLIMBRAMPAFTERPATHKEEPER($CLIENTSINDEXES)
			TAKECLIENTSQUEST("Agent of Unity", 35647, -292.87, -61.84, $CLIENTSINDEXES, TRUE, 15000)
			SLEEP(26000)
		ENDIF
		SWITCHTO($MAIN)
		WHILE NOT ISQUESTAVAILABLE(35649)
			$TARGET = -1
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Dark Commander")
			IF $INDEX <> -1 THEN
				$TARGET = $MOBS[$INDEX][0]
			ENDIF
			$LOOKFORBOSSTIMER = TIMERINIT()
			WHILE $INDEX == -1
				IF TIMERDIFF($LOOKFORBOSSTIMER) > 15000 THEN EXITLOOP
				SLEEP(1000)
				$MOBS = NPCARRAY()
				$INDEX = FINDCLOSEST($MOBS, "Dark Commander")
				IF $INDEX <> -1 THEN
					$TARGET = $MOBS[$INDEX][0]
				ENDIF
			WEND
			IF $TARGET THEN SELECTTARGET($TARGET)
			MASSSELECT2()
			MASSSPEEDPATH($CLIENTSINDEXES)
			MASSMOVETOCOORDENHANCED(-51.38, -331.41, $CLIENTSINDEXES, 10, 176)
			FULLBUFF()
			SLEEP(100)
			MASSMOVETOCOORDENHANCED(-51.38, -331.41, $CLIENTSINDEXES, 10, 176)
			SLEEP(100)
			SWITCHTO($MAIN)
			MASSSELECT2()
			SLEEP(250)
			MASSSELECT2()
			SLEEP(250)
			MASSSELECT2()
			IF GETGLOBALSETTING("UPDWaitForMysticRezStrategyBoss") THEN
				IF CHECKFORMYSTIC($CLIENTSINDEXES) AND NOT CHECKFORMYSTICREZ($CLIENTSINDEXES) THEN MYSTICAOEREVIVE($CLIENTSINDEXES)
			ENDIF
			IF GETGLOBALSETTING("UPDKeepSbUltiForStrategyBoss") THEN
				SBULTI($CLIENTSINDEXES, TRUE, FALSE, $TARGET)
			ENDIF
			PREPAREALTSFORNUKE($CLIENTSINDEXES)
			
			MASSNUKEBOSSTTR("Dark Commander",True, True, False, False, 400, True, True, True)
			SLEEP(1000)
			MASSRES3($CLIENTSINDEXES, -51.38, -331.41, 10, 176)
			SWITCHTO($MAIN)
			$TARGET = PLAYERTARGET()
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Epic Uncharted Treasure")
			IF $INDEX <> -1 THEN
				$TARGET = $MOBS[$INDEX][0]
			ENDIF
			IF $TARGET THEN SELECTTARGET($TARGET)
			WHILE NPCALIVE($TARGET, 0)
				SELECTTARGET($TARGET)
				MASSAUTOATTACK()
				SLEEP(100)
			WEND
			SWITCHTO($MAIN)
			SLEEP(250)
			IF GETGLOBALSETTING("UsePickupAll") THEN
				MASSPICKUPALL()
			ELSE
				MASSGATHERALL()
			ENDIF
			SWITCHTO($MAIN)
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Ocean Pillar Iron")
			IF $INDEX <> -1 THEN
				$TARGET = $MOBS[$INDEX][0]
			ENDIF
			IF $TARGET THEN SELECTTARGET($TARGET)
			MASSSELECT2()
			WHILE NPCALIVE($TARGET, 0)
				SELECTTARGET($TARGET)
				MASSAUTOATTACK()
				SLEEP(100)
			WEND
			SLEEP(250)
			SWITCHTO($MAIN)
			MASSRES3($CLIENTSINDEXES, -51.38, -331.41, 10, 176)
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Epic Uncharted Treasure")
			IF $INDEX <> -1 THEN
				$TARGET = $MOBS[$INDEX][0]
			ENDIF
			IF $TARGET THEN SELECTTARGET($TARGET)
			MASSSELECT2()
			WHILE NPCALIVE($TARGET, 0)
				SELECTTARGET($TARGET)
				MASSAUTOATTACK()
				SLEEP(100)
			WEND
			SWITCHTO($MAIN)
			SLEEP(250)
			IF GETGLOBALSETTING("UsePickupAll") THEN
				MASSPICKUPALL()
			ELSE
				MASSGATHERALL()
			ENDIF
			MASSSWITCHTOHUMANFORM()
			SLEEP(1000)
		WEND
		SWITCHTO($MAIN)
		SETSTATUS("UPD: Strategy boss done. Porting to Reflection room now.")
		UPDSTRATEGYTOREFLECTION($CLIENTSINDEXES)
	ENDFUNC
	FUNC UPDSTRATEGYTOREFLECTION($CLIENTSINDEXES)
		MASSSWITCHTOHUMANFORM()
		SLEEP(1000)
		MASSSPEEDPATH($CLIENTSINDEXES)
		MASSMOVETOCOORDENHANCED(-83.29, -334.49, $CLIENTSINDEXES, 10, 176)
		TAKECLIENTSQUEST("Agent of Strategy", 35649, -83.29, -334.49, $CLIENTSINDEXES, TRUE, 15000)
		SLEEP(26000)
	ENDFUNC
	FUNC MASSNOTINCOMBAT($CLIENTSINDEXES)
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF INCOMBAT() THEN
				RETURN FALSE
			ENDIF
		NEXT
		SWITCHTO($MAIN)
		RETURN TRUE
	ENDFUNC
	FUNC FINDINDEXOFANYMOBALIVEFROMLIST($MOBLIST)
		$INDEX = -1
		$TEMPINDEX = -1
		$MOBS = NPCARRAY()
		FOR $I = 0 TO UBOUND($MOBLIST) - 1
			$TEMPINDEX = FINDCLOSEST($MOBS, $MOBLIST[$I])
			IF $TEMPINDEX <> -1 THEN
				$INDEX = $TEMPINDEX
				EXITLOOP
			ENDIF
		NEXT
		RETURN $INDEX
	ENDFUNC
	FUNC COUNTNUMBEROFREFLECTIONMOBSSPAWNED()
		$COUNT = 0
		FOR $I = 100962 TO 100973
			IF INSTANCEVALUE($I) > 0 AND INSTANCEVALUE($I) < 14 THEN
				$COUNT += INSTANCEVALUE($I)
			ENDIF
		NEXT
		RETURN $COUNT
	ENDFUNC
	FUNC CLERICUSEULTI($CLIENTSINDEXES)
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF CLASS() == 7 THEN
				CASTSKILL(3240)
			ENDIF
		NEXT
		SWITCHTO($MAIN)
	ENDFUNC
	FUNC CLERICUSEANTISTUNANDBB($CLIENTSINDEXES)
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF CLASS() == 7 THEN
				USEITEMID(55067)
				CASTSKILL(2223)
			ENDIF
		NEXT
		SWITCHTO($MAIN)
	ENDFUNC
	FUNC UPDREFLECTIONMOBSTESTER()
		$CLIENTSINDEXES = GETSQUADALTS()
		UPDREFLECTIONMOBS($CLIENTSINDEXES)
		UPDREFLECTIONMOBS2($CLIENTSINDEXES)
	ENDFUNC
	DIM $REFLECTIONMOBIDS[12] = [48767, 48768, 48769, 48770, 48771, 48772, 48773, 48774, 48775, 48776, 48777, 48778]
	DIM $REFLECTIONMOBNAMES[12] = ["Blademaster's Nightmare", "Wizard's Nightmare", "Psychic's Nightmare", "Venomancer's Nightmare", "Barbarian's Nightmare", "Assassin's Nightmare", "Archer's Nightmare", "Winged Elf's Nightmare", "Seeker's Nightmare", "Mystic's Nightmare", "Duskblade's Nightmare", "Stormbringer's Nightmare"]
	$UPDREFLECTIONQUESTAVAILABLE = TRUE
	FUNC UPDREFLECTIONMOBS($CLIENTSINDEXES)
		SWITCHTO($MAIN)
		IF GETNPCUNIQUEID("Agent of Strategy") THEN
			UPDSTRATEGYTOREFLECTION($CLIENTSINDEXES)
		ELSEIF GETNPCUNIQUEID("Agent of Music") THEN
			UPDMUSICTOREFLECTION($CLIENTSINDEXES)
		ELSEIF GETNPCUNIQUEID("Agent of Wine") THEN
			UPDWINETOREFLECTION($CLIENTSINDEXES)
		ELSEIF GETNPCUNIQUEID("Agent of Unity") THEN
			SWITCHTOHUMANFORM()
			SLEEP(1000)
			IF ISQUESTAVAILABLE(35648) THEN
				SETSTATUS("UPD: got Calligraphy. Boo. Not doing Reflection mobs.")
				RETURN
			ELSEIF ISQUESTAVAILABLE(35643) THEN
				SETSTATUS("UPD: got Painting. Boo. Not doing Reflection mobs.")
				RETURN
			ENDIF
		ENDIF
		SETSTATUS("UPD: Reflection mobs starting.")
		SWITCHTO($MAIN)
		MASSMOVETOCOORDENHANCED(-137.62, 327.55, $CLIENTSINDEXES, 10, 176)
		$TIMER = TIMERINIT()
		$REFLECTIONQUESTOBTAINED = FALSE
		$PASSCONDITIONCLEARED = FALSE
		$OVERALLREFLECTIONTIMER = TIMERINIT()
		$LOOPCOUNTER = 0
		WHILE NOT $PASSCONDITIONCLEARED
			$LOOPCOUNTER += 1
			SETSTATUS("Reflection mobs: loop " & $LOOPCOUNTER)
			SWITCHTO($MAIN)
			MASSRES3($CLIENTSINDEXES, -137.62, 327.55, 10, 176)
			SWITCHTO($MAIN)
			$MOBS = NPCARRAY()
			$INDEX = FINDINDEXOFANYMOBALIVEFROMLIST($REFLECTIONMOBNAMES)
			WHILE $INDEX <> -1
				$TARGET = $MOBS[$INDEX][0]
				SELECTTARGET($TARGET)
				SLEEP(100)
				MASSSELECT2()
				MASSMACRO(1, $CLIENTSINDEXES, FALSE, TRUE)
				SLEEP(100)
				$INDEX = FINDINDEXOFANYMOBALIVEFROMLIST($REFLECTIONMOBNAMES)
			WEND
			$COUNTOFMOBSSPAWNED = COUNTNUMBEROFREFLECTIONMOBSSPAWNED()
			VENOSWITCHTOHUMANFORM()
			SLEEP(200)
			SWITCHTO($MAIN)
			MASSMOVETOCOORDENHANCED(-137.62, 327.55, $CLIENTSINDEXES, 10, 176)
			DESELECTTARGET()
			FULLBUFF()
			DESELECTTARGET()
			MYSTICSALVATIONPET($CLIENTSINDEXES)
			PREPAREALTSFORNUKE($CLIENTSINDEXES, FALSE, TRUE)
			SWITCHTO($MAIN)
			$TAKEQUESTTIMER = TIMERINIT()
			$FIGHTTIMER = TIMERINIT()
			$CANCELBBTIMER = TIMERINIT()
			$UPDREFLECTIONQUESTAVAILABLE = TRUE
			IF NOT HASQUEST(36507) THEN
				IF ISQUESTAVAILABLE(34952) THEN
					SETSTATUS("Quest is available to take.")
					TAKEQUEST("Guardian of Reflection", 34952, -137.7, 327.75)
					$REFLECTIONQUESTOBTAINED = FALSE
					$PASSCONDITIONCLEARED = FALSE
					$FIGHTTIMER = TIMERINIT()
				ELSE
					WHILE NOT ISQUESTAVAILABLE(34952)
						IF TIMERDIFF($TAKEQUESTTIMER) > 10000 THEN
							$PASSCONDITIONCLEARED = TRUE
							SETSTATUS("Quest still not available after 10s. We probably finished. Exiting.")
							$UPDREFLECTIONQUESTAVAILABLE = FALSE
							RETURN TRUE
						ENDIF
					WEND
				ENDIF
				IF ISQUESTAVAILABLE(34952) THEN
					SETSTATUS("Quest is available to take.")
					TAKEQUEST("Guardian of Reflection", 34952, -137.7, 327.75)
					SLEEP(100)
					$FIGHTTIMER = TIMERINIT()
				ENDIF
			ENDIF
			IF $UPDREFLECTIONQUESTAVAILABLE == FALSE THEN RETURN
			IF NOT $UPDREFLECTIONQUESTAVAILABLE THEN RETURN
			IF $PASSCONDITIONCLEARED AND FINDINDEXOFANYMOBALIVEFROMLIST($REFLECTIONMOBNAMES) == -1 THEN EXITLOOP
			IF GETGLOBALSETTING("UPDClericUsesBB") THEN
				IF GETGLOBALSETTING("UPDBMDoesNotTripleSpark") THEN
					SETSTATUS("Cleric and bm don't spark.")
					MASSTRIPLESPARKWITHOUTCLERICANDBM()
				ELSE
					SETSTATUS("Cleric doesn't spark.")
					MASSTRIPLESPARKWITHOUTCLERIC()
				ENDIF
			ELSE
				IF GETGLOBALSETTING("UPDBMDoesNotTripleSpark") THEN
					SETSTATUS("Bm doesn't spark.")
					MASSTRIPLESPARKWITHOUTBM()
				ELSE
					SETSTATUS("All spark")
					MASSTRIPLESPARK()
				ENDIF
			ENDIF
			$KILLMOBSTIMER = TIMERINIT()
			SWITCHTO($MAIN)
			DESELECTTARGET()
			SLEEP(50)
			DESELECTTARGET()
			SWITCHTO($MAIN)
			WHILE HASQUEST(34952)
				SLEEP(50)
			WEND
			IF GETGLOBALSETTING("UPDClericUsesBB") THEN CLERICUSEANTISTUNANDBB($CLIENTSINDEXES)
			SWITCHTO($MAIN)
			IF HASQUEST(36507) THEN
				$REFLECTIONQUESTOBTAINED = TRUE
			ENDIF
			IF $REFLECTIONQUESTOBTAINED THEN
				IF NOT HASQUEST(36507) THEN
					$PASSCONDITIONCLEARED = TRUE
				ENDIF
			ENDIF
			FOR $K = 1 TO 3
				SWITCHTO($MAIN)
				IF HASQUEST(36507) THEN
					$REFLECTIONQUESTOBTAINED = TRUE
				ENDIF
				IF $REFLECTIONQUESTOBTAINED THEN
					IF NOT HASQUEST(36507) THEN
						$PASSCONDITIONCLEARED = TRUE
					ENDIF
				ENDIF
				IF PLAYERTARGET() == 48833 THEN DESELECTTARGET()
				IF TIMERDIFF($KILLMOBSTIMER) > 5500 THEN
					MASSABSOLUTEDOMAIN($CLIENTSINDEXES)
				ENDIF
				IF TIMERDIFF($KILLMOBSTIMER) > 13000 AND GETGLOBALSETTING("UPDUseImmuneApothAtReflectionMobs") THEN
					MASSIMMUNEAPOTH($CLIENTSINDEXES)
				ENDIF
				$COUNTOFMOBSSPAWNED = COUNTNUMBEROFREFLECTIONMOBSSPAWNED()
				SETSTATUS(COUNTNUMBEROFREFLECTIONMOBSSPAWNED() & " mobs spawned total.")
				IF $PASSCONDITIONCLEARED AND NOT FINDINDEXOFANYMOBALIVEFROMLIST($REFLECTIONMOBNAMES) AND TIMERDIFF($FIGHTTIMER) > 25000 THEN
					CANCELCLERICBB($CLIENTSINDEXES)
					DESELECTTARGET()
					SLEEP(100)
					CONTINUELOOP
				ENDIF
				FOR $I = 0 TO UBOUND($REFLECTIONMOBNAMES) - 1
					IF TIMERDIFF($CANCELBBTIMER) > 30000 THEN CANCELCLERICBB($CLIENTSINDEXES)
					SWITCHTO($MAIN)
					$MOBS = NPCARRAY()
					$TARGET = PLAYERTARGET()
					$VALIDTARGET = 0
					FOR $J = 0 TO UBOUND($REFLECTIONMOBIDS) - 1
						IF $TARGET == $REFLECTIONMOBIDS[$J] THEN
							$VALIDTARGET = $TARGET
						ENDIF
					NEXT
					IF $VALIDTARGET == 0 THEN
						DESELECTTARGET()
						$INDEX = FINDCLOSEST($MOBS, $REFLECTIONMOBNAMES[$I])
						IF $INDEX <> -1 THEN
							$VALIDTARGET = $MOBS[$INDEX][0]
							SELECTTARGET($VALIDTARGET)
							MASSSELECT2()
						ENDIF
					ENDIF
					IF $VALIDTARGET == 0 THEN
						CONTINUELOOP
					ELSE
						SELECTTARGET($VALIDTARGET)
						MASSSELECT2()
					ENDIF
					IF GETGLOBALSETTING("UPDClericUsesBB") THEN
						MASSMACROUPD(1, $CLIENTSINDEXES, $REFLECTIONMOBNAMES, FALSE, TRUE, TRUE, 5000)
					ELSE
						MASSMACROUPD(1, $CLIENTSINDEXES, $REFLECTIONMOBNAMES, FALSE, TRUE, FALSE, 5000)
					ENDIF
					IF PLAYERTARGET() == 48833 THEN
						DESELECTTARGET()
						CONTINUELOOP
					ENDIF
					IF TIMERDIFF($KILLMOBSTIMER) > 5500 THEN
						MASSABSOLUTEDOMAIN($CLIENTSINDEXES)
					ENDIF
					IF TIMERDIFF($KILLMOBSTIMER) > 13000 AND GETGLOBALSETTING("UPDUseImmuneApothAtReflectionMobs") THEN
						MASSIMMUNEAPOTH($CLIENTSINDEXES)
					ENDIF
					$ITERATION = 0
					SWITCHTO($MAIN)
					$DMGTIMER = TIMERINIT()
					WHILE NPCALIVE($VALIDTARGET, 0)
						IF PLAYERTARGET() == 48833 THEN
							DESELECTTARGET()
							EXITLOOP
						ENDIF
						IF HASQUEST(36507) THEN
							$REFLECTIONQUESTOBTAINED = TRUE
						ENDIF
						IF $REFLECTIONQUESTOBTAINED THEN
							IF NOT HASQUEST(36507) THEN
								$PASSCONDITIONCLEARED = TRUE
							ENDIF
						ENDIF
						IF TIMERDIFF($DMGTIMER) > 10000 THEN EXITLOOP
						IF $VALIDTARGET == 48833 THEN
							DESELECTTARGET()
							EXITLOOP
						ENDIF
						MASSSELECT2()
						MASSMACROUPD(1, $CLIENTSINDEXES, $REFLECTIONMOBNAMES, FALSE, TRUE, FALSE, 5000)
						IF TIMERDIFF($KILLMOBSTIMER) > 5500 THEN
							MASSABSOLUTEDOMAIN($CLIENTSINDEXES)
						ENDIF
						IF TIMERDIFF($KILLMOBSTIMER) > 13000 AND GETGLOBALSETTING("UPDUseImmuneApothAtReflectionMobs") THEN
							MASSIMMUNEAPOTH($CLIENTSINDEXES)
						ENDIF
						$ITERATION += 1
						SLEEP(100)
					WEND
					SLEEP(100)
				NEXT
				SLEEP(100)
			NEXT
			SLEEP(1000)
		WEND
	ENDFUNC
	FUNC UPDREFLECTIONMOBS2($CLIENTSINDEXES)
		SWITCHTO($MAIN)
		IF MASSCHECKDBDEBUFF($CLIENTSINDEXES) THEN
			SETSTATUS("See db debuff. Waiting to see if any characters die.")
			SLEEP(8000)
		ENDIF
		IF MASSRES3($CLIENTSINDEXES, -137.62, 327.55, 10, 176) THEN
			MASSMOVETOCOORDENHANCED(-137.62, 327.55, $CLIENTSINDEXES, 10, 176)
			FULLBUFF()
		ELSEIF $UPDREFLECTIONQUESTAVAILABLE THEN
			MASSMOVETOCOORDENHANCED(-137.62, 327.55, $CLIENTSINDEXES, 10, 176)
			FULLBUFF()
		ENDIF
		SWITCHTO($MAIN)
		SETSTATUS("UPD: Reflection mobs done.")
	ENDFUNC
	FUNC MASSCHECKDBDEBUFF($CLIENTSINDEXES)
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF HASBUFF(277) THEN
				RETURN TRUE
			ENDIF
		NEXT
		SWITCHTO($MAIN)
		RETURN FALSE
	ENDFUNC
	FUNC UPDLASTBOSSTESTER()
		$CLIENTSINDEXES = GETSQUADALTS()
		UPDLASTBOSS($CLIENTSINDEXES)
	ENDFUNC
	FUNC UPDLASTBOSS($CLIENTSINDEXES)
		SWITCHTO($MAIN)
		IF GETNPCUNIQUEID("Agent of Unity") THEN
			DO
				SWITCHTOHUMANFORM()
				SLEEP(100)
			UNTIL INHUMANFORM()
			SLEEP(1000)
			IF ISQUESTAVAILABLE(35648) THEN
				SETSTATUS("UPD: got Calligraphy. Boo. Not doing Last boss.")
				RETURN
			ELSEIF ISQUESTAVAILABLE(35643) THEN
				SETSTATUS("UPD: got Painting. Boo. Not doing Last boss.")
				RETURN
			ENDIF
		ENDIF
		WHILE FINDINDEXOFANYMOBALIVEFROMLIST($REFLECTIONMOBNAMES) <> -1
			$INDEX = FINDINDEXOFANYMOBALIVEFROMLIST($REFLECTIONMOBNAMES)
			$MOBS = NPCARRAY()
			$TARGET = PLAYERTARGET()
			$VALIDTARGET = 0
			IF $INDEX == -1 THEN
				EXITLOOP
			ELSE
				$VALIDTARGET = $MOBS[$INDEX][0]
			ENDIF
			SELECTTARGET($VALIDTARGET)
			MASSSELECT2()
			IF $VALIDTARGET == 0 THEN
				SLEEP(50)
				CONTINUELOOP
			ELSE
				SELECTTARGET($VALIDTARGET)
				MASSSELECT2()
			ENDIF
			IF GETGLOBALSETTING("UPDClericUsesBB") THEN
				MASSMACROUPD(1, $CLIENTSINDEXES, $REFLECTIONMOBNAMES, FALSE, TRUE, TRUE, 4000)
			ELSE
				MASSMACROUPD(1, $CLIENTSINDEXES, $REFLECTIONMOBNAMES, FALSE, TRUE, FALSE, 4000)
			ENDIF
			SLEEP(100)
		WEND
		IF MASSCHECKDBDEBUFF($CLIENTSINDEXES) THEN
			SETSTATUS("See db debuff. Waiting to see if any characters die.")
			SLEEP(8000)
		ENDIF
		IF MASSRES3($CLIENTSINDEXES, -137.62, 327.55, 10, 176) THEN
			MASSMOVETOCOORDENHANCED(-137.62, 327.55, $CLIENTSINDEXES, 10, 176)
			FULLBUFF()
		ENDIF
		SETSTATUS("UPD: Lord of Paradise starting.")
		$LASTBOSSTARGET = 0
		$TARGET = -1
		$MOBS = NPCARRAY()
		$INDEX = FINDCLOSEST($MOBS, "Lord of Paradise")
		IF $INDEX <> -1 THEN
			MASSMOVETOCOORDENHANCED(-308.22, 328.74, $CLIENTSINDEXES, 10, 176)
		ELSE
			IF MASSGENIEENERGYCHECK($CLIENTSINDEXES, 75) THEN MASSSPEEDPATH($CLIENTSINDEXES)
			MASSMOVETOCOORDENHANCED(-173.27, 327.26, $CLIENTSINDEXES, 10, 176)
			MASSMOVETOCOORDENHANCED(-200.66, 325.07, $CLIENTSINDEXES, 10, 176)
			MASSJUMPTOCOORD(-221.98, 324.49, 500, 2, 100, 250, TRUE, TRUE, 5)
			SLEEP(500)
			IF MASSGENIEENERGYCHECK($CLIENTSINDEXES, 75) THEN MASSSPEEDPATH($CLIENTSINDEXES)
			MASSMOVETOCOORDENHANCED(-308.22, 328.74, $CLIENTSINDEXES, 10, 176)
		ENDIF
		SLEEP(1000)
		SLEEP(100)
		SWITCHTO($MAIN)
		IF GETGLOBALSETTING("updlastbossbuildextrachi") THEN
			MASSBUILDCHI2($CLIENTSINDEXES, 1000)
			MASSBUILDCHI2($CLIENTSINDEXES, 1000)
			MASSBUILDCHI2($CLIENTSINDEXES, 1000)
			MASSBUILDCHI2($CLIENTSINDEXES, 1000)
			MASSBUILDCHI2($CLIENTSINDEXES, 1000)
			MASSBUILDCHI2($CLIENTSINDEXES, 1000)
			SETSTATUS("Done building chi.")
		ENDIF
		$LASTBOSSLOOPCOUNTER = 0
		SWITCHTO($MAIN)
		$MOBS = NPCARRAY()
		$INDEX = FINDCLOSEST($MOBS, "Lord of Paradise")
		$LASTBOSSTIMELIMIT = TIMERINIT()
		WHILE $INDEX <> -1
			SWITCHTO($MAIN)
			SQUADLEAVEGLITCHFIX($CLIENTSINDEXES, 10)
			CHECKALLCHARINSIDEINSTANCE(176, $CLIENTSINDEXES)
			$NEARBYCHARS = GETNEARBYALTS()
			$TOTALCHARCOUNT = UBOUND($NEARBYCHARS)
			$TOTALDEADCHARCOUNT = COUNTDEADCHARACTERS($NEARBYCHARS)
			SETSTATUS($TOTALDEADCHARCOUNT & " dead characters.")
			IF $TOTALDEADCHARCOUNT > 8 THEN
				SWITCHTO($MAIN)
				SETSTATUS("UPD Last Boss: something went super wrong and squad wiped. Initiating recovery sequence.")
				SQUADLEAVEGLITCHFIX($CLIENTSINDEXES, 10)
				CHECKALLCHARINSIDEINSTANCE(176, $CLIENTSINDEXES)
				MASSRESTOTOWN()
				SWITCHTO($MAIN)
				SLEEP(7000)
				CLERICHEAL($CLIENTSINDEXES)
				FULLBUFF()
				UPDMASSNAVIGATETOCOORD($CLIENTSINDEXES, -308.22, 328.74, 19)
				FULLBUFF()
			ENDIF
			SWITCHTO($MAIN)
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Lord of Paradise")
			$TARGET = $MOBS[$INDEX][0]
			IF $TARGET THEN
				SELECTTARGET($TARGET)
				MASSSELECT2()
			ENDIF
			SLEEP(500)
			SWITCHTO($MAIN)
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Lord of Paradise")
			$TARGET = $MOBS[$INDEX][0]
			IF $TARGET THEN
				SELECTTARGET($TARGET)
				MASSSELECT2()
			ENDIF
			$KILLLASTBOSSTIMER = TIMERINIT()
			WHILE $INDEX <> -1
				SWITCHTO($MAIN)
				$NEARBYCHARS = GETNEARBYALTS()
				$TOTALCHARCOUNT = UBOUND($NEARBYCHARS)
				$TOTALDEADCHARCOUNT = COUNTDEADCHARACTERS($NEARBYCHARS)
				IF $TOTALDEADCHARCOUNT > 8 THEN
					SETSTATUS("Something went wrong and squad may have wiped!")
					EXITLOOP
				ENDIF
				IF TIMERDIFF($KILLLASTBOSSTIMER) > 60000 THEN
					SETSTATUS("UPD last boss: 60s passed and boss still alive. Something perhaps wrong. Exiting.")
					EXITLOOP
				ENDIF
				SWITCHTO($MAIN)
				$TARGET = $MOBS[$INDEX][0]
				IF $TARGET THEN SELECTTARGET($TARGET)
				MASSSELECT2()
				SWITCHTO($MAIN)
				IF $TARGET THEN SELECTTARGET($TARGET)
				MASSSELECT2()
				SWITCHTO($MAIN)
				IF CHECKFORCLERIC($CLIENTSINDEXES) THEN
					IF GETGLOBALSETTING("UPDWaitForMysticRezLastBoss") THEN
						IF CHECKFORMYSTIC($CLIENTSINDEXES) AND NOT CHECKFORMYSTICREZ($CLIENTSINDEXES) THEN MYSTICAOEREVIVE($CLIENTSINDEXES)
					ENDIF
					IF GETGLOBALSETTING("UPDKeepSbUltiForLastBoss") THEN
						SBULTI($CLIENTSINDEXES, TRUE, FALSE, $TARGET)
					ENDIF
					PREPAREALTSFORNUKE($CLIENTSINDEXES)
					SLEEP(4000)
					CLERICSOG($CLIENTSINDEXES, TRUE, FALSE)
					CLERICAUTOATTACK($CLIENTSINDEXES)
					SLEEP(1500)
					CLERICSOG($CLIENTSINDEXES, TRUE, TRUE)
					IF GETGLOBALSETTING("UPDKeepSbUltiForLastBoss") THEN
						SBULTI($CLIENTSINDEXES, FALSE, TRUE, $TARGET)
						SWITCHTO($MAIN)
						IF GETGLOBALSETTING("UPDSparkTiming") THEN
							SETSTATUS("Sparking later for better timings on fast computers.")
							SLEEP(5000)
						ELSE
							SETSTATUS("Sparking earlier for better timing on laggy computers.")
							SLEEP(3600)
						ENDIF
					ELSE
						SWITCHTO($MAIN)
						IF GETGLOBALSETTING("UPDSparkTiming") THEN
							SETSTATUS("Sparking later for better timings on fast computers.")
							SLEEP(5900)
						ELSE
							SETSTATUS("Sparking earlier for better timing on laggy computers.")
							SLEEP(4500)
						ENDIF
					ENDIF
					IF GETGLOBALSETTING("UPDBMDoesNotTripleSpark") THEN
						MASSNUKE(TRUE, FALSE, FALSE, FALSE, 400, TRUE, TRUE, TRUE, TRUE, FALSE, TRUE)
					ELSE
						MASSNUKE(TRUE, FALSE, FALSE, FALSE, 400, TRUE, TRUE, FALSE, FALSE, FALSE, TRUE)
					ENDIF
				ELSE
					IF GETGLOBALSETTING("UPDWaitForMysticRezLastBoss") THEN
						IF CHECKFORMYSTIC($CLIENTSINDEXES) AND NOT CHECKFORMYSTICREZ($CLIENTSINDEXES) THEN MYSTICAOEREVIVE($CLIENTSINDEXES)
					ENDIF
					IF GETGLOBALSETTING("UPDKeepSbUltiForLastBoss") THEN
						SBULTI($CLIENTSINDEXES, TRUE, FALSE, $TARGET)
					ENDIF
					PREPAREALTSFORNUKE($CLIENTSINDEXES)
					SLEEP(4000)
					UPDSINTANKSBOSSAWAYFROMSQUAD($CLIENTSINDEXES, $TARGET, -311.88, 329.93)
					IF GETGLOBALSETTING("UPDKeepSbUltiForLastBoss") THEN
						SBULTI($CLIENTSINDEXES, FALSE, TRUE, $TARGET)
					ENDIF
					SWITCHTO($MAIN)
					IF GETGLOBALSETTING("UPDBMDoesNotTripleSpark") THEN
						MASSNUKE(TRUE, FALSE, FALSE, FALSE, 400, TRUE, TRUE, TRUE, TRUE, FALSE, TRUE)
					ELSE
						MASSNUKE(TRUE, FALSE, FALSE, FALSE, 400, TRUE, TRUE, FALSE, FALSE, FALSE, TRUE)
					ENDIF
				ENDIF
				SWITCHTO($MAIN)
				$MOBS = NPCARRAY()
				$INDEX = FINDCLOSEST($MOBS, "Lord of Paradise")
				SLEEP(1000)
			WEND
			$MOBS = NPCARRAY()
			$INDEX = FINDCLOSEST($MOBS, "Lord of Paradise")
			SLEEP(1000)
		WEND
		SWITCHTO($MAIN)
		SETSTATUS("UPD last boss appears to be defeated. Hooray!.")
		IF MASSRES3($CLIENTSINDEXES, -137.62, 327.55, 10, 176) THEN
			MASSMOVETOCOORDENHANCED(-137.62, 327.55, $CLIENTSINDEXES, 10, 176)
			FULLBUFF()
		ENDIF
		SLEEP(1000)
		SWITCHTO($MAIN)
		$TARGET = 0
		$MOBS = NPCARRAY()
		$INDEX = FINDCLOSEST($MOBS, "Ultimate Uncharted Treasure")
		SETSTATUS("Looking for Ultimate Uncharted Treasure chest.")
		IF $INDEX <> -1 THEN
			$TARGET = $MOBS[$INDEX][0]
			IF $TARGET THEN SELECTTARGET($TARGET)
			SLEEP(100)
			MASSSELECT2()
		ELSE
			$LOOKFORCHESTTIMER = TIMERINIT()
			WHILE $INDEX == -1
				SWITCHTO($MAIN)
				$ARRAY = ITEMSARRAY()
				$DROPSCOUNT = UBOUND($ARRAY)
				IF $DROPSCOUNT > 59 THEN
					SETSTATUS("See drops already. Must have killed chest with aoes.")
					EXITLOOP
				ENDIF
				$TARGET = 0
				$MOBS = NPCARRAY()
				$INDEX = FINDCLOSEST($MOBS, "Ultimate Uncharted Treasure")
				SLEEP(100)
				IF TIMERDIFF($LOOKFORCHESTTIMER) > 30000 THEN
					SETSTATUS("Couldn't find last boss chest after 30s of looking. Resuming farming.")
					EXITLOOP
				ENDIF
			WEND
		ENDIF
		SWITCHTO($MAIN)
		SETSTATUS("Selecting chest.")
		MASSRES3($CLIENTSINDEXES, -51.38, -331.41, 10, 176)
		SWITCHTO($MAIN)
		$MOBS = NPCARRAY()
		$INDEX = FINDCLOSEST($MOBS, "Ultimate Uncharted Treasure")
		IF $INDEX <> -1 THEN
			$TARGET = $MOBS[$INDEX][0]
		ENDIF
		IF $TARGET THEN
			SELECTTARGET($TARGET)
			MASSSELECT2()
			WHILE NPCALIVE($TARGET, 0)
				SELECTTARGET($TARGET)
				MASSAUTOATTACK()
				SLEEP(100)
			WEND
		ENDIF
		SWITCHTO($MAIN)
		SLEEP(250)
		IF GETGLOBALSETTING("UsePickupAll") THEN
			MASSPICKUPALL()
		ELSE
			MASSGATHERALL()
		ENDIF
		MASSSWITCHTOHUMANFORM()
		SWITCHTO($MAIN)
		SETSTATUS("UPD: Lord of Paradise done. Run completed.")
		RETURN TRUE
	ENDFUNC
	FUNC CHECKFORCLERIC($CLIENTSINDEXES)
		$CLERICFOUND = FALSE
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF CLASS() == 7 THEN
				$CLERICFOUND = TRUE
			ENDIF
		NEXT
		RETURN $CLERICFOUND
		SWITCHTO($MAIN)
	ENDFUNC
	FUNC UPDSINTANKSBOSSAWAYFROMSQUAD($CLIENTSINDEXES, $TARGET, $X, $Y)
		$INDEXLOCATIONOFBESTSIN = -1
		$MAXHPOFBESTSIN = 0
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
			SWITCHTONUM($INDEX)
			IF CLASS() == 5 THEN
				$HPMP = GETHPMP()
				IF $HPMP[1] > $MAXHPOFBESTSIN THEN
					$INDEXLOCATIONOFBESTSIN = $I
					$MAXHPOFBESTSIN = $HPMP[1]
				ENDIF
			ENDIF
		NEXT
		IF $INDEXLOCATIONOFBESTSIN <> -1 THEN
			SWITCHTONUM($INDEXLOCATIONOFBESTSIN)
			MOVE5($X, $Y)
			CASTSKILL(6988)
			SLEEP(1000)
			$TARGETLASTBOSS = GETNPCUNIQUEID("Lord of Paradise")
			$TARGETPATHKEEPERBAJAN = GETNPCUNIQUEID("Pathkeeper Bajan")
			IF $TARGET == $TARGETLASTBOSS THEN
				IF GETGLOBALSETTING("UPDKeepSbUltiForLastBoss") THEN
					SBULTI($CLIENTSINDEXES, FALSE, TRUE, $TARGET)
				ENDIF
				SWITCHTONUM($INDEXLOCATIONOFBESTSIN)
				EXECUTEREGULARATTACK()
				SLEEP(500)
			ENDIF
			USEGENIESKILL(1002, $TARGET)
		ENDIF
		SWITCHTO($MAIN)
	ENDFUNC
#endregion UPD
FUNC JUMPTEST()
	LOCAL $BCONDITIONMET = FALSE
	WHILE NOT $BCONDITIONMET
		SLEEP(300)
		SEND("{SPACE down}")
		SLEEP(100)
		SEND("{SPACE up}")
		SLEEP(100)
		SEND("{SPACE down}")
		SLEEP(100)
		SEND("{SPACE up}")
		SLEEP(500)
		SEND("w")
	WEND
ENDFUNC
FUNC TRIAL1()
	LOCAL $CLIENTSINDEXES = GETSQUADALTS()
	SWITCHTO($MAIN)
	LOCAL CONST $PLAYER_COUNT = 10
	LOCAL $PLAYERCOORDS[$PLAYER_COUNT][2] = [[98.284, -1231.411], [98.863, -1180.328], [44.093, -1179.609], [43.865, -1230.998], [82.565, -1214.743], [81.227, -1196.01], [92.167, -1225.037], [91.809, -1186.582], [52.175, -1187.576], [51.617, -1223.625]]
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		IF $I >= $PLAYER_COUNT THEN EXITLOOP
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		LOCAL $X = $PLAYERCOORDS[$I][0]
		LOCAL $Y = $PLAYERCOORDS[$I][1]
		MOVETO2($X, $Y)
	NEXT
	SWITCHTO($MAIN)
	SETSTATUS("Done.")
ENDFUNC
FUNC UPDCALIRUNES()
	$PARTY = PARTYARRAY()
	IF UBOUND($PARTY) < 10 THEN
		SETSTATUS("Not enough party members")
		RETURN
	ENDIF
	$CLIENTSINDEXES = GETSQUADCLIENTSINDEXES($PARTY[0][0])
	DOCALIRUNES($CLIENTSINDEXES)
ENDFUNC
FUNC DOCALIRUNES($CLIENTSINDEXES)
	LOCAL $RUNELOCATIONS[16][10] = [["-18.12 14.09", "-50.20 1.89", "-44.97 -2.33", "-18.12 14.09", "-9.58 14.24", "-15.99 15.9", "-27.72 4.46", "3.22 17.56", "-15.78 13.53", "-20.015 16.91"], ["-10.93 50.52", "-42.99 10.43", "-58.13 23.67", "-10.93 50.52", "-10.76 27.18", "-32.58 40.28", "-34.6 12.4", "0.62 31.03", "-26.81 39.36", ""], ["-8.94 50.57", "-37.66 13.15", "-50.96 26.81", "-18.64 48.32", "-6.21 29.62", "-38.72 37.14", "-29.88 17.07", "4.53 33.49", "-28.02 39.07", ""], ["-9.93 43.67", "-42.99 11.83", "-50.12 21.39", "-17.4 44.99", "-7.37 27.81", "-39.28 33.32", "-26.07 9.37", "3.67 31.83", "-25.03 39.68", ""], ["-8.94 50.57", "-39.38 14.27", "-50.96 26.81", "-14.43 47.15", "-8.80 24.26", "-36.28 35.06", "-30.93 12.69", "-0.43 26.55", "-27.03 36.05", ""], ["-6.02 48.94", "-40.89 8.28", "-47.10 31.13", "-14.34 43.10", "-7.77 21.19", "-40.79 29.34", "-29.46 13.56", "6.88 31.12", "-24.39 37.29", ""], ["-7.79 46.48", "-43.25 4.41", "-41.53 23.09", "-18.33 42.48", "-8.80 24.26", "-37.84 31.83", "-30.35 10.78", "7.97 27.25", "-28.88 31.54", ""], ["-9.63 45.13", "-39.75 2.1", "-47.48 28.22", "-17.56 41.5", "-6.05 26.39", "-32.86 33.39", "-28.28 17.2", "1.47 33.63", "", ""], ["-7.56 43.77", "-35.99 7.04", "-47.04 26.46", "-17.24 38.35", "-3.95 21.74", "-36.82 30.27", "-25.90 16.86", "4.89 26.06", "", ""], ["-7.11 44.84", "-36.87 10.05", "-48.9 24.16", "-17.64 36.17", "-6.55 23.16", "-37.53 27.64", "-27.53 14.34", "", "", ""], ["-5.99 46.48", "-38.73 5.71", "-48.78 26.22", "-15.15 41.29", "-6.94 18.74", "", "", "", "", ""], ["-8.07 42.78", "-38.61 8.3", "", "", "", "", "", "", "", ""], ["-7.12 41.63", "-36.31 4.24", "", "", "", "", "", "", "", ""], ["-6.17 43.86", "", "", "", "", "", "", "", "", ""], ["-4.01 47.1", "", "", "", "", "", "", "", "", ""], ["-3.64 52.44", "", "", "", "", "", "", "", "", ""]]
	FOR $I = 0 TO UBOUND($RUNELOCATIONS) - 1
		FOR $J = 0 TO UBOUND($CLIENTSINDEXES) - 1
			SWITCHTONUM($CLIENTSINDEXES[$J])
			IF $RUNELOCATIONS[$I][$J] == "" THEN CONTINUELOOP
			$CORDS = STRINGSPLIT($RUNELOCATIONS[$I][$J], " ", 2)
			MOVETO(NUMBER($CORDS[0]), NUMBER($CORDS[1]))
		NEXT
		WAITCLIENTSTOFINISH($CLIENTSINDEXES)
		SLEEP(1000)
	NEXT
	LOCAL $LASTLOCATIONS[10] = ["-1.24 46.59", "-32.47 6.13", "-46.33 24.75", "-10.18 39.2", "-2.2 19.89", "-33.34 28.37", "-23.69 13.79", "5.54 35.19", "-20.68 35.3", "-13.24 20.39"]
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		$CORDS = STRINGSPLIT($LASTLOCATIONS[$I], " ", 2)
		MOVETO(NUMBER($CORDS[0]), NUMBER($CORDS[1]))
	NEXT
	WAITCLIENTSTOFINISH($CLIENTSINDEXES)
	SWITCHTO($MAIN)
ENDFUNC
FUNC NPCNAME($STRING, $MAXDISTANCE = 300, $POS = -1)
	$ARRAY = NPCARRAY()
	IF UBOUND($ARRAY) == 0 THEN RETURN 0
	$UID = 0
	$LAMBDA = 0
	IF STRINGLEFT($STRING, 5) == "FUNC:" THEN $LAMBDA = STRINGTRIMLEFT($STRING, 5)
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		IF($ARRAY[$I][2] == $STRING OR $STRING == "" OR(ISSTRING($LAMBDA) AND CALL($LAMBDA, $ARRAY, $I))) AND(STRINGLEFT($STRING, 4) == "Dead" OR NOT BITAND($ARRAY[$I][3], $NPCSTATUSBITDEAD)) THEN
			IF $POS <> -1 THEN
				$DIST = DISTANCEBETWEEN($ARRAY[$I][4], $ARRAY[$I][5], $POS[0], $POS[1])
			ELSE
				$DIST = DISTANCE($ARRAY[$I][4], $ARRAY[$I][5], $ARRAY[$I][6])
			ENDIF
			IF $DIST < $MAXDISTANCE THEN
				$UID = $ARRAY[$I][0]
				$MAXDISTANCE = $DIST
			ENDIF
		ENDIF
	NEXT
	RETURN $UID
ENDFUNC
FUNC MASSCLOSENPCWINDOW()
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		CLOSENPCWINDOW()
		SLEEP(50)
		CLOSENPCWINDOW()
	NEXT
	SWITCHTO($MAIN)
ENDFUNC

FUNC TAKECLIENTSQUEST($NPCNAME, $QUESTID, $XPOSITION, $YPOSITION, $CLIENTSINDEXES, $SLEEPBETWEENCLIENT = 0, $TIMELIMIT = FALSE, $MSDELAYTOPERMIT = 15000)
	$NPCUNIQUEID = GETNPCUNIQUEID($NPCNAME)
	IF $NPCUNIQUEID == 0 THEN RETURN
	MASSSELECT($NPCNAME, $CLIENTSINDEXES)
	IF($XPOSITION <> -1 AND $YPOSITION <> -1) OR($XPOSITION <> 0 AND $YPOSITION <> 0) THEN
		MOVECLIENTSTONPC($NPCNAME, $XPOSITION, $YPOSITION, $CLIENTSINDEXES, $TIMELIMIT, $MSDELAYTOPERMIT)
	ENDIF
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		IF HASQUEST($QUESTID) THEN CONTINUELOOP
		DROPDOWN()
		IF TRANSPORTMODE() == 1 OR INSTANCEID() == 176 Or GetNpcUniqueId("Lieutenant Bennett") THEN SWITCHTOHUMANFORM()
		IF NOT ISQUESTAVAILABLE($QUESTID) THEN CONTINUELOOP
		STARTNPCDIALOGUE($NPCUNIQUEID)
	NEXT
	SLEEP(300)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		IF NOT ISQUESTAVAILABLE($QUESTID) THEN CONTINUELOOP
		ACCEPTQUEST($QUESTID)
		SLEEP($SLEEPBETWEENCLIENT)
		IF $QUESTID == 41944 OR $QUESTID == 41949 OR $QUESTID == 41945 OR $QUESTID == 41950 OR $QUESTID == 34156 OR $QUESTID == 34155 THEN SLEEP(2500)
	NEXT
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		CLOSENPCWINDOW()
	NEXT
	SWITCHTO($MAIN)
ENDFUNC

FUNC MOVECLIENTSTONPC($NPCNAME, $XPOSITION, $YPOSITION, $CLIENTSINDEXES, $TIMELIMIT = FALSE, $MSDELAYTOPERMIT = 15000)
	IF NPCDISTANCE($NPCNAME) > 30 AND INSTANCEID() == 176 THEN
		SETSTATUS("speed pathing")
		MASSSPEEDPATH($CLIENTSINDEXES)
	ENDIF
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		IF NPCDISTANCE($NPCNAME) > 5 THEN
			IF INSTANCEID() == 176 THEN
				MOVETO2($XPOSITION, $YPOSITION)
				SETSTATUS("moving to: " & $XPOSITION & ", " & $YPOSITION)
			ELSE
				FLY($XPOSITION, $YPOSITION)
				SETSTATUS("flying to: " & $XPOSITION & ", " & $YPOSITION)
			ENDIF
		ENDIF
	NEXT
	WAITCLIENTSTOFINISH($CLIENTSINDEXES, $TIMELIMIT, $MSDELAYTOPERMIT)
  SwitchTo($Main)
ENDFUNC

FUNC MASSENTERNORTHERNREALM($CLIENTSINDEXES)
	SETSTATUS("Mass entering Northern Realm")
	DIM $WOYONPCSIMPERIAL[][5] = [["Messenger of Time Woyo", 41949, 477.03, 3234.14, 1], ["Messenger of Time Woyo", 41949, -1490.98, 984.39, 1], ["Messenger of Time Woyo", 41949, -761.59, -1330.7, 1], ["Messenger of Time Woyo", 41949, 1495.38, 1179.86, 1], ["Messenger of Time Woyo", 41949, 1618.22, 858.03, 1]]
	DIM $WOYONPCSDIVINE[][5] = [["Messenger of Time Woyo", 41944, 477.03, 3234.14, 1], ["Messenger of Time Woyo", 41944, -1490.98, 984.39, 1], ["Messenger of Time Woyo", 41944, -761.59, -1330.7, 1], ["Messenger of Time Woyo", 41944, 1495.38, 1179.86, 1], ["Messenger of Time Woyo", 41944, 1618.22, 858.03, 1]]
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		$TEAM = NORTHERNREALMTEAM()
		IF $TEAM == 1 THEN
			TAKENEARESTQUEST($WOYONPCSDIVINE)
		ELSEIF $TEAM == 2 THEN
			TAKENEARESTQUEST($WOYONPCSIMPERIAL)
		ENDIF
		SLEEP(2500)
	NEXT
ENDFUNC

FUNC MASSENTERFACTIONBASE($CLIENTSINDEXES)
	SETSTATUS("Mass entering faction base")
	$TARGET = GETNPCUNIQUEID("Faction Base Manager Zeen")
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		IF $TARGET == 0 THEN CONTINUELOOP
		QUICKSELECT($TARGET)
	NEXT
	SLEEP(500)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		IF $TARGET == 0 THEN CONTINUELOOP
		STARTNPCDIALOGUE($TARGET)
	NEXT
	SLEEP(1000)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		ENTERFACTIONBASEPACKET(PLAYERID(), FACTIONID())
	NEXT
	SWITCHTO($MAIN)
	SETSTATUS("Done.")
ENDFUNC
FUNC TURNINBHQUEST()
	TRANSFERMAP($MAP_MAIN, 0, 495.15, 3236.29)
	$QUESTID = GETCURRENTBHQUESTID()
	$OPTION = 0
	SETSTATUS("Turning in BH.")
	TALKTONPC("Head Hunter")
	COMPLETEQUESTOPTION($QUESTID, 0)
	HANDINQUEST($QUESTID, $OPTION)
	COMPLETEQUEST($QUESTID)
	COMPLETEQUEST2($QUESTID)
	COMPLETEQUESTOPTION($QUESTID, $OPTION)
	HANDINQUEST($QUESTID, $OPTION)
	COMPLETEQUEST($QUESTID)
	COMPLETEQUEST2($QUESTID)
	COMPLETEQUESTOPTION($QUESTID, $OPTION)
	AUTOQUEST($QUESTID, 3)
ENDFUNC
FUNC MASSTURNINBHQUEST()
	TURNINBHQUEST()
	$CLIENTSINDEXES = GETSQUADALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		TURNINBHQUEST()
	NEXT
ENDFUNC
FUNC TURNINBHQUESTS($CLIENTSINDEXES)
	$NPCNAME = "Head Hunter"
	$NPCUNIQUEID = GETNPCUNIQUEID($NPCNAME)
	$QUESTID = GETCURRENTBHQUESTID()
	$NPCPOSITION = GETNPCPOSITION($NPCNAME)
	$XPOSITION = 0
	$YPOSITION = 0
	IF $NPCPOSITION THEN
		$XPOSITION = $NPCPOSITION[0]
		$YPOSITION = $NPCPOSITION[1]
	ENDIF
	IF $NPCUNIQUEID <> 0 AND $QUESTID <> -1 THEN
		SETSTATUS("Turning in BHs.")
		MOVECLIENTSTONPC($NPCNAME, $XPOSITION, $YPOSITION, $CLIENTSINDEXES)
		TURNINCLIENTSQUEST($NPCUNIQUEID, $QUESTID, 0, $CLIENTSINDEXES)
	ENDIF
	LOCAL $ITEMSID = [69203, 69200, 69199, 69204, 69201, 69205, 54333, 54334, 69202]
	SETSTATUS("Opening BH and instance items.")
	FOR $J = 0 TO 2
		FOR $I = 0 TO UBOUND($ITEMSID) - 1
			USECLIENTSITEM($ITEMSID[$I], $CLIENTSINDEXES)
		NEXT
		IF $J = 2 THEN EXITLOOP
		SLEEP(4000)
	NEXT
	IF GETGLOBALSETTING("AutoPickUpNebula", FALSE) THEN TURNINCLIENTSFAKENPCQUEST(38842, 2, $CLIENTSINDEXES)
	IF GETGLOBALSETTING("AutoBankAfterBHTurnIn", FALSE) THEN AUTOBANKFORCLIENTS($CLIENTSINDEXES)
	SLEEP(1000)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		CLOSENPCWINDOW()
		CLOSENPCWINDOW()
	NEXT
	SLEEP(100)
	SETSTATUS("Done.")
	SWITCHTO($MAIN)
ENDFUNC
FUNC GETCURRENTBHQUESTID()
	LOCAL $QUESTS[9] = [37120, 37121, 19969, 37123, 37122, 19968, 19966, 46048, 19965]
	FOR $I = 0 TO UBOUND($QUESTS) - 1
		IF HASQUEST($QUESTS[$I]) THEN RETURN $QUESTS[$I]
	NEXT
	RETURN -1
ENDFUNC
FUNC TURNINCLIENTSQUEST($NPCUNIQUEID, $QUESTID, $OPTION, $CLIENTSINDEXES, $SWITCH = 0)
	SETSTATUS("Turning in questID " & $QUESTID)
	MASSSELECT($NPCUNIQUEID, $CLIENTSINDEXES, TRUE)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		IF NOT HASQUEST($QUESTID) THEN CONTINUELOOP
		STARTNPCDIALOGUE($NPCUNIQUEID)
	NEXT
	SLEEP(300)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		IF NOT HASQUEST($QUESTID) THEN CONTINUELOOP
		IF $SWITCH == 0 THEN
			HANDINQUEST($QUESTID, $OPTION)
		ELSEIF $SWITCH == 1 THEN
			COMPLETEQUEST($QUESTID)
		ELSEIF $SWITCH == 2 THEN
			COMPLETEQUEST2($QUESTID)
		ELSEIF $SWITCH == 3 THEN
			COMPLETEQUESTOPTION($QUESTID, $OPTION)
		ELSEIF $SWITCH == 4 THEN
			HANDINQUEST($QUESTID, $OPTION)
			COMPLETEQUEST($QUESTID)
			COMPLETEQUEST2($QUESTID)
			COMPLETEQUESTOPTION($QUESTID, $OPTION)
			AUTOQUEST($QUESTID, 3)
		ENDIF
	NEXT
	SLEEP(1000)
	SWITCHTO($MAIN)
ENDFUNC
FUNC TURNINCLIENTSQUEST2($NPCUNIQUEID, $QUESTID, $OPTION, $CLIENTSINDEXES, $SWITCH = 0)
	MASSSELECT($NPCUNIQUEID, $CLIENTSINDEXES, TRUE)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		IF NOT HASQUEST($QUESTID) THEN CONTINUELOOP
		STARTNPCDIALOGUE($NPCUNIQUEID)
	NEXT
	SLEEP(300)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		IF NOT HASQUEST($QUESTID) THEN CONTINUELOOP
		IF $SWITCH == 0 THEN
			HANDINQUEST($QUESTID, $OPTION)
		ELSEIF $SWITCH == 1 THEN
			COMPLETEQUEST($QUESTID)
		ELSEIF $SWITCH == 2 THEN
			COMPLETEQUEST2($QUESTID)
		ELSEIF $SWITCH == 3 THEN
			COMPLETEQUESTOPTION($QUESTID, $OPTION)
		ENDIF
	NEXT
	SLEEP(1000)
	SWITCHTO($MAIN)
ENDFUNC
FUNC USECLIENTSITEM($ITEMID, $CLIENTSINDEXES)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		USEITEMID($ITEMID, 0, 0)
	NEXT
	SLEEP(300)
	SWITCHTO($MAIN)
ENDFUNC
FUNC TURNINCLIENTSFAKENPCQUEST($QUESTID, $OPTION, $CLIENTSINDEXES)
	USECLIENTSITEM(56121, $CLIENTSINDEXES)
	SLEEP(4000)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		$FAKENPCUNIQUEID = FAKENPCID()
		IF $FAKENPCUNIQUEID <> 0 THEN
			SELECTTARGET($FAKENPCUNIQUEID)
		ENDIF
	NEXT
	SLEEP(1000)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		$FAKENPCUNIQUEID = FAKENPCID()
		IF $FAKENPCUNIQUEID <> 0 THEN
			STARTNPCDIALOGUE($FAKENPCUNIQUEID)
		ENDIF
	NEXT
	SLEEP(2000)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		HANDINQUEST($QUESTID, $OPTION)
	NEXT
	MASSCLOSENPCWINDOW()
	SWITCHTO($MAIN)
ENDFUNC
FUNC AUTOBANKFORCLIENTS($CLIENTSINDEXES)
	IF GETGLOBALSETTING("AutoBankRepairSpotAlternate") THEN
		MASSTELEPORTSTONETOBAMBOOVILLAGESQUAD()
	ELSEIF GETGLOBALSETTING("AutoBankRepairSpotAlternate2") THEN
		MASSTELEPORTSTONETOETHERBLADESQUAD()
	ELSE
		MASSTELEPORTSTONETOHHVILLAGESQUAD()
	ENDIF
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		AUTOBANKDAILY()
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC ENTERMAINSTANCE()
	$COUNT = 0
	STARTLISTENING()
	IF INSTANCEID() <> 198 THEN SENDPACKET("DE000F000000", 6, $GAME_PID)
	SLEEP(3000)
	IF SEETEXT("Can not activate M/A Instance") THEN RETURN FALSE
	WHILE TRUE
		$COUNT = 0
		FOR $I = 0 TO UBOUND($CLIENTS) - 1
			IF CLIENTINGROUP($CLIENTS[$I][2], "team") THEN
				SWITCHTONUM($I)
				IF INSTANCEID() <> 198 THEN
					$POS = PLAYERPOS()
					MOVETO2($POS[0] + 0.1, $POS[1] + 0.1)
					SLEEP(500)
					SENDPACKET("DE000F000000", 6, $GAME_PID)
				ELSE
					$COUNT += 1
				ENDIF
			ENDIF
		NEXT
		IF $COUNT == UBOUND($GROUP_TEAM) THEN EXITLOOP
		SLEEP(7000)
	WEND
	SWITCHTO($MAIN)
	RETURN TRUE
ENDFUNC
FUNC DELIVERWINE()
	DIM $NPCS[6][8] = [["Fresh Daughter's Wine", "Poor Daughter's Wine", "Glutinous Rice", 1, 40399, 0, 5, 0], ["Fresh Eastern Liquor", "Poor Eastern Liquor", "Millet Rice", 1, 40400, 0, 6, 0], ["Unprocessed", "Poor Fenyang Brew", "Sorghum Rice", 2, 40401, 0, 10, 0], ["Foreshot", "Poor Sorghum Wine", "Sorghum Rice", 1, 40401, 1, 7, 0], ["Erguotou", "Poor Sorghum Wine,Foreshot", "Sorghum Rice", 1, 40401, 1, 8, 0], ["Feint", "Poor Sorghum Wine,Foreshot,Erguotou", "Sorghum Rice", 1, 40401, 1, 9, 0]]
	$COUNT = 0
	WHILE HASQUEST(40402)
		$RICE = -1
		FOR $I = 0 TO UBOUND($NPCS) - 1
			IF UIWINDOWOPEN("Win_MaSpringWine" & $NPCS[$I][6]) THEN
				IF $NPCS[$I][7] == 0 THEN $RICE = $I
				$NPCS[$I][7] = 1
			ELSE
				$NPCS[$I][7] = 0
			ENDIF
		NEXT
		IF $RICE = -1 THEN
			SLEEP(500)
			CONTINUELOOP
		ENDIF
		$COUNT += 1
		TAKEQUEST("Yeast Messenger", 40398, 0, 0, 0, FALSE)
		FOR $I = 1 TO $NPCS[$RICE][3]
			TAKEQUEST("Fountain Water Messenger", 40397, 0, 0, 0, FALSE)
			IF $I < ($NPCS[$RICE][3]) THEN
				WHILE HASQUEST(40397)
					SLEEP(300)
				WEND
			ENDIF
		NEXT
		IF $NPCS[$RICE][3] > 1 THEN
			MOVETONPC("Grain Messenger")
			WHILE GETNPCUNIQUEID("Fountain Water")
				REGULARATTACKTARGET(GETNPCUNIQUEID("Fountain Water"))
				SLEEP(100)
			WEND
		ENDIF
		TAKEQUEST("Grain Messenger", $NPCS[$RICE][4], 0, 0, 0, FALSE)
		WHILE HASQUEST($NPCS[$RICE][4])
			SLEEP(500)
		WEND
		WHILE GETNPCUNIQUEID("Fountain Water")
			REGULARATTACKTARGET(GETNPCUNIQUEID("Fountain Water"))
			SLEEP(100)
		WEND
		WHILE GETNPCUNIQUEID("Apricot Village Fountain")
			REGULARATTACKTARGET(GETNPCUNIQUEID("Apricot Village Fountain"))
			SLEEP(100)
		WEND
		WHILE GETNPCUNIQUEID("Yeast")
			REGULARATTACKTARGET(GETNPCUNIQUEID("Yeast"))
			SLEEP(100)
		WEND
		WHILE GETNPCUNIQUEID($NPCS[$RICE][2])
			SLEEP(100)
		WEND
		$INTERMEDIATE = STRINGSPLIT($NPCS[$RICE][1], ",", 2)
		FOR $I = 0 TO UBOUND($INTERMEDIATE) - 1
			WHILE PLAYERTARGET() == 0 AND GETNPCUNIQUEID($INTERMEDIATE[$I])
				SLEEP(100)
			WEND
			IF $NPCS[$RICE][5] THEN TAKEQUEST("Fountain Water Messenger", 40397, 0, 0, 0, FALSE)
			MOVETONPC("Distiller Furnace")
			WHILE GETNPCUNIQUEID($INTERMEDIATE[$I])
				SLEEP(100)
			WEND
		NEXT
		WHILE PLAYERTARGET() == 0 AND GETNPCUNIQUEID($NPCS[$RICE][0])
			SLEEP(100)
		WEND
		MOVETONPC("Spring Wine Manager")
		WHILE GETNPCUNIQUEID($NPCS[$RICE][0])
			SLEEP(100)
		WEND
		FOR $I = 0 TO UBOUND($NPCS) - 1
			$NPCS[$I][7] = 1
		NEXT
	WEND
ENDFUNC
FUNC MASTERAPPRENTICEINSTANCESPRINGEVENT()
	SETSTATUS("M/A Instance: Spring")
	WHILE HASQUEST(40396) OR ISQUESTAVAILABLE(40396) OR HASQUEST(40402)
		TAKEQUEST("Senior Sister", 40396, 0, 0, 55, TRUE, FALSE)
		WHILE NOT HASQUEST(40402)
			SLEEP(100)
		WEND
		WAITFORNPC("Spring Wine Manager")
		DELIVERWINE()
	WEND
	GROUPTAKEQUEST("team", "Senior Sister", 40407, TRUE)
ENDFUNC
FUNC MASTERAPPRENTICEINSTANCESUMMEREVENT()
	SETSTATUS("M/A Instance: Summer")
	DIM $SPOTS[6][4] = [[205.05, 199.97, 206.73, 195.72], [212.68, 161.27, 209.95, 164.29], [179.06, 141.13, 181.21, 144.97], [149.03, 169.25, 153.99, 169.88], [164.62, 204.03, 168.7, 201.68], [181.3, 176.3, 181.37, 178.17]]
	IF NOT INHUMANFORM() THEN SWITCHTOHUMANFORM()
	SLEEP(500)
	WHILE HASQUEST(40607) OR ISQUESTAVAILABLE(40607) OR(HASQUEST(40608) AND INSTANCEVALUE(101407) == 1)
		IF ISQUESTAVAILABLE(40607) OR ISQUESTAVAILABLE(40614) THEN
			MOVEWHILEJUMPING(208, 225.9)
			TAKEQUEST("Second Sister", 40607, 0, 0, 55, TRUE, FALSE)
			SLEEP(2000)
			WHILE ISQUESTAVAILABLE(40614) AND NOT ITEMCOUNT(60962)
				TAKEQUEST("Second Sister", 40614, 0, 0, 55, TRUE, FALSE)
				SLEEP(1000)
			WEND
			MOVEWHILEJUMPING(212, 194, -1, 10)
		ENDIF
		WAITSTOP(4)
		$I = 0
		FOR $I = 0 TO UBOUND($SPOTS) - 1
			WHILE ALTITUDE() < 40 OR DISTANCE2D($SPOTS[$I][0], $SPOTS[$I][1]) > 1
				IF $I == 5 THEN
					MOVE2(177, 186)
					WAITSTOP(1)
					JUMPUPTHENMOVE(180.38, 184.52, -1, -1, -1, 1)
					WAITSTOP(2)
					JUMPUPTHENMOVE(180.81, 182.19)
					WAITSTOP(2)
					JUMPUPTHENMOVE(181.12, 178.1)
					WAITSTOP(2)
					JUMPUPTHENMOVE(181.3, 176.3, -1, -1, -1, 1)
					WAITSTOP(2)
				ELSE
					MOVE2($SPOTS[$I][2], $SPOTS[$I][3])
					TRUEJUMP()
					SLEEP(100)
					JUMPUP(11)
					SLEEP(1100)
					JUMPUP(11)
					SLEEP(800)
					MOVE2($SPOTS[$I][0], $SPOTS[$I][1])
					WAITSTOP(3)
				ENDIF
			WEND
			IF NOT HASQUEST(40608) OR INSTANCEVALUE(101407) <> 1 THEN
				IF $I >= 0 AND $I <= 2 THEN
					MOVE2(225, 211)
					MOVE2(218, 224)
				ELSE
					IF $I == 5 THEN MOVE2(170, 195)
					MOVE2(182.57, 216.97)
					MOVE2(199, 224)
				ENDIF
				JUMPUPTHENMOVE(206, 225)
				EXITLOOP
			ENDIF
			IF $I == 5 THEN
				PLACEABLEITEMSKILL(60962, 181.3, 176.3, 50)
			ELSE
				PLACEABLEITEMSKILL(60962, $SPOTS[$I][0], $SPOTS[$I][1], 44.3)
			ENDIF
			SLEEP(500)
		NEXT
	WEND
	GROUPTAKEQUEST("team", "Second Sister", 40676, TRUE)
ENDFUNC
FUNC GETAUTUMNEVENTARRAY()
	$ARRAY = 0
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF CLIENTINGROUP($CLIENTS[$I][2], "team") THEN
			SWITCHTONUM($I)
			$ARRAY = NPCARRAY()
			FOR $J = 0 TO UBOUND($ARRAY) - 1
				IF $ARRAY[$J][1] == 61265 OR $ARRAY[$J][1] == 61348 OR $ARRAY[$J][1] == 61290 THEN
					EXITLOOP 2
				ENDIF
			NEXT
		ENDIF
	NEXT
	SWITCHTO($MAIN)
	RETURN $ARRAY
ENDFUNC
FUNC AUTUMNEVENTCOUNTINVEHICLES()
	$COUNT = 0
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF CLIENTINGROUP($CLIENTS[$I][2], "team") THEN
			SWITCHTONUM($I)
			SWITCHTOHUMANFORM()
			SLEEP(100)
			IF INVEHICLE() THEN $COUNT = $COUNT + 1
		ENDIF
	NEXT
	SWITCHTO($MAIN)
	RETURN $COUNT
ENDFUNC
FUNC MASTERAPPRENTICEINSTANCEAUTUMNEVENT()
	SETSTATUS("M/A Instance: Autumn")
	WHILE HASQUEST(40844) OR ISQUESTAVAILABLE(40844) OR HASQUEST(40845)
		IF NOT HASQUEST(40845) THEN
			SLEEP(3000)
			IF NOT HASQUEST(40844) AND NOT ISQUESTAVAILABLE(40844) THEN RETURN
			SWITCHTO($MAIN)
			SWITCHTOHUMANFORM()
			SLEEP(100)
			IF GETNPCUNIQUEID("Third Senior Sister") == 0 THEN
				MOVE2(190, -292)
				MOVE2(320, -292)
			ENDIF
			TAKEQUEST("Third Senior Sister", 40844, 0, 0, 55, TRUE, FALSE)
			WHILE NOT HASQUEST(40845)
				SLEEP(1000)
			WEND
		ENDIF
		$IGNORE_COUNT = 3
		DIM $IGNOREARRAY[$IGNORE_COUNT] = [0, 0, 0]
		$CURRIGNORE = 0
		DIM $LASTPOS[3] = [0, 0, 0]
		$TIMER = TIMERINIT()
		$LASTTARGET = 0
		WHILE HASQUEST(40845)
			SLEEP(150)
			IF NOT INVEHICLE() THEN
				$TIMER = TIMERINIT()
				CONTINUELOOP
			ENDIF
			$ARRAY = GETAUTUMNEVENTARRAY()
			$VEHICLECOUNT = AUTUMNEVENTCOUNTINVEHICLES()
			$PLAYERPOS = PLAYERPOS()
			$TARGET = 0
			$TARGETDIST = 1000
			$POS = 0
			FOR $I = 0 TO UBOUND($ARRAY) - 1
				IF $VEHICLECOUNT > 1 AND($ARRAY[$I][1] == 61265 OR $ARRAY[$I][1] == 61348 OR $ARRAY[$I][1] == 61290) OR($VEHICLECOUNT == 1 AND $ARRAY[$I][1] == 61291) THEN
					$DIST = DISTANCEBETWEEN3DF($ARRAY[$I][4], $ARRAY[$I][5], $ARRAY[$I][6], $PLAYERPOS[0], $PLAYERPOS[1], $PLAYERPOS[2])
					IF $DIST < 0.3 THEN
						$CURRIGNORE = MOD($CURRIGNORE + 1, $IGNORE_COUNT)
						$IGNOREARRAY[$CURRIGNORE] = $ARRAY[$I][0]
					ENDIF
					IF _ARRAYSEARCH($IGNOREARRAY, $ARRAY[$I][0]) <> -1 THEN CONTINUELOOP
					IF $DIST < $TARGETDIST THEN
						$TARGET = $ARRAY[$I][0]
						$TARGETDIST = $DIST
						DIM $POS[3] = [$ARRAY[$I][4], $ARRAY[$I][5], $ARRAY[$I][6]]
					ENDIF
				ENDIF
			NEXT
			IF $TARGET == 0 THEN
				FOR $I = 0 TO UBOUND($IGNOREARRAY) - 1
					$IGNOREARRAY[$I] = 0
				NEXT
				CONTINUELOOP
			ENDIF
			IF UBOUND($POS) == 0 THEN CONTINUELOOP
			PRINT("JUMP " & JUMPSPEED() & "  " & $TARGETDIST & "  " & DISTANCEBETWEEN3D($PLAYERPOS, $LASTPOS) & " " & TIMERDIFF($TIMER) & "   " & HEX($TARGET))
			IF $TARGET <> $LASTTARGET THEN $TIMER = TIMERINIT()
			IF TIMERDIFF($TIMER) > 15000 THEN
				JUMPUP(10, TRUE)
				MOVERANDOMIFSTUCK($POS[0], $POS[1], 1)
				MOVERANDOMIFSTUCK($POS[0], $POS[1], 1)
				$TIMER = TIMERINIT()
				CONTINUELOOP
			ENDIF
			IF $TARGETDIST > 1 AND DISTANCEBETWEEN3D($PLAYERPOS, $LASTPOS) < 0.2 THEN
				$DIR = PLAYERDIR()
				$DIR[0] = $DIR[0] * -1
				$DIR[1] = $DIR[1] * -1
				MOVETO2($DIR[0], $DIR[1], 0, 2)
				SLEEP(100)
				JUMPUP(RANDOM(9, 12, 1), TRUE)
				SLEEP(100)
			ENDIF
			IF JUMPSPEED() <> 0 AND DISTANCEBETWEEN($PLAYERPOS[0], $PLAYERPOS[1], $POS[0], $POS[1]) < 0.2 THEN
				JUMPUP(-200)
			ENDIF
			MOVETO2($POS[0], $POS[1])
			$LASTPOS = PLAYERPOS()
			$LASTTARGET = $TARGET
		WEND
		IF HASQUEST(40844) OR ISQUESTAVAILABLE(40844) THEN
			SLEEP(10000)
		ENDIF
	WEND
	SLEEP(10000)
	$NEEDMOVE = FALSE
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF CLIENTINGROUP($CLIENTS[$I][2], "team") THEN
			SWITCHTO($CLIENTS[$I][2])
			IF GETNPCUNIQUEID("Third Senior Sister") == 0 THEN
				$NEEDMOVE = TRUE
			ENDIF
		ENDIF
	NEXT
	IF $NEEDMOVE THEN
		GROUPMOVE("team", 190, -292)
		GROUPMOVE("team", 320, -292)
	ENDIF
	GROUPTAKEQUEST("team", "Third Senior Sister", 40876, TRUE)
ENDFUNC
