		SETSTATUS("Failed to enter faction base")
		RETURN FALSE
	ENDIF
	WAITFORNPC("Faction Manager")
	TAKEQUEST("Faction Manager", 39528, -23.65, 698.78)
	MOVE(-26.2, 723.67)
	JUMPMOVE(-26.58, 733.19, 0.5)
	MOVE(-32.14, 741.52)
	MOVE(-26.48, 750.87)
	MOVE(-25.91, 799.72)
	JUMPMOVE(-47.42, 801.42, 0.5)
	TURNINQUEST("Old Man", 39529)
	SENDEXPRESSION(11)
	WHILE HASQUEST(39531) OR HASQUEST(39532)
		SLEEP(1000)
	WEND
	MOVE(-35.69, 800.58)
	JUMPMOVE(-22.42, 797.03, 0.5)
	MOVE(-25.09, 757.35)
	JUMPMOVE(-27.13, 748.51, 0.5)
	MOVE(-31.07, 740.18)
	MOVE(-26.51, 729.53)
	MOVE(-25.88, 702.58)
	AUTOPATHNOFLY(112, 653, TRUE)
	MOVE(202, 621)
	MOVE(227, 671)
	TURNINQUEST("Spirit Tree's Soul", 39530)
	SENDEXPRESSION(1025)
	WHILE HASQUEST(39533) OR HASQUEST(39534)
		SLEEP(1000)
	WEND
	DOEXITFACTIONBASE()
ENDFUNC
