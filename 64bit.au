ENDFUNC
FUNC FARMWARSONG()
	$PARTY = PARTYARRAY()
	$INSTANCE = INSTANCEID()
	WHILE UBOUND($PARTY) < 5 OR UBOUND($PARTY) > 6
		SETSTATUS("Form a squad with 5 to 6 characters. Make sure they are YOUR characters logged onto your computer!")
		SLEEP(5000)
		$PARTY = PARTYARRAY()
	WEND
	SWITCHTO($MAIN)
	SETSTATUS("Farm Warsong with " & PARTYCOUNT() & " characters.")
	$COUNT = 1
	SLEEP(1000)
	IF $INSTANCE <> 125 THEN TRANSFERMAP($MAP_MAIN, 0, 1762.42, 1151.86)
	$SEVENHOURTIMER = TIMERINIT()
	$MSINSEVENHOUR = 1000 * 60 * 60 * 7
	WHILE(PARTYCOUNT() > 4 AND PARTYCOUNT() < 7)
		IF TIMERDIFF($SEVENHOURTIMER) > $MSINSEVENHOUR THEN
			SETSTATUS("Farm Warsong: time farming exceeds 7 hours. Stopping to avoid hitting earning cap.")
			RETURN
		ENDIF
		$INSTANCE = INSTANCEID()
		WHILE $INSTANCE <> $MAP_MAIN AND $INSTANCE <> 125
			SLEEP(1000)
		WEND
		IF $INSTANCE <> 125 THEN
			IF NOT GETNPCUNIQUEID("Illusion Stone") THEN TRANSFERMAP($MAP_MAIN, 0, 1762.42, 1151.86)
		ENDIF
		SETSTATUS("Farm Warsong Run #" & $COUNT)
		SLEEP(2000)
		$CLIENTSINDEXES = GETSQUADALTS()
		IF GETNPCUNIQUEID("Illusion Stone") THEN
			GATHERALTSINSQUAD()
			SLEEP(2000)
			FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
				$INDEX = $CLIENTSINDEXES[$I]
				SWITCHTONUM($INDEX)
				IF $INSTANCE <> 127 THEN TAKEQUEST("Illusion Stone", 21194)
			NEXT
			SWITCHTO($MAIN)
		ENDIF
		SLEEP(8000)
		RUNWARSONG()
		SLEEP(60000)
		REFORMSQUAD()
		SLEEP(15000)
		WHILE INCOMBAT()
			SLEEP(1000)
		WEND
		$CLIENTSINDEXES = GETSQUADALTS()
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			SLEEP(100)
			WHILE INCOMBAT()
				SLEEP(1000)
			WEND
			$ARRAY = INVARRAY()
			$INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
			IF $INDEX <> -1 THEN
				USETELESTONE($ARRAY[$INDEX][1], $ARRAY[$INDEX][0], 9044)
			ENDIF
		NEXT
		SWITCHTO($MAIN)
		SLEEP(10000)
		$COUNT += 1
	WEND
	SETSTATUS("Finished. We ran Warsong " & $COUNT & " times.")
ENDFUNC
FUNC FINDMISSINGIDS($ARR1, $ARR2)
	DIM $MISSINGIDS[10]
	$FOUND = FALSE
	$MISSINGINDEX = 0
	FOR $I = 0 TO UBOUND($ARR1) - 1
		$FOUND = FALSE
		FOR $J = 0 TO UBOUND($ARR2) - 1
			IF $ARR1[$I][0] == $ARR2[$J][0] THEN
				$FOUND = TRUE
				EXITLOOP
			ENDIF
		NEXT
		IF NOT $FOUND THEN
			$MISSINGIDS[$MISSINGINDEX] = $ARR1[$I][0]
			$MISSINGINDEX += 1
		ENDIF
	NEXT
	IF $MISSINGINDEX > 0 THEN
		REDIM $MISSINGIDS[$MISSINGINDEX]
		RETURN $MISSINGIDS
	ELSE
		RETURN -1
	ENDIF
ENDFUNC
FUNC FINDMISSINGNAMES($ARR1, $ARR2)
	DIM $MISSINGNAMES[10]
	$FOUND = FALSE
	$MISSINGINDEX = 0
	FOR $I = 0 TO UBOUND($ARR1) - 1
		$FOUND = FALSE
		FOR $J = 0 TO UBOUND($ARR2) - 1
			IF $ARR1[$I][1] == $ARR2[$J][1] THEN
				$FOUND = TRUE
				EXITLOOP
			ENDIF
		NEXT
		IF NOT $FOUND THEN
			$MISSINGNAMES[$MISSINGINDEX] = $ARR1[$I][1]
			$MISSINGINDEX += 1
		ENDIF
	NEXT
	IF $MISSINGINDEX > 0 THEN
		REDIM $MISSINGNAMES[$MISSINGINDEX]
		RETURN $MISSINGNAMES
	ELSE
		RETURN -1
	ENDIF
ENDFUNC
FUNC FINDMISSINGNAMES2($ARR1, $ARR2)
	DIM $MISSINGNAMES[10]
	$FOUND = FALSE
	$MISSINGINDEX = 0
	FOR $I = 0 TO UBOUND($ARR1) - 1
		$FOUND = FALSE
		FOR $J = 0 TO UBOUND($ARR2) - 1
			IF $ARR1[$I] == $ARR2[$J] THEN
				$FOUND = TRUE
				EXITLOOP
			ENDIF
		NEXT
		IF NOT $FOUND THEN
			$MISSINGNAMES[$MISSINGINDEX] = $ARR1[$I]
			$MISSINGINDEX += 1
		ENDIF
	NEXT
	IF $MISSINGINDEX > 0 THEN
		REDIM $MISSINGNAMES[$MISSINGINDEX]
		RETURN $MISSINGNAMES
	ELSE
		RETURN -1
	ENDIF
ENDFUNC
