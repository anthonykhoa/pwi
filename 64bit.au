FUNC WAROMINE2()
	$CLOSESTMATCHINGCOORD = 0
	$INSTANCE = INSTANCEID()
	IF $INSTANCE == 168 THEN
	ENDIF
	DIM $QUESTS[4] = [33639, 33640, 33641, 33642]
	IF NOT ANYQUESTAVAILABLE($QUESTS) OR NOT HASANYQUEST($QUESTS) THEN RETURN
	SETSTATUS("Primal World - War O Mine")
	$MAP = INSTANCEID()
	IF $MAP <> $MAP_STORY THEN
		TRANSFERMAP($MAP_STORY, 2, 55.33, 352.41, 50)
	ENDIF
	DIM $COORDSTRACKER1[5][2] = [[23.88, 361.7], [68.43, 436.79], [88.43, 582.54], [89.44, 621.75], [136.87, 733.93]]
	DIM $COORDSTRACKER2[13][2] = [[161.52, 749.11], [163.57, 746.3], [166.77, 734.89], [209.19, 743.18], [296.13, 773.32], [404.37, 782.48], [576.21, 678.43], [628.64, 663.65], [687.46, 676.99], [738.51, 670.27], [773.89, 683.52], [772.43, 748.45], [797.94, 767.93]]
	DIM $COORDSTRACKER3[11][2] = [[771.12, 748.63], [782.88, 623.19], [745.76, 548.89], [690.14, 478.84], [741.59, 400.71], [735.12, 389.63], [741.3, 375.08], [713.28, 387.57], [749.62, 349.2], [785.14, 373.52], [822.85, 346.45]]
	DIM $COORDSTRACKER4[6][2] = [[786.34, 377.14], [744.83, 347.69], [689.57, 316.75], [544.19, 265.74], [516.19, 243.3], [444.73, 115.25]]
	IF ISQUESTAVAILABLE(33639) OR HASQUEST(33639) THEN
		IF HASBUFF("Escort State", 456) THEN
			$CLOSESTMATCHINGCOORD = FINDCLOSESTMATCHINGCOORDINATE($COORDSTRACKER1)
			SETSTATUS("Primal World - War O Mine: resuming where we left off after likely dc.")
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 0 THEN
			TRANSFERMAP($MAP_STORY, 2, 55.33, 352.41, 50)
			TAKEQUEST("Commander Feng", 33639)
			BUILDCHI()
			MOVE(23.88, 361.7)
			$CLOSESTMATCHINGCOORD = 1
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 1 THEN
			MOVE(68.43, 436.79)
			$CLOSESTMATCHINGCOORD = 2
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 2 THEN
			MOVE(88.43, 582.54)
			$CLOSESTMATCHINGCOORD = 3
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 3 THEN
			MOVE(89.44, 621.75)
			$CLOSESTMATCHINGCOORD = 4
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 4 THEN
			MOVE(136.87, 733.93)
			TURNINQUEST("Inkstone Elder", 33639)
			SLEEP(3000)
		ENDIF
	ENDIF
	IF ISQUESTAVAILABLE(33640) OR HASQUEST(33640) THEN
		$CLOSESTMATCHINGCOORD = 0
		IF HASBUFF("Escort State", 456) THEN
			$CLOSESTMATCHINGCOORD = FINDCLOSESTMATCHINGCOORDINATE($COORDSTRACKER2)
			SETSTATUS("Primal World - War O Mine: resuming where we left off after likely dc.")
