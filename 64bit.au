	SWITCHTO($MAIN)
	ClientsMoveAndWait(-709.13, -3.22, $CLIENTSINDEXES, 197)
	; Start a thread for each client index
	$MobName = "Armageddon" ;; next boss
	MASSNUKEBOSSTTR($MobName,True, True, False, False, 400, True, True, True)
	$MobName = "Illusion Lord: Tiger" ;; next boss
