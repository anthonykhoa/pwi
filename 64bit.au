		SENDENTERVEHICLE(NPCID(57205), $SEAT)
		SLEEP(5000)
	WEND
	WHILE INVEHICLE()
		SLEEP(2000)
	WEND
	MOVE(-536.36, -60.85)
	TAKEQUEST("Goldfish Flower Manager", 39236)
	WAITFORNPC("Handsome Tiger")
	TURNINQUEST("Handsome Tiger", 39230, -310.67, 152.96, 10)
	SENDEXPRESSION(15)
	TURNINAUTOQUEST(39230, 1)
	SLEEP(2000)
	TURNINQUEST("Handsome Tiger", 39209, -310.67, 152.96, 10)
