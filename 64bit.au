			ENDIF
			LOCAL $ACALL = DLLCALL("dwmapi.dll", "uint", "DwmSetIconicLivePreviewBitmap", "hwnd", $HWND, "handle", $HBITMAP, "struct*", $TCLIENT, "dword", $IFLAGS)
