FUNC CASTLEOFWONDROUSFATE()
	ADVENTUREKINGDOMMAP()
	SETSTATUS("Divination of Luck - Castle of Wondrous Fate")
	FLYUP()
	TURNINQUEST("Lilian", 39251, -780.85, -177.55, 7, 0, FALSE, TRUE)
	FLYUP()
	IF HASQUEST(39106) THEN
		TURNINQUEST("Katrin", 39106, -891.75, -183.36, 7, 0, FALSE, TRUE)
