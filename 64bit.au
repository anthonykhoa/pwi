		$ONEMINTIMER = TIMERINIT()
		$QUIT = FALSE
		WHILE NOT $QUIT
			$QUIT = TRUE
			IF TIMERDIFF($ONEMINTIMER) > 70000 THEN
				SETSTATUS("70s exceeded while trying to glitch reset characters. Continuing...")
				$QUIT = TRUE
				EXITLOOP
			ENDIF
			FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
				$INDEX = $CLIENTSINDEXES[$I]
				SWITCHTONUM($INDEX)
				IF DISTANCE2D(-299.15, -185.71) > 45 THEN CONTINUELOOP
				IF INCOMBAT() THEN
					$QUIT = FALSE
					CONTINUELOOP
				ENDIF
				$QUESTSAMOUNT = UBOUND(QUESTARRAY())
				$ARRAY = INVARRAY()
				$INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
				IF $INDEX == -1 THEN
					SETSTATUS("Out of teleport stones. Fix this for future runs.")
					CONTINUELOOP
				ENDIF
				SpeedPATH()
				MOVETO2(-317.27, -182.94)
				WHILE UBOUND(QUESTARRAY()) == $QUESTSAMOUNT
					IF TIMERDIFF($ONEMINTIMER) > 70000 THEN
						SETSTATUS("70s exceeded while trying to glitch reset this character. Continuing...")
						$QUIT = TRUE
						EXITLOOP
					ENDIF
					SLEEP(100)
				WEND
				IF DISTANCE2D(-299.15, -185.71) < 45 THEN USETELESTONE($ARRAY[$INDEX][1], $ARRAY[$INDEX][0], 6101)
				IF NOT $FASTRESETTIMING THEN
					SLEEP(1500)
				ELSE
					SLEEP(100)
				ENDIF
			NEXT
		WEND
		SWITCHTO($MAIN)
		IF GETGLOBALSETTING("UPDWait30sEachRun") THEN
			SLEEP(30000)
		ELSE
			SLEEP(10000)
		ENDIF
		MASSCLOSENPCWINDOW()
		SQUADLEAVEGLITCHFIX($MEMBERS, 10)
		CHECKALLCHARINSIDEINSTANCE(176, $SQUADLIST)
		IF GETGLOBALSETTING("docheckerboardafterupdreset") AND $PERMITCHECKERBOARD THEN
			SETSTATUS("UPD: Do checkerboard after reset is selected.")
			$CLIENTSINDEXES = GETSQUADALTS()
			IF NOT CHECKALLCHARINSIDEINSTANCE(176, $SQUADLIST) THEN
				SLEEP(30000)
			ELSE
				SLEEP(10000)
			ENDIF
			$CLIENTSINDEXES2 = GETNEARBYALTS()
			$COUNT = UBOUND($CLIENTSINDEXES2)
			WHILE $COUNT < 10
				SQUADLEAVEGLITCHFIX($MEMBERS, 10)
				SETSTATUS("UPD: waiting for count of characters to be 10.")
				SLEEP(5000)
				$CLIENTSINDEXES2 = GETNEARBYALTS()
				$COUNT = UBOUND($CLIENTSINDEXES2)
			WEND
			MASSCLOSENPCWINDOW()
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			UPDCHECKERBOARDHELPER($MEMBERS, $CLIENTSINDEXES)
		ENDIF
		SWITCHTO($MAIN)
		SETSTATUS("UPD reset: Done.")
	ENDFUNC
	FUNC PARTYARRAY2()
		$SQUADLIST = GETSQUADALTS()
		$SQUADLENGTH = UBOUND($SQUADLIST)
		DIM $SQUADLISTIDSANDNAMES[$SQUADLENGTH][2]
		FOR $I = 0 TO UBOUND($SQUADLIST) - 1
			$INDEX = $SQUADLIST[$I]
			SWITCHTONUM($INDEX)
			$SQUADLISTIDSANDNAMES[$I][0] = PLAYERID()
			$SQUADLISTIDSANDNAMES[$I][1] = PLAYERNAME()
		NEXT
		RETURN $SQUADLISTIDSANDNAMES
		SWITCHTO($MAIN)
	ENDFUNC
	FUNC SQUADCOMBATMODECHECK($CLIENTSINDEXES, $X, $Y, $DISTANCE, $MAXTIMETOWAITINMILLISECONDS)
		SWITCHTO($MAIN)
		$MAXTIMETOWAITFORCOMBATMODETOENDTIMER = TIMERINIT()
		$ALLOUTOFCOMBAT = FALSE
		$NUMOFCHARWHOHADCOMBAT = 0
		WHILE NOT $ALLOUTOFCOMBAT
			$TEMPCOMBATVARIABLE = TRUE
			IF TIMERDIFF($MAXTIMETOWAITFORCOMBATMODETOENDTIMER) > $MAXTIMETOWAITINMILLISECONDS THEN
				EXITLOOP
			ENDIF
			FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
				$INDEX = $CLIENTSINDEXES[$I]
				SWITCHTONUM($INDEX)
				IF DISTANCE2D($X, $Y) > $DISTANCE THEN CONTINUELOOP
				IF INCOMBAT() THEN
					$NUMOFCHARWHOHADCOMBAT += 1
					$TEMPCOMBATVARIABLE = FALSE
					SETSTATUS("In combat, " & INT(TIMERDIFF($MAXTIMETOWAITFORCOMBATMODETOENDTIMER) / 1000) & "s total.")
				ENDIF
			NEXT
			IF $TEMPCOMBATVARIABLE == FALSE THEN
				$ALLOUTOFCOMBAT = FALSE
			ELSE
				$ALLOUTOFCOMBAT = TRUE
				EXITLOOP
			ENDIF
			SLEEP(10000)
		WEND
		$TIMEWAITED = INT(TIMERDIFF($MAXTIMETOWAITFORCOMBATMODETOENDTIMER) / 1000)
		SWITCHTO($MAIN)
		IF $ALLOUTOFCOMBAT == FALSE THEN
			SETSTATUS("Waited " & $TIMEWAITED & " seconds for all characters to exit combat. At least one char was still in combat. Cross fingers!")
		ELSE
			SETSTATUS("Waited " & $TIMEWAITED & " seconds for all characters to exit combat. All char were out of combat! Reset won't have any issues.")
		ENDIF
		RETURN $ALLOUTOFCOMBAT
	ENDFUNC
	FUNC SQUADLEAVEGLITCHFIX($ORIGINALMEMBERSNAMES, $EXPECTEDPLAYERCOUNT)
		SWITCHTO($MAIN)
		$MAINNAME = PLAYERNAME()
		$CURRENTMEMBERS = PARTYARRAY()
		$MAINID = $CURRENTMEMBERS[0][0]
		$CURRENTMEMBERSNAMES = PARTYARRAY2()
		$CURRENTMEMBERSCOUNT = UBOUND($CURRENTMEMBERSNAMES)
		SWITCHTO($MAIN)
		$MAINID2 = PLAYERID()
		IF $CURRENTMEMBERSCOUNT < $EXPECTEDPLAYERCOUNT THEN
			SETSTATUS("Player may have left squad accidentally. Attempting to reinvite.")
			DO
				$DELAYNEEDED = FALSE
				SWITCHTO($MAIN)
				$MISSINGPLAYERSARRAY = FINDMISSINGNAMES($ORIGINALMEMBERSNAMES, $CURRENTMEMBERSNAMES)
				IF $MISSINGPLAYERSARRAY <> -1 THEN
					$DELAYNEEDED = TRUE
					FOR $I = 0 TO UBOUND($ORIGINALMEMBERSNAMES) - 1
						FOR $J = 0 TO UBOUND($MISSINGPLAYERSARRAY) - 1
							IF $ORIGINALMEMBERSNAMES[$I][0] <> $MAINID AND $ORIGINALMEMBERSNAMES[$I][1] == $MISSINGPLAYERSARRAY[$J] THEN
								INVITESQUAD($ORIGINALMEMBERSNAMES[$I][0])
								SLEEP(300)
							ENDIF
						NEXT
					NEXT
				ENDIF
				SLEEP(500)
				IF $MISSINGPLAYERSARRAY <> -1 THEN
					FOR $I = 0 TO UBOUND($MISSINGPLAYERSARRAY) - 1
						SETSTATUS("Reinviting " & $MISSINGPLAYERSARRAY[$I] & " to squad.")
						SWITCHTO($MISSINGPLAYERSARRAY[$I])
						SLEEP(1000)
						ACCEPTSQUADID($MAINID)
					NEXT
				ENDIF
				IF $DELAYNEEDED THEN SLEEP(5000)
				SWITCHTO($MAIN)
				$CURRENTMEMBERS = PARTYARRAY2()
				$CURRENTMEMBERSCOUNT = UBOUND($CURRENTMEMBERS)
			UNTIL $CURRENTMEMBERSCOUNT == $EXPECTEDPLAYERCOUNT
		ENDIF
		SWITCHTO($MAIN)
	ENDFUNC

	FUNC FARMUPD()
		MASSCLOSENPCWINDOW()
		SWITCHTO($MAIN)
		SETSTATUS("◙Starting UPD farming.◙")
		STARTLISTENING()
		$MEMBERS = PARTYARRAY2()
		$SQUADINDEXES = GETSQUADALTS()
		$PARTYCOUNT = UBOUND($MEMBERS)
		$INSTANCE = INSTANCEID()
		WHILE $PARTYCOUNT < 10
			SETSTATUS("Form a squad with 10 characters." & @CRLF & "Move character for 1s to cancel FarmUPD.")
			SLEEP(1000)
			$MEMBERS = PARTYARRAY2()
			$PARTYCOUNT = UBOUND($MEMBERS)
			IF MOVEKEY() <> 0 THEN
				SETSTATUS("Farm UPD cancelled by moving character.")
				RETURN
			ENDIF
		WEND
		$SQUADINDEXES = GETSQUADALTS()
		SWITCHTO($MAIN)
		SETSTATUS("Farm UPD with " & $PARTYCOUNT & " characters.")
		SLEEP(250)
		$CLIENTSINDEXES = GETNEARBYALTS()
		$NEARBYALTCOUNT = UBOUND($CLIENTSINDEXES)
		$INSTANCE = INSTANCEID()
		IF $INSTANCE == 176 THEN
		ELSE
			IF NOT GETNPCUNIQUEID("Swordsman Zenray") THEN
				SWITCHTO($MAIN)
				MASSTELEPORTSTONETOEASTARCHSQUAD()
				MASSDROPDOWN()
				SLEEP(10000)
				MASSMOVETOCOORD(1759.6, 1152.95)
				SLEEP(1000)
				MASSMOVETOCOORD(1759.6, 1152.95)
				SLEEP(5000)
				SWITCHTO($MAIN)
				$TARGET = GETNPCUNIQUEID("Illusion Stone")
				IF $TARGET THEN
					SELECTTARGET($TARGET)
					SLEEP(300)
					MASSSELECT2()
				ENDIF
				TAKECLIENTSQUEST("Illusion Stone", 34439, 1759.601, 1152.95, $CLIENTSINDEXES, 200)
				SLEEP(10000)
				MASSMOVETOCOORD(934.63, -942.33)
			ELSEIF GETNPCUNIQUEID("Swordsman Zenray") THEN
				SWITCHTO($MAIN)
				IF $NEARBYALTCOUNT == 10 THEN
					MASSMOVETOCOORD(934.63, -942.33)
				ELSEIF SKILLOFFCOOLDOWN(4638) THEN
					SWITCHTO($MAIN)
					CASTSKILL(4638)
					SLEEP(10000)
					MASSSQUADSIGNETACCEPT()
					SLEEP(12000)
					SWITCHTO($MAIN)
				ELSE
					SWITCHTO($MAIN)
					MASSTELEPORTSTONETOEASTARCHSQUAD()
					MASSDROPDOWN()
					SLEEP(10000)
					MASSMOVETOCOORD(1759.6, 1152.95)
					SLEEP(5000)
					SWITCHTO($MAIN)
					TAKECLIENTSQUEST("Illusion Stone", 34439, 1759.601, 1152.95, $CLIENTSINDEXES, 200)
					SLEEP(10000)
					MASSMOVETOCOORD(934.63, -942.33)
				ENDIF
			ENDIF
			TAKECLIENTSQUEST("Swordsman Zenray", 34438, 931.96, -940.34, $CLIENTSINDEXES)
			SLEEP(35000)
		ENDIF
		MASSCLOSENPCWINDOW()
		SQUADLEAVEGLITCHFIX($MEMBERS, 10)
		$RUNCOUNT = 0
		$FULLRUNCOUNT = 0
		WHILE NOT SEETEXT("Stop farming")
			IF RUNUPD($MEMBERS, $SQUADINDEXES) THEN
				$FULLRUNCOUNT += 1
			ENDIF
			$RUNCOUNT += 1
			SETSTATUS("UPD Farm: " & $FULLRUNCOUNT & " full run and " & $RUNCOUNT - $FULLRUNCOUNT & " partial runs completed.")
			SLEEP(1000)
		WEND
		SETSTATUS("Done farming UPD for now.")
	ENDFUNC
	FUNC CHECKALLCHARINSIDEINSTANCE($INSTANCEID, $SQUADINDEXES)
		$ALLCHARINSIDE = TRUE
		FOR $I = 0 TO UBOUND($SQUADINDEXES) - 1
			$INDEX = $SQUADINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF INSTANCEID() <> $INSTANCEID THEN
				$TIMER = TIMERINIT()
				$MADEITINSIDE = FALSE
				WHILE TRUE
					IF INSTANCEID() == $INSTANCEID THEN
						$MADEITINSIDE = TRUE
					ENDIF
					IF TIMERDIFF($TIMER) > 5000 THEN EXITLOOP
				WEND
				IF NOT $MADEITINSIDE THEN
					$ALLCHARINSIDE = FALSE
					IF $INSTANCEID == 176 THEN
						SETSTATUS("Didn't make it into UPD run. Navigating to UPD manually.")
						$ALLCHARINSIDE = FALSE
						IF NOT INCOMBAT() THEN
							SETSTATUS("Entering via Illusion Stone.")
							$TELEPORTSTONETIMER = TIMERINIT()
							$USETRANSFERMAP = FALSE
							DO
								TELEPORTSTONETO(9044)
								SLEEP(1000)
								IF TIMERDIFF($TELEPORTSTONETIMER) > 30000 THEN
									$USETRANSFERMAP = TRUE
									EXITLOOP
								ENDIF
							UNTIL GETNPCUNIQUEID("Illusion Stone")
							IF $USETRANSFERMAP THEN
								TRANSFERMAP(1, 1759.6, 1152.95)
							ENDIF
							SLEEP(1000)
							MOVE5(1759.6, 1152.95)
							SLEEP(1000)
							WHILE NOT INHUMANFORM()
								SWITCHTOHUMANFORM()
							WEND
							TAKEQUEST("Illusion Stone", 34439, 1759.57, 1153.91, 219.62, TRUE, FALSE, TRUE, 1)
							WHILE NOT GETNPCUNIQUEID("Swordsman Zenray")
								SLEEP(1000)
							WEND
						ELSE
							TRANSFERMAP(1, 1759.6, 1152.95)
							WHILE NOT GETNPCUNIQUEID("Illusion Stone")
								SLEEP(100)
							WEND
							WHILE NOT INHUMANFORM()
								SWITCHTOHUMANFORM()
							WEND
							TAKEQUEST("Illusion Stone", 34439, 1759.57, 1153.91, 219.62, TRUE, FALSE, TRUE, 1)
							WHILE NOT GETNPCUNIQUEID("Swordsman Zenray")
								SLEEP(1000)
							WEND
						ENDIF
						MOVETO2(934.63, -942.33)
						WHILE NOT INHUMANFORM()
							SWITCHTOHUMANFORM()
						WEND
						TAKEQUEST("Swordsman Zenray", 34438)
					ELSEIF $INSTANCEID == 186 THEN
						SETSTATUS("Didn't make it into DHJ run. Navigating to DHJ manually.")
						$ALLCHARINSIDE = FALSE
						IF NOT INCOMBAT() THEN
							SETSTATUS("Entering via Illusion Stone.")
							$TELEPORTSTONETIMER = TIMERINIT()
							$USETRANSFERMAP = FALSE
							DO
								TELEPORTSTONETO(9044)
								SLEEP(1000)
								IF TIMERDIFF($TELEPORTSTONETIMER) > 30000 THEN
									$USETRANSFERMAP = TRUE
									EXITLOOP
								ENDIF
							UNTIL GETNPCUNIQUEID("Illusion Stone")
							IF $USETRANSFERMAP THEN
								TRANSFERMAP(1, 1759.6, 1152.95)
							ENDIF
							SLEEP(1000)
							MOVE5(1759.6, 1152.95)
							SLEEP(1000)
							WHILE NOT INHUMANFORM()
								SWITCHTOHUMANFORM()
							WEND
							TAKEQUEST("Illusion Stone", 37947, 1759.57, 1153.91, 219.62, TRUE, FALSE, TRUE, 1)
							WHILE NOT GETNPCUNIQUEID("Lieutenant Bennett")
								SLEEP(1000)
							WEND
						ELSE
							TRANSFERMAP(1, 1759.6, 1152.95)
							WHILE NOT GETNPCUNIQUEID("Illusion Stone")
								SLEEP(100)
							WEND
							WHILE NOT INHUMANFORM()
								SWITCHTOHUMANFORM()
							WEND
							TAKEQUEST("Illusion Stone", 37947, 1759.57, 1153.91, 219.62, TRUE, FALSE, TRUE, 1)
							WHILE NOT GETNPCUNIQUEID("Lieutenant Bennett")
								SLEEP(1000)
							WEND
						ENDIF
						SLEEP(5000)
						TAKEQUEST("Lieutenant Bennett", 37848)
					ENDIF
				ENDIF
			ENDIF
		NEXT
		IF $ALLCHARINSIDE = FALSE THEN SLEEP(25000)
		SWITCHTO($MAIN)
		RETURN $ALLCHARINSIDE
	ENDFUNC
	FUNC RUNUPD($MEMBERS, $SQUADINDEXES)
		$FULLRUNCOMPLETED = FALSE
		SWITCHTO($MAIN)
		SLEEP(2000)
		MASSCLOSENPCWINDOW()
		SQUADLEAVEGLITCHFIX($MEMBERS, 10)
		CHECKALLCHARINSIDEINSTANCE(176, $SQUADINDEXES)
		$CLIENTSINDEXES = GETNEARBYALTS()
		$COUNT = UBOUND($CLIENTSINDEXES)
		WHILE $COUNT < 10
			SETSTATUS("UPD farming: waiting for count of characters to be 10.")
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			CHECKALLCHARINSIDEINSTANCE(176, $SQUADINDEXES)
			$CLIENTSINDEXES = GETNEARBYALTS()
			$COUNT = UBOUND($CLIENTSINDEXES)
		WEND
		MASSCLOSENPCWINDOW()
		SQUADLEAVEGLITCHFIX($MEMBERS, 10)
		CHECKALLCHARINSIDEINSTANCE(176, $SQUADINDEXES)
		UPDCHECKERBOARDHELPER($MEMBERS, $SQUADINDEXES)
		CHECKALLCHARINSIDEINSTANCE(176, $SQUADINDEXES)
		SWITCHTO($MAIN)
		UPDPILLARS($SQUADINDEXES)
		UPDPATHKEEPERBAJAN($SQUADINDEXES)
		SQUADLEAVEGLITCHFIX($MEMBERS, 10)
		IF ISQUESTAVAILABLE(35648) THEN
			SETSTATUS("UPD: got Calligraphy. Boo. Resetting with UPD Instance Reset I.")
			RESETUPD($MEMBERS, $SQUADINDEXES, FALSE)
		ELSEIF ISQUESTAVAILABLE(35643) THEN
			SETSTATUS("UPD: got Painting. Boo. Resetting with UPD Instance Reset I.")
			RESETUPD($MEMBERS, $SQUADINDEXES, FALSE)
		ELSEIF ISQUESTAVAILABLE(35647) THEN
			SETSTATUS("UPD: got Strategy. Good!.")
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			$CLIENTSINDEXES = GETNEARBYALTS()
			UPDSTRATEGY($SQUADINDEXES)
			MASSCLOSENPCWINDOW()
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			UPDREFLECTIONMOBS($SQUADINDEXES)
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			UPDREFLECTIONMOBS2($SQUADINDEXES)
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			IF UPDLASTBOSS($SQUADINDEXES) THEN
				$FULLRUNCOMPLETED = TRUE
			ENDIF
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			SWITCHTO($MAIN)
			IF GETGLOBALSETTING("UseResetUPD4") AND MASSTELEPORTINCENSECHECK($CLIENTSINDEXES) THEN
				RESETUPD4($MEMBERS, $SQUADINDEXES, FALSE)
			ELSEIF GETGLOBALSETTING("UseResetUPD3") THEN
				RESETUPD3($MEMBERS, $SQUADINDEXES, FALSE)
			ELSE
				RESETUPD2($MEMBERS, $SQUADINDEXES, FALSE)
			ENDIF
		ELSEIF ISQUESTAVAILABLE(35646) THEN
			SETSTATUS("UPD: got Music Good!.")
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			UPDMUSIC($SQUADINDEXES)
			MASSCLOSENPCWINDOW()
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			$SQUADINDEXES = GETNEARBYALTS()
			UPDREFLECTIONMOBS($SQUADINDEXES)
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			UPDREFLECTIONMOBS2($SQUADINDEXES)
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			IF UPDLASTBOSS($SQUADINDEXES) THEN
				$FULLRUNCOMPLETED = TRUE
			ENDIF
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			SWITCHTO($MAIN)
			IF GETGLOBALSETTING("UseResetUPD4") AND MASSTELEPORTINCENSECHECK($CLIENTSINDEXES) THEN
				RESETUPD4($MEMBERS, $SQUADINDEXES, FALSE)
			ELSEIF GETGLOBALSETTING("UseResetUPD3") THEN
				RESETUPD3($MEMBERS, $SQUADINDEXES, FALSE)
			ELSE
				RESETUPD2($MEMBERS, $SQUADINDEXES, FALSE)
			ENDIF
		ELSEIF ISQUESTAVAILABLE(35645) THEN
			SETSTATUS("UPD: got Wine. Good!.")
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			UPDWINE($SQUADINDEXES)
			MASSCLOSENPCWINDOW()
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			UPDREFLECTIONMOBS($SQUADINDEXES)
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			UPDREFLECTIONMOBS2($SQUADINDEXES)
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			IF UPDLASTBOSS($SQUADINDEXES) THEN
				$FULLRUNCOMPLETED = TRUE
			ENDIF
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			IF GETGLOBALSETTING("UseResetUPD4") AND MASSTELEPORTINCENSECHECK($CLIENTSINDEXES) THEN
				RESETUPD4($MEMBERS, $SQUADINDEXES, FALSE)
			ELSEIF GETGLOBALSETTING("UseResetUPD3") THEN
				RESETUPD3($MEMBERS, $SQUADINDEXES, FALSE)
			ELSE
				RESETUPD2($MEMBERS, $SQUADINDEXES, FALSE)
			ENDIF
		ENDIF
		RETURN $FULLRUNCOMPLETED
	ENDFUNC
	FUNC MASSTELEPORTINCENSECHECK($CLIENTSINDEXES)
		SETSTATUS("Checking if all char have teleport incense.")
		$ALLCHARHAVETELEPORTINCENSE = TRUE
		DIM $ITEMIDS[5] = [36906, 2100, 23434, 26652, 33917]
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			$ARRAY = INVARRAY()
			$TEMPCHARINCENSECHECK = FALSE
			FOR $J = 0 TO UBOUND($ITEMIDS) - 1
				$ITEMSINDEX = SEARCHITEMID($ARRAY, $ITEMIDS[$J])
				IF $ITEMSINDEX <> -1 THEN
					$TEMPCHARINCENSECHECK = TRUE
					EXITLOOP
				ENDIF
			NEXT
			IF $TEMPCHARINCENSECHECK == FALSE THEN
				$ALLCHARHAVETELEPORTINCENSE = FALSE
				SETSTATUS("No teleport incense found.")
			ENDIF
		NEXT
		IF $ALLCHARHAVETELEPORTINCENSE == TRUE THEN
			SETSTATUS("All characters have teleport incense.")
		ENDIF
		RETURN $ALLCHARHAVETELEPORTINCENSE
	ENDFUNC
	FUNC SBULTI($CLIENTSINDEXES, $WAIT, $USE, $TARGET)
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF CLASS() == 11 THEN
				$HPMP = GETHPMP()
				IF $HPMP[0] == 0 OR $HPMP[2] == 0 THEN
					SETSTATUS("Sb dead! Unable to ulti. Continuing...")
					RETURN
				ENDIF
				IF $WAIT THEN
					SETSTATUS("Waiting for sb ulti to be ready to use.")
					WHILE NOT SKILLOFFCOOLDOWN(3281)
						SLEEP(100)
					WEND
				ENDIF
				IF $USE THEN
					IF $TARGET <> 0 THEN
						DO
							CASTSKILL(3281)
							SLEEP(100)
						UNTIL NOT SKILLOFFCOOLDOWN(3281)
						SETSTATUS("Used sb ulti on target.")
					ENDIF
				ENDIF
			ENDIF
		NEXT
		SWITCHTO($MAIN)
	ENDFUNC
	FUNC CLERICAUTOATTACK($CLIENTSINDEXES)
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF CLASS() == 7 THEN
				$HPMP = GETHPMP()
				IF $HPMP[0] == 0 OR $HPMP[2] == 0 THEN
					SETSTATUS("Cleric dead! Unable to auto attack. Continuing...")
					RETURN
				ENDIF
				EXECUTEREGULARATTACK()
				RETURN
			ENDIF
		NEXT
		SWITCHTO($MAIN)
	ENDFUNC
	FUNC CLERICSOG(ByRef $CLIENTSINDEXES, $WAIT = TRUE, $USE = TRUE)
		$CLERICSOGTIMELIMITTIMER = TIMERINIT()
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF CLASS() == 7 THEN
				$HPMP = GETHPMP()
				IF $HPMP[0] == 0 OR $HPMP[2] == 0 THEN
					SETSTATUS("Cleric dead! Unable to build chi or Sog. Continuing...")
					RETURN
				ENDIF
				IF $WAIT THEN
					WHILE CHI() < 100
						BUILDCHI()
						SLEEP(100)
					WEND
				ENDIF
				SLEEP(100)
				WHILE SKILLCOOLDOWNTIME(6919) > 0
					SLEEP(100)
				WEND
				IF $USE THEN
					DO
						IF CHI() < 100 THEN BUILDCHI()
						CASTSKILL(6919)
						SLEEP(100)
					UNTIL SKILLCOOLDOWNTIME(6919) > 0
					SLEEP(750)
					CASTSKILL(360)
				ENDIF
			ENDIF
		NEXT
		SWITCHTO($MAIN)
	ENDFUNC
	FUNC CANCELCLERICBB(ByRef $CLIENTSINDEXES)
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF CLASS() == 7 THEN
				IF CURRENTSKILL() == 2223 THEN CANCELACTION()
			ENDIF
		NEXT
		SWITCHTO($MAIN)
	ENDFUNC
	FUNC CLERICHEAL(ByRef $CLIENTSINDEXES)
		DIM $CLERICAOEHEALIDS[6] = [3546, 3549, 3550, 3548, 3547, 2223]
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF CLASS() == 7 THEN
				CASTFIRSTSKILL($CLERICAOEHEALIDS)
			ENDIF
		NEXT
		SWITCHTO($MAIN)
	ENDFUNC
	FUNC MASSCANCELACTION(ByRef $CLIENTSINDEXES)
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			CANCELACTION()
		NEXT
		SWITCHTO($MAIN)
	ENDFUNC
	FUNC MASSCHICHECK(ByRef $CLIENTSINDEXES, $MINCHIVALUEREQUIRED)
		$SQUADHASCHI = TRUE
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF CHI() < $MINCHIVALUEREQUIRED THEN
				$SQUADHASCHI = FALSE
				RETURN $SQUADHASCHI
			ENDIF
		NEXT
		SWITCHTO($MAIN)
		RETURN $SQUADHASCHI
	ENDFUNC
	FUNC MYSTICCHIPLANT(ByRef $CLIENTSINDEXES)
		$FAILEDTOCASTFULLCHISKILL = FALSE
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF CLASS() == 9 THEN
				$HPMP = GETHPMP()
				IF $HPMP[0] == 0 OR $HPMP[2] == 0 THEN
					RESINPLACE()
					SLEEP(8000)
				ENDIF
				IF CHI() < 200 THEN
					IF SKILLOFFCOOLDOWN(7365) THEN
						$TIMER = TIMERINIT()
						DO
							IF TIMERDIFF($TIMER) > 5000 THEN
								SETSTATUS("Mystic tried for 5s and couldn't cast full-chi skill. Exiting and building chi with macro(7) instead.")
								$FAILEDTOCASTFULLCHISKILL = TRUE
								EXITLOOP
							ENDIF
							CASTSKILL(7365)
							SLEEP(1000)
						UNTIL NOT SKILLOFFCOOLDOWN(7365)
					ENDIF
					IF NOT SKILLOFFCOOLDOWN(7365) OR $FAILEDTOCASTFULLCHISKILL THEN
						DO
							BUILDCHI()
							SLEEP(100)
						UNTIL CHI() > 150
					ENDIF
				ENDIF
			ENDIF
		NEXT
		SWITCHTO($MAIN)
	ENDFUNC
	FUNC PREPAREALTSFORNUKE(ByRef $CLIENTSINDEXES, $BUILDCHIONLY = FALSE, $REFLECTIONMOBS = FALSE)
		SETSTATUS("Preparing alts for nuke.")
		$PREPARETIMER = TIMERINIT()
		FULLBUFF()
		IF NOT MASSCHICHECK($CLIENTSINDEXES, 390) THEN
			SETSTATUS("Squad needs chi still probably.")
			FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
				$INDEX = $CLIENTSINDEXES[$I]
				SWITCHTONUM($INDEX)
				$TIMER = TIMERINIT()
				IF CLASS() == 9 THEN
					$HPMP = GETHPMP()
					IF $HPMP[0] == 0 OR $HPMP[2] == 0 THEN
						SETSTATUS("Mystic dead! Unable to build chi for squad. Continuing...")
						RETURN
					ENDIF
					IF $BUILDCHIONLY THEN
						DO
							BUILDCHI()
							IF TIMERDIFF($PREPARETIMER) > 60000 THEN SETSTATUS("Over 60s passed while building chi. Exiting.")
						UNTIL CHI() > 390 AND SKILLOFFCOOLDOWN(4078)
					ELSE
						IF SKILLOFFCOOLDOWN(4078) AND CHI() > 100 THEN
							SETSTATUS("Chi above 100. Casting chi plant immediately.")
							DO
								CASTSKILL(4078)
								SLEEP(100)
								IF TIMERDIFF($TIMER) > 5000 THEN
									SETSTATUS("Spent more than 5s trying to cast chi plant. Exiting...")
									EXITLOOP
								ENDIF
							UNTIL NOT SKILLOFFCOOLDOWN(4078)
						ELSEIF SKILLOFFCOOLDOWN(4078) AND CHI() < 100 THEN
							DO
								SETSTATUS("Chi below 100. Building chi then casting chi plant.")
								BUILDCHI()
								CASTSKILL(4078)
								SLEEP(100)
								IF TIMERDIFF($TIMER) > 25000 THEN
									SETSTATUS("Spent more than 25s trying to build 1 spark chi. Exiting...")
									EXITLOOP
								ENDIF
							UNTIL NOT SKILLOFFCOOLDOWN(4078)
						ELSE
							DO
								SETSTATUS("Chi plant on cooldown. Building chi and waiting for it, then casting it.")
								BUILDCHI()
								IF TIMERDIFF($TIMER) > 40000 THEN
									SETSTATUS("more than 35s passed waiting on chi plant cd. exiting...")
									EXITLOOP
								ENDIF
								IF MASSCHICHECK($CLIENTSINDEXES, 380) THEN
									SETSTATUS("Alts have enough chi now. Continuing...")
									EXITLOOP
								ENDIF
								SWITCHTONUM($INDEX)
								SLEEP(100)
							UNTIL SKILLOFFCOOLDOWN(4078)
							$TIMER = TIMERINIT()
							DO
								CASTSKILL(4078)
								SLEEP(100)
								IF TIMERDIFF($TIMER) > 5000 THEN
									SETSTATUS("Spent more than 5s trying to cast chi plant. Exiting...")
									EXITLOOP
								ENDIF
							UNTIL NOT SKILLOFFCOOLDOWN(4078)
						ENDIF
					ENDIF
					CONTINUELOOP
				ELSEIF CLASS() == 3 THEN
					IF GETGLOBALSETTING("UPDVenoGoesFoxFormForNuke") == TRUE THEN
						SWITCHTOSECONDFORM()
					ELSE
						IF NOT $REFLECTIONMOBS THEN
							SWITCHTOHUMANFORM()
						ENDIF
					ENDIF
					CONTINUELOOP
				ELSEIF CLASS() == 4 THEN
					SWITCHTOHUMANFORM()
					CONTINUELOOP
				ELSEIF CLASS() == 7 THEN
					IF INHUMANFORM() THEN
						SWITCHTOSECONDFORM(TRUE)
					ENDIF
					CONTINUELOOP
				ENDIF
			NEXT
		ELSE
			SETSTATUS("Squad already full on chi.")
			FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
				$INDEX = $CLIENTSINDEXES[$I]
				SWITCHTONUM($INDEX)
				IF CLASS() == 3 THEN
					IF GETGLOBALSETTING("UPDVenoGoesFoxFormForNuke") THEN
						SWITCHTOSECONDFORM()
					ELSE
						IF NOT $REFLECTIONMOBS THEN
							SWITCHTOHUMANFORM()
						ENDIF
					ENDIF
					CONTINUELOOP
				ELSEIF CLASS() == 4 THEN
					SWITCHTOHUMANFORM()
					CONTINUELOOP
				ELSEIF CLASS() == 7 THEN
					IF INHUMANFORM() THEN
						SWITCHTOSECONDFORM(TRUE)
					ENDIF
					CONTINUELOOP
				ENDIF
			NEXT
		ENDIF
		SWITCHTO($MAIN)
	ENDFUNC
	FUNC CHECKFORMYSTIC(ByRef $CLIENTSINDEXES)
		$HAVEMYSTIC = FALSE
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF CLASS() == 9 THEN
				SETSTATUS("We have a mystic in squad.")
				$HAVEMYSTIC = TRUE
				EXITLOOP
			ENDIF
		NEXT
		SWITCHTO($MAIN)
		IF NOT $HAVEMYSTIC THEN SETSTATUS("No mystic found in squad. Won't check for rez buffs.")
		RETURN $HAVEMYSTIC
	ENDFUNC
	FUNC CHECKFORMYSTICREZ(ByRef $CLIENTSINDEXES)
		$ALLHAVEREZ = TRUE
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF NOT HASBUFF("Resurrect", 189) THEN
				$ALLHAVEREZ = FALSE
				EXITLOOP
			ENDIF
		NEXT
		SWITCHTO($MAIN)
		RETURN $ALLHAVEREZ
	ENDFUNC
	FUNC MYSTICAOEREVIVE(ByRef $CLIENTSINDEXES)
		$TIMER = TIMERINIT()
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF CLASS() == 9 THEN
				DO
					IF TIMERDIFF($TIMER) > 200000 THEN
						SETSTATUS("Waited too long for mystic rez buff on all char. Continuing...")
						EXITLOOP
					ENDIF
					CASTSKILL(1860)
					SLEEP(1000)
					BUILDCHI()
					CASTSKILL(4078)
					SLEEP(100)
				UNTIL CHECKFORMYSTICREZ($CLIENTSINDEXES)
				SETSTATUS("All char have resurrect buff. Safe to proceed.")
			ENDIF
		NEXT
		SWITCHTO($MAIN)
	ENDFUNC
	FUNC MYSTICSALVATIONPET(ByRef $CLIENTSINDEXES)
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF CLASS() == 9 THEN
				CASTSKILL(6286)
			ENDIF
			IF CLASS() == 3 THEN
				SWITCHTOSECONDFORM()
			ENDIF
		NEXT
		SWITCHTO($MAIN)
	ENDFUNC
