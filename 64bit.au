		ENDIF
		IF $CLOSESTMATCHINGCOORD = 1 THEN
			MOVE(505.99, 215.98)
			$CLOSESTMATCHINGCOORD = 2
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 2 THEN
			MOVE(475.12, 307.81)
			$CLOSESTMATCHINGCOORD = 3
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 3 THEN
			MOVEWHILEJUMPING(469.63, 316.84, -1, 6)
			$CLOSESTMATCHINGCOORD = 4
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 4 THEN
			MOVE(398.86, 461.22)
			$CLOSESTMATCHINGCOORD = 5
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 5 THEN
			MOVEWHILEJUMPING(436.1, 483.39, -1, 30)
			$CLOSESTMATCHINGCOORD = 6
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 6 THEN
			MOVE(436.31, 493.82)
			$CLOSESTMATCHINGCOORD = 7
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 7 THEN
			MOVE(481.2, 531.44)
			$CLOSESTMATCHINGCOORD = 8
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 8 THEN
			MOVEWHILEJUMPING(508.91, 591.06, -1, 50)
			$CLOSESTMATCHINGCOORD = 9
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 9 THEN
			MOVEWHILEJUMPING(496.89, 663.45, -1, 60)
			$CLOSESTMATCHINGCOORD = 10
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 10 THEN
			MOVEWHILEJUMPING(495.64, 695.05, -1, 25)
			$CLOSESTMATCHINGCOORD = 11
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 11 THEN
			MOVEWHILEJUMPING(446.62, 739.4, -1, 50)
			$CLOSESTMATCHINGCOORD = 12
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 12 THEN
			MOVE(426.57, 759.62)
			$CLOSESTMATCHINGCOORD = 13
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 13 THEN
			MOVEWHILEJUMPINGANDLAND(411.2, 766.69)
			$CLOSESTMATCHINGCOORD = 14
		ENDIF
		IF $CLOSESTMATCHINGCOORD = 14 THEN
			MOVE(419.07, 773.94)
			USEANCIENTGIFT()
			TURNINQUEST("Light Empress Althea", 44184, 419.07, 773.94)
			BUILDCHI(1000, 399)
			SLEEP(3000)
			TURNINAUTOQUEST(44117)
		ENDIF
	ENDIF
ENDFUNC
FUNC FINDFROZENMODELEFFECT(BYREF $NPCARRAY)
	IF GETGLOBALSETTING("waterofimarlowgraphics") THEN
		RETURN FINDCLOSEST($NPCARRAY, 72271, 1, 0, TRUE)
	ELSE
		$NPCARRAY_ORIGINAL = $NPCARRAY
		$POS = GETNPCPOSITION(72270, 1)
		$PLAYERS = PLAYERARRAY()
		$TIMER = TIMERINIT()
		DIM $OBSTACLE[5][3] = [[-1592.38, 1227.03, 30], [-1447.4, 1219.74, 22], [-1457.96, 1135.94, 28], [-1608.14, 1118.21, 31], [-1454.26, 1181.84, 23.1]]
		FOR $I = 0 TO UBOUND($NPCARRAY) - 1
			IF TIMERDIFF($TIMER) > 5000 THEN
				SETSTATUS("debug: findfrozenmodeleffect exceeded 5s. exiting loop")
				EXITLOOP
			ENDIF
			$NPC = $NPCARRAY[$I][10]
			IF $NPCARRAY[$I][1] <> 72271 THEN CONTINUELOOP
			$NPCARRAY[$I][1] = 0
			DIM $TARGETMOB[2] = [$NPCARRAY[$I][4], $NPCARRAY[$I][5]]
			$MODEL = _MEMORYREAD(_MEMORYREAD($NPC + $NPCMODELPOLICY, $GAME_PROCESS) + 8, $GAME_PROCESS)
			$TABLE = READHASHTABLE($MODEL + $MODELEFFECTSOFFSET)
			FOR $J = 0 TO UBOUND($TABLE) - 1
				IF TIMERDIFF($TIMER) > 5000 THEN
					SETSTATUS("debug: findfrozenmodeleffect exceeded 5s. exiting loop")
					EXITLOOP
				ENDIF
				IF STRINGINSTR("" & _MEMORYREAD($TABLE[$J][1], $GAME_PROCESS, "byte[512]"), "B2DFBBAEC1AAC8EB5CD7B4CCACD0A7B9FB5CCAACB1F8BDABBEFC5FD4F6C7BFCAA9B7C5D5D6D7D33031B3D6D0F8B2C2BCC92E676678") AND(UBOUND($POS) == 0 OR DISTANCEBETWEEN($POS[0], $POS[1], $NPCARRAY[$I][4], $NPCARRAY[$I][5]) > 40) AND(UBOUND($POS) == 0 OR CHECKPATHSAFE($POS, 40, $TARGETMOB)) AND ISCLOSESTTOME($NPCARRAY, $PLAYERS, $I) THEN
					$ANIVAL = _MEMORYREAD($TABLE[$J][1], $GAME_PROCESS, "byte[512]")
					$NPCARRAY[$I][1] = 72271
					FOR $K = 0 TO UBOUND($OBSTACLE) - 1
						IF TIMERDIFF($TIMER) > 5000 THEN
							SETSTATUS("debug: findfrozenmodeleffect exceeded 5s. exiting loop")
							EXITLOOP
						ENDIF
						DIM $OBSTACLEPOS[2] = [$OBSTACLE[$K][0], $OBSTACLE[$K][1]]
						IF NOT CHECKPATHSAFE($OBSTACLEPOS, $OBSTACLE[$K][2], $TARGETMOB) THEN
							$NPCARRAY[$I][1] = 0
						ENDIF
					NEXT
				ENDIF
			NEXT
		NEXT
		IF UBOUND($NPCARRAY) THEN
			RETURN FINDCLOSEST($NPCARRAY, 72271, 1, 0, TRUE)
		ELSE
			RETURN FINDCLOSEST($NPCARRAY_ORIGINAL, 72271, 1, 0, TRUE)
		ENDIF
	ENDIF
ENDFUNC
FUNC ISCLOSESTTOME(BYREF $NPCARRAY, BYREF $PLAYERS, $IDX)
	$MYPOS = PLAYERPOS()
	$DIST = DISTANCEBETWEEN($NPCARRAY[$IDX][4], $NPCARRAY[$IDX][5], $MYPOS[0], $MYPOS[1])
	$TIMER = TIMERINIT()
	FOR $I = 0 TO UBOUND($PLAYERS) - 1
		IF TIMERDIFF($TIMER) > 15000 THEN
			SETSTATUS("isclosesttome exceeds 15s. exitting.")
			RETURN FALSE
		ENDIF
		$PLAYERDIST = DISTANCEBETWEEN($PLAYERS[$I][4], $PLAYERS[$I][5], $NPCARRAY[$IDX][4], $NPCARRAY[$IDX][5])
		PRINT($PLAYERS[$I][2] & " -$#- " & $PLAYERDIST)
		IF $PLAYERDIST < 30 AND($PLAYERDIST + 10) < $DIST AND $PLAYERS[$I][6] < ($MYPOS[2] + 5) THEN
			RETURN FALSE
		ENDIF
	NEXT
	RETURN TRUE
ENDFUNC
FUNC THEWATEROFIMAR()
	IF NOT ISQUESTAVAILABLE(46018) AND NOT HASQUEST(46018) THEN RETURN
	SETSTATUS("Neverfall - The Water of Imar")
	IF NOT CANTELEPORT() THEN
		TRANSFERMAP($MAP_NEVERFALL, 0)
		FLY(1107, 1278, 40, 0)
	ELSE
		TRANSFERMAP($MAP_NEVERFALL, 0, -1437, 1456, 40)
	ENDIF
	IF NOT HASQUEST(46018) THEN TAKEQUEST("Landar", 46018, -1437, 1456, 40)
	SELFBUFF()
	DIM $WATERSPOTS[7][2] = [[-1556, 1281], [-1472.13, 1255.69], [-1468.82, 1211.34], [-1483.47, 1152.98], [-1535.17, 1141.02], [-1543.32, 1192.45], [-1532.23, 1239.57]]
	FLYRANDOM($WATERSPOTS, 15, 0)
	DIM $KILLPOS[2] = [0, 0]
	$TIMER = 0
	$LASTTARGETTIMER = TIMERINIT()
	$LASTID = 0
	$BUFFTIMER = TIMERINIT()
	$WASDEAD = FALSE
	$DEATHCOUNTER = 0
	DIM $CENTER[2] = [-1529.7, 1198.41]
	DIM $AVOIDPLACES[6][2] = [[-1537.63, 1293.75], [-1570.76, 1280.5], [-1586.29, 1210.72], [-1479.55, 1146.1], [-1454.82, 1195.38], [-1484.33, 1275.76]]
	WHILE HASQUEST(46018)
		IF TIMERDIFF($BUFFTIMER) > 15000 THEN
			BUFFCHECK(TRUE)
			$BUFFTIMER = TIMERINIT()
		ENDIF
		$HPMP = GETHPMP()
		IF $HPMP[0] == 0 OR $WASDEAD THEN
			$DEATHCOUNTER += 1
			SETSTATUS("We died doing Water of Imar, returning... :<")
			RESURRECTIFDEAD()
			SETSTATUS("Water of Imar: waiting 30s to avoid glitching.")
			SLEEP(30000)
			USEITEMID(38408)
			SELFBUFF()
			$WASDEAD = FALSE
			FLY(-1561.84, 1249.22, 15, 0)
			SLEEP(1000)
			$TIMER = TIMERINIT()
			$POS = PLAYERPOS()
		ENDIF
		$NPCARRAY = NPCARRAY()
		$SOULIDX = FINDCLOSEST($NPCARRAY, 72272, 1)
		$TARGET = 0
		$SCARYIDX = FINDCLOSEST($NPCARRAY, 72270, 1)
		AVOIDPLACES($AVOIDPLACES, $CENTER[0], $CENTER[1], 10, 15)
		IF TRANSPORTMODE() == 2 THEN
			IF($SCARYIDX == -1 OR DISTANCE2D($NPCARRAY[$SCARYIDX][4], $NPCARRAY[$SCARYIDX][5]) > 50) AND NOT INCOMBAT() THEN
				DESELECTTARGET()
				DROPDOWN()
			ELSEIF NOT INCOMBAT() THEN
				FLYRANDOM($WATERSPOTS, 15, 0)
			ENDIF
			SLEEP(100)
			CONTINUELOOP
		ENDIF
		IF $SCARYIDX <> -1 THEN
			IF DISTANCE2D($NPCARRAY[$SCARYIDX][4], $NPCARRAY[$SCARYIDX][5]) < 25 THEN
				IF NOT FLYUP() THEN $WASDEAD = TRUE
				ABSOLUTEDOMAIN()
				FLYRANDOM($WATERSPOTS, 15, 0)
				SLEEP(100)
				CONTINUELOOP
			ENDIF
		ENDIF
		IF $SOULIDX <> -1 AND DISTANCEBETWEEN($NPCARRAY[$SOULIDX][4], $NPCARRAY[$SOULIDX][5], $KILLPOS[0], $KILLPOS[1]) < 10 THEN
			$TARGET = $NPCARRAY[$SOULIDX][0]
		ELSE
			$IDX = FINDFROZENMODELEFFECT($NPCARRAY)
			IF $IDX <> -1 THEN
				$LASTTARGETTIMER = TIMERINIT()
				$SELECTID = $NPCARRAY[$IDX][0]
				$TARGET = $SELECTID
				$KILLPOS[0] = $NPCARRAY[$IDX][4]
				$KILLPOS[1] = $NPCARRAY[$IDX][5]
			ENDIF
		ENDIF
		$CURPOS = PLAYERPOS()
		IF $TARGET THEN
			IF CHI() > 300 THEN
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
			ENDIF
			$ATTACKER = PLAYERTARGET()
			$DIST = NPCDISTANCE($ATTACKER, 0)
			IF $ATTACKER AND $DIST < 10 AND COUNTMOBSINAREA($CURPOS[0], $CURPOS[1], 10, 72271, 1, $NPCARRAY) > 1 AND KILLTARGET($ATTACKER, 100, 1) THEN
			ELSE
				KILLTARGET($TARGET, 100)
			ENDIF
		ELSEIF ACTIONFLAG() THEN
			MOVETO2(1, 0, 0, 3)
		ELSEIF PLAYERTARGET() AND INCOMBAT() THEN
			$ATTACKER = PLAYERTARGET()
			$DIST = NPCDISTANCE($ATTACKER, 0)
			IF $DIST > 0 AND $DIST < 10 THEN
				IF NOT FLYUP(140) THEN CONTINUELOOP
			ENDIF
		ENDIF
		IF QUESTKILLCOUNT(46018) > 7 THEN
			USEANCIENTGIFT()
		ENDIF
		SLEEP(100)
	WEND
	FLYUP(150)
	IF NOT CANTELEPORT() THEN
		FLY(1107, 1278, 40, 0)
	ELSE
		FLY(-1428, 1444, 17)
	ENDIF
	IF $DEATHCOUNTER = 1 THEN
		SETSTATUS("Neverfall - The Water of Imar - done. Died " & $DEATHCOUNTER & " time.")
	ELSEIF $DEATHCOUNTER > 1 THEN
		SETSTATUS("Neverfall - The Water of Imar - done. Died " & $DEATHCOUNTER & " times.")
	ELSE
		SETSTATUS("Neverfall - The Water of Imar - done.")
	ENDIF
ENDFUNC
FUNC MOVEANDOVERSHOOTTARGET($TARGX, $TARGY, $OVERSHOOTDECIMAL, $USEMOVEMENTSPEEDSKILLS = FALSE)
	$POS = PLAYERPOS()
	$DISTANCE = DISTANCE2D($TARGX, $TARGY)
	$CALCULATEDTARGX = 0
	$CALCULATEDTARGY = 0
	$CHANGEX = $TARGX - $POS[0]
	$CHANGEY = $TARGY - $POS[1]
	$CALCULATEDTARGX = $TARGX + ($OVERSHOOTDECIMAL * $CHANGEX)
	$CALCULATEDTARGY = $TARGY + ($OVERSHOOTDECIMAL * $CHANGEX)
	IF $USEMOVEMENTSPEEDSKILLS THEN
		MOVE($CALCULATEDTARGX, $CALCULATEDTARGY)
	ELSE
		MOVE2($CALCULATEDTARGX, $CALCULATEDTARGY)
	ENDIF
ENDFUNC
FUNC HEROSPIRIT()
	IF NOT ISQUESTAVAILABLE(47166) AND NOT HASQUEST(47166) THEN RETURN
	SETSTATUS("Neverfall - Hero Spirit")
	USEITEMID(38408)
	IF NOT CANTELEPORT() THEN
		TRANSFERMAP($MAP_NEVERFALL, 0)
		SLEEP(3000)
		FLY(-1819, 792)
	ELSE
		TRANSFERMAP($MAP_NEVERFALL, 0, -1819, 792)
		SLEEP(3000)
	ENDIF
	IF CHI() < 399 THEN USEGENIECHI()
	IF NOT HASQUEST(47166) THEN
		TRANSFERMAP($MAP_NEVERFALL, 0, -1946.94, 700)
		DROPDOWN()
		MOVE(-1929.09, 707.16)
		MOVE(-1919.69, 714.97)
		MOVE(-1905.24, 715.47)
		MOVE(-1903.32, 732.33)
		IF NOT HASQUEST(47166) THEN TAKEQUEST("Valkyrie Valkyrie", 47166, -1903.7, 735.73)
		SELFBUFF()
		WAITTOFINISH()
		MOVE(-1903.32, 732.33)
		MOVE(-1905.24, 715.47)
		MOVE(-1919.69, 714.97)
		MOVE(-1929.09, 707.16)
		MOVE(-1946.94, 700)
		SWITCHTOHUMANFORM()
		SLEEP(1000)
		FLYUP(292.6)
	ELSE
		TRANSFERMAP($MAP_NEVERFALL, 0, -1819, 792)
	ENDIF
	SLEEP(1000)
	DIM $BOSSLOCATIONS[16][3] = [[-1745.91, 866.87, 295.28], [-1585.54, 829.69, 265.69], [-1487.94, 838.41, 259.82], [-1389.81, 820.49, 265.04], [-1334.34, 733.72, 280.5], [-1417.56, 658.03, 280.5], [-1430.22, 459.1, 285.77], [-1424.69, 349.29, 276.81], [-1331.47, 274.65, 261.28], [-1244.44, 270.55, 230.55], [-1223.77, 361.64, 209.18], [-1138.1, 416.96, 209.18], [-1200.39, 478.42, 217.4], [-1193.55, 625.31, 232.09], [-1257.97, 732.2, 238.17], [-1316.06, 770.77, 249.21]]
	$PLAYERPOS = PLAYERPOS()
	SWITCHTOHUMANFORM()
	SLEEP(1000)
	$SPARKTIMER = TIMERINIT()
	DIM $CHARMOFNOTIONSIDS[6] = [5477, 5481, 5480, 5479, 5478, 5482]
	WHILE HASQUEST(47166)
		FOR $I = 0 TO UBOUND($BOSSLOCATIONS) - 1
			SETSTATUS("Check pos " & $I & " at " & $BOSSLOCATIONS[$I][0] & ", " & $BOSSLOCATIONS[$I][1] & ", " & $BOSSLOCATIONS[$I][2])
			GENIECHISKILL(399)
			IF NOT HASQUEST(47166) THEN EXITLOOP
			FLYUP($BOSSLOCATIONS[$I][2])
			MOVE2($BOSSLOCATIONS[$I][0], $BOSSLOCATIONS[$I][1], $BOSSLOCATIONS[$I][2], 0)
			$PLAYERS = PLAYERARRAY()
			$GUNA = GETNPCUNIQUEID("Rebel Valkyrie Guna")
			$ROTA = GETNPCUNIQUEID("Rebel Valkyrie Rota")
			$GUNANEARBYPLAYERCOUNT = ISCROWDED2("Rebel Valkyrie Guna")
			$ROTANEARBYPLAYERCOUNT = ISCROWDED2("Rebel Valkyrie Rota")
			$SPARKEDYET = FALSE
			$SPARKTIMER = 0
			IF $GUNA AND $GUNANEARBYPLAYERCOUNT == 0 THEN
				USEANCIENTGIFT()
				SETSTATUS("Hero Spirit: Guna boss spotted and available to kill.")
				FOR $J = 1 TO 4
					IF GETNPCUNIQUEID("Rebel Valkyrie Guna") THEN
						$BOSPOS = GETNPCPOSITION("Rebel Valkyrie Guna")
						$PLAYERPOS = PLAYERPOS()
						IF $J == 1 OR $J == 2 THEN
							MOVE($BOSPOS[0], $BOSPOS[1])
							FLYUP($BOSPOS[2])
						ELSEIF $J == 3 OR $J == 4 THEN
							MOVEANDOVERSHOOTTARGET($BOSPOS[0], $BOSPOS[1], 0.5)
						ENDIF
						SLEEP(100)
					ELSE
						EXITLOOP
					ENDIF
				NEXT
				$SEEKEREQUIPATTACK = TRUE
				$SEEKEREQUIPDEF = TRUE
				$SEEKERATTACKGEARTIMER = 0
				$SINTIMER = TIMERINIT()
				$CLERICTIMER = 0
				$SINUSECANCELACTION = FALSE
				$CHARMOFNOTIONSTIMER = 0
				IF CLASS() == 7 AND INHUMANFORM() THEN
					SWITCHTOSECONDFORM()
					SLEEP(1000)
				ENDIF
				WHILE GETNPCUNIQUEID("Rebel Valkyrie Guna")
					BUFFCHECK()
					IF NOT HASQUEST(47166) THEN EXITLOOP
					IF CLASS() == 5 AND(CURRENTSKILL() == 3777 OR(CURRENTSKILL() == 0 AND QUEUEDSKILL() == 3777)) AND TIMERDIFF($SINTIMER) > 140 THEN
						CANCELACTION()
						$SINTIMER = TIMERINIT()
					ENDIF
					IF CLASS() == 8 AND NOT HASBUFF("Attack Level increased", 135) THEN
						IF TIMERDIFF($SEEKERATTACKGEARTIMER) > 29000 OR $SEEKERATTACKGEARTIMER == 0 THEN
							$SEEKEREQUIPDEF = TRUE
							$SEEKERATTACKGEARTIMER = TIMERINIT()
						ENDIF
						IF $SEEKEREQUIPDEF == TRUE THEN
							SWAPGEAR(2)
							$SEEKEREQUIPDEF = FALSE
							$SEEKEREQUIPATTACK = TRUE
						ENDIF
					ELSEIF CLASS() == 8 AND HASBUFF("Attack Level increased", 135) AND $SEEKEREQUIPATTACK == TRUE THEN
						SWAPGEAR(0)
						$SEEKEREQUIPATTACK = FALSE
						$SEEKERATTACKGEARTIMER = TIMERINIT()
					ENDIF
					IF CLASS() == 7 AND NOT HASBUFF("Focus Accelerated channeling", 37) THEN
						IF $CLERICTIMER == 0 THEN
							IF SKILLOFFCOOLDOWN(566) THEN
								USESKILL(566, PLAYERID())
							ENDIF
							$CLERICTIMER = TIMERINIT()
						ELSEIF TIMERDIFF($CLERICTIMER) > 10500 THEN
							IF SKILLOFFCOOLDOWN(566) THEN
								USESKILL(566, PLAYERID())
							ENDIF
							$CLERICTIMER = TIMERINIT()
						ENDIF
					ENDIF
					IF CLASS() == 7 AND HASBUFF("Specific skill's damage is increased.", 366) THEN
						USESKILL(921, $GUNA)
					ENDIF
					IF CLASS() == 7 AND($CHARMOFNOTIONSTIMER == 0 OR TIMERDIFF($CHARMOFNOTIONSTIMER) > 15000) THEN
						$CHARMOFNOTIONSTIMER2 = TIMERINIT()
						WHILE TIMERDIFF($CHARMOFNOTIONSTIMER2) < 1000
							IF GETNPCUNIQUEID("Rebel Valkyrie Guna") AND PLAYERTARGET() == GETNPCUNIQUEID("Rebel Valkyrie Guna") THEN
								CASTFIRSTSKILL($CHARMOFNOTIONSIDS)
							ENDIF
							SLEEP(100)
						WEND
						$CHARMOFNOTIONSTIMER = TIMERINIT()
					ENDIF
					IF CHI() > 300 AND TIMERDIFF($SPARKTIMER) > 17000 THEN
						WHILE CHI() > 300
							TRIPLESPARK()
							SLEEP(50)
						WEND
						CASTFIRSTSKILL($CHARMOFNOTIONSIDS)
						SLEEP(1000)
						$SPARKTIMER = TIMERINIT()
					ENDIF
					KILL("Rebel Valkyrie Guna", 100, 2, 3)
					IF RESURRECTIFDEAD() THEN
						$I = RANDOM(0, 15)
						FLY($BOSSLOCATIONS[$I][0], $BOSSLOCATIONS[$I][1], $BOSSLOCATIONS[$I][2], 0)
						FLYUP($BOSSLOCATIONS[$I][2])
						EXITLOOP
					ENDIF
					SLEEP(100)
				WEND
				SWITCHTOHUMANFORM()
				SLEEP(1000)
				IF $I < 4 THEN
					$I = 15
					CONTINUELOOP
				ENDIF
			ELSEIF $ROTA AND $ROTANEARBYPLAYERCOUNT == 0 THEN
				USEANCIENTGIFT()
				SETSTATUS("Hero Spirit: Rota boss spotted and available to kill.")
				FOR $J = 1 TO 4
					IF GETNPCUNIQUEID("Rebel Valkyrie Rota") THEN
						$BOSPOS = GETNPCPOSITION("Rebel Valkyrie Rota")
						IF $J == 1 OR $J == 2 THEN
							MOVE($BOSPOS[0], $BOSPOS[1])
							FLYUP($BOSPOS[2])
						ELSEIF $J == 3 OR $J == 4 THEN
							MOVE($BOSPOS[0], $BOSPOS[1])
						ENDIF
						SLEEP(100)
					ELSE
						EXITLOOP
					ENDIF
				NEXT
				$SEEKEREQUIPATTACK = TRUE
				$SEEKEREQUIPDEF = TRUE
				$SEEKERATTACKGEARTIMER = 0
				$SINTIMER = TIMERINIT()
				$CLERICTIMER = 0
				$SINUSECANCELACTION = FALSE
				$CHARMOFNOTIONSTIMER = 0
				IF CLASS() == 7 AND INHUMANFORM() THEN
					SWITCHTOSECONDFORM()
					SLEEP(1000)
				ENDIF
				WHILE GETNPCUNIQUEID("Rebel Valkyrie Rota")
					BUFFCHECK()
					IF CLASS() == 5 AND(CURRENTSKILL() == 3777 OR(CURRENTSKILL() == 0 AND QUEUEDSKILL() == 3777)) AND TIMERDIFF($SINTIMER) > 140 THEN
						CANCELACTION()
						$SINTIMER = TIMERINIT()
					ENDIF
					IF CLASS() == 8 AND NOT HASBUFF("Attack Level increased", 135) THEN
						IF TIMERDIFF($SEEKERATTACKGEARTIMER) > 29000 OR $SEEKERATTACKGEARTIMER == 0 THEN
							$SEEKEREQUIPDEF = TRUE
							$SEEKERATTACKGEARTIMER = TIMERINIT()
						ENDIF
						IF $SEEKEREQUIPDEF == TRUE THEN
							SWAPGEAR(2)
							$SEEKEREQUIPDEF = FALSE
							$SEEKEREQUIPATTACK = TRUE
						ENDIF
					ELSEIF CLASS() == 8 AND HASBUFF("Attack Level increased", 135) AND $SEEKEREQUIPATTACK == TRUE THEN
						SWAPGEAR(0)
						$SEEKEREQUIPATTACK = FALSE
						$SEEKERATTACKGEARTIMER = TIMERINIT()
					ENDIF
					IF CLASS() == 7 AND NOT HASBUFF("Focus Accelerated channeling", 37) THEN
						IF $CLERICTIMER == 0 THEN
							IF SKILLOFFCOOLDOWN(566) THEN
								USESKILL(566, PLAYERID())
							ENDIF
							$CLERICTIMER = TIMERINIT()
						ELSEIF TIMERDIFF($CLERICTIMER) > 10500 THEN
							IF SKILLOFFCOOLDOWN(566) THEN
								USESKILL(566, PLAYERID())
							ENDIF
							$CLERICTIMER = TIMERINIT()
						ENDIF
					ENDIF
					IF CLASS() == 7 AND HASBUFF("Specific skill's damage is increased.", 366) THEN
						USESKILL(921, $ROTA)
					ENDIF
					IF CLASS() == 7 AND($CHARMOFNOTIONSTIMER == 0 OR TIMERDIFF($CHARMOFNOTIONSTIMER) > 15000) THEN
						$CHARMOFNOTIONSTIMER2 = TIMERINIT()
						WHILE TIMERDIFF($CHARMOFNOTIONSTIMER2) < 1000
							IF GETNPCUNIQUEID("Rebel Valkyrie Rota") AND PLAYERTARGET() == GETNPCUNIQUEID("Rebel Valkyrie Rota") THEN
								CASTFIRSTSKILL($CHARMOFNOTIONSIDS)
							ENDIF
							SLEEP(100)
						WEND
						$CHARMOFNOTIONSTIMER = TIMERINIT()
					ENDIF
					IF NOT HASQUEST(47166) THEN EXITLOOP
					IF CHI() > 300 AND TIMERDIFF($SPARKTIMER) > 17000 THEN
						WHILE CHI() > 300
							TRIPLESPARK()
							SLEEP(50)
						WEND
						CASTFIRSTSKILL($CHARMOFNOTIONSIDS)
						SLEEP(1000)
						$SPARKTIMER = TIMERINIT()
					ENDIF
					KILL("Rebel Valkyrie Rota", 100, 2, 3)
					IF RESURRECTIFDEAD() THEN
						$I = RANDOM(0, 15)
						FLY($BOSSLOCATIONS[$I][0], $BOSSLOCATIONS[$I][1], $BOSSLOCATIONS[$I][2], 0)
						FLYUP($BOSSLOCATIONS[$I][2])
						EXITLOOP
					ENDIF
					SLEEP(100)
				WEND
				$SPARKTIMER = 0
				SWITCHTOHUMANFORM()
				SLEEP(1000)
				IF $I >= 4 THEN
					$I = 12
					CONTINUELOOP
				ENDIF
			ENDIF
			IF NOT HASQUEST(47166) THEN
				EXITLOOP
			ENDIF
			IF RESURRECTIFDEAD() THEN
				$I = RANDOM(0, 15)
				FLY($BOSSLOCATIONS[$I][0], $BOSSLOCATIONS[$I][1], $BOSSLOCATIONS[$I][2], 0)
				CONTINUELOOP
			ENDIF
			SLEEP(100)
		NEXT
		SLEEP(100)
	WEND
	SETSTATUS("Neverfall - Hero Spirit: Done.")
ENDFUNC
DIM $ADVENTUREKINGDOMGAMETELEPORTS[15][5] = [["Whack-A-Mole Manager", 0, -296.02, 87.86, 17], ["Shooting Gallery Manager", 0, -520.93, -448.09, 17], ["Drift Race Manager", 0, -805.41, -149, 17], ["Eye of Jade Manager", 0, -214.91, -37.49, 17], ["Pterosaur's Flight Manager", 0, -208.15, -208.91], ["Whirling Flash Manager", 0, -350.23, 97.11, 17], ["Kraken's Vengeance Manager", 0, -334.4, 169.04, 17], ["Horizon Leap Manager", 0, -618.24, 159.19, 17], ["Goldfish Flower Manager", 0, -535.59, -55.94, 17], ["Teleporter Yeon", 0, -520.77, -44.86, 17], ["Teleport Mushi", 0, -328.62, 33.54, 17], ["Teleporter Gevis", 0, -897.98, -200.66, 17], ["Teleporter Safrey", 0, -447.87, -341.75, 17], ["Teleporter Lanz", 0, -593.48, 139.5, 17], ["Teleporter Kooh", 0, -797.27, 224.5, 17]]
DIM $ADVENTUREKINGDOMRIDETELEPORTS[12][5] = [["Eye of Jade Manager", 0, -214.91, -37.49, 17], ["Pterosaur's Flight Manager", 0, -208.15, -208.91], ["Whirling Flash Manager", 0, -350.23, 97.11, 17], ["Kraken's Vengeance Manager", 0, -334.4, 169.04, 17], ["Horizon Leap Manager", 0, -618.24, 159.19, 17], ["Goldfish Flower Manager", 0, -535.59, -55.94, 17], ["Teleporter Yeon", 0, -520.77, -44.86, 17], ["Teleport Mushi", 0, -328.62, 33.54, 17], ["Teleporter Gevis", 0, -897.98, -200.66, 17], ["Teleporter Safrey", 0, -447.87, -341.75, 17], ["Teleporter Lanz", 0, -593.48, 139.5, 17], ["Teleporter Kooh", 0, -797.27, 224.5, 17]]
FUNC DORIDE($RIDEID, $MANAGER, $QUEST, $NEXTQUEST)
	WAITFORNPC($MANAGER)
	SWITCHTOHUMANFORM()
	SLEEP(1000)
	$TIMER = TIMERINIT()
	$POS = PLAYERPOS()
	$ALREADYTRIEDTOUNGLITCH = FALSE
	FOR $I = 1 TO 2
		SETSTATUS("Trying to ride: " & STRINGTRIMRIGHT($MANAGER, STRINGLEN(" Manager")) & " #" & $I)
		TALKTONPC($MANAGER, 2, TRUE, FALSE)
		SLEEP(1000)
		WHILE NOT HASQUEST($QUEST)
			IF TIMERDIFF($TIMER) > 120000 AND $ALREADYTRIEDTOUNGLITCH == FALSE THEN
				SETSTATUS("Waited over 2 min to try and ride. Possibly something wrong. Will unglitch by transfering map.")
				ADVENTUREKINGDOMUNGLITCH()
				$ALREADYTRIEDTOUNGLITCH = TRUE
				TALKTONPC($MANAGER, 2, TRUE, FALSE)
				SLEEP(1000)
				$TIMER = TIMERINIT()
			ENDIF
			IF TIMERDIFF($TIMER) > 300000 THEN
				SETSTATUS("Waited over 5 min to try and ride. Already tried unglitching. Something has gone wrong. Continuing with other rides.")
				EXITLOOP
			ENDIF
			$SEAT = RANDOM(0, 7, 1)
			SENDENTERVEHICLE(NPCID($RIDEID), $SEAT)
			SLEEP(5000)
		WEND
		WHILE HASQUEST($QUEST)
			SETSTATUS("Riding: " & STRINGTRIMRIGHT($MANAGER, STRINGLEN(" Manager")) & " #" & $I)
			$ALREADYTRIEDTOUNGLITCH = FALSE
			SLEEP(1000)
		WEND
		SLEEP(1000)
		$TIMER = TIMERINIT()
		$POS = PLAYERPOS()
	NEXT
	SETSTATUS("Moving to Next Ride")
	TALKTONPC($MANAGER, 2, TRUE, FALSE)
	SLEEP(500)
	TAKEQUEST($MANAGER, $NEXTQUEST)
	SLEEP(5000)
	CLOSENPCWINDOW()
	SLEEP(250)
ENDFUNC
FUNC DOALLADVENTURERIDES()
	ADVENTUREKINGDOMMAP()
	SETSTATUS("Adventure Kingdom Rides")
	DORIDE(57205, "Goldfish Flower Manager", 39240, 39231)
	DORIDE(56507, "Eye of Jade Manager", 39238, 39232)
	DORIDE(57445, "Pterosaur's Flight Manager", 39243, 39233)
	DORIDE(56506, "Whirling Flash Manager", 39242, 39236)
	DORIDE(56504, "Kraken's Vengeance Manager", 39239, 39234)
	DORIDE(56505, "Horizon Leap Manager", 39241, 39235)
	SETSTATUS("Finished rides.")
ENDFUNC
FUNC DOALLADVENTUREKINGDOM()
	ADVENTUREKINGDOMMAP()
	$REQUIRETICKET = TRUE
	DIVINATIONOFLUCK()
	USEMESSAGEHOOK()
	DOALLADVENTURERIDES()
	WHILE ITEMCOUNT(56690)
		SHOOTINGGALLERY()
	WEND
	WHILE ITEMCOUNT(56691)
		WACKAMOLE()
	WEND
	WHILE ITEMCOUNT(56692)
		DRIFTRACE($REQUIRETICKET)
	WEND
	WHILE ITEMCOUNT(56693)
		TIGERGAUNTLET()
	WEND
	DOALLTUROQUESTS()
ENDFUNC
FUNC WLDTICKETS()
	ADVENTUREKINGDOMMAP()
	$REQUIRETICKET = TRUE
	DIVINATIONOFLUCK()
	WHILE ITEMCOUNT(56690)
		SHOOTINGGALLERY()
	WEND
	WHILE ITEMCOUNT(56691)
		WACKAMOLE()
	WEND
	WHILE ITEMCOUNT(56692)
		DRIFTRACE($REQUIRETICKET)
	WEND
	WHILE ITEMCOUNT(56693)
		TIGERGAUNTLET()
	WEND
	AUTOBANKDAILY()
	ENTERMYHOME()
ENDFUNC
FUNC PRINTRIDES()
	DIM $RIDEIDS[6] = [57205, 56507, 57445, 56506, 56504, 56505]
	FOR $I = 0 TO 5
		WHILE NOT NPCID($RIDEIDS[$I])
			SLEEP(1000)
		WEND
		$POS = GETNPCPOSITION($RIDEIDS[$I], 1)
		PRINT($I & ": " & HEX(NPCID($RIDEIDS[$I]), 8) & "   " & ROUND($POS[0], 2) & "," & ROUND($POS[1], 2) & ", " & ROUND($POS[2], 2))
	NEXT
ENDFUNC
FUNC ISDRIFTCAR($ARRAY, $I)
	IF DISTANCE2D($ARRAY[$I][4], $ARRAY[$I][5]) < 1 THEN
		RETURN FALSE
	ENDIF
	IF $ARRAY[$I][2] == "Drift Penguin Car" OR $ARRAY[$I][2] == "Drift Pig Car" OR $ARRAY[$I][2] == "Drift Coocoo Car" THEN
		RETURN TRUE
	ENDIF
	RETURN FALSE
ENDFUNC
FUNC DRIFTRACE3()
	$REQUIRETICKET = FALSE
	DRIFTRACE($REQUIRETICKET)
ENDFUNC
FUNC DRIFTRACE2()
	WHILE ITEMCOUNT(56692)
		$REQUIRETICKET = TRUE
		DRIFTRACE($REQUIRETICKET)
	WEND
ENDFUNC
FUNC DRIFTRACE($REQUIRETICKET)
	IF ITEMCOUNT(56692) == 0 AND $REQUIRETICKET == TRUE THEN
		SETSTATUS("Drift Race: No required item.")
		RETURN
	ENDIF
	$USEDHUMANFORM = FALSE
	ADVENTUREKINGDOMMAP()
	SETSTATUS("Heading to Drift Race")
	IF NOT GETNPCUNIQUEID("Surrounding Ribbon") THEN
		TAKENEARESTQUEST($ADVENTUREKINGDOMGAMETELEPORTS, 39312)
		WAITFORNPC("Surrounding Ribbon")
	ENDIF
	FLY(RANDOM(-806, -786.2), RANDOM(-150, -145), 8)
	WAITSTOP(1)
	SWITCHTOHUMANFORM()
	SLEEP(500)
	WAITFORNPC("Surrounding Ribbon")
	IF NOT GETNPCUNIQUEID("Surrounding Ribbon") THEN
		SETSTATUS("Waiting for Drift Race to open")
		WAITINHOMESTEADFORNPCHOUR("Drift Race Manager", 2)
	ENDIF
	STARTLISTENING()
	SETSTATUS("Trying to Sign Up for Drift Race")
	WHILE NOT INVEHICLE() AND DISTANCE2D(-813.85, -99.82) > 35
		SWITCHTOHUMANFORM()
		SLEEP(500)
		SENDPACKET("2300" & _HEX(GETNPCUNIQUEID("Surrounding Ribbon")), 6, $GAME_PID)
		SLEEP(1000)
		WHILE NOT SEETEXT("Sign-up Successful") AND NOT INVEHICLE() AND DISTANCE2D(-813.85, -99.82) > 35
			SWITCHTOHUMANFORM()
			SLEEP(500)
			SENDPACKET("250071000000" & _HEX(8) & _HEX(3) & _HEX(1), 18, $GAME_PID)
			SLEEP(3000)
		WEND
		IF GETNPCUNIQUEID("Drift Coocoo Car") THEN
			EXITLOOP
		ELSE
			SETSTATUS("No cars at Drift Race, waiting for next round")
			WAITFORNPC("Drift Coocoo Car")
		ENDIF
	WEND
	SETSTATUS("Waiting for Drift Race to begin")
	WHILE NOT INVEHICLE() AND DISTANCE2D(-813.85, -99.82) > 35
		SLEEP(100)
	WEND
	WHILE NOT INVEHICLE()
		MOVETO2(-813.85, -99.82)
		SWITCHTOHUMANFORM()
		SLEEP(500)
	WEND
	DIM $LASTPOS[3] = [0, 0, 0]
	$STUNTIMER = 0
	$CHECKTIMER = 0
	SETSTATUS("In Drift Race")
	WHILE INVEHICLE()
		$HEALPOS = GETNPCPOSITION("Heal")
		$POS = PLAYERPOS()
		IF AVOID("Reduce HP", 10, 14, 2, FALSE) THEN
			$CHECKTIMER = 0
			SLEEP(100)
		ELSEIF AVOID("Freeze", 10, 14, 2, FALSE) THEN
			$CHECKTIMER = 0
			SLEEP(100)
		ELSEIF UBOUND($HEALPOS) AND DISTANCE2D($HEALPOS[0], $HEALPOS[1]) < 20 THEN
			$CHECKTIMER = 0
			IF DISTANCE2D($HEALPOS[0], $HEALPOS[1]) > 1 THEN
				MOVETO2($HEALPOS[0], $HEALPOS[1], -1, 0, FALSE)
			ENDIF
		ELSE
			$MOBS = NPCARRAY()
			$I = FINDCLOSEST($MOBS, "FUNC:IsDriftCar")
			IF $I <> -1 THEN
				IF $CHECKTIMER AND TIMERDIFF($CHECKTIMER) > 300 THEN
					IF(DISTANCEBETWEEN3D($POS, $LASTPOS) / TIMERDIFF($CHECKTIMER)) * 1000 < 3 THEN
						$STUNTIMER = TIMERINIT()
					ELSE
						$STUNTIMER = 0
					ENDIF
					$CHECKTIMER = 0
				ENDIF
				IF $STUNTIMER AND TIMERDIFF($STUNTIMER) < 3000 THEN
					CIRCLEAVOID($MOBS[$I][0], 15, 22, -813.69, -99.68, 36, 0, 10, FALSE, 0, FALSE)
				ELSE
					$STUNTIMER = 0
					MOVETO2($MOBS[$I][4], $MOBS[$I][5], -1, 0, FALSE)
					IF DISTANCE2D($MOBS[$I][4], $MOBS[$I][5]) > 2 AND $CHECKTIMER == 0 AND $STUNTIMER == 0 THEN
						$CHECKTIMER = TIMERINIT()
						$LASTPOS = $POS
					ENDIF
				ENDIF
			ENDIF
		ENDIF
		SLEEP(350)
	WEND
	SLEEP(RANDOM(1000, 6000, 1))
	SETSTATUS("Finished.")
ENDFUNC
FUNC SHOOTINGGALLERY2()
	WHILE ITEMCOUNT(56690)
		SHOOTINGGALLERY()
	WEND
ENDFUNC
FUNC SHOOTINGGALLERY()
	IF ITEMCOUNT(56690) == 0 THEN
		SETSTATUS("Shooting Gallery: No required item.")
		RETURN
	ENDIF
	ADVENTUREKINGDOMMAP()
	IF NOT GETNPCUNIQUEID("Shooting Gallery Manager") THEN
		TAKENEARESTQUEST($ADVENTUREKINGDOMGAMETELEPORTS, 39313)
		WAITFORNPC("Shooting Gallery Manager")
	ENDIF
	WAITFORNPC("Shooting Gallery Manager")
	IF NOT GETNPCUNIQUEID("Shooting Gallery Manager") THEN
		SETSTATUS("Waiting for Shooting Gallery to Open (npc not up yet)")
		WAITINHOMESTEADFORNPCHOUR(56648, 1)
	ENDIF
	SWITCHTOHUMANFORM()
	SLEEP(500)
	TAKEQUEST("Shooting Gallery Manager", 39016, -519.48, -450.37, 55, TRUE, FALSE)
	SLEEP(2000)
	WHILE NOT HASQUEST(39016)
		ENTERHOME(PLAYERID())
		WHILE @MIN <> 1
			SLEEP(30000)
		WEND
		SLEEP(RANDOM(60000, 200000))
		EXITHOME()
		SLEEP(10000)
		TAKEQUEST("Shooting Gallery Manager", 39016, -519.48, -450.37, 55, TRUE, FALSE)
		SLEEP(2000)
	WEND
	DO
		$MOBS = NPCARRAY()
		_ARRAYSHUFFLE($MOBS)
		FOR $I = 0 TO UBOUND($MOBS) - 1
			IF $MOBS[$I][1] == 56606 THEN
				SENDENTERVEHICLE($MOBS[$I][0], 0)
				SLEEP(1300)
				EXITLOOP
			ENDIF
		NEXT
	UNTIL INVEHICLE()
	SETSTATUS("Doing Shooting Gallery")
	WHILE INVEHICLE() AND((HASQUEST(39265) AND QUESTPERCENT(39265) < 71) OR(HASQUEST(39018) AND QUESTPERCENT(39018) < 71))
		$TARGET = GETNPCUNIQUEID("NoName 57364", 60)
		IF $TARGET == 0 THEN $TARGET = GETNPCUNIQUEID("NoName 57497", 60)
		IF $TARGET == 0 THEN $TARGET = GETNPCUNIQUEID("NoName 57279", 60)
		IF $TARGET > 0 THEN
			SELECTTARGET($TARGET)
			SLEEP(50)
			USEVEHICLESKILL(4679, $TARGET)
		ENDIF
		SLEEP(100)
	WEND
	WHILE HASQUEST(39265) OR HASQUEST(39018)
		SETSTATUS("Shooting Gallery Score: " & ROUND(QUESTPERCENT(39018)))
		SLEEP(1000)
	WEND
	WHILE INVEHICLE()
		SLEEP(1000)
	WEND
	SLEEP(2000)
	SETSTATUS("Finished.")
ENDFUNC
FUNC WACKAMOLE2()
	WHILE ITEMCOUNT(56691)
		WACKAMOLE()
	WEND
ENDFUNC
FUNC WACKAMOLE()
	IF ITEMCOUNT(56691) == 0 THEN
		SETSTATUS("Whack-A-Mole: No required item.")
		RETURN
	ENDIF
	ADVENTUREKINGDOMMAP()
	SETSTATUS("Heading to Whack-A-Mole")
	IF NOT GETNPCUNIQUEID("Whack-A-Mole Manager") THEN
		TAKENEARESTQUEST($ADVENTUREKINGDOMGAMETELEPORTS, 39311)
		WAITFORNPC("Whack-A-Mole Manager")
	ENDIF
	WAITFORNPC("Whack-A-Mole Manager")
	IF NOT GETNPCUNIQUEID("Whack-A-Mole Manager") THEN
		SETSTATUS("Waiting for Whack-A-Mole to Open (npc not there yet)")
		WAITINHOMESTEADFORNPCHOUR(56649, 1)
	ENDIF
	IF NOT ISQUESTAVAILABLE(39122) THEN
		SETSTATUS("Waiting for Whack-A-Mole to Open (quest not available yet)")
		WAITINHOMESTEADFORNPCHOUR(56649, 1)
	ENDIF
	SWITCHTOHUMANFORM()
	SLEEP(500)
	TAKEQUEST("Whack-A-Mole Manager", 39122, -296.02, 87.86, 55, TRUE, FALSE)
	SLEEP(2000)
	WHILE NOT HASQUEST(39122)
		ENTERHOME(PLAYERID())
		WHILE @MIN <> 1
			SLEEP(30000)
		WEND
		SLEEP(RANDOM(60000, 200000))
		EXITHOME()
		SLEEP(10000)
		TAKEQUEST("Whack-A-Mole Manager", 39122, -296.02, 87.86, 55, TRUE, FALSE)
		SLEEP(2000)
	WEND
	DO
		$MOBS = NPCARRAY()
		_ARRAYSHUFFLE($MOBS)
		FOR $I = 0 TO UBOUND($MOBS) - 1
			IF $MOBS[$I][1] == 56542 THEN
				SENDENTERVEHICLE($MOBS[$I][0], 0)
				SLEEP(1300)
				EXITLOOP
			ENDIF
		NEXT
	UNTIL INVEHICLE()
	SETSTATUS("Doing Whack-A-Mole")
	$POS = PLAYERPOS()
	STARTLISTENING()
	WHILE INVEHICLE() AND((HASQUEST(39210) AND QUESTPERCENT(39210) < 161) OR(HASQUEST(39122) AND QUESTPERCENT(39122) < 161))
		$ARRAY = NPCARRAY()
		FOR $I = 0 TO UBOUND($ARRAY) - 1
			IF DISTANCEBETWEEN($POS[0], $POS[1], $ARRAY[$I][4], $ARRAY[$I][5]) < 5 THEN
				SELECTTARGET($ARRAY[$I][0])
				SLEEP(50)
				USEVEHICLESKILL(4365, $ARRAY[$I][0])
				SLEEP(50)
				IF SEETEXT("^9AA6FFVehicle Skill is in cooldown") THEN
					SLEEP(300)
				ENDIF
			ENDIF
		NEXT
		SLEEP(50)
	WEND
	WHILE HASQUEST(39210) OR HASQUEST(39122)
		SETSTATUS("Whack-A-Mole Score: " & ROUND(QUESTPERCENT(39122)))
		SLEEP(1000)
	WEND
	WHILE INVEHICLE()
		SLEEP(1000)
	WEND
	SLEEP(2000)
	SETSTATUS("Finished.")
ENDFUNC
DIM $TURO_NPCS[10][6] = [["Little Boy", 38928, -910.94, -430.71, 17, 0], ["Cupid", 38932, -774.23, -303.2, 17, 0], ["Rabbit Doctor", 38929, -722.36, -329.9, 17, 0], ["Whirling Maiden", 38931, -444.61, -337.16, 17, 0], ["Mr. Ape", 38930, -552.9, -160.22, 17, 0], ["Tan the Panda", 38935, -410.04, 108.83, 17, 0], ["Pele the Emperor Penguin", 38933, -205.37, 122.01, 17, 0], ["Artes", 38937, -527.38, 359.21, 17, 0], ["Leroin", 38936, -625.33, 284.82, 17, 0], ["Savagian Elder", 38925, -575.65, 131.35, 17, 0]]
GLOBAL $HTUROTIMER = 0
FUNC RESETTURO()
	$HTUROTIMER = 0
	FOR $I = 0 TO UBOUND($TURO_NPCS) - 1
		$TURO_NPCS[$I][5] = 0
	NEXT
ENDFUNC
FUNC DOALLTUROQUESTS()
	FINDTUROQUESTS(FALSE, 1)
ENDFUNC
FUNC DOALLTUROQUESTS2()
	FINDTUROQUESTS(FALSE, 7)
ENDFUNC
FUNC DOALLTUROQUESTS3()
	FINDTUROQUESTS(FALSE, 7)
ENDFUNC
FUNC DOALLTUROQUESTS4()
	FINDTUROQUESTS(FALSE, 1)
ENDFUNC
FUNC DOONLYCANDYQUESTS()
	FINDTUROQUESTS(TRUE)
ENDFUNC
FUNC COUNTADVENTUREORDERS()
	$COUNT = ITEMCOUNT(57871)
	RETURN $COUNT
ENDFUNC
FUNC TUROQUESTCOUNT()
	DIM $RESULTS[3] = [0, 0, 0]
	$COUNT = 0
	$QUESTS = QUESTARRAY()
	FOR $I = 0 TO UBOUND($TURO_NPCS) - 1
		$CODE = ISQUESTAVAILABLE($TURO_NPCS[$I][1])
		IF $CODE == 21 THEN
			$RESULTS[0] += 1
			IF $I == 0 OR $I == 2 OR $I == 4 THEN
				$RESULTS[1] += 1
			ENDIF
		ELSEIF $CODE == 0 THEN
			$RESULTS[2] += 1
		ENDIF
	NEXT
	RETURN $RESULTS
ENDFUNC
FUNC FINDTUROQUESTS($DOCANDY, $MAXREPEATCOUNT = 1)
	$REPEATS = 0
	$RESULTS = TUROQUESTCOUNT()
	SETSTATUS("Will check up to " & $MAXREPEATCOUNT & " times over " & $MAXREPEATCOUNT & " hours to obtain turo adventure items.")
	$INITIALCOUNT = COUNTADVENTUREORDERS()
	$COUNT = COUNTADVENTUREORDERS() - $INITIALCOUNT
	WHILE $REPEATS < $MAXREPEATCOUNT
		IF $COUNT >= 10 THEN
			SETSTATUS("We looked for Turo Quests " & $REPEATS & " times so far and collected " & $COUNT & " turo adventure orders. All done for the day.")
			RETURN
		ENDIF
		IF INHOMESTEAD() THEN
			EXITHOME()
			SLEEP(5000)
		ENDIF
		$INSTANCE = INSTANCEID()
		IF $INSTANCE <> 191 THEN
			IF NOT ISADVENTUREKINGDOMOPEN() THEN RETURN
			SETSTATUS("Starting Turo Quest Search")
			TRANSFERMAP($MAP_ADVENTUREKINGDOM)
		ENDIF
		IF $HTUROTIMER == 0 THEN
			$HTUROTIMER = TIMERINIT()
		ELSE
			$NEEDED = 3600 * 1000 - TIMERDIFF($HTUROTIMER)
			IF $NEEDED > 0 THEN
				SETSTATUS("Finding Turo Quests - Waiting for timer to hit 1 hour")
				ENTERHOME(PLAYERID())
				SLEEP($NEEDED)
				EXITHOME()
			ENDIF
			$HTUROTIMER = TIMERINIT()
		ENDIF
		SLEEP(5000)
		IF INHOMESTEAD() THEN EXITHOME()
		SWITCHTOHUMANFORM()
		SLEEP(100)
		FINISHTUROQUESTS()
		FLYUP()
		SETSTATUS("Finding Turo Quests")
		$RANDOFFSET = RANDOM(0, 9, 1)
		FOR $I = 0 TO UBOUND($TURO_NPCS) - 1
			$J = MOD($I + $RANDOFFSET, UBOUND($TURO_NPCS))
			IF $DOCANDY AND $J <> 0 AND $J <> 2 AND $J <> 4 THEN
				CONTINUELOOP
			ENDIF
			IF HASQUEST($TURO_NPCS[$J][1]) OR ISQUESTAVAILABLE($TURO_NPCS[$J][1]) THEN
				SETSTATUS("Checking Turo Quest - " & $TURO_NPCS[$J][0])
				FLY($TURO_NPCS[$J][2], $TURO_NPCS[$J][3], $TURO_NPCS[$J][4], 0)
				IF GETNPCUNIQUEID($TURO_NPCS[$J][0]) THEN
					DROPDOWN()
					MOVETONPC($TURO_NPCS[$J][0])
					IF GETNPCUNIQUEID($TURO_NPCS[$J][0]) THEN
						TAKEQUEST($TURO_NPCS[$J][0], $TURO_NPCS[$J][1])
						$TURO_NPCS[$J][5] = 1
						FINISHTUROQUESTS()
					ENDIF
					FLYUP()
				ENDIF
			ELSEIF NOT ISQUESTAVAILABLE($TURO_NPCS[$J][1]) THEN
				$TURO_NPCS[$J][5] = 1
			ENDIF
		NEXT
		$REPEATS += 1
		$COUNT = COUNTADVENTUREORDERS() - $INITIALCOUNT
		SETSTATUS("We looked for Turo Quests " & $REPEATS & " times so far and collected " & $COUNT & " turo adventure orders.")
		UPDATEADVENTUREKINGDOM()
	WEND
ENDFUNC
FUNC FINISHTUROQUESTS($DOALL = FALSE)
	ADVENTUREKINGDOMMAP()
	IF INHOMESTEAD() THEN
		EXITHOME()
		SLEEP(5000)
	ENDIF
	$INSTANCE = INSTANCEID()
	IF $INSTANCE <> 191 THEN TRANSFERMAP($MAP_ADVENTUREKINGDOM)
	RABBITDOCTOR()
	LITTLEBOY()
	CUPID()
	MRAPE()
	WHIRLINGMAIDEN()
	PELE()
	TANPANDA()
	LEROIN()
	ARTES()
	SAVAGIAN()
ENDFUNC
FUNC SAVAGIAN()
	ADVENTUREKINGDOMMAP()
	IF NOT HASQUEST(38925) OR HASQUEST(38926) OR HASQUEST(38927) THEN RETURN
	SETSTATUS("Doing Turo Quest - Savagian")
	SENDPACKET("3E0049", 3, $GAME_PID)
	TURNINAUTOQUEST(38938, 1)
	FLYUP()
	FLY(-705.21, 108.51, 16)
	TURNINQUEST("Savagian Elder", 38939)
