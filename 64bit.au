			_SENDMESSAGE($HWND, $__WINAPICONSTANT_WM_SETFONT, $HFONT, $BREDRAW, 0, "hwnd")
		ENDFUNC
		FUNC _WINAPI_SETPARENT($HWNDCHILD, $HWNDPARENT)
			LOCAL $ACALL = DLLCALL("user32.dll", "hwnd", "SetParent", "hwnd", $HWNDCHILD, "hwnd", $HWNDPARENT)
