	FUNC RESETUPD3($MEMBERS, $SQUADLIST, $PERMITCHECKERBOARD = TRUE)
		$SQUADLIST = GETSQUADALTS()
		SETSTATUS("UPD: Resetting UPD run without using entrance items. Starting from final boss room. Will run into fire and release to town for fast reset.")
		$CLIENTSINDEXES = GETSQUADALTS()
		SWITCHTO($MAIN)
		MASSMOVETOCOORDENHANCED(-285.42, 293.03, $SQUADLIST)
		MASSMOVETOCOORDENHANCED(-280.38, 285.43, $SQUADLIST)
		SWITCHTO($MAIN)
		SLEEP(5000)
		MASSRESTOTOWN()
		SWITCHTO($MAIN)
		SLEEP(7000)
		CLERICHEAL($CLIENTSINDEXES)
		SLEEP(4000)
		CLERICHEAL($CLIENTSINDEXES)
		SLEEP(4000)
		CLERICHEAL($CLIENTSINDEXES)
		CANCELCLERICBB($CLIENTSINDEXES)
		SLEEP(3500)
		MASSMOVETOCOORDENHANCED(-371.088, -208.61, $SQUADLIST)
		MASSMOVETOCOORDENHANCED(-354.02, -175.38, $SQUADLIST)
		MASSMOVETOCOORDENHANCED(-332.82, -134.4, $SQUADLIST)
		MASSMOVETOCOORDENHANCED(-319.23, -147.66, $SQUADLIST)
		MASSMOVETOCOORD(-319.23, -147.66)
		MASSSWITCHTOHUMANFORM()
		SLEEP(2500)
		$GENIESREADY = FALSE
		$MAXTIMETOWAITFORGENIES = TIMERINIT()
		WHILE NOT $GENIESREADY
			$GENIESREADY = MASSGENIEENERGYCHECK($SQUADLIST, 75)
			IF TIMERDIFF($MAXTIMETOWAITFORGENIES) > 30000 THEN
				SETSTATUS("waited more than 30s for genies to be ready for holy path. continuing...")
				EXITLOOP
			ENDIF
			SLEEP(100)
		WEND
		MASSSpeedPATH($SQUADLIST)
		FOR $I = 0 TO UBOUND($SQUADLIST) - 1
			$INDEX = $SQUADLIST[$I]
			SWITCHTONUM($INDEX)
			TRUEJUMP()
		NEXT
		SLEEP(750)
		FOR $I = 0 TO UBOUND($SQUADLIST) - 1
			$INDEX = $SQUADLIST[$I]
			SWITCHTONUM($INDEX)
			TRUEJUMP()
		NEXT
		SLEEP(700)
		FOR $I = 0 TO UBOUND($SQUADLIST) - 1
			$INDEX = $SQUADLIST[$I]
			SWITCHTONUM($INDEX)
			MOVETO2(-290.54, -186.97)
		NEXT
		SLEEP(7000)
		FOR $I = 0 TO UBOUND($SQUADLIST) - 1
			$INDEX = $SQUADLIST[$I]
			SWITCHTONUM($INDEX)
			$JUMPTIMER = TIMERINIT()
			$POS = PLAYERPOS()
			WHILE $POS[2] > 82 AND DISTANCE2D(-290.54, -186.97) > 5
				IF TIMERDIFF($JUMPTIMER) > 45000 THEN
					SLEEP(5000)
					IF NOT TELEPORTINCENSE() THEN TOWNPORTAL()
					SLEEP(15000)
					UPDNAVIGATETOCOORD(-318.47, -104.03)
					MOVE2(-319.23, -147.66)
					SLEEP(500)
					$JUMPTIMER = TIMERINIT()
				ENDIF
				$POS = PLAYERPOS()
				IF $POS[2] <= 89 THEN
					MOVE5(-290.54, -186.97, -1, 0, TRUE, FALSE, 30000, 5, TRUE, 176, 29000)
				ELSEIF DISTANCE(-308.8, -161.08, 126.22) < 5 THEN
					CANCELACTION()
					SLEEP(1000)
					TRUEJUMP()
					MOVE5(-290.54, -186.97, -1, 0, TRUE, FALSE, 30000, 5, TRUE, 176, 29000)
				ELSEIF DISTANCE(-319.23, -147.66, 127.01) < 5 THEN
					CANCELACTION()
					SLEEP(1000)
					MOVETO2(-319.23, -147.66)
					SLEEP(2000)
					JUMPUPTHENMOVEUPD(-308.8, -161.08, -1, -1, -1, 2, -1, FALSE, 3, 30000, 3.5)
					SLEEP(1000)
					TRUEJUMP()
					MOVE5(-290.54, -186.97, -1, 0, TRUE, FALSE, 30000, 5, TRUE, 176, 29000)
				ELSE
					SLEEP(1000)
					IF NOT TELEPORTINCENSE() THEN TOWNPORTAL()
					SLEEP(15000)
					UPDNAVIGATETOCOORD(-318.47, -104.03)
					MOVE2(-319.23, -147.66)
					SLEEP(500)
					$JUMPTIMER = TIMERINIT()
				ENDIF
				SLEEP(100)
				$POS = PLAYERPOS()
			WEND
		NEXT
		SWITCHTO($MAIN)
		$FASTRESETTIMING = FALSE
		IF GETGLOBALSETTING("waitUpTo5MinutesForUPDReset") THEN
			IF SQUADCOMBATMODECHECK($SQUADLIST, -299.15, -185.71, 45, 300000) THEN
				$FASTRESETTIMING = TRUE
			ENDIF
		ELSEIF GETGLOBALSETTING("waitUpTo2MinutesForUPDReset") THEN
			IF SQUADCOMBATMODECHECK($SQUADLIST, -299.15, -185.71, 45, 120000) THEN
				$FASTRESETTIMING = TRUE
			ENDIF
		ELSEIF GETGLOBALSETTING("waitUpTo1MinutesForUPDReset") THEN
			IF SQUADCOMBATMODECHECK($SQUADLIST, -299.15, -185.71, 45, 60000) THEN
				$FASTRESETTIMING = TRUE
			ENDIF
		ENDIF
		SWITCHTO($MAIN)
		DIM $TELEPORTSTONEARRAY[UBOUND($SQUADLIST)][2]
		FOR $I = 0 TO UBOUND($SQUADLIST) - 1
			$INDEX = $SQUADLIST[$I]
			SWITCHTONUM($INDEX)
			$ARRAY = INVARRAY()
			$INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
			$ITEMID = -1
			$ITEMPOS = -1
			IF $INDEX == -1 THEN
				SETSTATUS("Out of teleport stones. Fix this for future runs.")
			ELSE
				$ITEMID = $ARRAY[$INDEX][1]
				$ITEMPOS = $ARRAY[$INDEX][0]
			ENDIF
			$TELEPORTSTONEARRAY[$I][0] = $ITEMID
			$TELEPORTSTONEARRAY[$I][1] = $ITEMPOS
		NEXT
		SWITCHTO($MAIN)
		REFORMSQUAD()
		SLEEP(500)
		SWITCHTO($MAIN)
		CHECKALLCHARINSIDEINSTANCE(176, $SQUADLIST)
		$ONEMINTIMER = TIMERINIT()
		$QUIT = FALSE
		WHILE NOT $QUIT
			$QUIT = TRUE
			IF TIMERDIFF($ONEMINTIMER) > 70000 THEN
				SETSTATUS("70s exceeded while trying to glitch reset characters. Continuing...")
				$QUIT = TRUE
				EXITLOOP
			ENDIF
			FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
				$INDEX = $CLIENTSINDEXES[$I]
				SWITCHTONUM($INDEX)
				IF DISTANCE2D(-299.15, -185.71) > 45 THEN CONTINUELOOP
				IF INCOMBAT() THEN
					$QUIT = FALSE
					CONTINUELOOP
				ENDIF
				$QUESTSAMOUNT = UBOUND(QUESTARRAY())
				$ARRAY = INVARRAY()
				$INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
				IF $INDEX == -1 THEN
					SETSTATUS("Out of teleport stones. Fix this for future runs.")
					CONTINUELOOP
				ENDIF
				SpeedPATH()
				MOVETO2(-317.27, -182.94)
				WHILE UBOUND(QUESTARRAY()) == $QUESTSAMOUNT
					IF TIMERDIFF($ONEMINTIMER) > 70000 THEN
						SETSTATUS("70s exceeded while trying to glitch reset this character. Continuing...")
						$QUIT = TRUE
						EXITLOOP
					ENDIF
					SLEEP(100)
				WEND
				IF DISTANCE2D(-299.15, -185.71) < 45 THEN USETELESTONE($ARRAY[$INDEX][1], $ARRAY[$INDEX][0], 6101)
				IF NOT $FASTRESETTIMING THEN
					SLEEP(1500)
				ELSE
					SLEEP(100)
				ENDIF
			NEXT
		WEND
		SWITCHTO($MAIN)
		IF GETGLOBALSETTING("UPDWait30sEachRun") THEN
			SLEEP(30000)
		ELSE
			SLEEP(10000)
		ENDIF
		MASSCLOSENPCWINDOW()
		SQUADLEAVEGLITCHFIX($MEMBERS, 10)
		CHECKALLCHARINSIDEINSTANCE(176, $SQUADLIST)
		IF GETGLOBALSETTING("docheckerboardafterupdreset") AND $PERMITCHECKERBOARD THEN
			SETSTATUS("UPD: Do checkerboard after reset is selected.")
			$CLIENTSINDEXES = GETSQUADALTS()
			IF NOT CHECKALLCHARINSIDEINSTANCE(176, $SQUADLIST) THEN
				SLEEP(30000)
			ELSE
				SLEEP(10000)
			ENDIF
			$CLIENTSINDEXES2 = GETNEARBYALTS()
			$COUNT = UBOUND($CLIENTSINDEXES2)
			WHILE $COUNT < 10
				SQUADLEAVEGLITCHFIX($MEMBERS, 10)
				SETSTATUS("UPD: waiting for count of characters to be 10.")
				SLEEP(5000)
				$CLIENTSINDEXES2 = GETNEARBYALTS()
				$COUNT = UBOUND($CLIENTSINDEXES2)
			WEND
			MASSCLOSENPCWINDOW()
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			UPDCHECKERBOARDHELPER($MEMBERS, $CLIENTSINDEXES)
		ENDIF
		SWITCHTO($MAIN)
		SETSTATUS("UPD reset: Done.")
	ENDFUNC
	FUNC RESETUPD4BUTTON()
		$PERMITCHECKERBOARD = TRUE
		$MEMBERS = PARTYARRAY2()
		$SQUADLIST = GETSQUADALTS()
		RESETUPD4($MEMBERS, $SQUADLIST, $PERMITCHECKERBOARD)
	ENDFUNC
	FUNC RESETUPD4($MEMBERS, $SQUADLIST, $PERMITCHECKERBOARD = TRUE)
		$SQUADLIST = GETSQUADALTS()
		SETSTATUS("UPD: Resetting UPD run without using entrance items. Starting from final boss room. Will run into fire and release to town for fast reset.")
		$CLIENTSINDEXES = GETSQUADALTS()
		SWITCHTO($MAIN)
		MASSTELEPORTINCENSESQUAD($CLIENTSINDEXES)
		SWITCHTO($MAIN)
		SLEEP(15000)
		MASSCANCELACTION($CLIENTSINDEXES)
		SWITCHTO($MAIN)
		IF MASSGENIEENERGYCHECK($CLIENTSINDEXES, 75) THEN MASSSpeedPATH($CLIENTSINDEXES)
