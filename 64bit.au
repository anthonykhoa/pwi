FUNC DIVINATIONOFLUCK()
	ADVENTUREKINGDOMMAP()
	DIVINATIONOFLUCKQUESTS2()
	SLEEP(5000)
	IF ISQUESTAVAILABLE(38918) THEN
		IF NOT GETNPCUNIQUEID("Larpa the Wizard") THEN
			FLY(-534, -48)
		ENDIF
		TAKEQUEST("Larpa the Wizard", 38918)
		WHILE HASQUEST(38918)
			SLEEP(200)
		WEND
	ELSE
		DIVINATIONOFLUCKQUESTS()
	ENDIF
	SLEEP(5000)
	DIVINATIONOFLUCKQUESTS()
	SETSTATUS("Finished.")
ENDFUNC
FUNC GETWEEKDAY()
	$OFFSET = 0
	IF @HOUR > 12 THEN $OFFSET = 1
	$DAY = MOD(@WDAY + $OFFSET - 1, 7) + 1
	RETURN $DAY
ENDFUNC
FUNC SENDEXPRESSION($ID)
	IF NOT INHUMANFORM() THEN
		SWITCHTOHUMANFORM()
		SLEEP(300)
	ENDIF
	SENDPACKET("3000" & _HEX($ID, 4), 4, $GAME_PID)
ENDFUNC
