	$HPULLTIMER = TIMERINIT()
	SETSTATUS("debugc8")
	WHILE ITEMCOUNT(57292) > 0
		IF TIMERDIFF($HTIMER) > 245000 THEN
			MOVE(-429.12, -339.56)
			MOVE(-419.4, -340.38)
			$HTIMER = TIMERINIT()
		ENDIF
		$ARRAY = NPCARRAY()
		DIM $DEST[2] = [-455.34, -354.12]
		$THRALL = FINDCLOSEST($ARRAY, "Blossoming Flower Ball")
		$DIST = SQRT(($ARRAY[$THRALL][4] - $DEST[0]) ^ 2 + ($ARRAY[$THRALL][5] - $DEST[1]) ^ 2)
		$NEWDIST = $DIST - 4
		IF $NEWDIST < 0 THEN $NEWDIST = 0
		JUMPMOVE($DEST[0] + ($ARRAY[$THRALL][4] - $DEST[0]) * $NEWDIST / $DIST, $DEST[1] + ($ARRAY[$THRALL][5] - $DEST[1]) * $NEWDIST / $DIST, 0.3)
		IF TIMERDIFF($HPULLTIMER) > 3000 THEN
			BUFFEREDSELECT($ARRAY[$THRALL][0])
			SLEEP(300)
			USEITEMID(57292, 1)
			SLEEP(300)
			$HPULLTIMER = TIMERINIT()
		ENDIF
		SLEEP(100)
	WEND
	MOVE(-454.94, -356.01)
	TURNINQUEST("Happy Old Man", 39252)
	MOVE(-446.52, -352.5)
	MOVE(-428.47, -334.57)
	MOVE(-390.77, -334.36)
	MOVE(-367.99, -335.26)
	MOVE(-359.29, -350.02)
	MOVE(-358.43, -370.98)
	MOVE(-337.06, -376.25)
	JUMPMOVE(-327.48, -374.66)
