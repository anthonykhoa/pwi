FUNC FINDCLOSESTMATCHINGCOORDINATE($COORDSARRAY)
	$CURRENTDESTNUMBER = 0
	$SHORTESTDISTANCESOFAR = 99999
	FOR $I = 0 TO UBOUND($COORDSARRAY) - 1
		$CURRENTDISTANCE = DISTANCE2D($COORDSARRAY[$I][0], $COORDSARRAY[$I][1])
		IF $CURRENTDISTANCE <= $SHORTESTDISTANCESOFAR THEN
			$SHORTESTDISTANCESOFAR = $CURRENTDISTANCE
			$CURRENTDESTNUMBER = $I
		ENDIF
	NEXT
	RETURN $CURRENTDESTNUMBER
ENDFUNC
