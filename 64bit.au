	GUICTRLSETBKCOLOR($APOTHLABEL, $GUI_BKCOLOR_TRANSPARENT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKHEIGHT)
	GUICTRLSETTIP(-1, "Special consumables that share a 2min cd. Only tick one box. If you tick both boxes, only Apoth with highest % will get used.")
	AUTOPOTCONTROL("ImmuneApoth", "Use Potent Invincibility Apoth (10s immunity) if current HP% is lower than the % set by slider.", $Y + 20)
	AUTOPOTCONTROL("FullHPApoth", "Use Potent Recovery Apoth (100% hp recovered) if current HP% is lower than the % set by slider.")
	$Y += 92
	GUICTRLCREATEGROUP("DEFENSE CHARMS", 20, $Y, 270, 70)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKHEIGHT)
	$DEFENSECHARMLABEL = GUICTRLCREATELABEL("", 20, $Y, 270, 10)
	GUICTRLSETBKCOLOR($DEFENSECHARMLABEL, $GUI_BKCOLOR_TRANSPARENT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKHEIGHT)
	GUICTRLSETTIP(-1, "Defense charms come in 2 types: physical or magical, which share same 10s cd since last use." & @CRLF & "Defense Charms block a certain % of incoming damage on 1 or 2 hits." & @CRLF & "Most common type of Defense Charm is made from Lucky Coins;" & @CRLF & "1) reduces damage of 2 physical hits by 66%" & @CRLF & "2) reduces damage of 2 magical hits by 66%")
	$Y += 18
	$HPHYSDEFCHARM = GUICTRLCREATECHECKBOX("Physical Defense Charm", 30, $Y, 200, 20, $BS_AUTOCHECKBOX)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Uses first physical-dmg-reducing defense charm found in inventory.")
	$AUTOPOTENABLED.add("PhysDefCharm", $HPHYSDEFCHARM)
	$Y += 24
	$HMAGDEFCHARM = GUICTRLCREATECHECKBOX("Magical Defense Charm", 30, $Y, 200, 20, $BS_AUTOCHECKBOX)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Uses first magical-dmg-reducing defense charm found in inventory.")
	$AUTOPOTENABLED.add("MagDefCharm", $HMAGDEFCHARM)
	$Y += 35
	GUICTRLCREATEGROUP("SKILLS", 20, $Y, 270, 115)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKHEIGHT)
	$SKILLSLABEL = GUICTRLCREATELABEL("", 20, $Y, 270, 10)
	GUICTRLSETBKCOLOR($SKILLSLABEL, $GUI_BKCOLOR_TRANSPARENT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKHEIGHT)
	GUICTRLSETTIP(-1, "Use various genie skills or character skills for survival.")
	AUTOPOTCONTROL("AD", "Cast Absolute Domain (genie skill) if current HP% is lower than % on slider.", $Y + 20)
	AUTOPOTCONTROL("Tree", "Cast Tree of Protection (genie skill) if current HP% is lower than % on slider.")
	AUTOPOTCONTROL("Macro(2)", "Executes first ready skill in Macro(2) depending on HP." & @CRLF & "Put skills into your character's Macro(2) which will either heal character or reduce damage taken.")
	$AUTOPOTHELPCONTROLTEXT = "Autopot automatically provides extra survival for your character." & @CRLF & @CRLF & "Some functionality of TheNightmareStuff's autopot is obsolete if you use ""Enable ingame autopot"" setting" & @CRLF & "(Ingame autpot uses hp food, mp food, elixer, defense charms, and apothecary item)" & @CRLF & @CRLF & "Use of AD and Tree (genie skills) and Macro(2) is NOT covered by in-game autopot though!"
	ADDHELPCONTROL($AUTOPOTHELPCONTROLTEXT, 280, $YOFFSET + 5)
ENDFUNC
FUNC REFRESHAUTOPOTSETTINGS()
	LOADCHARCHECKBOX("autopot", "enabled", $HAUTOPOT)
	LOADAUTOPOTNUMBER("HP")
	LOADAUTOPOTNUMBER("MP")
	LOADAUTOPOTNUMBER("Elixer")
	LOADAUTOPOTNUMBER("ImmuneApoth")
	LOADAUTOPOTNUMBER("FullHPApoth")
	LOADCHARCHECKBOX("autopot", "PhysDefCharm", $AUTOPOTENABLED.item("PhysDefCharm"))
	LOADCHARCHECKBOX("autopot", "MagDefCharm", $AUTOPOTENABLED.item("MagDefCharm"))
	LOADAUTOPOTNUMBER("AD")
	LOADAUTOPOTNUMBER("Tree")
	LOADAUTOPOTNUMBER("Macro(2)")
ENDFUNC
FUNC LOADAUTOPOTNUMBER($TEXT)
	$CHECKBOX = $AUTOPOTENABLED.item($TEXT)
	$SLIDER = $AUTOPOTVALUE.item($TEXT)
	$LABEL = $AUTOPOTVALUELABEL.item($TEXT)
	$VALUE = NUMBER(INIREAD("settings-" & NORMALIZEDNAME() & ".ini", "autopot", $TEXT, -101))
	IF $VALUE > -1 THEN
		GUICTRLSETSTATE($CHECKBOX, $GUI_CHECKED)
	ELSE
		GUICTRLSETSTATE($CHECKBOX, $GUI_UNCHECKED)
		$VALUE = -1 - $VALUE
	ENDIF
	GUICTRLSETDATA($SLIDER, $VALUE)
	GUICTRLSETDATA($LABEL, $VALUE & "%")
ENDFUNC
FUNC SAVEAUTOPOTSETTINGS()
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "autopot", "enabled", ISCHECKED($HAUTOPOT))
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "autopot", "PhysDefCharm", ENABLEDAUTOPOT("PhysDefCharm"))
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "autopot", "MagDefCharm", ENABLEDAUTOPOT("MagDefCharm"))
	FOR $KEY IN $AUTOPOTVALUE
		INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "autopot", $KEY, VALUEAUTOPOT($KEY))
	NEXT
	SETSTATUS("Autopot settings saved.")
ENDFUNC
FUNC LOADCHARCHECKBOX($SECTIONNAME, $VARIABLE, $CHECKBOX)
	IF INIREAD("settings-" & NORMALIZEDNAME() & ".ini", $SECTIONNAME, $VARIABLE, "False") == "True" THEN
		GUICTRLSETSTATE($CHECKBOX, $GUI_CHECKED)
	ELSE
		GUICTRLSETSTATE($CHECKBOX, $GUI_UNCHECKED)
	ENDIF
ENDFUNC
FUNC LOADCHECKBOX($SECTIONNAME, $VARIABLE, $CHECKBOX)
	IF INIREAD("settings.ini", $SECTIONNAME, $VARIABLE, "False") == "True" THEN
		GUICTRLSETSTATE($CHECKBOX, $GUI_CHECKED)
	ELSE
		GUICTRLSETSTATE($CHECKBOX, $GUI_UNCHECKED)
	ENDIF
ENDFUNC
GLOBAL $PAUSEAUTOPOTTIMER = 0
GLOBAL $PAUSEAUTOPOT = FALSE
GLOBAL $CHECKFORGLITCHEDCHAR = TIMERINIT()
FUNC RUNAUTOPOT()
	IF TIMERDIFF($CHECKFORGLITCHEDCHAR) > 60000 THEN
		STARTLISTENING()
		IF SEETEXT("Please try again in 15s") THEN
			SLEEP(30000)
		ENDIF
		$CHECKFORGLITCHEDCHAR = TIMERINIT()
	ENDIF
	IF MOVEKEY() THEN
		$PAUSEAUTOPOT = TRUE
		$PAUSEAUTOPOTTIMER = TIMERINIT()
		RETURN
	ENDIF
	IF $PAUSEAUTOPOT AND TIMERDIFF($PAUSEAUTOPOTTIMER) < 30000 THEN
		RETURN
	ELSE
		$PAUSEAUTOPOT = FALSE
		$PAUSEAUTOPOTTIMER = TIMERINIT()
	ENDIF
	$HP = VALUEAUTOPOT("HP")
	$MP = VALUEAUTOPOT("MP")
	$ELIX = VALUEAUTOPOT("Elixer")
	$APOTH_IMMUNE = VALUEAUTOPOT("ImmuneApoth")
	$APOTH_FULLHP = VALUEAUTOPOT("FullHPApoth")
	$PDEFCHARM = ENABLEDAUTOPOT("PhysDefCharm")
	$MDEFCHARM = ENABLEDAUTOPOT("MagDefCharm")
	$AD = VALUEAUTOPOT("AD")
	$TREE = VALUEAUTOPOT("Tree")
	$MAC = VALUEAUTOPOT("Macro(2)")
	DOAUTOPOTACTION($HP, $MP, $ELIX, $APOTH_IMMUNE, $APOTH_FULLHP, $PDEFCHARM, $MDEFCHARM, $AD, $TREE, $MAC)
ENDFUNC
FUNC MASSSQUADSIGNETACCEPT()
	$PARTY = PARTYARRAY()
	IF UBOUND($PARTY) == 0 THEN RETURN
	$LEADER = $PARTY[0][0]
	$CLIENTSINDEXES = GETSQUADCLIENTSINDEXES($LEADER)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF $CLIENTS[$INDEX][2] == $MAIN THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		ACCEPTSUMMON($LEADER, 0)
		SLEEP(500)
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC GETSQUADCLIENTSINDEXES($LEADER)
	LOCAL $SQUADLIST[0]
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($I)
		IF PARTYCOUNT() == 0 OR PARTYARRAY()[0][0] <> $LEADER THEN CONTINUELOOP
		_ARRAYADD($SQUADLIST, $I)
	NEXT
	SWITCHTO($MAIN)
	RETURN $SQUADLIST
ENDFUNC
FUNC GETSQUADCLIENTSINDEXESNOMAIN($LEADER)
	LOCAL $SQUADLIST[0]
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($I)
		IF $CLIENTS[$I][2] == $MAIN OR PARTYCOUNT() == 0 OR PARTYARRAY()[0][0] <> $LEADER THEN CONTINUELOOP
		_ARRAYADD($SQUADLIST, $I)
	NEXT
	SWITCHTO($MAIN)
	RETURN $SQUADLIST
ENDFUNC
FUNC GETMAINCLIENTINDEX()
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF $CLIENTS[$I][2] == $MAIN THEN RETURN $I
	NEXT
	RETURN -1
	SWITCHTO($MAIN)
ENDFUNC

Func ClientsMove($x, $y, ByRef $ClientsIndexes, $Instance = 0)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SwitchToNum($ClientsIndexes[$i])
    If $Instance <> 0 And InstanceId() <> $Instance Then ContinueLoop
		CancelAction()
		MoveTo2($x, $y)
	NEXT
	SWITCHTO($MAIN)
EndFunc

FUNC MASSMOVE()
	$CLIENTSINDEXES = GETNEARBYALTS()
	$MAINPOSITION = PLAYERPOS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF $CLIENTS[$INDEX][2] == $MAIN THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		CANCELACTION()
		MOVETO($MAINPOSITION[0], $MAINPOSITION[1])
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSMOVE2()
	$CLIENTSINDEXES = GETNEARBYALTS()
	$MAINPOSITION = PLAYERPOS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF $CLIENTS[$INDEX][2] == $MAIN THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		CANCELACTION()
		MOVETO2($MAINPOSITION[0], $MAINPOSITION[1])
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSMOVETOCOORD2()
	$POS = PLAYERPOS()
	MASSMOVETOCOORD($POS[0] + 2, $POS[1] + 2)
ENDFUNC
FUNC MASSMOVETOCOORDENHANCED($X, $Y, $SQUADINDEXES, $COUNTEXPECTED = 10, $INSTANCE = 176, $TIMELIMIT = 60000, $TOLERANCE = 5)
	SWITCHTO($MAIN)
	$SUCCESS = TRUE
	$STARTINGPOS = PLAYERPOS()
	$ANALTNEEDEDRES = FALSE
	FOR $I = 0 TO UBOUND($SQUADINDEXES) - 1
		$INDEX = $SQUADINDEXES[$I]
		SWITCHTONUM($INDEX)
		$HPMP = GETHPMP()
		IF $HPMP[0] == 0 OR $HPMP[2] == 0 THEN
			$ANALTNEEDEDRES = TRUE
			RESINPLACE()
		ENDIF
	NEXT
	SWITCHTO($MAIN)
	IF $ANALTNEEDEDRES THEN SLEEP(8000)
	FOR $I = 0 TO UBOUND($SQUADINDEXES) - 1
		$INDEX = $SQUADINDEXES[$I]
		SWITCHTONUM($INDEX)
		RESURRECTIFDEAD()
	NEXT
	$CLIENTSINDEXES = GETNEARBYALTS()
	$CLIENTSCOUNT = UBOUND($CLIENTSINDEXES)
	IF $CLIENTSCOUNT < $COUNTEXPECTED THEN
		SWITCHTO($MAIN)
		FOR $I = 0 TO UBOUND($SQUADINDEXES) - 1
			$INDEX = $SQUADINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF DISTANCE2D($STARTINGPOS[0], $STARTINGPOS[1]) > $TOLERANCE THEN
				SETSTATUS("Trying to move character individually to starting position.")
				IF NOT MOVE5($X, $Y, -1, 0, TRUE, FALSE, $TIMELIMIT, 3) THEN
					SETSTATUS("Failed to move char to to starting position. Taking corrective actions.")
					IF $INSTANCE == 176 AND INSTANCEID() == 176 THEN
						TELEPORTINCENSE()
						SLEEP(15000)
						CANCELACTION()
						IF NOT UPDNAVIGATETOCOORD($X, $Y) THEN
							CHECKALLCHARINSIDEINSTANCE(176, $SQUADINDEXES)
							UPDNAVIGATETOCOORD($X, $Y)
						ENDIF
						SWITCHTONUM($INDEX)
					ELSEIF $INSTANCE == 176 AND INSTANCEID() <> 176 THEN
						IF NOT INCOMBAT() THEN
							SETSTATUS("Entering via Illusion Stone.")
							TELEPORTSTONETO(9044)
							SLEEP(5000)
							MOVETO2(1759.6, 1152.95)
							SLEEP(5000)
							WHILE NOT INHUMANFORM()
								SWITCHTOHUMANFORM()
							WEND
							TAKEQUEST("Illusion Stone", 34439, 1759.57, 1153.91, 219.62, TRUE, FALSE, TRUE, 1)
							SLEEP(7500)
						ELSE
							TELEPORTINCENSE()
							WAITSTOP(5)
							SETSTATUS("Swimming.")
							GOTOUNCHARTEDPARADISE()
						ENDIF
						MOVETO2(934.63, -942.33)
						WHILE NOT INHUMANFORM()
							SWITCHTOHUMANFORM()
						WEND
						TAKEQUEST("Swordsman Zenray", 34438)
						SLEEP(25000)
						IF NOT UPDNAVIGATETOCOORD($X, $Y) THEN
							CHECKALLCHARINSIDEINSTANCE(176, $SQUADINDEXES)
							UPDNAVIGATETOCOORD($X, $Y)
						ENDIF
					ENDIF
				ELSE
				ENDIF
			ENDIF
		NEXT
	ENDIF
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		CANCELACTION()
		MOVETO2($X, $Y)
	NEXT
	SWITCHTO($MAIN)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF DISTANCE2D($X, $Y) > $TOLERANCE THEN
			IF NOT MOVE5($X, $Y, -1, 0, TRUE, FALSE, $TIMELIMIT, 3) THEN
				IF $INSTANCE == 176 AND INSTANCEID() == 176 THEN
					TELEPORTINCENSE()
					SLEEP(15000)
					CANCELACTION()
					IF NOT UPDNAVIGATETOCOORD($X, $Y) THEN
						CHECKALLCHARINSIDEINSTANCE(176, $SQUADINDEXES)
						UPDNAVIGATETOCOORD($X, $Y)
					ENDIF
					SWITCHTONUM($INDEX)
				ELSEIF $INSTANCE == 176 AND INSTANCEID() <> 176 THEN
					IF NOT INCOMBAT() THEN
						SETSTATUS("Entering via Illusion Stone.")
						TELEPORTSTONETO(9044)
						SLEEP(5000)
						MOVETO2(1759.6, 1152.95)
						SLEEP(5000)
						WHILE NOT INHUMANFORM()
							SWITCHTOHUMANFORM()
						WEND
						TAKEQUEST("Illusion Stone", 34439, 1759.57, 1153.91, 219.62, TRUE, FALSE, TRUE, 1)
						SLEEP(7500)
					ELSE
						TELEPORTINCENSE()
						WAITSTOP(5)
						SETSTATUS("Swimming.")
						GOTOUNCHARTEDPARADISE()
					ENDIF
					MOVETO2(934.63, -942.33)
					WHILE NOT INHUMANFORM()
						SWITCHTOHUMANFORM()
					WEND
					TAKEQUEST("Swordsman Zenray", 34438)
					SLEEP(25000)
					IF NOT UPDNAVIGATETOCOORD($X, $Y) THEN
						CHECKALLCHARINSIDEINSTANCE(176, $SQUADINDEXES)
						UPDNAVIGATETOCOORD($X, $Y)
					ENDIF
				ENDIF
			ELSE
			ENDIF
		ENDIF
	NEXT
	SWITCHTO($MAIN)
	RETURN $SUCCESS
ENDFUNC
FUNC MASSMOVETOCOORD($X, $Y, $CLIENTSINDEXES = GETNEARBYALTS(), $CHECKINSTANCE = TRUE, $INSTANCE = 176)
	$SUCCESS = TRUE
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		CANCELACTION()
		MOVETO2($X, $Y)
	NEXT
	SWITCHTO($MAIN)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF $CHECKINSTANCE AND INSTANCEID() <> $INSTANCE THEN
			SETSTATUS("Not in the correct instance.")
			$SUCCESS = FALSE
			EXITLOOP
		ENDIF
		IF DISTANCE2D($X, $Y) > 1 THEN
			IF NOT MOVE5($X, $Y, -1, 0, TRUE, FALSE, 30000, 3) THEN
				$SUCCESS = FALSE
			ENDIF
		ENDIF
	NEXT
	SWITCHTO($MAIN)
	RETURN $SUCCESS
ENDFUNC
FUNC MASSDROPDOWN()
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		CANCELACTION()
		DROPDOWN()
	NEXT
ENDFUNC
FUNC MASSJUMPTOCOORD($X, $Y, $SLEEP1 = 500, $NUMJUMPS = 2, $SLEEP2 = 100, $SLEEP3 = 250, $FORWARDJUMP = TRUE, $SKIPIFDEAD = TRUE, $TOLERANCE = 3, $MAXTIMELIMIT = 20000)
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		$HPMP = GETHPMP()
		IF $SKIPIFDEAD AND $HPMP[0] == 0 THEN CONTINUELOOP
		TRUEJUMP()
		IF $FORWARDJUMP THEN MOVETO2($X, $Y)
	NEXT
	SLEEP($SLEEP1)
	IF $NUMJUMPS == 2 THEN
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF $SKIPIFDEAD AND $HPMP[0] == 0 THEN CONTINUELOOP
			TRUEJUMP()
		NEXT
		SLEEP($SLEEP2)
	ENDIF
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		MOVETO2($X, $Y)
	NEXT
	SWITCHTO($MAIN)
	WAITSTOP2(5, -1, 7000)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF DISTANCE2D($X, $Y) > $TOLERANCE THEN
			MOVEWHILEJUMPINGANDLANDUPD($X, $Y, -1, 1, FALSE, $MAXTIMELIMIT, $TOLERANCE)
		ENDIF
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSMOVE3($X, $Y, $USESPEED = TRUE)
	SWITCHTO($MAIN)
	$CLIENTSINDEXES = GETSQUADALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		CANCELACTION()
		IF $USESPEED THEN
			MOVETO3($X, $Y)
		ELSE
			MOVETO2($X, $Y)
		ENDIF
	NEXT
	WAITCLIENTSTOFINISH($CLIENTSINDEXES)
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSSELECTPLAYERTARGET()
	$TARGET = PLAYERTARGET()
	$CLIENTSINDEXES = GETNEARBYALTS()
	MASSSELECT($TARGET, $CLIENTSINDEXES)
ENDFUNC
FUNC MASSSELECT($TARGET, $CLIENTSINDEXES, $FORCEWINDOWOPEN = FALSE)
	$OPEN = NPCWINDOWOPEN()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF $CLIENTS[$INDEX][2] <> $MAIN THEN
			SWITCHTONUM($INDEX)
			IF $TARGET > 0 THEN
				QUICKSELECT($TARGET)
			ELSE
				DESELECTTARGET()
			ENDIF
		ENDIF
	NEXT
	SLEEP(100)
	IF $OPEN OR $FORCEWINDOWOPEN THEN
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "alts") THEN CONTINUELOOP
			SWITCHTONUM($INDEX)
			$WORK = WORKID()
			IF $WORK == 0 OR $WORK == 7 THEN STARTNPCDIALOGUE($TARGET)
		NEXT
	ENDIF
	SWITCHTO($MAIN)
ENDFUNC

Func QuickSelectClientsTarget($TargetId, $ClientsIndexes)
  For $i = 0 To UBound($ClientsIndexes) - 1
    SwitchToNum($ClientsIndexes[$i])
    QuickSelect($TargetId)
  Next
  SwitchTo($Main)
EndFunc

FUNC MASSFOLLOWCOMMAND()
	$CLIENTSINDEXES = GETNEARBYALTS()
	MASSFOLLOW($CLIENTSINDEXES)
ENDFUNC
FUNC MASSFOLLOW($CLIENTSINDEXES)
	$TARGET = PLAYERID()
	MASSSELECT($TARGET, $CLIENTSINDEXES)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF CLIENTINGROUP($CLIENTS[$INDEX][2], "alts") THEN
			SWITCHTONUM($INDEX)
			CANCELACTION()
			WHILE CURRENTSKILL() <> 0 OR QUEUEDSKILL() <> 0
				CANCELACTION()
				SLEEP(25)
			WEND
			FOLLOWPLAYER($TARGET)
		ENDIF
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MSPREADCOMMAND5()
	$RADIUS = 5
	MASSSPREAD($RADIUS)
ENDFUNC
FUNC MSPREADCOMMAND10()
	$RADIUS = 10
	MASSSPREAD($RADIUS)
ENDFUNC
FUNC MSPREADCOMMAND15()
	$RADIUS = 15
	MASSSPREAD($RADIUS)
ENDFUNC
FUNC MSPREADCOMMAND20()
	$RADIUS = 20
	MASSSPREAD($RADIUS)
ENDFUNC
FUNC MASSSPREAD($RADIUS)
	$CLIENTSINDEXES = GETNEARBYALTS()
	$NUMPOSITIONS = 0
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF CLIENTINGROUP($CLIENTS[$INDEX][2], "alts") THEN
			$NUMPOSITIONS += 1
		ENDIF
	NEXT
	$CENTERPOS = PLAYERPOS()
	$CENTERX = $CENTERPOS[0]
	$CENTERY = $CENTERPOS[1]
	$SPREADCOORDINATES = SPREADCOORDINATES($CENTERX, $CENTERY, $NUMPOSITIONS, $RADIUS)
	$CURRENTALT = 0
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF CLIENTINGROUP($CLIENTS[$INDEX][2], "MassTarget") AND NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "Main") THEN
			SWITCHTONUM($INDEX)
			CANCELACTION()
			$DESTX = $SPREADCOORDINATES[$CURRENTALT][0]
			$DESTY = $SPREADCOORDINATES[$CURRENTALT][1]
			MOVETO2($DESTX, $DESTY)
			$CURRENTALT += 1
		ENDIF
	NEXT
	SLEEP(100)
	SWITCHTO($MAIN)
ENDFUNC
FUNC DEG2RAD($DEGREES)
	RETURN $DEGREES * (3.14159265358979 / 180)
ENDFUNC
FUNC SPREADCOORDINATES($CENTERX, $CENTERY, $NUMPOSITIONS, $RADIUS = 10)
	LOCAL $SPREADCOORDINATES[$NUMPOSITIONS][2]
	LOCAL $ANGLESTEP = 360 / $NUMPOSITIONS
	LOCAL $ANGLE = 0
	FOR $I = 0 TO $NUMPOSITIONS - 1
		$SPREADCOORDINATES[$I][0] = $CENTERX + $RADIUS * COS(DEG2RAD($ANGLE))
		$SPREADCOORDINATES[$I][1] = $CENTERY + $RADIUS * SIN(DEG2RAD($ANGLE))
		$ANGLE += $ANGLESTEP
	NEXT
	RETURN $SPREADCOORDINATES
ENDFUNC
GLOBAL $JITTER = 10
FUNC MSCATTERCOMMAND()
	$CLIENTSINDEXES = GETNEARBYALTS()
	MSCATTER($CLIENTSINDEXES, $JITTER)
ENDFUNC
FUNC MSCATTER($CLIENTSINDEXES, $JITTER = 10)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF $CLIENTS[$INDEX][2] == $MAIN THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		SCATTER($JITTER)
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC SCATTER($JITTER = 10)
	$POS = PLAYERPOS()
	IF TRANSPORTMODE() <> 0 THEN
		$ZJITTER = 2 * RANDOM($JITTER) - $JITTER
		IF RANDOM(0, 2, 1) > 0 THEN $ZJITTER = ABS($ZJITTER)
		MOVETO($POS[0] + 2 * RANDOM($JITTER) - $JITTER, $POS[1] + 2 * RANDOM($JITTER) - $JITTER, $POS[2] + $ZJITTER, 1)
	ELSE
		MOVETO($POS[0] + 2 * RANDOM($JITTER) - $JITTER, $POS[1] + 2 * RANDOM($JITTER) - $JITTER)
	ENDIF
ENDFUNC
FUNC MASSSTOPMOVING()
	$TARGET = PLAYERID()
	$COUNT = 0
	$CLIENTSINDEX = GETNEARBYALTS()
	SWITCHTO($MAIN)
	FOR $I = 0 TO UBOUND($CLIENTSINDEX) - 1
		IF CLIENTINGROUP($CLIENTSINDEX[$I][2], "alts") THEN
			SWITCHTONUM($I)
			IF CURRENTSKILL() <> 0 OR QUEUEDSKILL() <> 0 THEN
				$POS = PLAYERPOS()
				MOVETO($POS[0], $POS[1])
			ENDIF
		ENDIF
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
