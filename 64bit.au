	FUNC RESETUPD2($MEMBERS, $SQUADLIST, $PERMITCHECKERBOARD = TRUE)
		SWITCHTO($MAIN)
		IF GETNPCUNIQUEID("Agent of Unity") THEN
			SWITCHTOHUMANFORM()
			SLEEP(1000)
			IF ISQUESTAVAILABLE(35648) THEN
				SETSTATUS("UPD: got Calligraphy. Boo. Will use UPD Reset instead of UPD Reset II.")
				RESETUPD($MEMBERS, $SQUADLIST, FALSE)
				RETURN
			ELSEIF ISQUESTAVAILABLE(35643) THEN
				SETSTATUS("UPD: got Painting Boo. Will use UPD Reset instead of UPD Reset II.")
				RESETUPD($MEMBERS, $SQUADLIST, FALSE)
				RETURN
			ELSEIF ISQUESTAVAILABLE(35649) THEN
				SETSTATUS("UPD: current run already completed and starting from first room. Will call Reset UPD instead.")
				RESETUPD($MEMBERS, $SQUADLIST, FALSE)
				RETURN
			ENDIF
		ENDIF
		SETSTATUS("UPD: Resetting UPD run without using entrance items. Starting from final boss room.")
		LOCAL $CLIENTSINDEXES = GETSQUADALTS()
		SWITCHTO($MAIN)
		MASSSWITCHTOHUMANFORM(FALSE)
		SWITCHTO($MAIN)
		MASSSpeedPATH($CLIENTSINDEXES)
		MASSMOVETOCOORDENHANCED(-245.56, 324.99, $SQUADLIST)
		SLEEP(1000)
		MASSJUMPTOCOORD(-232.46, 325.34, 500, 2, 100, 250, TRUE, TRUE, 10)
		MASSJUMPTOCOORD(-211.63, 324.76, 500, 2, 100, 250, TRUE, TRUE, 5)
		MASSSpeedPATH($CLIENTSINDEXES)
		MASSJUMPTOCOORD(-121.01, 321.3, 500, 2, 100, 250, TRUE, TRUE, 10)
		MASSSWITCHTOHUMANFORM(TRUE)
		SLEEP(1000)
		TAKECLIENTSQUEST("Agent of Reflection", 35644, -120.81, 321.05, $CLIENTSINDEXES)
		SLEEP(23000)
		MASSCLOSENPCWINDOW()
		SWITCHTO($MAIN)
		$NEARBYALTS = GETNEARBYALTS()
		IF UBOUND($NEARBYALTS) < 10 THEN
			MASSTELEPORTINCENSESQUAD($CLIENTSINDEXES)
			SLEEP(15000)
			MASSMOVETOCOORDENHANCED(-371.088, -208.61, $CLIENTSINDEXES)
		ENDIF
		MASSMOVETOCOORDENHANCED(-371.088, -208.61, $SQUADLIST)
		MASSCLOSENPCWINDOW()
		MASSSpeedPATH($CLIENTSINDEXES)
		MASSMOVETOCOORDENHANCED(-354.02, -175.38, $SQUADLIST)
		MASSMOVETOCOORDENHANCED(-332.82, -134.4, $SQUADLIST)
		MASSMOVETOCOORDENHANCED(-319.23, -147.66, $SQUADLIST)
		MASSMOVETOCOORD(-319.23, -147.66)
		MASSSWITCHTOHUMANFORM()
		SLEEP(2500)
		$GENIESREADY = FALSE
		$MAXTIMETOWAITFORGENIES = TIMERINIT()
		WHILE NOT $GENIESREADY
			$GENIESREADY = MASSGENIEENERGYCHECK($SQUADLIST, 75)
			IF TIMERDIFF($MAXTIMETOWAITFORGENIES) > 30000 THEN
				SETSTATUS("waited more than 30s for genies to be ready for holy path. continuing...")
				EXITLOOP
			ENDIF
			SLEEP(100)
		WEND
		MASSSpeedPATH($SQUADLIST)
		FOR $I = 0 TO UBOUND($SQUADLIST) - 1
			$INDEX = $SQUADLIST[$I]
			SWITCHTONUM($INDEX)
			TRUEJUMP()
		NEXT
		SLEEP(750)
		FOR $I = 0 TO UBOUND($SQUADLIST) - 1
			$INDEX = $SQUADLIST[$I]
			SWITCHTONUM($INDEX)
			TRUEJUMP()
		NEXT
		SLEEP(700)
		FOR $I = 0 TO UBOUND($SQUADLIST) - 1
			$INDEX = $SQUADLIST[$I]
			SWITCHTONUM($INDEX)
			MOVETO2(-290.54, -186.97)
		NEXT
		SLEEP(7000)
		FOR $I = 0 TO UBOUND($SQUADLIST) - 1
			$INDEX = $SQUADLIST[$I]
			SWITCHTONUM($INDEX)
			$JUMPTIMER = TIMERINIT()
			$POS = PLAYERPOS()
			WHILE $POS[2] > 82 AND DISTANCE2D(-290.54, -186.97) > 5
