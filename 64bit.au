			LOCAL $ACALL = DLLCALL("gdi32.dll", "int", "GetTextFaceW", "handle", $HDC, "int", 2048, "wstr", "")
			IF @ERROR OR NOT $ACALL[0] THEN RETURN SETERROR(@ERROR + 10, @EXTENDED, "")
