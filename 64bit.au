ENDFUNC
FUNC UIWINDOWOPEN($NAME = "", $SETOPEN = -1)
	$UIMANAGER = _MEMORYREAD(_MEMORYREAD(_MEMORYREAD($ADDRESS_BASE, $GAME_PROCESS) + 28, $GAME_PROCESS) + 24, $GAME_PROCESS)
	$CURRMANAGER = _MEMORYREAD($UIMANAGER + 8, $GAME_PROCESS)
	$COUNT = _MEMORYREAD($CURRMANAGER + 536 + 12, $GAME_PROCESS)
	$LIST = _MEMORYREAD($CURRMANAGER + 536, $GAME_PROCESS)
	FOR $I = 0 TO $COUNT - 1
		$UI = _MEMORYREAD($LIST + $I * 4, $GAME_PROCESS)
		$WINDOWNAME = _MEMORYREAD(_MEMORYREAD($UI + 80, $GAME_PROCESS), $GAME_PROCESS, "char[100]")
		IF $WINDOWNAME == $NAME THEN
			IF $SETOPEN <> -1 THEN
				_MEMORYWRITE($UI + 24, $GAME_PROCESS, $SETOPEN, "byte")
				_MEMORYWRITE($UI + 148, $GAME_PROCESS, $SETOPEN, "byte")
			ENDIF
			$ISOPEN = _MEMORYREAD($UI + 24, $GAME_PROCESS) <> 0
			RETURN $ISOPEN
		ENDIF
	NEXT
	RETURN FALSE
ENDFUNC
FUNC HOMEITEMS()
	$HOMESTEADBASE = _MEMORYREAD(PLAYERBASE() + $PLAYERHOMESTEAD_OFFSET, $GAME_PROCESS)
	$BASE = _MEMORYREAD(_MEMORYREAD($HOMESTEADBASE + $HOMESTEADRESOURCES, $GAME_PROCESS) + $HOMESTEADITEMLIST, $GAME_PROCESS)
	$COUNT = _MEMORYREAD(_MEMORYREAD($HOMESTEADBASE + $HOMESTEADRESOURCES, $GAME_PROCESS) + $HOMESTEADITEMLIST + 12, $GAME_PROCESS)
	DIM $RESULT[0][4]
	$RESULTCOUNT = 0
	FOR $I = 0 TO $COUNT - 1
		$ITEMBASE = _MEMORYREAD($BASE + 4 * $I, $GAME_PROCESS)
		$ID = _MEMORYREAD($ITEMBASE + 0, $GAME_PROCESS, "int")
		$ITEMPLACEDCOUNT = _MEMORYREAD($ITEMBASE + 12, $GAME_PROCESS, "int")
		$ITEMCOUNT = _MEMORYREAD($ITEMBASE + 20, $GAME_PROCESS, "int")
		$PROSP = _MEMORYREAD($ITEMBASE + 4, $GAME_PROCESS, "int")
		IF $ITEMCOUNT > 0 THEN
			$RESULTCOUNT = $RESULTCOUNT + 1
			REDIM $RESULT[$RESULTCOUNT][4]
			$RESULT[$RESULTCOUNT - 1][0] = $ID
			$RESULT[$RESULTCOUNT - 1][1] = $ITEMCOUNT
			$RESULT[$RESULTCOUNT - 1][2] = $ITEMPLACEDCOUNT
			$RESULT[$RESULTCOUNT - 1][3] = $PROSP
		ENDIF
	NEXT
	RETURN $RESULT
ENDFUNC
FUNC HOMERECIPES()
	$HOMESTEADBASE = _MEMORYREAD(PLAYERBASE() + $PLAYERHOMESTEAD_OFFSET, $GAME_PROCESS)
	$PRODUCELISTBASE = _MEMORYREAD(_MEMORYREAD($HOMESTEADBASE + $HOMESTEADRESOURCES, $GAME_PROCESS) + $HOMESTEADPRODUCELIST, $GAME_PROCESS)
	DIM $ADDRESSES[6] = [48, 64, 80, 96, 112, 208]
	DIM $RESULT[0][3]
	$RESULTCOUNT = 0
	FOR $K = 0 TO UBOUND($ADDRESSES) - 1
		$COUNT = _MEMORYREAD($PRODUCELISTBASE + $ADDRESSES[$K] + 12, $GAME_PROCESS)
		$BASE = _MEMORYREAD($PRODUCELISTBASE + $ADDRESSES[$K], $GAME_PROCESS)
		FOR $I = 0 TO $COUNT - 1
			$ITEMBASE = _MEMORYREAD($BASE + 4 * $I, $GAME_PROCESS)
			$ID = _MEMORYREAD($ITEMBASE + 0, $GAME_PROCESS, "int")
			$ITEMCOUNT = _MEMORYREAD($ITEMBASE + 4, $GAME_PROCESS, "int")
			IF $ITEMCOUNT > 0 THEN
				$RESULTCOUNT = $RESULTCOUNT + 1
				REDIM $RESULT[$RESULTCOUNT][3]
				$RESULT[$RESULTCOUNT - 1][0] = $ID
				$RESULT[$RESULTCOUNT - 1][1] = $ITEMCOUNT
				$RESULT[$RESULTCOUNT - 1][2] = $K
			ENDIF
		NEXT
	NEXT
	RETURN $RESULT
ENDFUNC
FUNC HOMESTEADINFO()
	$HOMESTEADBASE = _MEMORYREAD(PLAYERBASE() + $PLAYERHOMESTEAD_OFFSET, $GAME_PROCESS)
	$FARMBASE = _MEMORYREAD($HOMESTEADBASE + $HOMESTEADFARMLIST, $GAME_PROCESS)
	$RESOURCEBASE = _MEMORYREAD($HOMESTEADBASE + $HOMESTEADRESOURCES, $GAME_PROCESS)
	DIM $ARRAY[14]
	$ARRAY[0] = _MEMORYREAD($FARMBASE + $HOMESTEADSEEDID, $GAME_PROCESS)
	$ARRAY[1] = _MEMORYREAD($FARMBASE + $HOMESTEADSEEDTIMESTAMP, $GAME_PROCESS)
	$ARRAY[2] = _MEMORYREAD($FARMBASE + $HOMESTEADANIMALID, $GAME_PROCESS)
	$ARRAY[3] = _MEMORYREAD($FARMBASE + $HOMESTEADANIMALTIMESTAMP, $GAME_PROCESS)
	$ARRAY[4] = _MEMORYREAD($RESOURCEBASE + $HOMESTEADLEVEL, $GAME_PROCESS)
	$ARRAY[5] = _MEMORYREAD($RESOURCEBASE + $HOMESTEADXP, $GAME_PROCESS)
	$ARRAY[6] = _MEMORYREAD($RESOURCEBASE + $HOMESTEADENERGY, $GAME_PROCESS)
	$ARRAY[7] = _MEMORYREAD($RESOURCEBASE + $HOMESTEADPROSPERITY, $GAME_PROCESS)
	$ARRAY[8] = _MEMORYREAD($RESOURCEBASE + $HOMESTEADCLEANNESS, $GAME_PROCESS)
	$ARRAY[9] = _MEMORYREAD($RESOURCEBASE + $HOMESTEADSTONE, $GAME_PROCESS)
	$ARRAY[10] = _MEMORYREAD($RESOURCEBASE + $HOMESTEADWOOD, $GAME_PROCESS)
	$ARRAY[11] = _MEMORYREAD($RESOURCEBASE + $HOMESTEADCRYSTAL, $GAME_PROCESS)
	$ARRAY[12] = _MEMORYREAD($RESOURCEBASE + $HOMESTEADCLOTH, $GAME_PROCESS)
	$ARRAY[13] = _MEMORYREAD($RESOURCEBASE + $HOMESTEADGEM, $GAME_PROCESS)
	RETURN $ARRAY
ENDFUNC
FUNC HOMESTEADINFOEXPERIMENTAL()
	$HOMESTEADBASE = _MEMORYREAD(PLAYERBASE() + $PLAYERHOMESTEAD_OFFSET, $GAME_PROCESS)
	$RESOURCEBASE = _MEMORYREAD($HOMESTEADBASE + $HOMESTEADRESOURCES, $GAME_PROCESS)
	DIM $ARRAY[100]
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		$ARRAY[$I] = _MEMORYREAD($RESOURCEBASE + $I * 4, $GAME_PROCESS)
		SETSTATUS("$i = " & $I & ": " & $ARRAY[$I])
	NEXT
ENDFUNC
FUNC HOMESTEADINFO2()
	$HOMESTEADBASE = _MEMORYREAD(PLAYERBASE() + $PLAYERHOMESTEAD_OFFSET, $GAME_PROCESS)
	$ITEMLISTBASE = _MEMORYREAD(_MEMORYREAD($HOMESTEADBASE + $HOMESTEADRESOURCES, $GAME_PROCESS) + $HOMESTEADITEMLIST, $GAME_PROCESS)
	$ITEMLISTCOUNT = _MEMORYREAD(_MEMORYREAD($HOMESTEADBASE + $HOMESTEADRESOURCES, $GAME_PROCESS) + $HOMESTEADITEMLIST + 12, $GAME_PROCESS)
	$PRODUCELISTBASE = _MEMORYREAD(_MEMORYREAD($HOMESTEADBASE + $HOMESTEADRESOURCES, $GAME_PROCESS) + $HOMESTEADPRODUCELIST, $GAME_PROCESS)
	PRINT("HI2 " & HEX($ITEMLISTBASE))
	DIM $ADDRESSES[4] = [48, 112, 208]
	FOR $K = 0 TO UBOUND($ADDRESSES) - 1
		$COUNT = _MEMORYREAD($PRODUCELISTBASE + $ADDRESSES[$K] + 12, $GAME_PROCESS)
		PRINT(HEX($ADDRESSES[$K]) & "    GROUP  " & HEX($PRODUCELISTBASE + $ADDRESSES[$K]))
		$BASE = _MEMORYREAD($PRODUCELISTBASE + $ADDRESSES[$K], $GAME_PROCESS)
		FOR $I = 0 TO $COUNT - 1
			$ITEMBASE = _MEMORYREAD($BASE + 4 * $I, $GAME_PROCESS)
			FOR $J = 0 TO 9
				CONSOLEWRITE(_MEMORYREAD($ITEMBASE + 4 * $J, $GAME_PROCESS, "int") & " ")
			NEXT
			CONSOLEWRITE(@CRLF)
		NEXT
	NEXT
	PRINT("ITEM LIST")
	$COUNT = $ITEMLISTCOUNT
	$BASE = $ITEMLISTBASE
	FOR $I = 0 TO $COUNT - 1
		$ITEMBASE = _MEMORYREAD($BASE + 4 * $I, $GAME_PROCESS)
		FOR $J = 0 TO 9
			CONSOLEWRITE(_MEMORYREAD($ITEMBASE + 4 * $J, $GAME_PROCESS, "int") & " ")
		NEXT
		CONSOLEWRITE(@CRLF)
	NEXT
ENDFUNC
FUNC WORKID()
	$WORKMAN = _MEMORYREAD(PLAYERADDRESS() + $OFFSET_ACTIONBASE, $GAME_PROCESS)
	$PRIORITY = _MEMORYREAD($WORKMAN + 56, $GAME_PROCESS)
	IF $PRIORITY == -1 THEN RETURN -1
	$WORKLIST = _MEMORYREAD($WORKMAN + 8 + $PRIORITY * 16, $GAME_PROCESS)
	$WORK = _MEMORYREAD($WORKLIST + 0, $GAME_PROCESS)
	$WORKID = _MEMORYREAD($WORK + 4, $GAME_PROCESS)
	RETURN $WORKID
ENDFUNC
FUNC HOMESTEADFORMULAS()
	$HOMESTEADBASE = _MEMORYREAD(PLAYERBASE() + $PLAYERHOMESTEAD_OFFSET, $GAME_PROCESS)
	$PRODUCELISTBASE = _MEMORYREAD(_MEMORYREAD($HOMESTEADBASE + $HOMESTEADRESOURCES, $GAME_PROCESS) + $HOMESTEADPRODUCELIST, $GAME_PROCESS)
ENDFUNC
FUNC ALIVE()
	$PLAYER = PLAYERADDRESS()
	RETURN _MEMORYREAD($PLAYER + $HP_OFFSET, $GAME_PROCESS) > 0
ENDFUNC
FUNC GETHPMP()
	LOCAL $HPMP[7] = [0, 0, 0, 0, 0, 0, 0]
	$PLAYER = PLAYERADDRESS()
	$HPMP[0] = _MEMORYREAD($PLAYER + $HP_OFFSET, $GAME_PROCESS)
	$HPMP[1] = _MEMORYREAD($PLAYER + $MAXHP_OFFSET, $GAME_PROCESS)
	$HPMP[2] = _MEMORYREAD($PLAYER + $MP_OFFSET, $GAME_PROCESS)
	$HPMP[3] = _MEMORYREAD($PLAYER + $MAXMP_OFFSET, $GAME_PROCESS)
	$HPMP[4] = _MEMORYREAD($PLAYER + $HPCOOLDOWN_OFFSET, $GAME_PROCESS)
	$HPMP[5] = _MEMORYREAD($PLAYER + $MPCOOLDOWN_OFFSET, $GAME_PROCESS)
	$HPMP[6] = _MEMORYREAD($PLAYER + $ELIXCOOLDOWN_OFFSET, $GAME_PROCESS)
	RETURN $HPMP
ENDFUNC

FUNC GETMAXHP()
	$PLAYER = PLAYERADDRESS()
	$MAXHPCURRENT = _MEMORYREAD($PLAYER + $MAXHP_OFFSET, $GAME_PROCESS)
	RETURN $MAXHPCURRENT
ENDFUNC

FUNC GETDEFENSECHARMSTATUS()
	LOCAL $RESULT[3] = [0, 0, 0]
	$PLAYER = PLAYERADDRESS()
	$RESULT[0] = _MEMORYREAD($PLAYER + $PLAYERCHARMCOOLDOWN_OFFSET, $GAME_PROCESS)
	$STATUS = _MEMORYREAD($PLAYER + $PLAYERCHARMACTIVE_OFFSET, $GAME_PROCESS)
	$RESULT[1] = (BITAND($STATUS, $PLAYERCHARMACTIVE_PHYSBIT) > 0)
	$RESULT[2] = (BITAND($STATUS, $PLAYERCHARMACTIVE_MAGBIT) > 0)
	RETURN $RESULT
ENDFUNC
FUNC INSTANCEID()
	RETURN _MEMORYREAD(_MEMORYREAD(_MEMORYREAD(_MEMORYREAD($ADDRESS_BASE, $GAME_PROCESS) + 28, $GAME_PROCESS) + 28, $GAME_PROCESS) + 152, $GAME_PROCESS)
ENDFUNC
GLOBAL $BUFFCOUNT = $BUFFLIST + 12
FUNC BUFFCOUNT($BUFFID)
	$LIST = BUFFARRAY()
	FOR $I = 0 TO UBOUND($LIST) - 1
		IF $LIST[$I][0] == $BUFFID THEN RETURN $LIST[$I][2]
	NEXT
	RETURN -1
ENDFUNC
FUNC BUFFARRAY($SQUADMEM = -1)
	$BUFFLISTOFFSET = $BUFFLIST
	IF $SQUADMEM == -1 THEN
		$PLAYER = PLAYERADDRESS()
	ELSE
		$PLAYER = $SQUADMEM
		$BUFFLISTOFFSET = 88
	ENDIF
	LOCAL $LIST = _MEMORYREAD($PLAYER + $BUFFLISTOFFSET, $GAME_PROCESS)
	LOCAL $COUNT = _MEMORYREAD($PLAYER + $BUFFLISTOFFSET + 12, $GAME_PROCESS)
	IF $COUNT = 0 THEN RETURN
	LOCAL $ARRAY[$COUNT][3]
	FOR $I = 0 TO $COUNT - 1
		$ID = _MEMORYREAD($LIST + $I * 26, $GAME_PROCESS, "ushort")
		$ARRAY[$I][0] = $ID
		$ARRAY[$I][1] = INIREAD("buffs_str.ini", "Buffs", "BUFFS_DESC_" & $ID, "Unknown")
		$ARRAY[$I][2] = _MEMORYREAD($LIST + $I * 26 + 14, $GAME_PROCESS, "byte")
	NEXT
	RETURN $ARRAY
ENDFUNC
FUNC MACROARRAY($MACRO)
	DIM $SKILLS[8]
	$MACRO_HEAD = _MEMORYREAD($ADDRESS_BASE, $GAME_PROCESS)
	$MACRO_HEAD = _MEMORYREAD($MACRO_HEAD + $MACRO_OFFSET0, $GAME_PROCESS)
	$MACRO_HEAD = _MEMORYREAD($MACRO_HEAD + $MACRO_OFFSET1, $GAME_PROCESS)
	$MACRO_2 = _MEMORYREAD($MACRO_HEAD + $MACRO_OFFSET2, $GAME_PROCESS)
	$MACRO_3 = _MEMORYREAD($MACRO_2 + $MACRO_OFFSET3 + $MACRO * 4, $GAME_PROCESS)
	$MACRO_TABLE = _MEMORYREAD($MACRO_3 + $MACRO_OFFSET4, $GAME_PROCESS)
	$ICON = _MEMORYREAD($MACRO_3 + 24, $GAME_PROCESS)
	FOR $I = 0 TO UBOUND($SKILLS) - 1
		$SKILLS[$I] = $ICON == 0 ? 0 : _MEMORYREAD($MACRO_TABLE + $I * 4, $GAME_PROCESS, "int")
	NEXT
	RETURN $SKILLS
ENDFUNC
FUNC ITEMSARRAY()
	$POINTER_BASE = _MEMORYREAD(_MEMORYREAD($ADDRESS_BASE, $GAME_PROCESS) + 28, $GAME_PROCESS)
	$SORTEDLIST = _MEMORYREAD($POINTER_BASE + 28, $GAME_PROCESS)
	$ITEMBASE = _MEMORYREAD($SORTEDLIST + 40, $GAME_PROCESS)
	$ITEMCOUNT = _MEMORYREAD($ITEMBASE + 20, $GAME_PROCESS)
	IF $ITEMCOUNT = 0 THEN RETURN
	$ITEMLIST = _MEMORYREAD($ITEMBASE + 24, $GAME_PROCESS)
	DIM $ARRAY[1][7], $COUNTER = 0
	FOR $I = 0 TO 768
		$ENTRY = _MEMORYREAD($ITEMLIST + $I * 4, $GAME_PROCESS)
		WHILE $ENTRY <> 0
			$ITEM = _MEMORYREAD($ENTRY + 4, $GAME_PROCESS)
			PRINT(HEX($ITEM))
			REDIM $ARRAY[$COUNTER + 1][7]
			$ARRAY[$COUNTER][0] = _MEMORYREAD($ITEM + 276, $GAME_PROCESS)
			$ARRAY[$COUNTER][1] = _MEMORYREAD($ITEM + 280, $GAME_PROCESS)
			$ARRAY[$COUNTER][2] = _MEMORYREAD(_MEMORYREAD($ITEM + 360, $GAME_PROCESS), $GAME_PROCESS, "wchar[100]")
			$ARRAY[$COUNTER][3] = $I * 4
			$ARRAY[$COUNTER][4] = _MEMORYREAD($ITEM + 60, $GAME_PROCESS, "float")
			$ARRAY[$COUNTER][5] = _MEMORYREAD($ITEM + 68, $GAME_PROCESS, "float")
			$ARRAY[$COUNTER][6] = _MEMORYREAD($ITEM + 64, $GAME_PROCESS, "float")
			$COUNTER += 1
			$ENTRY = _MEMORYREAD($ENTRY, $GAME_PROCESS)
		WEND
	NEXT
	RETURN $ARRAY
ENDFUNC
FUNC INSTANCEVALUE($KEY)
	$ARRAY = INSTANCEVALUETABLE()
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		IF $ARRAY[$I][0] == $KEY THEN
			RETURN $ARRAY[$I][1]
		ENDIF
	NEXT
	RETURN 0
ENDFUNC
FUNC READHASHTABLE($ADDRESS, $MAXSIZE = 10000, $USEMAXSIZE = TRUE)
	$HASHTABLE = _MEMORYREAD($ADDRESS, $GAME_PROCESS)
	$SIZE = _MEMORYREAD($ADDRESS + 8, $GAME_PROCESS)
	DIM $RESULT[0][2]
	IF $SIZE > $MAXSIZE AND $USEMAXSIZE THEN
		RETURN $RESULT
	ENDIF
	$COUNTER = 0
	$TIMER = TIMERINIT()
	FOR $I = 0 TO $SIZE - 1
		IF TIMERDIFF($TIMER) > 30000 THEN
			SETSTATUS("readhashtabledebug timerdiff over 30000")
			DIM $RESULT[0][2]
			RETURN $RESULT
		ENDIF
		$ENTRY = _MEMORYREAD($HASHTABLE + 4 * $I, $GAME_PROCESS)
		WHILE $ENTRY <> 0
			IF TIMERDIFF($TIMER) > 30000 THEN
				SETSTATUS("readhashtabledebug 2 timerdiff over 30000")
				DIM $RESULT[0][2]
				RETURN $RESULT
			ENDIF
			REDIM $RESULT[$COUNTER + 1][2]
			$RESULT[$COUNTER][0] = _MEMORYREAD($ENTRY + 8, $GAME_PROCESS)
			$RESULT[$COUNTER][1] = _MEMORYREAD($ENTRY + 4, $GAME_PROCESS)
			$COUNTER += 1
			$ENTRY = _MEMORYREAD($ENTRY, $GAME_PROCESS)
			IF $COUNTER > $MAXSIZE AND $USEMAXSIZE THEN RETURN $RESULT
		WEND
	NEXT
	RETURN $RESULT
ENDFUNC
FUNC GAMEREADY()
	$PLAYER = PLAYERADDRESS()
	IF $PLAYER == 0 THEN RETURN FALSE
	RETURN _MEMORYREAD($PLAYER + $PLAYERGAMEREADY, $GAME_PROCESS, "byte") <> 0
ENDFUNC
FUNC INSTANCEVALUETABLE()
	RETURN READHASHTABLE(_MEMORYREAD(_MEMORYREAD($ADDRESS_BASE, $GAME_PROCESS) + 28, $GAME_PROCESS) + $INSTANCEVALUETABLE_OFFSET, 10000, TRUE)
ENDFUNC
FUNC FREEINVSLOTS()
	$PLAYER = PLAYERADDRESS()
	$INVBASE = _MEMORYREAD($PLAYER + $INVENTORYLISTOFFSET, $GAME_PROCESS)
	$INVCOUNT = _MEMORYREAD($INVBASE + $INVENTORYSIZEOFFSET, $GAME_PROCESS)
	RETURN $INVCOUNT - UBOUND(INVARRAY())
ENDFUNC
FUNC INVARRAY($TYPE = 0, $SORTED = TRUE, $OFFSET = -1)
	$PLAYER = PLAYERADDRESS()
	$INVOFFSET = $INVENTORYLISTOFFSET
	IF $TYPE == 1 THEN $INVOFFSET = $QUESTINVLISTOFFSET
	IF $TYPE == 2 THEN $INVOFFSET = $PLAYERAVATARBAG_OFFSET
	IF $TYPE == 3 THEN $INVOFFSET = $EQUIPPEDLISTOFFSET
	IF $TYPE == 4 THEN $INVOFFSET = $PLAYERWARDROBEBAG_OFFSET
	IF $TYPE == 5 THEN $INVOFFSET = $PLAYERGLYPHBAG_OFFSET
	IF $TYPE == 6 THEN $INVOFFSET = $PLAYERBANK_OFFSET
	IF $TYPE == 7 THEN $INVOFFSET = $PLAYERCUPBOARD_OFFSET
	IF $TYPE == 8 THEN $INVOFFSET = $PLAYERSTASHBAG_OFFSET
	IF $OFFSET <> -1 THEN $INVOFFSET = $INVENTORYLISTOFFSET + $OFFSET
	$INVBASE = _MEMORYREAD($PLAYER + $INVOFFSET, $GAME_PROCESS)
	$INVCOUNT = _MEMORYREAD($INVBASE + $INVENTORYSIZEOFFSET, $GAME_PROCESS)
	$INVLIST = _MEMORYREAD($INVBASE + $SORTEDINVENTORYLISTOFFSET, $GAME_PROCESS)
	DIM $ARRAY[$INVCOUNT][6], $COUNTER = 0
	FOR $I = 0 TO $INVCOUNT - 1
		$ITEM = _MEMORYREAD($INVLIST + $I * 4, $GAME_PROCESS)
		IF $ITEM <> 0 OR NOT $SORTED THEN
			$ARRAY[$COUNTER][0] = $I
			$ARRAY[$COUNTER][1] = _MEMORYREAD($ITEM + $INVID_OFFSET, $GAME_PROCESS)
			$ARRAY[$COUNTER][2] = $ITEM
			$ARRAY[$COUNTER][3] = $TYPE <> 4 ? _MEMORYREAD($ITEM + $INVSTACKAMOUNT_OFFSET, $GAME_PROCESS) : _MEMORYREAD($ITEM + 40, $GAME_PROCESS)
			$ARRAY[$COUNTER][4] = $TYPE <> 4 ? _MEMORYREAD($ITEM + $INVDURABILITY_OFFSET, $GAME_PROCESS) : _MEMORYREAD($ITEM + $INVFASHCOLOR_OFFSET, $GAME_PROCESS, "word")
			$COUNTER += 1
		ENDIF
	NEXT
	REDIM $ARRAY[$COUNTER][6]
	RETURN $ARRAY
ENDFUNC
FUNC REFINEITEM0()
	$PLAYER = PLAYERADDRESS()
	$INVBASE = _MEMORYREAD($PLAYER + $INVENTORYLISTOFFSET, $GAME_PROCESS)
	$INVCOUNT = _MEMORYREAD($INVBASE + $INVENTORYSIZEOFFSET, $GAME_PROCESS)
	$INVLIST = _MEMORYREAD($INVBASE + $SORTEDINVENTORYLISTOFFSET, $GAME_PROCESS)
	$ITEM = _MEMORYREAD($INVLIST + 0 * 4, $GAME_PROCESS)
	$REFINE = _MEMORYREAD($ITEM + $ITEMREFINE, $GAME_PROCESS)
	RETURN $REFINE
ENDFUNC
FUNC ITEMTYPE($ITEM)
	$TYPE = _MEMORYREAD($ITEM + $ITEMTYPEX, $GAME_PROCESS)
	RETURN $TYPE
ENDFUNC
FUNC GEARADDONSFROMITEM($ITEM)
	$ADDONLIST = _MEMORYREAD($ITEM + $GEARADDONLIST_OFFSET, $GAME_PROCESS)
	$COUNT = _MEMORYREAD($ITEM + $GEARADDONLIST_OFFSET + 4, $GAME_PROCESS)
	DIM $GEAR[$COUNT]
	FOR $I = 0 TO $COUNT - 1
		$GEAR[$I] = _MEMORYREAD($ADDONLIST + 28 * $I, $GAME_PROCESS, "ushort")
	NEXT
	RETURN $GEAR
ENDFUNC
FUNC QUESTARRAY()
	$PLAYER = PLAYERADDRESS()
	$QUESTBASE = _MEMORYREAD($PLAYER + $QUESTLIST_OFFSET, $GAME_PROCESS)
	$QUESTLIST = _MEMORYREAD($QUESTBASE + 8, $GAME_PROCESS)
	$QUESTCOUNT = _MEMORYREAD($QUESTLIST + 0, $GAME_PROCESS, "byte")
	$QUESTVISIBLE = _MEMORYREAD($QUESTLIST + 4, $GAME_PROCESS, "byte")
	DIM $ARRAY[$QUESTCOUNT][4]
	FOR $I = 0 TO $QUESTCOUNT - 1
		$ARRAY[$I][0] = _MEMORYREAD($QUESTLIST + 8 + 32 * $I, $GAME_PROCESS, "ushort")
		$ARRAY[$I][1] = _MEMORYREAD($QUESTLIST + 8 + 32 * $I + 21, $GAME_PROCESS, "ushort")
		$ARRAY[$I][2] = _MEMORYREAD($QUESTLIST + 8 + 32 * $I + 23, $GAME_PROCESS, "ushort")
		$ARRAY[$I][3] = _MEMORYREAD($QUESTLIST + 8 + 32 * $I + 25, $GAME_PROCESS, "ushort")
	NEXT
	RETURN $ARRAY
ENDFUNC
FUNC NPCARRAY()
	$POINTER_BASE = _MEMORYREAD(_MEMORYREAD($ADDRESS_BASE, $GAME_PROCESS) + 28, $GAME_PROCESS)
	$SORTEDLIST = _MEMORYREAD($POINTER_BASE + 28, $GAME_PROCESS)
	$NPCBASE = _MEMORYREAD($SORTEDLIST + $NPCLISTOFFSET, $GAME_PROCESS)
	$NPCCOUNT = _MEMORYREAD($NPCBASE + $NPCCOUNTEROFFSET, $GAME_PROCESS)
	IF $NPCCOUNT = 0 THEN RETURN
	$NPCLIST = _MEMORYREAD($NPCBASE + $SORTEDNPCLISTOFFSET, $GAME_PROCESS)
	DIM $ARRAY[$NPCCOUNT][12]
	$TIMER = TIMERINIT()
	FOR $I = 0 TO $NPCCOUNT - 1
		IF TIMERDIFF($TIMER) > 15000 THEN
			RETURN FALSE
		ENDIF
		$NPC = _MEMORYREAD($NPCLIST + $I * 4, $GAME_PROCESS)
		IF($NPC <> 0 AND _MEMORYREAD($NPC + $NPCUIDOFFSET, $GAME_PROCESS)) THEN
			$ARRAY[$I][0] = _MEMORYREAD($NPC + $NPCUIDOFFSET, $GAME_PROCESS)
			$ARRAY[$I][1] = _MEMORYREAD($NPC + $NPCIDOFFSET, $GAME_PROCESS)
			$ARRAY[$I][2] = _MEMORYREAD(_MEMORYREAD($NPC + $NPCNAMEOFFSET, $GAME_PROCESS), $GAME_PROCESS, "wchar[100]")
			$ARRAY[$I][3] = _MEMORYREAD($NPC + $NPCSTATUSOFFSET, $GAME_PROCESS)
			IF $ARRAY[$I][2] == "" THEN $ARRAY[$I][2] = "NoName " & $ARRAY[$I][1]
			IF BITAND($ARRAY[$I][3], $NPCSTATUSBITDEAD) THEN
				$ARRAY[$I][2] = "Dead " & $ARRAY[$I][2]
				$ARRAY[$I][1] = 0
			ENDIF
			$ARRAY[$I][4] = _MEMORYREAD($NPC + $NPCX, $GAME_PROCESS, "float")
			$ARRAY[$I][5] = _MEMORYREAD($NPC + $NPCY, $GAME_PROCESS, "float")
			$ARRAY[$I][6] = _MEMORYREAD($NPC + $NPCZ, $GAME_PROCESS, "float")
			$ARRAY[$I][7] = _MEMORYREAD($NPC + $NPCHPOFFSET, $GAME_PROCESS)
			$ARRAY[$I][8] = _MEMORYREAD($NPC + $NPCHPMAXOFFSET, $GAME_PROCESS)
			$ARRAY[$I][9] = _MEMORYREAD($NPC + $NPCANIMATIONKIND, $GAME_PROCESS)
			$ARRAY[$I][10] = $NPC
		ENDIF
	NEXT
	RETURN $ARRAY
ENDFUNC
FUNC NPCHPPERCENT($NPCID)
	$ARRAY = NPCARRAY()
	$PERCENTHP = 0
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		IF $ARRAY[$I][1] == $NPCID THEN
			IF $ARRAY[$I][7] <= $ARRAY[$I][8] THEN
				$PERCENTHP = ROUND($ARRAY[$I][7] / $ARRAY[$I][8])
				RETURN $PERCENTHP
			ENDIF
		ENDIF
	NEXT
	RETURN $PERCENTHP
ENDFUNC
FUNC NPCHPPERCENTNAME($NPCNAME)
	$ARRAY = NPCARRAY()
	$PERCENTHP = 0
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		IF $ARRAY[$I][2] == $NPCNAME THEN
			IF $ARRAY[$I][7] <= $ARRAY[$I][8] THEN
				$PERCENTHP = ROUND($ARRAY[$I][7] / $ARRAY[$I][8])
				RETURN $PERCENTHP
			ENDIF
		ENDIF
	NEXT
	RETURN $PERCENTHP
ENDFUNC
FUNC NPCTARGET($NPC)
	RETURN _MEMORYREAD($NPC + $NPCTARGET, $GAME_PROCESS)
ENDFUNC
FUNC NPCOWNER($NPC)
	RETURN _MEMORYREAD($NPC + $NPCOWNEROFFSET, $GAME_PROCESS)
ENDFUNC
FUNC OWNEDNPC()
	$ARRAY = NPCARRAY()
	$PLAYERID = PLAYERID()
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		IF NPCOWNER($ARRAY[$I][10]) == $PLAYERID THEN RETURN $ARRAY[$I][0]
	NEXT
	RETURN 0
ENDFUNC
FUNC FAKENPCID()
	$POINTER_BASE = _MEMORYREAD(_MEMORYREAD($ADDRESS_BASE, $GAME_PROCESS) + 28, $GAME_PROCESS)
	$SORTEDLIST = _MEMORYREAD($POINTER_BASE + 28, $GAME_PROCESS)
	$NPCBASE = _MEMORYREAD($SORTEDLIST + $NPCLISTOFFSET, $GAME_PROCESS)
	$NPCCOUNT = _MEMORYREAD($NPCBASE + $FAKENPCLISTOFFSET - 4, $GAME_PROCESS)
	IF $NPCCOUNT = 0 THEN RETURN
	$NPCLIST = _MEMORYREAD($NPCBASE + $FAKENPCLISTOFFSET, $GAME_PROCESS)
	FOR $I = 0 TO 75
		$NPC = _MEMORYREAD($NPCLIST + $I * 4, $GAME_PROCESS)
		IF($NPC <> 0) THEN
			RETURN _MEMORYREAD($NPC + 8, $GAME_PROCESS)
		ENDIF
	NEXT
	RETURN 0
ENDFUNC
FUNC PLAYERARRAY()
	$PLAYERLISTOFFSET = 28
	$PLAYERCOUNTEROFFSET = 60
	$PLAYERX = 60
	$PLAYERY = 68
	$PLAYERZ = 64
	$POINTER_BASE = _MEMORYREAD(_MEMORYREAD($ADDRESS_BASE, $GAME_PROCESS) + 28, $GAME_PROCESS)
	$SORTEDLIST = _MEMORYREAD($POINTER_BASE + 28, $GAME_PROCESS)
	$PLAYER_BASE = _MEMORYREAD($SORTEDLIST + 32, $GAME_PROCESS)
	$COUNT = _MEMORYREAD($PLAYER_BASE + 24, $GAME_PROCESS)
	$LENGTH = _MEMORYREAD($PLAYER_BASE + 36, $GAME_PROCESS)
	IF $COUNT = 0 THEN RETURN
	$LIST = _MEMORYREAD($PLAYER_BASE + 28, $GAME_PROCESS)
	DIM $ARRAY[1][8], $COUNTER = 0
	FOR $I = 0 TO($LENGTH - 1)
		$ENTRY = _MEMORYREAD($LIST + $I * 4, $GAME_PROCESS)
		WHILE $ENTRY <> 0
			$ITEM = _MEMORYREAD($ENTRY + 4, $GAME_PROCESS)
			PRINT(HEX($ITEM))
			REDIM $ARRAY[$COUNTER + 1][8]
			$ARRAY[$COUNTER][0] = _MEMORYREAD($ITEM + $PLAYERIDOFFSET, $GAME_PROCESS)
			$ARRAY[$COUNTER][1] = _MEMORYREAD($ITEM + $PLAYERCLASS_OFFSET, $GAME_PROCESS)
			$ARRAY[$COUNTER][2] = _MEMORYREAD(_MEMORYREAD($ITEM + $PLAYERNAME_OFFSET, $GAME_PROCESS), $GAME_PROCESS, "wchar[100]")
			$ARRAY[$COUNTER][3] = _MEMORYREAD($ITEM + $BUFFCOUNT, $GAME_PROCESS)
			$ARRAY[$COUNTER][4] = _MEMORYREAD($ITEM + $PLAYERX, $GAME_PROCESS, "float")
			$ARRAY[$COUNTER][5] = _MEMORYREAD($ITEM + $PLAYERY, $GAME_PROCESS, "float")
			$ARRAY[$COUNTER][6] = _MEMORYREAD($ITEM + $PLAYERZ, $GAME_PROCESS, "float")
			$ARRAY[$COUNTER][7] = _MEMORYREAD($ITEM + $PLAYERFACTIONID_OFFSET, $GAME_PROCESS)
			$COUNTER += 1
			$ENTRY = _MEMORYREAD($ENTRY, $GAME_PROCESS)
		WEND
	NEXT
	RETURN $ARRAY
ENDFUNC
FUNC CHATARRAY()
	$CHAT_COUNT = _MEMORYREAD($ADDRESS_CHAT_BASE + $CHATCOUNT_OFFSET, $GAME_PROCESS)
	$CHAT_LIST = _MEMORYREAD($ADDRESS_CHAT_BASE, $GAME_PROCESS)
	DIM $ARRAY[$CHAT_COUNT][2]
	FOR $I = 0 TO $CHAT_COUNT - 1
		$ARRAY[$I][0] = _MEMORYREAD($CHAT_LIST + 36 * $I + 20, $GAME_PROCESS)
		$ARRAY[$I][1] = _MEMORYREAD(_MEMORYREAD($CHAT_LIST + 36 * $I + 8, $GAME_PROCESS), $GAME_PROCESS, "wchar[255]")
	NEXT
	RETURN $ARRAY
ENDFUNC
FUNC TOWERPOINTS()
	DIM $ARRAY[4]
	$ARRAY[0] = _MEMORYREAD($ADDRESS_TOWER_POINTS, $GAME_PROCESS)
	$ARRAY[1] = _MEMORYREAD($ADDRESS_TOWER_POINTS + 4, $GAME_PROCESS)
	$ARRAY[2] = _MEMORYREAD($ADDRESS_TOWER_POINTS - 8, $GAME_PROCESS)
	$ARRAY[3] = _MEMORYREAD($ADDRESS_TOWER_POINTS - 20, $GAME_PROCESS)
	RETURN $ARRAY
ENDFUNC
FUNC NRPOINTS()
	DIM $ARRAY[8]
	$ARRAY[0] = _MEMORYREAD($ADDRESS_NR_POINTS + 0, $GAME_PROCESS)
	$ARRAY[1] = _MEMORYREAD($ADDRESS_NR_POINTS + 4, $GAME_PROCESS)
	$ARRAY[2] = _MEMORYREAD($ADDRESS_NR_POINTS + 16, $GAME_PROCESS)
	$ARRAY[3] = _MEMORYREAD($ADDRESS_NR_POINTS + 20, $GAME_PROCESS)
	$ARRAY[4] = _MEMORYREAD($ADDRESS_NR_POINTS + 24, $GAME_PROCESS)
	$ARRAY[5] = _MEMORYREAD($ADDRESS_NR_POINTS + 28, $GAME_PROCESS)
	$ARRAY[6] = _MEMORYREAD($ADDRESS_NR_POINTS + 32, $GAME_PROCESS)
	$ARRAY[7] = _MEMORYREAD($ADDRESS_NR_POINTS + 68, $GAME_PROCESS)
	RETURN $ARRAY
ENDFUNC
