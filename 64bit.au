ENDFUNC
FUNC ISWEAKCHARACTER()
	RETURN ISCHECKED($HWEAKCHARACTER)
ENDFUNC
FUNC HANDLETOWERANCIENTGIFT()
	IF ISCHECKED($HUSEANCIENTGIFTTOWER) THEN
		WHILE NOT HASBUFF("Increase the gain for XP, Spirit, and Vitae.", 296) AND ITEMCOUNT(47242) > 0
			USEITEMID(47242)
			SLEEP(1000)
		WEND
	ENDIF
ENDFUNC
FUNC SHOULDUSESPIRITOFDEFENSE()
	IF NOT ISCHECKED($HUSESPIRITOFDEFENSE) THEN RETURN FALSE
	LOCAL $BUFFSIDS[4] = [64, 31, 28, 65]
	RETURN NOT HAVEALLBUFFS($BUFFSIDS)
ENDFUNC
FUNC SHOULDUSESPIRITOFASSAULT()
	IF NOT ISCHECKED($HUSESPIRITOFASSAULT) THEN RETURN FALSE
	LOCAL $BUFFSIDS[2] = [66, 68]
	RETURN NOT HAVEALLBUFFS($BUFFSIDS)
ENDFUNC
FUNC USEHOLYPATH()
	IF NOT ISCHECKED($HUSEHOLYPATH) THEN RETURN FALSE
	RETURN TRUE
ENDFUNC
FUNC USEGENIECHI()
	IF NOT ISCHECKED($HUSEGENIECHI) THEN RETURN FALSE
	RETURN TRUE
ENDFUNC
FUNC ISSTRONGCHARACTER()
	IF NOT ISCHECKED($HSTRONGCHARACTER) THEN RETURN FALSE
	RETURN TRUE
ENDFUNC
FUNC KILLPORTALMOBS10ATATIME()
	IF NOT ISCHECKED($HKILLPORTALMOBS10ATATIME) THEN RETURN FALSE
	RETURN TRUE
ENDFUNC
FUNC USEMACRO7CHI()
	IF NOT ISCHECKED($HMACRO7CHI) THEN RETURN FALSE
	RETURN TRUE
ENDFUNC
FUNC TOWERROOMKEYID()
	$ARRAY = NPCARRAY()
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		IF $ARRAY[$I][1] >= 47593 AND $ARRAY[$I][1] <= 47646 THEN RETURN $ARRAY[$I][1]
	NEXT
	RETURN 0
ENDFUNC
FUNC ROOMLABEL()
	$ID = TOWERROOMKEYID()
	IF $ID < 47593 OR $ID > 47646 THEN
		RETURN ""
	ENDIF
	FOR $I = 1 TO 8
		IF $ID < (47593 + 6 * $I) THEN
			RETURN $ROOM_NAMES[$I]
		ENDIF
	NEXT
	IF $ID == 47641 THEN RETURN "Four Wraith Kings"
	IF $ID == 47642 THEN RETURN "High Sage Esher"
	IF $ID == 47643 THEN RETURN "Bodhi of Grief"
	IF $ID == 47644 THEN RETURN "Matreya"
	IF $ID == 47645 THEN RETURN "Zen Ji"
	IF $ID == 47646 THEN RETURN "Mara Papman"
	RETURN ""
ENDFUNC
FUNC RESTARTROOM()
	$CURRENTLYSETROOM = GUICTRLREAD($HRESTARTROOM)
	IF $CURRENTLYSETROOM < 1 OR $CURRENTLYSETROOM > 108 THEN
		SETSTATUS("Invalid room number. Please set between 1 and 108.")
		RETURN
	ENDIF
	DO
		SETSTATUS("Restarting Tower Room: " & GUICTRLREAD($HRESTARTROOM))
		SENDPACKET("25006100000004000000" & _HEX(INT(GUICTRLREAD($HRESTARTROOM))), 14, $GAME_PID)
		SLEEP(1000)
		UPDATEROOMLABEL()
		SLEEP(4000)
	UNTIL ROOMLABEL() == GUICTRLREAD($HRESTARTUNTIL) OR GUICTRLREAD($HRESTARTUNTIL) == "Any"
	SETSTATUS("Restarting Tower Room - done.")
ENDFUNC
FUNC UPDATEROOMLABEL()
	$INSTANCE = INSTANCEID()
	IF $INSTANCE >= 172 AND $INSTANCE <= 175 THEN
		$ID = TOWERROOMKEYID()
		IF $ID <= 47646 AND $ID >= 47593 THEN
			$CHALLENGELABEL = "Room Challenge: " & ROOMLABEL()
			IF $CHALLENGELABEL <> GUICTRLREAD($HROOMLABEL) THEN GUICTRLSETDATA($HROOMLABEL, $CHALLENGELABEL)
			$ROOMNUMBER = CURRENTROOMNUMBER()
			$TEXT = "Room Number: " & $ROOMNUMBER
			IF $ROOMNUMBER > 0 THEN
				IF $TEXT <> GUICTRLREAD($HROOMNUMBERLABEL) THEN GUICTRLSETDATA($HROOMNUMBERLABEL, $TEXT)
			ENDIF
		ENDIF
	ELSE
		$CHALLENGELABEL = "Room Challenge: "
		$ROOMNUMBERLABEL = "Room Number: "
		IF $CHALLENGELABEL <> GUICTRLREAD($HROOMLABEL) THEN GUICTRLSETDATA($HROOMLABEL, $CHALLENGELABEL)
		IF $ROOMNUMBERLABEL <> GUICTRLREAD($HROOMNUMBERLABEL) THEN GUICTRLSETDATA($HROOMNUMBERLABEL, $ROOMNUMBERLABEL)
	ENDIF
ENDFUNC
FUNC FARMROOM()
	$ROOMNUMBER = CURRENTROOMNUMBER()
	$INV = INVARRAY()
	$REWARDROOM = $ROOMNUMBER
	IF $ROOMNUMBER == 0 THEN RETURN
	$COUNT = 0
	WHILE NOT GETNPCUNIQUEID("Master of Solitude")
		HANDLEBUFFS()
		SLEEP(500)
		HANDLEROOM()
		IF $COUNT == 0 THEN
			ACCEPTTOWERREWARD($REWARDROOM)
			$COUNT = $COUNT + 1
		ENDIF
		SLEEP(500)
		GOTOTOWERROOM($ROOMNUMBER)
	WEND
ENDFUNC
FUNC RUNTOWER()
	$STOPROOM = NUMBER(GUICTRLREAD($HSTOPROOM))
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "tower", "StopRoom", $STOPROOM)
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "tower", "WeakChar", ISCHECKED($HWEAKCHARACTER))
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "tower", "UseAncientGift", ISCHECKED($HUSEANCIENTGIFTTOWER))
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "tower", "UseSpiritOfDefense", ISCHECKED($HUSESPIRITOFDEFENSE))
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "tower", "UseSpiritOfAssault", ISCHECKED($HUSESPIRITOFASSAULT))
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "tower", "UseHolyPath", ISCHECKED($HUSEHOLYPATH))
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "tower", "UseGenieChi", ISCHECKED($HUSEGENIECHI))
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "tower", "StrongCharacter", ISCHECKED($HSTRONGCHARACTER))
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "tower", "PortalKill10", ISCHECKED($HKILLPORTALMOBS10ATATIME))
	INIWRITE("settings-" & NORMALIZEDNAME() & ".ini", "tower", "Macro7Chi", ISCHECKED($HMACRO7CHI))
	DOTOWER($STOPROOM)
ENDFUNC
FUNC _EXIT()
	SAVEWINDOWSIZE()
	_TIMER_KILLALLTIMERS($HGUI)
	GUIDELETE($HGUI)
	EXIT
ENDFUNC
GLOBAL $PAUSED
HOTKEYSET("^{PAUSE}", "MASSTOGGLEPAUSE")
HOTKEYSET("+{ESC}", "MASSEXIT")
FUNC MASSTOGGLEPAUSE()
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($I)
		TOGGLEPAUSE()
	NEXT
	SWITCHTO($MAIN)
	TOGGLEPAUSE()
ENDFUNC
FUNC TOGGLEPAUSE()
	$PAUSED = NOT $PAUSED
	$TIMER = TIMERINIT()
	$CHECKTIME = 60000
	IF $PAUSED THEN SETSTATUS("Pausing bot. Press Ctrl+PAUSE to unpause.")
	IF NOT $PAUSED THEN SETSTATUS("Resuming bot.")
	WHILE $PAUSED
		SLEEP(100)
		IF TIMERDIFF($TIMER) > $CHECKTIME THEN
			SETSTATUS("Bot has been paused for " & INT(TIMERDIFF($TIMER) / 60000) & " minutes. Press Ctrl+PAUSE to unpause.")
			$CHECKTIME += 60000
		ENDIF
	WEND
ENDFUNC
FUNC MASSEXIT()
	SETCLIENTSDATA()
	SWITCHTO($MAIN)
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($I)
		IF NOT CLIENTINGROUP($CLIENTS[$I][2], "main") THEN CONTINUELOOP
		_EXIT()
		SWITCHTO($MAIN)
		DO
			MASSEXIT()
		UNTIL NOT UBOUND($CLIENTS)
	NEXT
	SETCLIENTSDATA()
	_EXIT()
ENDFUNC

FUNC USEAVAILABLEITEM($ID1, $ID2, $ISSKILL = 0, $DELAY = 300)
    ; Try using the first item ID
    IF USEITEMID($ID1, $ISSKILL, $DELAY) THEN
        RETURN 1 ; Successfully used the first item
    ENDIF

    ; If the first item wasn't available, try the second item ID
    IF USEITEMID($ID2, $ISSKILL, $DELAY) THEN
        RETURN 1 ; Successfully used the second item
    ENDIF

    RETURN 0 ; Neither item was available
ENDFUNC

FUNC USEAVAILABLEITEM2($ID1, $ISSKILL = 0, $DELAY = 300)
    ; Try using the first item ID
    IF USEITEMID($ID1, $ISSKILL, $DELAY) THEN
        RETURN 1 ; Successfully used the first item
    ENDIF

    RETURN 0 ; Neither item was available
ENDFUNC

FUNC USEGENIECHITTR($DELAY = 300)
    ; Try using the first item ID
    IF CASTSKILL(4893, 1) THEN
        RETURN 1 ; Successfully used the first item
    ENDIF

    SLEEP($DELAY)
    ; If the first item wasn't available, try the second item ID
    IF USEITEMID(1047, 1) THEN
        RETURN 1 ; Successfully used the second item
    ENDIF

    RETURN 0 ; Neither item was available
ENDFUNC


