FUNC VITAEMOBSAPEX($FIGHT, $FIGHTONGROUND, $IGNOREVITAEGAIN, $PERMITSOLO)
	$PAUSEVITMOBS = FALSE
	$PAUSEVITMOBSTIMER = 0
	$VITAECURRENT = VITAEFROMMOBS()
	$VITAELIMIT = VITAEFROMMOBSDAILYLIMIT()
	IF NOT $IGNOREVITAEGAIN AND $VITAECURRENT >= $VITAELIMIT THEN
		SETSTATUS("Vitae mobs already completed today. Continuing...")
		RETURN
	ENDIF
	SETSTATUS("Heading to vitae mob spot in Western Steppes.")
	DIM $BUFFSIDS[4] = [64, 31, 28, 65]
	IF NOT HAVEALLBUFFS($BUFFSIDS) THEN USEITEMID(38408)
	$SPARKTIMER = TIMERINIT()
	$VITAEBARFULLTIMER = 0
	$KILLMOBS = TRUE
	$VITAEBARFULL = FALSE
	$SOLOING = FALSE
	$STARTINGPOSITION = PLAYERPOS()
	IF DISTANCEBETWEEN3DF($STARTINGPOSITION[0], $STARTINGPOSITION[1], $STARTINGPOSITION[2], -1504.93, 1897.9, 158.48) > 100 THEN
		TRANSFERMAP(178, 0, -1427.613, 1444.192)
		FLY(-1158.195, 1626.556)
		FLYUP(140)
	ENDIF
	FLY(-1463.413, 1919.003, 118.907, 1, FALSE)
	FLY(-1504.93, 1897.9, 148.48, 0, TRUE)
	FLYUP(148.48)
	$COUNT = SETHOSTPARTY()
	$CLIENTSINDEXES = GETNEARBYALTS(100, TRUE)
	$COUNTOFPARTYMEMBERSNEARBY = UBOUND($CLIENTSINDEXES)
	SETSTATUS("Vitae mobs: count of party members = " & $COUNT)
	SETSTATUS("Vitae mobs: count of party members nearby = " & $COUNTOFPARTYMEMBERSNEARBY)
	$WAITTIMER = TIMERINIT()
	$WAITTIMER2 = TIMERINIT()
	$WAITTIMER3 = TIMERINIT()
	$LASTCOUNTOFPLAYERS = 0
	SETSTATUS("Vitae mobs: arrived at gather spot for vitae mobs. Waiting for squad members to arrive.")
	DO
		IF MOVEKEY() THEN
			$PAUSEVITMOBS = TRUE
			$PAUSEVITMOBSTIMER = TIMERINIT()
			SLEEP(100)
			CONTINUELOOP
		ENDIF
		IF $PAUSEVITMOBS AND TIMERDIFF($PAUSEVITMOBSTIMER) < 30000 THEN
			SLEEP(100)
			CONTINUELOOP
		ELSE
			$PAUSEVITMOBS = FALSE
			$PAUSEVITMOBSTIMER = TIMERINIT()
		ENDIF
		IF $PERMITSOLO THEN EXITLOOP
		$COUNT = SETHOSTPARTY()
		IF $COUNT == 0 OR $COUNT == 1 THEN
			$SOLOING = TRUE
			EXITLOOP
		ENDIF
		IF TIMERDIFF($WAITTIMER) > 300000 THEN
			SETSTATUS("Vitae mobs: 5 minutes since last char arrived. Waited long enough. Starting vit mobs.")
			EXITLOOP
		ENDIF
		IF TIMERDIFF($WAITTIMER2) > 30000 THEN
			$WAITTIMER2 = TIMERINIT()
			IF $COUNTOFPARTYMEMBERSNEARBY <> $LASTCOUNTOFPLAYERS THEN
				$LASTCOUNTOFPLAYERS = $COUNTOFPARTYMEMBERSNEARBY
				SETSTATUS("Vitae mobs: party count = " & $COUNT)
				SETSTATUS("Vitae mobs: nearby party count = " & $COUNTOFPARTYMEMBERSNEARBY)
				$WAITTIMER = TIMERINIT()
			ENDIF
			$COUNTOFPARTYMEMBERSNEARBY = UBOUND($CLIENTSINDEXES)
		ENDIF
		IF TIMERDIFF($WAITTIMER3) > 30000 THEN
			IF VITAEFROMMOBS() <> $VITAECURRENT THEN
				SETSTATUS("Vitae mobs: saw an increase of vitae. Will resume killing mobs shortly with the others.")
				EXITLOOP
			ENDIF
			$WAITTIMER3 = TIMERINIT()
		ENDIF
		IF TIMERDIFF($WAITTIMER) < 5000 THEN
			$CLIENTSINDEXES = GETNEARBYALTS(100, TRUE)
		ELSEIF TIMERDIFF($WAITTIMER) >= 5000 AND TIMERDIFF($WAITTIMER) < 60000 THEN
			$CLIENTSINDEXES = GETNEARBYALTS(15, TRUE)
		ELSEIF TIMERDIFF($WAITTIMER) >= 60000 AND TIMERDIFF($WAITTIMER) < 65000 THEN
			$CLIENTSINDEXES = GETNEARBYALTS(100, TRUE)
		ELSEIF TIMERDIFF($WAITTIMER) >= 65000 AND TIMERDIFF($WAITTIMER) < 120000 THEN
			$CLIENTSINDEXES = GETNEARBYALTS(15, TRUE)
		ELSEIF TIMERDIFF($WAITTIMER) >= 120000 AND TIMERDIFF($WAITTIMER) < 125000 THEN
			$CLIENTSINDEXES = GETNEARBYALTS(100, TRUE)
		ELSEIF TIMERDIFF($WAITTIMER) >= 125000 AND TIMERDIFF($WAITTIMER) < 180000 THEN
			$CLIENTSINDEXES = GETNEARBYALTS(15, TRUE)
		ELSEIF TIMERDIFF($WAITTIMER) >= 180000 AND TIMERDIFF($WAITTIMER) < 185000 THEN
			$CLIENTSINDEXES = GETNEARBYALTS(100, TRUE)
		ELSEIF TIMERDIFF($WAITTIMER) >= 185000 AND TIMERDIFF($WAITTIMER) < 240000 THEN
			$CLIENTSINDEXES = GETNEARBYALTS(15, TRUE)
		ELSEIF TIMERDIFF($WAITTIMER) >= 240000 THEN
			$CLIENTSINDEXES = GETNEARBYALTS(100, TRUE)
		ELSE
			$CLIENTSINDEXES = GETNEARBYALTS(100, TRUE)
		ENDIF
		SLEEP(1000)
	UNTIL $COUNTOFPARTYMEMBERSNEARBY == $COUNT
	IF NOT $PERMITSOLO THEN
		SLEEP(20000)
	ENDIF
	$COUNT = SETHOSTPARTY()
	$COUNTOFPARTYMEMBERSNEARBY = GETNEARBYALTS(120)
	IF $PERMITSOLO THEN
		SETSTATUS("Vitae mobs, soloing: buffing up.")
	ELSE
		SETSTATUS("Vitae mobs, group: All party members (" & $COUNTOFPARTYMEMBERSNEARBY & ") appear to have arrived. Buffing up.")
	ENDIF
	$TIMEALLOCATEDFORBUFFS = TIMERINIT()
	$GENIECHI = FALSE
	$CHI = 399
	WHILE TIMERDIFF($TIMEALLOCATEDFORBUFFS) < 10000
		IF NOT $GENIECHI THEN
			GENIECHISKILL($CHI)
			$GENIECHI = TRUE
		ENDIF
		SELFBUFF()
	WEND
	IF $FIGHTONGROUND THEN
		DROPDOWN()
	ELSE
		FLYUP(130)
	ENDIF
	$MOBS = NPCARRAY()
	$CURRTARGET = PLAYERTARGET()
	$INDEX = FINDCLOSEST($MOBS, "Apex Sacred Spirit")
	$HPMP = GETHPMP()
	$NUMBEROFDEATHS = 0
	$IGNOREVITAEGAINTIMER = 0
	$ONETIMEGROUNDBUFF = FALSE
	$ONETIMEGROUNDBUFFTIMER = TIMERINIT()
	$BUFFTIMER = TIMERINIT()
	$DURATIONTIMER = TIMERINIT()
	$COUNTNEARBYPLAYERSTIMER = TIMERINIT()
	USEANCIENTGIFT()
	$CLASS = CLASS()
	$SINTIMER = TIMERINIT()
	$SEEKEREQUIPDEF = TRUE
	$SEEKEREQUIPATTACK = TRUE
	$SEEKERATTACKGEARTIMER = 0
	$CLERICTIMER = 0
	WHILE $KILLMOBS
		IF NOT $ONETIMEGROUNDBUFF AND TIMERDIFF($ONETIMEGROUNDBUFFTIMER) > 60000 THEN
			SELFBUFF()
			$ONETIMEGROUNDBUFF = TRUE
		ENDIF
		USEANCIENTGIFT()
		IF MOVEKEY() THEN
			$PAUSEVITMOBS = TRUE
			$PAUSEVITMOBSTIMER = TIMERINIT()
			SLEEP(100)
			CONTINUELOOP
		ENDIF
		IF $PAUSEVITMOBS AND TIMERDIFF($PAUSEVITMOBSTIMER) < 30000 THEN
			SLEEP(100)
			CONTINUELOOP
		ELSE
			$PAUSEVITMOBS = FALSE
			$PAUSEVITMOBSTIMER = TIMERINIT()
		ENDIF
		$HPMP = GETHPMP()
		IF $HPMP[0] == 0 THEN
			$HADTOGOTOTOWN = FALSE
			SETSTATUS("Vitae mobs: died. Will release, use spirit of def, and return.")
			RESINPLACE()
			SLEEP(2000)
			$HPMP = GETHPMP()
			IF $HPMP[0] == 0 THEN
				$HADTOGOTOTOWN = TRUE
				GOTOTOWNAFTERDEATH()
				SLEEP(2000)
			ENDIF
			USEITEMID(38408)
			SELFBUFF()
			$NUMBEROFDEATHS += 1
			IF $HADTOGOTOTOWN THEN
				IF $NUMBEROFDEATHS < 2 THEN
					FLYUP(140)
					FLY(-1504.93, 1897.9, 148.48)
				ELSE
					FLYUP(140)
					FLY(-1463.413, 1919.003, 118.907, 1, FALSE)
					FLY(-1504.93, 1897.9, 148.48, 0, TRUE)
					FLYUP(148.48)
					IF ISMELEECLASS() THEN
						$FIGHTONGROUND = FALSE
						$FIGHT = FALSE
					ELSE
						$FIGHTONGROUND = FALSE
					ENDIF
				ENDIF
			ELSE
				IF $NUMBEROFDEATHS >= 2 THEN
					FLYUP(148.48)
					IF ISMELEECLASS() THEN
						$FIGHTONGROUND = FALSE
						$FIGHT = FALSE
					ELSE
						$FIGHTONGROUND = FALSE
					ENDIF
				ENDIF
			ENDIF
		ENDIF
		IF TIMERDIFF($BUFFTIMER) > 610000 THEN
			SELFBUFF()
			$BUFFTIMER = TIMERINIT()
		ENDIF
		IF NOT $FIGHTONGROUND THEN
			IF ALTITUDE() < 125 THEN FLYUP(130)
		ENDIF
		IF $FIGHT THEN
			IF TIMERDIFF($SPARKTIMER) > 16000 AND NOT(HASBUFF("Intuition Increased magic attack", 46) OR HASBUFF("Sharpen Increased physical attack", 32)) THEN
				IF CHI() > 300 THEN
					TRIPLESPARK()
					$SPARKTIMER = TIMERINIT()
					SLEEP(2500)
				ENDIF
			ENDIF
			IF CLASS() == 7 AND NOT HASBUFF("Focus Accelerated channeling", 37) THEN
				IF $CLERICTIMER == 0 THEN
					IF SKILLOFFCOOLDOWN(566) THEN
						USESKILL(566, PLAYERID())
					ENDIF
					$CLERICTIMER = TIMERINIT()
					CONTINUELOOP
				ELSEIF TIMERDIFF($CLERICTIMER) > 10500 THEN
					IF SKILLOFFCOOLDOWN(566) THEN
						USESKILL(566, PLAYERID())
					ENDIF
					$CLERICTIMER = TIMERINIT()
					CONTINUELOOP
				ENDIF
			ENDIF
			IF CLASS() == 5 AND(CURRENTSKILL() == 3777 OR(CURRENTSKILL() == 0 AND QUEUEDSKILL() == 3777)) AND TIMERDIFF($SINTIMER) > 100 THEN
				CANCELACTION()
				$SINTIMER = TIMERINIT()
			ENDIF
			IF CLASS() == 8 AND NOT HASBUFF("Attack Level increased", 135) THEN
				IF TIMERDIFF($SEEKERATTACKGEARTIMER) > 29000 OR $SEEKERATTACKGEARTIMER == 0 THEN
					$SEEKEREQUIPDEF = TRUE
					$SEEKERATTACKGEARTIMER = TIMERINIT()
				ENDIF
				IF $SEEKEREQUIPDEF == TRUE THEN
					SWAPGEAR(2)
					$SEEKEREQUIPDEF = FALSE
					$SEEKEREQUIPATTACK = TRUE
				ENDIF
			ELSEIF CLASS() == 8 AND HASBUFF("Attack Level increased", 135) AND $SEEKEREQUIPATTACK == TRUE THEN
				SWAPGEAR(0)
				$SEEKEREQUIPATTACK = FALSE
				$SEEKERATTACKGEARTIMER = TIMERINIT()
			ENDIF
			$MOBS = NPCARRAY()
			$CURRTARGET = PLAYERTARGET()
			$INDEX = FINDCLOSEST($MOBS, $CURRTARGET, 0, TRUE)
			IF $INDEX == -1 OR $MOBS[$INDEX][2] <> "Apex Sacred Spirit" OR NOT INCOMBAT() OR DISTANCE2D($MOBS[$INDEX][4], $MOBS[$INDEX][5]) > 40 THEN
				$INDEX = FINDCLOSEST($MOBS, "Apex Sacred Spirit")
			ENDIF
			IF $INDEX <> -1 THEN
				$HPMP = GETHPMP()
				IF $HPMP[0] / $HPMP[1] < 0.65 THEN
					KILL($MOBS[$INDEX][0], 200, 0, 2)
					CONTINUELOOP
				ELSE
					KILL($MOBS[$INDEX][0], 200, 0, 1)
				ENDIF
			ENDIF
		ENDIF
		$COUNT = SETHOSTPARTY()
		IF TIMERDIFF($COUNTNEARBYPLAYERSTIMER) > 60000 THEN
			SETSTATUS("Vitae from mobs = " & VITAEFROMMOBS() & "/" & $VITAELIMIT)
			BUFFCHECK(TRUE)
			IF NOT HAVEALLBUFFS($BUFFSIDS) THEN USEITEMID(38408)
			$CLIENTSINDEXES = GETNEARBYALTS(120)
			IF $FIGHTONGROUND == FALSE THEN
				$CLIENTSINDEXES2 = GETNEARBYALTS(17)
				$COUNT120 = UBOUND($CLIENTSINDEXES)
				$COUNT17 = UBOUND($CLIENTSINDEXES2)
				IF $COUNT120 == $COUNT17 THEN
					SETSTATUS("Vit mobs: no players left on ground. Ending vit mobs for this character.")
					$KILLMOBS = FALSE
				ENDIF
			ENDIF
			IF UBOUND($CLIENTSINDEXES) <> $COUNTOFPARTYMEMBERSNEARBY THEN
				IF $COUNTOFPARTYMEMBERSNEARBY == $COUNT THEN
					$IGNOREVITAEGAINTIMER = 0
				ELSE
					$IGNOREVITAEGAINTIMER = TIMERINIT()
				ENDIF
			ENDIF
			$COUNTOFPARTYMEMBERSNEARBY = UBOUND($CLIENTSINDEXES)
			$COUNTNEARBYPLAYERSTIMER = TIMERINIT()
		ENDIF
		IF VITAEFROMMOBS() >= $VITAELIMIT AND NOT $VITAEBARFULL THEN
			$VITAEBARFULL = TRUE
			$VITAEBARFULLTIMER = TIMERINIT()
			IF NOT $IGNOREVITAEGAIN THEN
				SETSTATUS("Vitae mobs: vitae bar full. Ending vitae mobs now.")
				EXITLOOP
			ELSE
				SETSTATUS("Vitae mobs: vitae bar full. Ignore vitae gain selected so will continue with this character until rest of squad has left.")
			ENDIF
		ENDIF
		IF NOT $IGNOREVITAEGAIN AND $VITAEBARFULL AND TIMERDIFF($VITAEBARFULLTIMER) > 120000 THEN
			SETSTATUS("Vitae mobs: Ending vit mobs for this character.")
			$KILLMOBS = FALSE
		ENDIF
		IF $IGNOREVITAEGAIN AND $VITAEBARFULL AND $IGNOREVITAEGAINTIMER <> 0 AND TIMERDIFF($IGNOREVITAEGAINTIMER) > 180000 THEN
			SETSTATUS("Vitae mobs: done for this char that ignores vitae mobs + it appears all other char who don't ignore vitae mobs have left. Ending...")
			$KILLMOBS = FALSE
		ENDIF
		IF NOT $IGNOREVITAEGAIN AND $VITAEBARFULL AND $VITAEBARFULLTIMER <> 0 AND TIMERDIFF($VITAEBARFULLTIMER) > 120000 THEN
			SETSTATUS("Vitae mobs: Leaving vit mobs now.")
			$KILLMOBS = FALSE
		ENDIF
		SLEEP(100)
	WEND
	SETSTATUS("Vitae mobs done. Took " & INT(TIMERDIFF($DURATIONTIMER) / 60000) & " minutes.")
	GOTOTOWNAFTERDEATH()
	IMMUNEAPOTH()
	SLEEP(100)
	IMMUNEAPOTH()
	FLYUP(190)
ENDFUNC
FUNC VITAEMOBSRISING($FIGHT, $FIGHTONGROUND, $IGNOREVITAEGAIN, $PERMITSOLO)
	$PAUSEVITMOBS = FALSE
	$PAUSEVITMOBSTIMER = 0
	$VITAECURRENT = VITAEFROMMOBS()
	$VITAELIMIT = VITAEFROMMOBSDAILYLIMIT()
	IF $VITAECURRENT >= $VITAELIMIT AND NOT $IGNOREVITAEGAIN THEN
		SETSTATUS("Vitae mobs already completed today. Continuing...")
		RETURN
	ENDIF
	SETSTATUS("Heading to Rising Sky vitae mob spot in Western Steppes.")
	DIM $BUFFSIDS[4] = [64, 31, 28, 65]
	IF NOT HAVEALLBUFFS($BUFFSIDS) THEN USEITEMID(38408)
	$SPARKTIMER = TIMERINIT()
	$VITAEBARFULLTIMER = 0
	$KILLMOBS = TRUE
	$VITAEBARFULL = FALSE
	$SOLOING = FALSE
	$STARTINGPOSITION = PLAYERPOS()
	IF INSTANCEID() <> 178 OR(INSTANCEID() == 178 AND DISTANCEBETWEEN3DF($STARTINGPOSITION[0], $STARTINGPOSITION[1], $STARTINGPOSITION[2], -1592.47, 150.32, 209) > 100) THEN
		TRANSFERMAP(178, 0, -1424.55, 138.4)
		FLY(RANDOM(-1567, -1553.65), RANDOM(170.05, 187.55))
	ENDIF
	FLY(RANDOM(-1567, -1553.65), RANDOM(170.05, 187.55))
	$COUNT = SETHOSTPARTY()
	$CLIENTSINDEXES = GETNEARBYALTS(15, TRUE)
	$COUNTOFPARTYMEMBERSNEARBY = UBOUND($CLIENTSINDEXES)
	SETSTATUS("Vitae mobs: count of party members = " & $COUNT)
	SETSTATUS("Vitae mobs: count of party members nearby = " & $COUNTOFPARTYMEMBERSNEARBY)
	$WAITTIMER = TIMERINIT()
	$WAITTIMER2 = TIMERINIT()
	$WAITTIMER3 = TIMERINIT()
	$LASTCOUNTOFPLAYERS = 0
	SETSTATUS("Vitae mobs: arrived at gather spot for vitae mobs. Waiting for squad members to arrive.")
	DIM $AVOIDPLACES[4][2] = [[-1598.24, 195.1], [-1553.04, 125.45], [-1496.19, 189.17], [-1482.01, 223.52]]
	DIM $MOBLOCATIONS[4][3] = [[-1595.08, 228.84, 182.01], [-1582.42, 157.02, 181.01], [-1517.16, 142.71, 181.01], [-1510.46, 213.77, 181.19]]
	DO
		IF MOVEKEY() THEN
			$PAUSEVITMOBS = TRUE
			$PAUSEVITMOBSTIMER = TIMERINIT()
			SLEEP(100)
			CONTINUELOOP
		ENDIF
		IF $PAUSEVITMOBS AND TIMERDIFF($PAUSEVITMOBSTIMER) < 30000 THEN
			SLEEP(100)
			CONTINUELOOP
		ELSE
			$PAUSEVITMOBS = FALSE
			$PAUSEVITMOBSTIMER = TIMERINIT()
		ENDIF
		IF $PERMITSOLO THEN EXITLOOP
		$COUNT = SETHOSTPARTY()
		IF $COUNT == 0 OR $COUNT == 1 THEN
			$SOLOING = TRUE
			EXITLOOP
		ENDIF
		IF TIMERDIFF($WAITTIMER) <= 120000 THEN
			$CLIENTSINDEXES = GETNEARBYALTS(15, TRUE)
		ELSE
			$CLIENTSINDEXES = GETNEARBYALTS(100, TRUE)
		ENDIF
		IF TIMERDIFF($WAITTIMER) > 300000 THEN
			SETSTATUS("Vitae mobs: 5 minutes since last char arrived. Waited long enough. Starting vit mobs.")
			EXITLOOP
		ENDIF
		IF TIMERDIFF($WAITTIMER2) > 30000 THEN
			$WAITTIMER2 = TIMERINIT()
			IF $COUNTOFPARTYMEMBERSNEARBY <> $LASTCOUNTOFPLAYERS THEN
				$LASTCOUNTOFPLAYERS = $COUNTOFPARTYMEMBERSNEARBY
				SETSTATUS("Vitae mobs: party count = " & $COUNT)
				SETSTATUS("Vitae mobs: nearby party count = " & $COUNTOFPARTYMEMBERSNEARBY)
				$WAITTIMER = TIMERINIT()
			ENDIF
			$COUNTOFPARTYMEMBERSNEARBY = UBOUND($CLIENTSINDEXES)
		ENDIF
		IF TIMERDIFF($WAITTIMER3) > 30000 THEN
			IF VITAEFROMMOBS() <> $VITAECURRENT THEN
				SETSTATUS("Vitae mobs: saw an increase of vitae. Will resume killing mobs shortly with the others.")
				EXITLOOP
			ENDIF
			$WAITTIMER3 = TIMERINIT()
		ENDIF
		SLEEP(1000)
	UNTIL $COUNTOFPARTYMEMBERSNEARBY == $COUNT
	IF NOT $PERMITSOLO THEN
		SLEEP(20000)
	ENDIF
	IF $PERMITSOLO THEN
		SETSTATUS("Vitae mobs, soloing: buffing up.")
	ELSE
		SETSTATUS("Vitae mobs, group: All party members appear to have arrived. Buffing up.")
	ENDIF
	$TIMEALLOCATEDFORBUFFS = TIMERINIT()
	$GENIECHI = FALSE
	$CHI = 399
	WHILE TIMERDIFF($TIMEALLOCATEDFORBUFFS) < 10000
		IF NOT $GENIECHI THEN
			GENIECHISKILL($CHI)
			$GENIECHI = TRUE
		ENDIF
		SELFBUFF()
	WEND
	IF $FIGHTONGROUND THEN
		MOVETO2(RANDOM(-1567, -1553.65), RANDOM(170.05, 187.55))
		SLEEP(2000)
	ELSE
		FLY(RANDOM(-1567, -1553.65), RANDOM(170.05, 187.55))
		FLYUP(212)
	ENDIF
	$HPMP = GETHPMP()
	$NUMBEROFDEATHS = 0
	$BUFFTIMER = TIMERINIT()
	$DURATIONTIMER = TIMERINIT()
	$COUNTNEARBYPLAYERSTIMER = TIMERINIT()
	$STUCKTIMER = TIMERINIT()
	$XRANDOM = RANDOM(-1565.34, -1518.73)
	$YRANDOM = RANDOM(141.18, 197.83)
	DIM $DESTINATION[2] = [$XRANDOM, $YRANDOM]
	$TIMETOSLEEP = (RANDOM(1000, 5000))
	$TIMETOSLEEPTIMER = TIMERINIT()
	$IGNOREVITAEGAINTIMER = 0
	USEANCIENTGIFT()
	$COUNTOFPARTYMEMBERSNEARBY = GETNEARBYALTS(200)
	$CLASS = CLASS()
	$SINTIMER = TIMERINIT()
	$SEEKEREQUIPDEF = TRUE
	$SEEKEREQUIPATTACK = TRUE
	$SEEKERATTACKGEARTIMER = 0
	$CLERICTIMER = 0
	$POS = PLAYERPOS()
	$BESTMOBSPOTINDEX = PICKBESTMOBSPOT($MOBLOCATIONS, "Sacred Spirit Rising Sky", 30)
	$MOBS = NPCARRAY()
	$CURRTARGET = PLAYERTARGET()
	$INDEX = FINDCLOSEST($MOBS, "Sacred Spirit Rising Sky")
	WHILE $KILLMOBS
		USEANCIENTGIFT()
		IF MOVEKEY() THEN
			$PAUSEVITMOBS = TRUE
			$PAUSEVITMOBSTIMER = TIMERINIT()
			SLEEP(100)
			CONTINUELOOP
		ENDIF
		IF $PAUSEVITMOBS AND TIMERDIFF($PAUSEVITMOBSTIMER) < 30000 THEN
			SLEEP(100)
			CONTINUELOOP
		ELSE
			$PAUSEVITMOBS = FALSE
			$PAUSEVITMOBSTIMER = TIMERINIT()
		ENDIF
		$HPMP = GETHPMP()
		IF $HPMP[0] == 0 THEN
			$HADTOGOTOTOWN = FALSE
			SETSTATUS("Vitae mobs: died. Will release, use spirit of def, and return.")
			RESINPLACE()
			SLEEP(1000)
			$HPMP = GETHPMP()
			IF $HPMP[0] == 0 OR $HPMP[2] == 0 THEN
				$HADTOGOTOTOWN = TRUE
				GOTOTOWNAFTERDEATH()
				SLEEP(2000)
			ENDIF
			USEITEMID(38408)
			SELFBUFF()
			$NUMBEROFDEATHS += 1
			IF $HADTOGOTOTOWN THEN
				IF $NUMBEROFDEATHS < 2 THEN
					FLY(RANDOM(-1567, -1553.65), RANDOM(170.05, 187.55))
				ELSEIF $NUMBEROFDEATHS > 2 AND $NUMBEROFDEATHS < 5 THEN
					FLY(RANDOM(-1567, -1553.65), RANDOM(170.05, 187.55))
					FLYUP(212)
					IF ISMELEECLASS() THEN
						$FIGHTONGROUND = FALSE
						$FIGHT = FALSE
					ELSE
						$FIGHTONGROUND = FALSE
					ENDIF
				ELSE
					SETSTATUS("Vitae from mobs = " & VITAEFROMMOBS() & "/" & $VITAELIMIT)
					SETSTATUS("Vitae mobs: died more than 4 times. Check if white name. Ending for today.")
					RETURN
				ENDIF
			ELSE
				IF $NUMBEROFDEATHS > 2 AND $NUMBEROFDEATHS < 4 THEN
					FLYUP(212)
					IF ISMELEECLASS() THEN
						$FIGHTONGROUND = FALSE
						$FIGHT = FALSE
					ELSE
						$FIGHTONGROUND = FALSE
					ENDIF
				ELSEIF $NUMBEROFDEATHS > 4 THEN
					SETSTATUS("Vitae from mobs = " & VITAEFROMMOBS() & "/" & $VITAELIMIT)
					SETSTATUS("Vitae mobs: died more than 4 times. Check if white name. Ending for today.")
					RETURN
				ENDIF
			ENDIF
		ENDIF
		IF TIMERDIFF($BUFFTIMER) > 600000 THEN
			SELFBUFF()
			$BUFFTIMER = TIMERINIT()
		ENDIF
		IF NOT $FIGHTONGROUND THEN
			IF ALTITUDE() < 205 THEN FLYUP(212)
		ENDIF
		IF $FIGHT THEN
			$MOBS = NPCARRAY()
			$CURRTARGET = PLAYERTARGET()
			IF $CURRTARGET THEN
				$INDEX = FINDCLOSEST($MOBS, $CURRTARGET, 0, TRUE, TRUE, 5000, 30)
			ELSE
				$INDEX = FINDCLOSEST($MOBS, "Sacred Spirit Rising Sky", 2, 0, TRUE, 5000, 30)
			ENDIF
			IF $INDEX == -1 THEN
				IF GETGLOBALSETTING("RisingSkyVitMobsAllowKillSteal") THEN
					$BESTMOBSPOTINDEX = PICKBESTMOBSPOT($MOBLOCATIONS, "Sacred Spirit Rising Sky", 30, TRUE)
				ELSE
					$BESTMOBSPOTINDEX = PICKBESTMOBSPOT($MOBLOCATIONS, "Sacred Spirit Rising Sky", 30, FALSE)
				ENDIF
				IF $BESTMOBSPOTINDEX == -1 THEN
					IF TIMERDIFF($TIMETOSLEEPTIMER) > $TIMETOSLEEP THEN
						$TIMETOSLEEP = (RANDOM(1000, 5000))
						$DESTINATION[0] = RANDOM(-1565.34, -1518.73)
						$DESTINATION[1] = RANDOM(141.18, 197.83)
						MOVETO($DESTINATION[0], $DESTINATION[1])
						$TIMETOSLEEPTIMER = TIMERINIT()
					ENDIF
				ELSE
					$DESTINATION[0] = $MOBLOCATIONS[$BESTMOBSPOTINDEX][0]
					$DESTINATION[1] = $MOBLOCATIONS[$BESTMOBSPOTINDEX][1]
					MOVETO($DESTINATION[0], $DESTINATION[1])
				ENDIF
			ENDIF
			AVOIDPLACES($AVOIDPLACES, -1553.45, 172.29, 10, 15)
			IF TIMERDIFF($STUCKTIMER) > 2500 THEN
				IF AREWESTUCK($STUCKTIMER, $POS[0], $POS[1], 2500, 1.5) THEN
					TRUEJUMP()
					SLEEP(300)
					MOVETO2($DESTINATION[0], $DESTINATION[1])
					SLEEP(300)
				ENDIF
				$STUCKTIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
			IF $INDEX <> -1 THEN
				$TARGETUID = $MOBS[$INDEX][0]
				$TARGETX = $MOBS[$INDEX][4]
				$TARGETY = $MOBS[$INDEX][5]
				$MOBCOUNTNEARTARGET = COUNTMOBSINAREA($TARGETX, $TARGETY, 12, 76009, 1, $MOBS)
				$HPMP = GETHPMP()
				IF $HPMP[0] / $HPMP[1] < 0.65 THEN
					KILL($TARGETUID, 200, 0, 2)
				ELSE
					IF $MOBCOUNTNEARTARGET == 1 THEN
						KILL($TARGETUID, 200, 0, 0)
					ELSE
						KILL($TARGETUID, 200, 0, 1)
					ENDIF
				ENDIF
			ENDIF
			IF CLASS() == 7 AND NOT HASBUFF("Focus Accelerated channeling", 37) THEN
				IF $CLERICTIMER == 0 THEN
					IF SKILLOFFCOOLDOWN(566) THEN
						USESKILL(566, PLAYERID())
					ENDIF
					$CLERICTIMER = TIMERINIT()
				ELSEIF TIMERDIFF($CLERICTIMER) > 10500 THEN
					IF SKILLOFFCOOLDOWN(566) THEN
						USESKILL(566, PLAYERID())
					ENDIF
					$CLERICTIMER = TIMERINIT()
				ENDIF
			ENDIF
			IF CLASS() == 5 AND(CURRENTSKILL() == 3777 OR(CURRENTSKILL() == 0 AND QUEUEDSKILL() == 3777)) AND TIMERDIFF($SINTIMER) > 100 THEN
				CANCELACTION()
				$SINTIMER = TIMERINIT()
			ENDIF
			IF CLASS() == 8 AND NOT HASBUFF("Attack Level increased", 135) THEN
				IF TIMERDIFF($SEEKERATTACKGEARTIMER) > 29000 OR $SEEKERATTACKGEARTIMER == 0 THEN
					$SEEKEREQUIPDEF = TRUE
					$SEEKERATTACKGEARTIMER = TIMERINIT()
				ENDIF
				IF $SEEKEREQUIPDEF == TRUE THEN
					SWAPGEAR(2)
					$SEEKEREQUIPDEF = FALSE
					$SEEKEREQUIPATTACK = TRUE
				ENDIF
			ELSEIF CLASS() == 8 AND HASBUFF("Attack Level increased", 135) AND $SEEKEREQUIPATTACK == TRUE THEN
				SWAPGEAR(0)
				$SEEKEREQUIPATTACK = FALSE
				$SEEKERATTACKGEARTIMER = TIMERINIT()
			ENDIF
			IF TIMERDIFF($SPARKTIMER) > 18000 THEN
				$MOBS = NPCARRAY()
				$INDEX = FINDCLOSEST($MOBS, "Sacred Spirit Rising Sky", 2, 0, TRUE, 5000, 30)
				IF $INDEX <> -1 THEN
					$TARGETUID = $MOBS[$INDEX][0]
					SELECTTARGET($TARGETUID)
				ENDIF
				IF CHI() > 300 AND $INDEX <> -1 THEN
					IF ISMELEECLASS() AND DISTANCE2D($MOBS[$INDEX][4], $MOBS[$INDEX][5]) < 10 THEN
						IF NOT(HASBUFF("Intuition Increased magic attack", 46) OR HASBUFF("Sharpen Increased physical attack", 32)) THEN
							TRIPLESPARK()
							$SPARKTIMER = TIMERINIT()
							SLEEP(2500)
						ENDIF
					ELSEIF DISTANCE2D($MOBS[$INDEX][4], $MOBS[$INDEX][5]) < 30 THEN
						IF NOT(HASBUFF("Intuition Increased magic attack", 46) OR HASBUFF("Sharpen Increased physical attack", 32)) THEN
							TRIPLESPARK()
							$SPARKTIMER = TIMERINIT()
							SLEEP(2500)
						ENDIF
					ENDIF
				ENDIF
			ENDIF
		ENDIF
		$COUNT = SETHOSTPARTY()
		IF TIMERDIFF($COUNTNEARBYPLAYERSTIMER) > 60000 THEN
			SETSTATUS("Vitae from mobs = " & VITAEFROMMOBS() & "/" & $VITAELIMIT)
			BUFFCHECK(TRUE)
			IF NOT HAVEALLBUFFS($BUFFSIDS) THEN USEITEMID(38408)
			$CLIENTSINDEXES = GETNEARBYALTS(120)
			IF UBOUND($CLIENTSINDEXES) <> $COUNTOFPARTYMEMBERSNEARBY THEN
				IF $COUNTOFPARTYMEMBERSNEARBY == $COUNT THEN
					$IGNOREVITAEGAINTIMER = 0
				ELSE
					$IGNOREVITAEGAINTIMER = TIMERINIT()
				ENDIF
			ENDIF
			$COUNTOFPARTYMEMBERSNEARBY = UBOUND($CLIENTSINDEXES)
			$COUNTNEARBYPLAYERSTIMER = TIMERINIT()
		ENDIF
		IF VITAEFROMMOBS() >= $VITAELIMIT AND NOT $VITAEBARFULL THEN
			$VITAEBARFULL = TRUE
			$VITAEBARFULLTIMER = TIMERINIT()
			SETSTATUS("Vitae mobs: vitae bar full. Ending vit mobs now.")
			EXITLOOP
		ENDIF
		IF NOT $IGNOREVITAEGAIN AND $VITAEBARFULL AND TIMERDIFF($VITAEBARFULLTIMER) > 120000 THEN
			SETSTATUS("Vitae mobs: Ending vit mobs for this character.")
			$KILLMOBS = FALSE
		ENDIF
		IF $IGNOREVITAEGAIN AND $VITAEBARFULL AND $IGNOREVITAEGAINTIMER <> 0 AND TIMERDIFF($IGNOREVITAEGAINTIMER) > 180000 THEN
			SETSTATUS("Vitae mobs: done for this char that ignores vitae mobs + it appears all other char who don't ignore vitae mobs have left. Ending...")
			$KILLMOBS = FALSE
		ENDIF
		IF NOT $IGNOREVITAEGAIN AND $VITAEBARFULL AND $VITAEBARFULLTIMER <> 0 AND TIMERDIFF($VITAEBARFULLTIMER) > 120000 THEN
			SETSTATUS("Vitae mobs: Leaving vit mobs now.")
			$KILLMOBS = FALSE
		ENDIF
		SLEEP(100)
	WEND
	SETSTATUS("Vitae mobs done. Took " & INT(TIMERDIFF($DURATIONTIMER) / 60000) & " minutes.")
	GOTOTOWNAFTERDEATH()
	SLEEP(100)
	FLYUP(215)
ENDFUNC
FUNC SAROKKANCHEST()
	SETSTATUS("Start scanning for Sarokkan boss chest")
	$TARGET = 0
	$INV = ITEMSARRAY()
	$BIGNOTESPREVIOUS = ITEMCOUNT(21652)
	WHILE TRUE
		$MOBS = NPCARRAY()
		$TARGET = GETNPCUNIQUEID("Sarokkan Legendary Collection")
		IF $TARGET > 0 THEN
			PLAYERTARGET($TARGET)
			SELECTTARGET($TARGET)
			REGATTACK($TARGET)
			REGATTACK($TARGET)
			REGATTACK($TARGET)
			REGATTACK($TARGET)
			REGATTACK($TARGET)
			REGATTACK($TARGET)
			REGATTACK($TARGET)
			EXITLOOP
		ENDIF
	WEND
	SETSTATUS("Chest detected and attacked. Attempting to pick drops with all nearby char.")
	MASSGATHERALL()
	$CLIENTSINDEXES = GETNEARBYALTS(10)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		SETSTATUS("# big notes = " & ITEMCOUNT(21652))
	NEXT
	SETSTATUS("Done.")
ENDFUNC
