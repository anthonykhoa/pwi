	SLEEP(5000)
	CLOSENPCWINDOW()
	SLEEP(5000)
	IF HASQUEST(51939) THEN
		FLYTOCOORDS(93, 374, 64)
		SLEEP(5000)
	ENDIF
	FLYTOCOORDS(184, 404, 69)
	SLEEP(5000)
	TALKTONPC("Holy Ritualmaster")
