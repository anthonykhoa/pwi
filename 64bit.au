FUNC LIFEHUNTERSPAM($DELAY1, $DELAY2)
	IF CLASS() <> 5 THEN
		SETSTATUS("Not an assassin. Make sure bot is set to an assassin character.")
		RETURN
	ENDIF
	$PARTY = PARTYARRAY()
	SETSTATUS("☻ -------------------------------- LIFE HUNTER SPAM ------------------------------- ☻")
	$TARGET = PLAYERTARGET()
	WHILE MOVEKEY() == 0 AND GETHPMP()[0] > 0 AND $TARGET
		FOR $I = 0 TO UBOUND($PARTY) - 1
			IF $TARGET == $PARTY[$I][0] THEN
				CONTINUELOOP
			ENDIF
		NEXT
		IF NOT SKILLOFFCOOLDOWN(3777) THEN EXITLOOP
		USESKILL(3777, $TARGET)
		SLEEP($DELAY1)
		CANCELACTION()
		SLEEP($DELAY2)
		$TARGET = PLAYERTARGET()
		$PARTY = PARTYARRAY()
	WEND
	SETSTATUS("☻ ---------------------------------- LF cancelled ---------------------------------- ☻")
ENDFUNC
