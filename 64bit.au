	LOADCHARCHECKBOX("tower", "UseAncientGift", $HUSEANCIENTGIFTTOWER)
	LOADCHARCHECKBOX("tower", "UseSpiritOfDefense", $HUSESPIRITOFDEFENSE)
	LOADCHARCHECKBOX("tower", "UseSpiritOfAssault", $HUSESPIRITOFASSAULT)
	LOADCHARCHECKBOX("tower", "UseHolyPath", $HUSEHOLYPATH)
	LOADCHARCHECKBOX("tower", "UseGenieChi", $HUSEGENIECHI)
	LOADCHARCHECKBOX("tower", "StrongCharacter", $HSTRONGCHARACTER)
	LOADCHARCHECKBOX("tower", "Macro7Chi", $HMACRO7CHI)
	LOADCHARCHECKBOX("tower", "PortalKill10", $HKILLPORTALMOBS10ATATIME)
