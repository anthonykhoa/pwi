FUNC CAMERADIR()
	$PLAYER = PLAYERADDRESS()
	DIM $DIR[3]
	$DIR[0] = _MEMORYREAD($PLAYER + $PLAYERCAMX_OFFSET, $GAME_PROCESS, "float")
	$DIR[1] = _MEMORYREAD($PLAYER + $PLAYERCAMX_OFFSET + 8, $GAME_PROCESS, "float")
	$DIR[2] = _MEMORYREAD($PLAYER + $PLAYERCAMX_OFFSET + 4, $GAME_PROCESS, "float")
	RETURN $DIR
ENDFUNC
FUNC PLAYERDIR()
	$PLAYER = PLAYERADDRESS()
	DIM $DIR[3]
	$DIR[0] = _MEMORYREAD($PLAYER + 44, $GAME_PROCESS, "float")
	$DIR[1] = _MEMORYREAD($PLAYER + 52, $GAME_PROCESS, "float")
	$DIR[2] = 0
	RETURN $DIR
ENDFUNC
FUNC ZOOM($AMOUNT = -1)
	$CAMBASE = PLAYERBASE() + $PLAYERCAMX_OFFSET
	IF $AMOUNT == -1 THEN
		RETURN _MEMORYREAD($CAMBASE + 200, $GAME_PROCESS, "float")
	ELSE
		_MEMORYWRITE($CAMBASE + 200, $GAME_PROCESS, $AMOUNT, "float")
		_MEMORYWRITE($CAMBASE + 140, $GAME_PROCESS, 256)
	ENDIF
ENDFUNC
