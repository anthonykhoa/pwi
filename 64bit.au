FUNC ADVENTUREKINGDOMUNGLITCH()
	SETSTATUS("Exiting and re-entering Adventure Kingdom to unglitch ride.")
	$POS = PLAYERPOS()
	TRANSFERMAP($MAP_MAIN, 0, 1254.52, 862.06)
	SLEEP(5000)
	ENTERADVENTUREKINGDOM()
	FLY($POS[0], $POS[1])
	SLEEP(1000)
ENDFUNC
FUNC ISADVENTUREKINGDOMOPEN()
	SETSTATUS("Checking Adventure Kingdom")
	TRANSFERMAP($MAP_MAIN, 0, 1254.52, 862.06)
	RETURN GETNPCUNIQUEID("Tremolo the Tiger") <> 0
ENDFUNC
FUNC ENTERADVENTUREKINGDOM()
	TAKEQUEST("Tremolo the Tiger", 39314, 1254.52, 862.06)
	WAITFORNPC("Teleporter Yeon")
ENDFUNC
FUNC EXITADVENTUREKINGDOM()
	TAKENEARESTQUEST($ADVENTUREKINGDOMEXITNPCS)
	WAITFORNPC("Cosmetic Master Yun")
ENDFUNC
FUNC ENTEROHT()
	FLY(1528, 1044, 278.42)
	TAKEQUEST("Messenger of Time", 13778)
	WHILE NOT GETNPCUNIQUEID("Apothecary Te")
		SLEEP(1000)
	WEND
	TAKEQUEST("Messenger of Time", 13846)
	WHILE NOT GETNPCUNIQUEID("Sentinel Yi") AND NOT GETNPCUNIQUEID("Sentinel Ping")
		SLEEP(1000)
	WEND
ENDFUNC
FUNC EXITOHT()
	IF NOT TELEPORTINCENSE() THEN TOWNPORTAL()
	WHILE NOT GETNPCUNIQUEID("Teleport Master Yao")
		TELEPORTSTONETOETHERBLADE()
		SLEEP(1000)
	WEND
ENDFUNC
FUNC ENTERMOMAGANON()
	FLY(-2825.77, 3092.21, 55)
	WHILE GETNPCUNIQUEID("Teleport Master Lu")
		MOVETO(-2780.34, 3112.58)
		WAITSTOP()
		SLEEP(3000)
	WEND
	WAITFORNPC("Blacksmith Tuan Yu")
ENDFUNC
FUNC EXITMOMAGANON()
	FLY(-682.38, -498.32, 60)
	WHILE GETNPCUNIQUEID("Tang Wuyang")
		MOVETO(-708, -488)
		SLEEP(300)
		WAITSTOP()
		SLEEP(2000)
	WEND
	WAITFORNPC("Teleport Master Lu")
	IF NOT CANTELEPORT() THEN MOVE(-2707, 3094)
ENDFUNC
FUNC ENTERLOTHRANIS()
	FLY(-2825.77, 3092.21, 55, 1)
	MOVE(-2782.41, 3077.71)
	WHILE GETNPCUNIQUEID("Teleport Master Lu")
		MOVETO(-2780.39, 3074.51)
		WAITSTOP()
		SLEEP(4000)
	WEND
	WAITFORNPC("Tan Yangtzu")
ENDFUNC
FUNC EXITLOTHRANIS()
	TAKEQUEST("Teleport Master", 6294, 754.2, -485.39)
	WAITFORNPC("Teleport Master Lu")
	IF NOT CANTELEPORT() THEN MOVE(-2707, 3094)
ENDFUNC
FUNC ENTERMORAI()
	DIM $QUESTS[15] = [25970, 25970, 25969, 25957, 25957, 25969, 25971, 25971, 25972, 25972, 32349, 32349, 25970, 25971, 25957]
	TAKEQUEST("Messenger of Time Woyo", $QUESTS[CLASS()], 480.49, 3235.84)
	WAITFORNPC("Teleporter Shia Sol")
	$CLASS = CLASS()
	IF $CLASS == 11 OR $CLASS == 10 THEN
		FLYUP(180)
		FLY(-1760, 305, 18, 0)
	ELSEIF $CLASS == 3 OR $CLASS == 4 OR $CLASS == 14 THEN
		FLYUP()
	ENDIF
	FLY(-1748.94, 312.33, 17)
	FLYUP()
	SLEEP(100)
ENDFUNC
FUNC EXITMORAI()
	TAKENEARESTQUEST($MORAI_EXIT_NPCS)
	USETELEPORTMASTER("Teleporter Mon Suer", 0)
	WAITFORNPC("Messenger of Time Woyo")
ENDFUNC
FUNC ENTERFACTIONBASE()
	IF FACTIONID() == 0 THEN RETURN FALSE
	IF TELEPORTTOFACTIONBASE() THEN RETURN TRUE
	RETURN ENTERFACTIONBASEFROMNPC()
ENDFUNC
FUNC ENTERFACTIONBASEFROMNPC()
	TRANSFERMAP($MAP_MAIN, 0, 1718.44, 1062.93)
	TALKTONPC("Faction Base Manager Zeen")
	FOR $I = 0 TO 6
		ENTERFACTIONBASEPACKET(PLAYERID(), FACTIONID())
		SLEEP(4000)
		IF INSTANCEID() == 135 THEN
			SETSTATUS("In Factionbase")
			RETURN TRUE
		ENDIF
	NEXT
	RETURN FALSE
ENDFUNC
FUNC TELEPORTTOFACTIONBASE()
	IF INSTANCEID() == $MAP_NORTHERNREALM THEN TRANSFERMAP($MAP_MAIN)
	IF NOT SKILLOFFCOOLDOWN(4636, 4) THEN RETURN FALSE
	$SKILL = SKILLOFFCOOLDOWN(4636, 4)
	IF $SKILL == 0 THEN RETURN FALSE
	IF SKILLCASTCONDITION($SKILL) <> 0 THEN RETURN FALSE
	WHILE SKILLOFFCOOLDOWN(4636, 4)
		CASTSKILL(4636, 4)
		WAITTOFINISH()
	WEND
	RETURN TRUE
ENDFUNC
FUNC DOEXITFACTIONBASE()
	WHILE INSTANCEID() <> 1
		SENDPACKET("DB00", 2, $GAME_PID)
		SLEEP(4000)
	WEND
	WHILE NOT(INSTANCEID() == 1 AND UBOUND((NPCARRAY())) > 0 AND PLAYERID() <> 0)
		SLEEP(1000)
	WEND
	SLEEP(1000)
ENDFUNC
FUNC INITIALMAP()
	FOR $I = 0 TO 1
		$ID = INSTANCEID()
		IF $ID == $MAP_MAIN THEN RETURN $MAP_MAIN
		IF $ID == $MAP_MORAI THEN RETURN $MAP_MORAI
		IF $ID == $MAP_PRIMAL THEN RETURN $MAP_PRIMAL
		IF $ID == $MAP_STORY THEN RETURN $MAP_STORY
		IF $ID == $MAP_NEVERFALL THEN RETURN $MAP_NEVERFALL
		IF $ID == $MAP_ADVENTUREKINGDOM THEN RETURN $MAP_ADVENTUREKINGDOM
		IF $ID == $MAP_ULFGARD THEN RETURN $MAP_ULFGARD
		IF $ID == $MAP_LOTH THEN RETURN $MAP_LOTH
		IF $ID == $MAP_MOMA THEN RETURN $MAP_MOMA
		IF $ID == $MAP_FACTIONBASE THEN RETURN $MAP_FACTIONBASE
		IF $ID == $MAP_NORTHERNREALM THEN RETURN $MAP_NORTHERNREALM
		IF $ID >= 180 AND $ID <= 183 THEN RETURN $MAP_HOME
		IF $ID == $MAP_OHT THEN RETURN $MAP_OHT
		SLEEP(1000)
	NEXT
	RETURN $MAP_UNKNOWN
ENDFUNC
FUNC ENTERPRIMAL()
	DIM $QUESTS[15] = [30519, 30519, 30522, 30520, 30520, 30522, 30521, 30521, 30523, 30523, 32346, 32346, 30519, 30521, 30520]
