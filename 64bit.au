FUNC TTR4_1_NOINV()
	SWITCHTO($MAIN)
	$CLIENTSINDEXES = GetSquadAlts()
	$ARRAY = INVARRAY()
	SLEEP(2000)
	$INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
	USETELESTONE($ARRAY[$INDEX][1], $ARRAY[$INDEX][0], 3401)
	SLEEP(2000)
	TRANSFERMAP($MAP_MAIN, 0, -2694.79, 1183.94, 70)
	SLEEP(2000)
	$CLIENTSINDEXES = GetSquadAlts()
	MOVE(-2691.19, 1192.58)
	USEAVAILABLEITEM(32014, 31647) ; squad signets
	SLEEP(10000)
	MASSSQUADSIGNETACCEPT()
	SLEEP(10000)
	MOVE(-2689.914, 1196.032)
	MASSMOVE()
	SLEEP(10000)
	MOVE(-541.83, -258.47)
	TAKEQUEST("Chap.4: Rhapsody of the Revived", 40324)
	SLEEP(1000)
	ClientsMoveAndWait(-542.29, -253.81, $CLIENTSINDEXES, 197) ; this works, but this is the entrance
	SLEEP(3000) ; first is the default arg, 2nd is the fact that not all quests are taken by the NPC
	NPCHELPER() ; sends us to 2nd room in TTR
	SLEEP(10000)
	ClientsMoveAndWait(-642.1, -254.13, $CLIENTSINDEXES, 197)
	TAKEQUEST("Master Thief Inna Woo", 40878)
	FULLBUFF()
	; mystic buffs for all?
	MASSBUFFCHECK()
	IF SKILLOFFCOOLDOWN(1860) THEN
		CASTSKILL(1860)
	ENDIF
	
	; pass
	; pass
	SLEEP(5000)
        ClientsMoveAndWait(-693.78, -254.81, $CLIENTSINDEXES, 197)
        ClientsMoveAndWait(-692.07, -234.23, $CLIENTSINDEXES, 197) ; end of the movement
	MOVE(-693.29, -183.58)
        $MobName = "Soulbanisher"
	TargetSpecificMobKillStop($MobName, 0)
	Sleep(2000)
	SWITCHTO($MAIN)
        Sleep(3000) ; FIRST BATCH
	SWITCHTO($MAIN)
        $MobName = "Shattered Dream Raptor"
	TargetSpecificMobKillStop($MobName, 0)
        Sleep(2000)
	$MobName = "Shattered Dream Raptor"
	TargetSpecificMobKillStop($MobName, 0)
	$MobName = "Soulbanish Summoner"
	TargetSpecificMobKillStop($MobName, 0)
        $MobName = "Revived Twilight Brute"
	TargetSpecificMobKillStop($MobName, 0)
	$MobName = "Revived Twilight Brute"
	TargetSpecificMobKillStop($MobName, 0)
	$MobName = "Shattered Dream Raptor"
	TargetSpecificMobKillStop($MobName, 0)
	$MobName = "Revived Head Hunter"
	TargetSpecificMobKillStop($MobName, 0)
	$MobName = "Shattered Dream Raptor"
	TargetSpecificMobKillStop($MobName, 0)
	$MobName = "Revived Head Hunter"
	TargetSpecificMobKillStop($MobName, 0)
        Sleep(2000)
	ClientsMoveAndWait(-693.24, -175.22, $CLIENTSINDEXES, 197)
	; if any clients died, res with mystic buff
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			$HPMP = GETHPMP()
			IF $HPMP[0] == 0 OR $HPMP[2] == 0 THEN
				RESINPLACE()
				
			ENDIF	
	NEXT
	SLEEP(10000)
	SWITCHTO($MAIN)
	; add running in straight line to end of hall
	MOVE(-693.46, -104.18)
	$MobName = "Masterless Phantom"
	TargetSpecificMobKillStop($MobName, 0)
	Sleep(500)
	$MobName = "Masterless Phantom" ; again just for sanity check
	TargetSpecificMobKillStop($MobName, 0)
	MOVE(-693.46, -104.18)
	ClientsMoveAndWait(-693.41, -191.04, $CLIENTSINDEXES, 197)
	FULLBUFF()
	; mystic buffs for all?
	MYSTICAOEREVIVE($CLIENTSINDEXES)
	ClientsMoveAndWait(-693.59, -104.90, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-765.20, -105.62, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-772.11, -139.16, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-758.29, -137.31, $CLIENTSINDEXES, 197)
	MOVE(-790.21, -136.88)

	$MobName = "Soulbanish Summoner"
	TargetSpecificMobKillStop($MobName, 0) ; might be 59772, not sure yet. ; this is the summoner
	; IDs of mobs: 59744, 59744, 59813, 59813, 59812
	;$Target = WaitToFindTarget2(59744) ; the 5 mobs that spawn from the summoner

	$MobName = "Shattered Dream Raptor"
	TargetSpecificMobKillStop($MobName, 0)

	$MobName = "Shattered Dream Raptor"
	TargetSpecificMobKillStop($MobName, 0)

	$MobName = "Revived Head Hunter"
	TargetSpecificMobKillStop($MobName, 0)

	$MobName = "Revived Head Hunter"
	TargetSpecificMobKillStop($MobName, 0)

	$MobName = "Revived Twilight Brute"
	TargetSpecificMobKillStop($MobName, 0)

	; When they die, start moving again
	ClientsMoveAndWait(-817.33, -150.49, $CLIENTSINDEXES, 197)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			$HPMP = GETHPMP()
			IF $HPMP[0] == 0 OR $HPMP[2] == 0 THEN
				RESINPLACE()
			ENDIF	
	NEXT
	SLEEP(10000)
	ClientsMoveAndWait(-817.71, -182.62, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-804.72, -183.61, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-801.96, -169.07, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-737.72, -169.14, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-733.82, -233.18, $CLIENTSINDEXES, 197)
	FULLBUFF()
	IF SKILLOFFCOOLDOWN(1860) THEN
		CASTSKILL(1860)
	ENDIF
	VENOSWITCHTOFOXFORM()
	MYSTICCHIPLANT($CLIENTSINDEXES)
	SWITCHTO($MAIN)
	MOVE(-733.42, -170.81) ; move with main
	MOVE(-790.50, -176.95)
	MassGenieChiSkill(350, TRUE)
	SLEEP(1000)
	USEAVAILABLEITEM2(55067) ; anti stun pot
	$MobName = "Twilight Emperor"
	TargetSpecificMobKillStop($MobName, 5, True)
	; MASSNUKEBOSSTTR($MobName,True, True, False, False, 400, True, True)
	$MobName = "Revived Head Hunter"
	TargetSpecificMobKillStop($MobName, 0)
	$MobName = "Revived Head Hunter"
	TargetSpecificMobKillStop($MobName, 0)
	; if any clients died, res with mystic buff
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			$HPMP = GETHPMP()
			IF $HPMP[0] == 0 OR $HPMP[2] == 0 THEN
				RESINPLACE()
				
			ENDIF	
	NEXT
	SLEEP(10000)
	ClientsMoveAndWait(-778.41, -196.93, $CLIENTSINDEXES, 197)
	IF GETGLOBALSETTING("UsePickupAll") THEN
    	  MASSPICKUPALL()
  	ELSE
    	  MASSGATHERALL()
	ENDIF
  	MASSSWITCHTOHUMANFORM()
	SLEEP(1000)
	SETSTATUS("TTR: 1st boss done, poggers.")
	ClientsMoveAndWait(-733.82, -233.18, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-758.82, -230.76, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-762.27, -284.82, $CLIENTSINDEXES, 197)
	TAKEQUEST("Princess of Moonlight", 40328)
	; Onto part 2!
	; Alts go here, main moves back to original pos.
	ClientsMoveAndWait(-759.36, -263.10, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-808.07, -263.55, $CLIENTSINDEXES, 197)
	SWITCHTO($MAIN)
	ClientsMoveAndWait(-759.36, -263.10, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-758.86, -223.23, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-801.83, -183.52, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-817.60, -183.54, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-817.67, -137.47, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-772.30, -137.20, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-764.76, -104.35, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-789.60, -104.48, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-788.25, -36.97, $CLIENTSINDEXES, 197)
	; Now: add this coordinate
	ClientsMoveAndWait(-787.72, -15.17, $CLIENTSINDEXES, 197)
	ClientsMoveAndWait(-787.61, -14.38, $CLIENTSINDEXES, 197)
	For $i = 0 To UBound($ClientsIndexes) - 1
      		SwitchToNum($ClientsIndexes[$i])
		If Class() == 8 THEN
			USEGENIECHITTR()
			SLEEP(40000)
			USEGENIECHITTR()
		ENDIF
	NEXT
	ClientsDoubleJumpAndMove(-778.55, -14.46, $ClientsIndexes, 200, 200)
	ClientsMoveAndWait(-789.61, -20.07, $CLIENTSINDEXES, 197) ; this is to twilight minister
	For $i = 0 To UBound($ClientsIndexes) - 1
      		SwitchToNum($ClientsIndexes[$i])
		IF CLASS() == 7 THEN
			CASTSKILL(3550)
		ENDIF
	NEXT
	$MAXHPCHECKER = 0
	For $i = 0 To UBound($ClientsIndexes) - 1
      		SwitchToNum($ClientsIndexes[$i])
		$CHECKING = GETMAXHP()
		If Class() == 8 AND $MAXHPCHECKER < $CHECKING THEN
			$MAXHPCHECKER = GETMAXHP()
		ENDIF
	NEXT
	; if the class == seeker:
	For $i = 0 To UBound($ClientsIndexes) - 1
      		SwitchToNum($ClientsIndexes[$i])
		$MAXHP = GETMAXHP()
        	If Class() == 8 AND $MAXHP == $MAXHPCHECKER Then ; Seeker class
			MOVE(-749.08, -12.26)
			MOVE(-743.02, -8.86)
			$Mobs = NPCARRAY()
			$Index = FindClosest($Mobs, "Armageddon", 2, 0, True, 20, 300)
