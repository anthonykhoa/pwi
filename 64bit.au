FUNC RUNDHJ(ByRef $ClientsIndexes)
  SwitchTo($MAIN)
  SetStatus("Starting Dhj")
  SquadLeaveFix($ClientsIndexes)
  ClientsMoveAndWait(103.250, 13.298, $CLIENTSINDEXES, 186)
  TakeQuest("Archmage Marjorie", 39550, 91.49, 32.37, 55, False, True, False)
  MoveAndWait(97.913, 27.120)
  ClientsMoveAndWait(115.15, 37.56, $CLIENTSINDEXES, 186)
  MassGenieChiSkill(350, TRUE)
  ClientsMoveAndWait(128.77, 39.35, $CLIENTSINDEXES, 186)
  SquadLeaveFix($ClientsIndexes)
  FULLBUFF()
  While True
    WaitForNpc("Voodoo Chill")
    SquadLeaveFix($ClientsIndexes)
    MoveClientsToNpc("Vodoo Chill", $ClientsIndexes, 128.77, 39.35)
    If IsQuestAvailable(37647) Then
      SETSTATUS("Starting fairy boss.")
      TAKEQUEST("Voodoo Chill", 37647, 128.77, 39.35, 60.77, TRUE, TRUE, FALSE, 186)
      ExitLoop
    Else
      SETSTATUS("Resetting fairy boss.")
      TAKEQUEST("Voodoo Chill", 37717, 128.77, 39.35, 60.77, TRUE, TRUE, FALSE, 186)
      Sleep(12000)
    EndIf
  WEnd
  SquadLeaveFix($ClientsIndexes)
  IF MASSGENIEENERGYCHECK($CLIENTSINDEXES, 165) THEN MASSSpeedPATH($CLIENTSINDEXES)
  ClientsMoveAndWait(186.72, 39.06, $ClientsIndexes, 186)
  Sleep(2000)
  ClientsJumpMoveAndWait(210.13, 38.34, $ClientsIndexes, 186)
  IF GETGLOBALSETTING("dhjFairyBossMysticSecondChiPlant") THEN PREPAREALTSFORNUKE($CLIENTSINDEXES, FALSE, FALSE)
  SquadLeaveFix($ClientsIndexes)
  TAKEQUEST("Flame Guardian", 37801, 210.13, 38.34, 61.23, TRUE, TRUE, FALSE, 186)
  ; KillDhjBoss($ClientsIndexes) commented out to prevent execution
  For $i = 0 To UBound($ClientsIndexes) - 1
      	SwitchToNum($ClientsIndexes[$i])
        If Class() == 8 Then ; Seeker class
		CastSkill(2251) ; SS
	ENDIF
  Next
  ; Sleep(2000)
  ; LEAVESQUAD() ; comment out for now
  For $i = 0 To UBound($ClientsIndexes) - 1
      	SwitchToNum($ClientsIndexes[$i])
        If Class() == 8 Then ; Seeker class
	    
            SetStatus("Seeker using will surge")
            $SecondTarget = WaitToFindTarget(53500)
            QuickSelect($SecondTarget)
            
            $SkillID = CastSkill(970, 1) ; Will surge            
            ; Cast
            CastSkill($SkillID)
	    Sleep(100)
        EndIf
    Next
    ; Cleric casts IMMO second
    For $i = 0 To UBound($ClientsIndexes) - 1
    	SwitchToNum($ClientsIndexes[$i])
    	If Class() == 7 Then ; Cleric (EP) class
        	$FirstTarget = WaitToFindClassMatch($ClientsIndexes)
		SwitchToNum($ClientsIndexes[$i])
    		QuickSelect($FirstTarget)
        	Sleep(500)
        	$SkillID = 6916 ; SOG skill ID
        	CastSkill($SkillID)
        	Sleep(1000)
        	$SecondTarget = WaitToFindTarget(53500)
        	QuickSelect($SecondTarget)
    	EndIf
    Next

    SWITCHTO($MAIN)
    ; RejoinSquad2()
    For $i = 0 To UBound($ClientsIndexes) - 1
      	SwitchToNum($ClientsIndexes[$i])
        If Class() == 8 Then ; Seeker class
	    ;Sleep(1000)
	    ;CastSkill(2251) ; SS 
	    ;Sleep(1000)
            SetStatus("Seeker casting QPQ")
            $SecondTarget = WaitToFindTarget(53500)
            QuickSelect($SecondTarget)
            
            ;           
            ; Cast
            CastSkill($SkillID)
            ;Sleep(2000)
            CastSkill(2252) ; QPQ
            Sleep(2000)
	    CastSkill(2249) ; chaos blade
	    Sleep(2000)
        EndIf
    Next
  KillTargetClientsUpdatedForDHJ($SecondTarget, $ClientsIndexes, 0, 34)
  SWITCHTO($MAIN)
  ClientsJumpMoveAndWait(243.18, 39.23, $ClientsIndexes, 0)
  SETSTATUS("Looking for chest.")
  IF GETGLOBALSETTING("UsePickupAll") THEN
    MASSPICKUPALL()
  ELSE
    MASSGATHERALL()
  ENDIF
  AutoAttackTargetClients(54651, $ClientsIndexes, 1)
  IF GETGLOBALSETTING("UsePickupAll") THEN
    MASSPICKUPALL()
  ELSE
    MASSGATHERALL()
  ENDIF
  CleanDHItems() 
  MASSSWITCHTOHUMANFORM()
  SLEEP(1000)
  SETSTATUS("DHJ: Fairy boss done.")
  ResetDhjFairyBoss($ClientsIndexes)
ENDFUNC

Func ResetDhjFairyBoss(ByRef $ClientsIndexes)
  IF MASSGENIEENERGYCHECK($CLIENTSINDEXES, 75) THEN MASSSpeedPATH($CLIENTSINDEXES)
  ClientsMoveAndWait(152.51, 39.1, $ClientsIndexes, 186)
  IF MASSGENIEENERGYCHECK($CLIENTSINDEXES, 75) THEN MASSSpeedPATH($CLIENTSINDEXES)
  ClientsMoveAndWait(108.81, 44.56, $ClientsIndexes, 186)
  ResetDhj($ClientsIndexes)
EndFunc

FUNC RESETDHJBUTTON()
  $ClientsIndexes = GETSQUADALTS()
  ResetDhj($ClientsIndexes)
ENDFUNC

FUNC RESETDHJBUTTON2()
  $MEMBERS = PARTYARRAY2()
  $SQUADLIST = GETSQUADALTS()
  RESETDHJ2($MEMBERS, $SQUADLIST)
ENDFUNC

Func ResetDhjButton3()
  $SquadAlts = GetSquadAlts()
  ResetDhjFairyBoss($SquadAlts)
EndFunc

Func ClientsTrueJump(ByRef $ClientsIndexes)
  FOR $I = 0 TO UBOUND($ClientsIndexes ) - 1
    SwitchToNum($ClientsIndexes[$I])
    TRUEJUMP()
  NEXT
  SWITCHTO($MAIN)
EndFunc

Func ClientsDoubleJumpAndMove($x, $y, ByRef $ClientsIndexes, $FirstDelay = 700, $SecondDelay = 700)
  ClientsTrueJump($ClientsIndexes)
  Sleep($FirstDelay)
  ClientsJumpMoveAndWait($x, $y, $ClientsIndexes, $SecondDelay)
EndFunc

Func ClientsDoubleJumpAndMove2($x, $y, $FirstDelay = 700, $SecondDelay = 700)
  $ClientsIndexes = GetSquadAlts()
  ClientsTrueJump($ClientsIndexes)
  Sleep($FirstDelay)
  ClientsJumpMoveAndWait($x, $y, $ClientsIndexes, $SecondDelay)
EndFunc

Func ClientsJumpMoveAndWait($x, $y, ByRef $ClientsIndexes, $Delay = 700)
  ClientsTrueJump($ClientsIndexes)
  Sleep($Delay)
  ClientsMove($x, $y, $ClientsIndexes)
  WaitClientsToFinish($ClientsIndexes)
EndFunc

Func ClientsJumpAndMove($x, $y, ByRef $ClientsIndexes, $Instance = 0)
  ClientsTrueJump($ClientsIndexes)
  ClientsMove($x, $y, $ClientsIndexes, $Instance)
EndFunc

Func ClientsMoveAndWait($x, $y, ByRef $ClientsIndexes, $instance = 0)
  ClientsMove($x, $y, $ClientsIndexes, $Instance)
  WaitClientsToFinish($ClientsIndexes)
EndFunc

Func WaitClientsForInstance($InstanceId, $ClientsIndexes)
  For $i = 0 To UBound($ClientsIndexes) - 1
    SwitchToNum($ClientsIndexes[$i])
    While InstanceId() <> $InstanceId
      Sleep(200)
    WEnd
  Next
  SwitchTo($Main)
EndFunc

FUNC RESETDHJ($ClientsIndexes)
  SETSTATUS("DHJ: Resetting DHJ run without using entrance items. Starting from fairy boss room or main hall.")
  ClientsMoveAndWait(119.85, 66.59, $ClientsIndexes, 186)
  ClientsMoveAndWait(111.29, 66.87, $ClientsIndexes, 186)
  ClientsDoubleJumpAndMove(101.800, 66.684, $ClientsIndexes)
  ClientsJumpAndMove(96, 66.684, $ClientsIndexes, 186)
  Sleep(700)
  ClientsJumpMoveAndWait(91.5, 70.352,$ClientsIndexes, 500)
  ClientsDoubleJumpAndMove(91.66, 93.92,$ClientsIndexes, 500, 0)
  ClientsMoveAndWait(91.66, 93.92, $ClientsIndexes)
  ClientsDoubleJumpAndMove(91.33, 95.93, $ClientsIndexes)
  ClientsJumpMoveAndWait(91.22, 108.33, $ClientsIndexes, 300)
  ReformSquad ($ClientsIndexes)
  MASSSpeedPATH($ClientsIndexes)
  ClientsMoveAndWait(48.69, 145.56, $ClientsIndexes, 186)
  ClientsMoveAndWait(24.35, 146.61, $ClientsIndexes, 186)
  ClientsMoveAndWait(25.67, 134.73, $ClientsIndexes, 186)
  WaitClientsToDie($ClientsIndexes)
  GlitchTeleportClients($ClientsIndexes)
  WaitClientsForInstance(186, $ClientsIndexes)
  Sleep(10000)
  SETSTATUS("Reset DHJ done.")
ENDFUNC

Func WaitClientsToDie(ByRef $ClientsIndexes)
  For $i = 0 To UBound($ClientsIndexes) - 1
    SwitchToNum($ClientsIndexes[$i])
    While Alive()
      Sleep(200)
    WEnd
  Next
  Sleep(1000)
  SwitchTo($Main)
EndFunc

Func GlitchTeleportClients(ByRef $ClientsIndexes)
  Dim $ClientsQuests[UBound($ClientsIndexes)]

  For $i = 0 To UBound($ClientsIndexes) - 1
    SwitchToNum($ClientsIndexes[$i])
    $ClientsQuests[$i] = UBound(QuestArray())
  Next

  Dim $Glitched[UBound($ClientsIndexes)]
  $GlitchedCount = 0
  While $GlitchedCount < UBound($ClientsIndexes)
    For $i = 0 To UBound($ClientsIndexes) - 1
      If $Glitched[$i] Then ContinueLoop
      SwitchToNum($ClientsIndexes[$i])
      If Not Alive() Then
        GoToTownAfterDeath()
        ContinueLoop
      EndIf

      If UBound(QUESTARRAY()) > $ClientsQuests[$i] Then
        TeleportStoneTo(9022)
        $Glitched[$i] = True
        $GlitchedCount += 1
      EndIf
    Next
    Sleep(100)
  WEnd
  SwitchTo($Main)
EndFunc

FUNC RESETDHJ2($MEMBERS, $SQUADLIST)
  SETSTATUS("DHJ: Resetting DHJ run without using entrance items. Starting from LAST boss room.")
  MASSSpeedPATH($SQUADLIST)
  MASSMOVETOCOORD(-158.27, 146.98, $SQUADLIST, TRUE, 186)
  REFORMSQUAD()
  SLEEP(1000)
  MASSMOVETOCOORD(-157.53, 135.43, $SQUADLIST, TRUE, 186)
  SLEEP(15000)
  SQUADCOMBATMODECHECK($SQUADLIST, -157.53, 135.43, 10, 120000)
  $ONEMINTIMER = TIMERINIT()
  FOR $I = 0 TO UBOUND($SQUADLIST) - 1
    $INDEX = $SQUADLIST[$I]
    SWITCHTONUM($INDEX)
    $QUESTSAMOUNT = UBOUND(QUESTARRAY())
    $ARRAY = INVARRAY()
    $INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
    IF $INDEX == -1 THEN
      SETSTATUS("Out of teleport stones. Fix this for future runs.")
      CONTINUELOOP
    ENDIF
    $HPMP = GETHPMP()
    DO
      GOTOTOWNAFTERDEATH()
      SLEEP(100)
      $HPMP = GETHPMP()
    UNTIL $HPMP[2] > 0
    WHILE UBOUND(QUESTARRAY()) == $QUESTSAMOUNT
      IF TIMERDIFF($ONEMINTIMER) > 180000 THEN
        SETSTATUS("180s exceeded while trying to glitch reset this character. Continuing...")
        EXITLOOP
      ENDIF
      SLEEP(100)
    WEND
    USETELESTONE($ARRAY[$INDEX][1], $ARRAY[$INDEX][0], 6101)
  NEXT
  SLEEP(3000)
  CLERICHEAL($SQUADLIST)
  SLEEP(4000)
  CLERICHEAL($SQUADLIST)
  SLEEP(4000)
  CLERICHEAL($SQUADLIST)
  CANCELCLERICBB($SQUADLIST)
  SETSTATUS("Reset DHJ done.")
  $CHECKALLCHARINSQUADTIMER = TIMERINIT()
  WHILE TIMERDIFF($CHECKALLCHARINSQUADTIMER) < 30000
    SLEEP(1000)
  WEND
ENDFUNC
#EndRegion DHJ
#region UPD
	FUNC RESETUPD0BUTTON()
		$PERMITCHECKERBOARD = TRUE
		$MEMBERS = PARTYARRAY2()
		$SQUADLIST = GETSQUADALTS()
		RESETUPD0($MEMBERS, $SQUADLIST, $PERMITCHECKERBOARD)
	ENDFUNC
	FUNC RESETUPD0($MEMBERS, $SQUADLIST, $PERMITCHECKERBOARD)
		SWITCHTO($MAIN)
		$CLIENTSINDEXES = GETSQUADALTS()
		$FASTRESETTIMING = FALSE
		IF GETGLOBALSETTING("waitUpTo5MinutesForUPDReset") THEN
			IF SQUADCOMBATMODECHECK($SQUADLIST, -299.15, -185.71, 45, 300000) THEN
				$FASTRESETTIMING = TRUE
			ENDIF
		ELSEIF GETGLOBALSETTING("waitUpTo2MinutesForUPDReset") THEN
			IF SQUADCOMBATMODECHECK($SQUADLIST, -299.15, -185.71, 45, 120000) THEN
				$FASTRESETTIMING = TRUE
			ENDIF
		ELSEIF GETGLOBALSETTING("waitUpTo1MinutesForUPDReset") THEN
			IF SQUADCOMBATMODECHECK($SQUADLIST, -299.15, -185.71, 45, 60000) THEN
				$FASTRESETTIMING = TRUE
			ENDIF
		ENDIF
		SWITCHTO($MAIN)
		DIM $TELEPORTSTONEARRAY[UBOUND($SQUADLIST)][2]
		FOR $I = 0 TO UBOUND($SQUADLIST) - 1
			$INDEX = $SQUADLIST[$I]
			SWITCHTONUM($INDEX)
			$ARRAY = INVARRAY()
			$INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
			$ITEMID = -1
			$ITEMPOS = -1
			IF $INDEX == -1 THEN
				SETSTATUS("Out of teleport stones. Fix this for future runs.")
			ELSE
				$ITEMID = $ARRAY[$INDEX][1]
				$ITEMPOS = $ARRAY[$INDEX][0]
			ENDIF
			$TELEPORTSTONEARRAY[$I][0] = $ITEMID
			$TELEPORTSTONEARRAY[$I][1] = $ITEMPOS
		NEXT
		SWITCHTO($MAIN)
		REFORMSQUAD()
		SLEEP(500)
		SWITCHTO($MAIN)
		CHECKALLCHARINSIDEINSTANCE(176, $SQUADLIST)
		$ONEMINTIMER = TIMERINIT()
		$QUIT = FALSE
		WHILE NOT $QUIT
			$QUIT = TRUE
			IF TIMERDIFF($ONEMINTIMER) > 70000 THEN
				SETSTATUS("70s exceeded while trying to glitch reset characters. Continuing...")
				$QUIT = TRUE
				EXITLOOP
			ENDIF
			FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
				$INDEX = $CLIENTSINDEXES[$I]
				SWITCHTONUM($INDEX)
				IF DISTANCE2D(-299.15, -185.71) > 45 THEN CONTINUELOOP
				IF INCOMBAT() THEN
					$QUIT = FALSE
					CONTINUELOOP
				ENDIF
				$QUESTSAMOUNT = UBOUND(QUESTARRAY())
				$ARRAY = INVARRAY()
				$INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
				IF $INDEX == -1 THEN
					SETSTATUS("Out of teleport stones. Fix this for future runs.")
					CONTINUELOOP
				ENDIF
				SpeedPATH()
				MOVETO2(-317.27, -182.94)
				WHILE UBOUND(QUESTARRAY()) == $QUESTSAMOUNT
					IF TIMERDIFF($ONEMINTIMER) > 70000 THEN
						SETSTATUS("70s exceeded while trying to glitch reset this character. Continuing...")
						$QUIT = TRUE
						EXITLOOP
					ENDIF
					SLEEP(100)
				WEND
				IF DISTANCE2D(-299.15, -185.71) < 45 THEN USETELESTONE($ARRAY[$INDEX][1], $ARRAY[$INDEX][0], 6101)
				IF NOT $FASTRESETTIMING THEN
					SLEEP(1500)
				ELSE
					SLEEP(100)
				ENDIF
			NEXT
		WEND
		SWITCHTO($MAIN)
		IF GETGLOBALSETTING("UPDWait30sEachRun") THEN
			SLEEP(30000)
		ELSE
			SLEEP(10000)
		ENDIF
		SQUADLEAVEGLITCHFIX($MEMBERS, 10)
		CHECKALLCHARINSIDEINSTANCE(176, $SQUADLIST)
		IF GETGLOBALSETTING("docheckerboardafterupdreset") AND $PERMITCHECKERBOARD THEN
			SETSTATUS("UPD: Do checkerboard after reset is selected.")
			$CLIENTSINDEXES = GETSQUADALTS()
			IF NOT CHECKALLCHARINSIDEINSTANCE(176, $SQUADLIST) THEN
				SLEEP(30000)
			ELSE
				SLEEP(10000)
			ENDIF
			$CLIENTSINDEXES2 = GETNEARBYALTS()
			$COUNT = UBOUND($CLIENTSINDEXES2)
			WHILE $COUNT < 10
				SQUADLEAVEGLITCHFIX($MEMBERS, 10)
				SETSTATUS("UPD: waiting for count of characters to be 10.")
				SLEEP(5000)
				$CLIENTSINDEXES2 = GETNEARBYALTS()
				$COUNT = UBOUND($CLIENTSINDEXES2)
			WEND
			MASSCLOSENPCWINDOW()
			SQUADLEAVEGLITCHFIX($MEMBERS, 10)
			UPDCHECKERBOARDHELPER($MEMBERS, $CLIENTSINDEXES)
		ENDIF
		SWITCHTO($MAIN)
		SETSTATUS("UPD reset: Done.")
	ENDFUNC
