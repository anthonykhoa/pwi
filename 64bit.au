ENDFUNC
FUNC JUMPFORTRIAL()
	$PLAYER = PLAYERADDRESS()
	_MEMORYWRITE($PLAYER + $PLAYERJUMPSPEED, $GAME_PROCESS, 12, "float")
	_MEMORYWRITE($PLAYER + $PLAYERJUMPMODE, $GAME_PROCESS, 0)
	_MEMORYWRITE($PLAYER + $PLAYERJUMPCOUNT, $GAME_PROCESS, 1)
ENDFUNC
FUNC MASSJUMP($NUMBEROFJUMPS = 2, $DELAYBETWEENJUMPS = 100, $MOVEAFTERJUMP = TRUE, $AVOIDJUMPIFCLOSE = TRUE)
	$POS = PLAYERPOS()
	$TARGET = PLAYERID()
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		IF CLIENTINGROUP($CLIENTS[$INDEX][2], "main") THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		IF CLASS() <> 7 THEN SWITCHTOHUMANFORM()
		IF DISTANCE2D($POS[0], $POS[1]) < 0.4 AND $AVOIDJUMPIFCLOSE THEN CONTINUELOOP
		TRUEJUMP()
	NEXT
	IF $NUMBEROFJUMPS > 1 THEN
		SLEEP($DELAYBETWEENJUMPS)
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
			IF CLIENTINGROUP($CLIENTS[$INDEX][2], "main") THEN CONTINUELOOP
			SWITCHTONUM($INDEX)
			IF DISTANCE2D($POS[0], $POS[1]) < 0.4 AND $AVOIDJUMPIFCLOSE THEN CONTINUELOOP
			TRUEJUMP()
		NEXT
		SLEEP(100)
	ENDIF
	IF $MOVEAFTERJUMP THEN
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
			IF CLIENTINGROUP($CLIENTS[$INDEX][2], "main") THEN CONTINUELOOP
			SWITCHTONUM($INDEX)
			MOVETO2($POS[0], $POS[1])
		NEXT
	ENDIF
	SWITCHTO($MAIN)
ENDFUNC
FUNC GENIECHISKILL($CHI = 399, $ONLYCHANTOFCHI = FALSE)
	IF CHI() < $CHI THEN
		IF $ONLYCHANTOFCHI THEN
			IF SKILLOFFCOOLDOWN(4893, 1) AND GENIEENERGY() >= 50 THEN
				CASTSKILL(4893, 1)
			ENDIF
		ELSE
			IF SKILLOFFCOOLDOWN(4893, 1) AND GENIEENERGY() >= 50 THEN
				CASTSKILL(4893, 1)
			ELSEIF SKILLOFFCOOLDOWN(1047, 1) AND GENIEENERGY() >= 130 THEN
				CASTSKILL(1047, 1)
			ELSEIF SKILLOFFCOOLDOWN(1042, 1) AND GENIEENERGY() >= 166 THEN
				USEGENIESKILL(1042, PLAYERTARGET())
			ENDIF
		ENDIF
	ENDIF
ENDFUNC
FUNC MASSGENIECHISKILL($CHI = 399, $ONLYCHANTOFCHI = FALSE)
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		GENIECHISKILL($CHI, $ONLYCHANTOFCHI)
	NEXT
	SWITCHTO($MAIN)
ENDFUNC

