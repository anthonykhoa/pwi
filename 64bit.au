		GLOBAL CONST $JOB_OBJECT_SET_ATTRIBUTES = 2
		GLOBAL CONST $JOB_OBJECT_SET_SECURITY_ATTRIBUTES = 16
		GLOBAL CONST $JOB_OBJECT_TERMINATE = 8
