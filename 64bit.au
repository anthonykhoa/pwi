	RETURN _MEMORYREAD($PLAYER + $PLAYERVITAEFROMMOBS_OFFSET, $GAME_PROCESS)
ENDFUNC
FUNC VITAEFROMMOBSDAILYLIMIT()
	$BOUNDARY = BOUNDARY()
	$LIMIT = 0
	IF $BOUNDARY == 0 THEN
	ELSEIF $BOUNDARY > 0 AND $BOUNDARY <= 10 THEN
		$LIMIT = 4000
	ELSEIF $BOUNDARY > 10 AND $BOUNDARY <= 20 THEN
		$LIMIT = 8000
	ELSEIF $BOUNDARY > 20 AND $BOUNDARY <= 30 THEN
		$LIMIT = 12000
	ELSEIF $BOUNDARY > 30 AND $BOUNDARY <= 40 THEN
		$LIMIT = 16000
	ELSEIF $BOUNDARY > 40 AND $BOUNDARY <= 50 THEN
		$LIMIT = 20000
	ELSEIF $BOUNDARY > 50 AND $BOUNDARY <= 60 THEN
		$LIMIT = 25000
	ELSEIF $BOUNDARY > 60 AND $BOUNDARY <= 70 THEN
		$LIMIT = 40000
	ELSEIF $BOUNDARY > 70 AND $BOUNDARY <= 80 THEN
		$LIMIT = 80000
	ELSEIF $BOUNDARY > 80 AND $BOUNDARY <= 90 THEN
		$LIMIT = 100000
	ELSEIF $BOUNDARY > 90 AND $BOUNDARY <= 100 THEN
		$LIMIT = 60000
	ENDIF
	RETURN $LIMIT
ENDFUNC
FUNC FACTIONID()
	$PLAYER = PLAYERADDRESS()
	RETURN _MEMORYREAD($PLAYER + $PLAYERFACTIONID_OFFSET, $GAME_PROCESS)
ENDFUNC
