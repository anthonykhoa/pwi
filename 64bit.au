FUNC SENDEXPRESSIONTESTER($STARTID, $ENDID)
	$INSTANCEORIGINAL = INSTANCEID()
	SETSTATUS("Starting expression testing. Change maps to end testing (ie enter or exit hs)")
	SLEEP(20000)
	SETSTATUS("Starting:")
	FOR $I = $STARTID TO $ENDID
		IF MOVEKEY() THEN
			SETSTATUS("Pausing for 10s.")
			SLEEP(10000)
		ENDIF
		IF INSTANCEID() <> $INSTANCEORIGINAL THEN
			SETSTATUS("Send expression testing, ended early.")
			RETURN
		ENDIF
		STARTLISTENING()
		SETSTATUS("id = " & $I)
		SENDEXPRESSION($I)
		SLEEP(6000)
		CANCELACTION()
		IF SEETEXT("Stop") THEN
			SETSTATUS("Pausing...")
			WHILE NOT SEETEXT("Go")
				SLEEP(1000)
				STARTLISTENING()
			WEND
		ENDIF
		SETSTATUS("Resuming...")
	NEXT
	SETSTATUS("Done.")
ENDFUNC
FUNC TIGERGATE($ARRAY, $I)
	RETURN($ARRAY[$I][1] > 56962 AND $ARRAY[$I][1] <= 57006)
ENDFUNC
FUNC TIGERBUFFVALUE()
	IF HASBUFF("", 378) THEN RETURN 45
	$BUFFCOUNT = BUFFCOUNT(379)
	IF $BUFFCOUNT == -1 THEN RETURN $BUFFCOUNT
	$COUNT = 0
	WHILE $BUFFCOUNT <= 0 OR $BUFFCOUNT > 44
		$BUFFCOUNT = BUFFCOUNT(379)
		SLEEP(1000)
		$COUNT += 1
		IF $COUNT == 10 THEN
			SETSTATUS("Tiger Gauntlet Error - Invalid Count: " & $BUFFCOUNT)
			RETURN 45
		ENDIF
	WEND
	RETURN $BUFFCOUNT
ENDFUNC
FUNC GRABTIGERBUFF($BUFFVAL)
	SETSTATUS("Tiger Gauntlet - Gate #" & $BUFFVAL)
	$POS = GETNPCPOSITION(56961 + $BUFFVAL, 1)
	IF UBOUND($POS) == 0 THEN
		RETURN FALSE
	ENDIF
	$TIMER = TIMERINIT()
	WHILE TIGERBUFFVALUE() <> $BUFFVAL
		IF TIMERDIFF($TIMER) > 60000 THEN
			SETSTATUS("Timer exceeded 60s. $BUFFVAL = " & $BUFFVAL & " and BuffCount = " & BUFFCOUNT(379))
			SETSTATUS("Distance to gate = " & DISTANCE2D($POS[0], $POS[1]) & ". Exiting loop.")
			EXITLOOP
		ENDIF
		PRINT("BuffCount " & BUFFCOUNT(379))
		$PLAYERPOS = PLAYERPOS()
		IF $POS[2] - $PLAYERPOS[2] > 10 THEN
			RETURN FALSE
		ELSEIF $PLAYERPOS[2] - $POS[2] > 1.5 THEN
			JUMPUP(-10, TRUE)
		ENDIF
		$DIST = DISTANCE2D($POS[0], $POS[1])
		IF $DIST > 1.5 THEN
			MOVETO2($POS[0], $POS[1])
		ENDIF
		IF TIGERBUFFVALUE() > $BUFFVAL THEN
			SLEEP(2000)
			IF TIGERBUFFVALUE() > $BUFFVAL THEN
				EXITLOOP
			ENDIF
		ENDIF
		SLEEP(100)
	WEND
	RETURN TRUE
ENDFUNC
FUNC CHECKFALLWATERFALL()
	$POS = PLAYERPOS()
	IF $POS[2] < 33 THEN
		SETSTATUS("Tiger Gauntlet - Fuck I fell off the Waterfall")
		RETURN TRUE
	ENDIF
	RETURN FALSE
ENDFUNC
