			$INDEX = $SQUADLIST[$I]
			SWITCHTONUM($INDEX)
			MOVETO2(-290.54, -186.97)
		NEXT
		SLEEP(7000)
		FOR $I = 0 TO UBOUND($SQUADLIST) - 1
			$INDEX = $SQUADLIST[$I]
			SWITCHTONUM($INDEX)
			$JUMPTIMER = TIMERINIT()
			$POS = PLAYERPOS()
			WHILE $POS[2] > 82 AND DISTANCE2D(-290.54, -186.97) > 5
				IF TIMERDIFF($JUMPTIMER) > 45000 THEN
					SLEEP(5000)
					IF NOT TELEPORTINCENSE() THEN TOWNPORTAL()
					SLEEP(15000)
					UPDNAVIGATETOCOORD(-318.47, -104.03)
					MOVE2(-319.23, -147.66)
					SLEEP(500)
					$JUMPTIMER = TIMERINIT()
				ENDIF
				$POS = PLAYERPOS()
