	MASSNUKE(TRUE, FALSE, TRUE, TRUE, 400, TRUE, FALSE, TRUE, TRUE, TRUE, $Target)
ENDFUNC
FUNC MASSNUKENOGENIECHI()
	MASSNUKE(FALSE, TRUE, FALSE, FALSE)
ENDFUNC
FUNC MASSNUKENOGENIECHINOSPARK()
	MASSNUKE(FALSE, TRUE, FALSE, FALSE, 400, FALSE)
ENDFUNC
FUNC MASSNUKEWITHGENIECHIRANGEDONLY()
	MASSNUKE(TRUE, TRUE, TRUE, FALSE)
ENDFUNC
FUNC MASSNUKEWITHGENIECHIRANGEDONLYRETURNTOSTART()
	MASSNUKE(TRUE, TRUE, TRUE, TRUE)
ENDFUNC
FUNC FINDFIRSTEMPTYSLOT($ARR)
	FOR $I = 0 TO UBOUND($ARR) - 1
		IF $ARR[$I] = "" THEN
			RETURN $I
		ENDIF
	NEXT
	RETURN -1
ENDFUNC
FUNC SEEKERGEARSWAP($SEEKEREQUIPATTACK = TRUE, $SEEKEREQUIPDEF = TRUE, $SEEKERATTACKGEARTIMER = 0)
	IF CLASS() == 8 AND NOT HASBUFF("Attack Level increased", 135) THEN
		IF TIMERDIFF($SEEKERATTACKGEARTIMER) > 29000 OR $SEEKERATTACKGEARTIMER == 0 THEN
			$SEEKEREQUIPDEF = TRUE
			$SEEKERATTACKGEARTIMER = TIMERINIT()
		ENDIF
		IF $SEEKEREQUIPDEF == TRUE THEN
			SWAPGEAR(2)
			$SEEKEREQUIPDEF = FALSE
			$SEEKEREQUIPATTACK = TRUE
		ENDIF
	ELSEIF CLASS() == 8 AND HASBUFF("Attack Level increased", 135) AND $SEEKEREQUIPATTACK == TRUE THEN
		SWAPGEAR(0)
		$SEEKEREQUIPATTACK = FALSE
		$SEEKERATTACKGEARTIMER = TIMERINIT()
	ENDIF
ENDFUNC
FUNC ASSASSINLIFEHUNTERCANCEL($SINTIMER)
	IF CLASS() == 5 AND CURRENTSKILL() == 3777 AND TIMERDIFF($SINTIMER) > 40 THEN
		CANCELACTION()
		$SINTIMER = TIMERINIT()
	ENDIF
ENDFUNC
FUNC MASSNUKE($GENIECHI = FALSE, $FOLLOW = TRUE, $RANGEDONLY = FALSE, $RETURNTOSTARTINGPOSITION = FALSE, $CHI = 400, $USESPARK = TRUE, $ENDWITHTARGETDEATH = FALSE, $BMDOESNOTTRIPLESPARK = FALSE, $UPDBMDOESNOTTRIPLESPARK = FALSE, $FAIRYBOSSNUKEDHJ = FALSE, $UPDNUKE = FALSE, $CHECKBOSSHP = FALSE)
  $Target = PlayerTarget()
	IF $RANGEDONLY THEN SETSTATUS("Ranged mass nuke")
	$ORIGINALTARGET = $TARGET
	$TIMER = TIMERINIT()
	IF $TARGET == 0 THEN
		$ALREADYUSINGSKILLSENDER = FALSE
		RETURN
	ENDIF
	SETSTATUS("----------------------------------- MASS NUKING ----------------------------------")
	$ORIGINALTARGET = $TARGET
	FOR $I = 0 TO UBOUND($IGNORE_CLIENTS) - 1
		$IGNORE_CLIENTS[$I] = ""
	NEXT
	$CLIENTSINDEXES = GETNEARBYALTS()
	$INDEXLOCATIONOFBESTSIN = -1
	$MAXHPOFBESTSIN = 0
	$USELIFEHUNTERSPAM = FALSE
	$SLEEPDURATION1 = 100
	$SLEEPDURATION2 = 10
	IF GETGLOBALSETTING("useSkillSender") THEN
		$SLEEPDURATION1 = 90
		$SLEEPDURATION2 = 10
	ENDIF
	IF GETGLOBALSETTING("useLifeHunterSpamInMassNuke100_10") THEN
		$USELIFEHUNTERSPAM = TRUE
	ENDIF
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		IF CLASS() == 5 THEN
			$HPMP = GETHPMP()
			IF $HPMP[1] > $MAXHPOFBESTSIN THEN
				$INDEXLOCATIONOFBESTSIN = $I
				$MAXHPOFBESTSIN = $HPMP[1]
			ENDIF
		ENDIF
	NEXT
	IF $USESPARK THEN
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF CLASS() == 0 THEN
				IF INSTANCEID() == 176 AND $UPDBMDOESNOTTRIPLESPARK AND NOT GETGLOBALSETTING("bmDoubleSparkInstead") THEN
					CONTINUELOOP
				ELSEIF $BMDOESNOTTRIPLESPARK AND NOT GETGLOBALSETTING("bmDoubleSparkInstead") THEN
					CONTINUELOOP
				ELSEIF GETGLOBALSETTING("bmDoubleSparkInstead") THEN
					CASTSKILL(227)
				ENDIF
			ENDIF
			TRIPLESPARK()
		NEXT
	ENDIF
	SLEEP(350)
	IF $GENIECHI THEN MASSGENIECHISKILL($CHI, TRUE)
	SLEEP(350)
	SWITCHTO($MAIN)
	$MAINHPMP = GETHPMP()
	$MOVED = FALSE
	$POS = PLAYERPOS()
	MASSSELECT2()
	$SEEKEREQUIPATTACK = TRUE
	$SEEKEREQUIPDEF = TRUE
	$SEEKERATTACKGEARTIMER = 0
	$SINTIMER = TIMERINIT()
	$GENIESKILLTIMER = TIMERINIT()
	$CASTFRENZYALREADY = FALSE
	DIM $SINKNIFETHROWSKILLIDS[6] = [3802, 3799, 3800, 3801, 3803, 3804]
	DIM $BMHFIDS[7] = [413, 3931, 3932, 3933, 3934, 3935, 3936]
	DIM $BARBRANGEDSKILLIDS[9] = [3864, 4408, 502, 3853, 3854, 3855, 3856, 3857, 3858]
	$FIRSTUSETIMER = 0
	$CHECKDISTANCETOTARGETTIMER = 0
	$MAXTIMEALLOWEDFORNUKE = TIMERINIT()
	$MAINDIED = FALSE
	$TARGETHP = 0
	$CHECKEDBOSSHPYET = FALSE
	WHILE MOVEKEY() == 0
		SWITCHTO($MAIN)
		IF $UPDNUKE AND TIMERDIFF($MAXTIMEALLOWEDFORNUKE) > 180000 THEN
			SETSTATUS("More than 180s passed on boss nuke. Something likely went wrong. Exiting.")
			EXITLOOP
		ENDIF
		IF $CHECKBOSSHP AND NOT $CHECKEDBOSSHPYET AND TIMERDIFF($MAXTIMEALLOWEDFORNUKE) > 8000 THEN
			$TARGETHP = TARGETHPPERCENT()
			$CHECKEDBOSSHPYET = TRUE
			SETSTATUS("Boss hp % is " & $TARGETHP)
			IF $TARGETHP > 99.99 THEN
				SETSTATUS("Boss hp still completely full. Maybe didn't sog boss in time (DHJ fairy). Exiting.")
				RETURN
			ENDIF
		ENDIF
		$HPMP = GETHPMP()
		IF $HPMP[0] == 0 OR $HPMP[2] == 0 THEN
			$MAINDIED = TRUE
			EXITLOOP
		ENDIF
		$TARGET = PLAYERTARGET()
		IF $ENDWITHTARGETDEATH AND NOT $TARGET THEN
			$ALREADYUSINGSKILLSENDER = FALSE
			FOR $I = 0 TO UBOUND($IGNORE_CLIENTS) - 1
				$IGNORE_CLIENTS[$I] = ""
			NEXT
			SETSTATUS("------------------------------- Mass Nuke cancelled ------------------------------")
			RETURN
		ENDIF
		$SINTARGET = PLAYERTARGET()
		$TARGETPOS = -1
		IF $TARGET THEN $TARGETPOS = TARGETPOS()
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			IF CLIENTINGROUP($CLIENTS[$INDEX][2], "ignore") THEN CONTINUELOOP
			IF CLIENTINGROUP($CLIENTS[$INDEX][2], "main") THEN
				IF GETGLOBALSETTING("MassNukeUseFrenzyOnMain") AND TIMERDIFF($GENIESKILLTIMER) > 5000 AND NOT $CASTFRENZYALREADY THEN
					USEGENIESKILL(978, PLAYERID())
					$CASTFRENZYALREADY = TRUE
				ENDIF
			ENDIF
			IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
			SWITCHTONUM($INDEX)
			$HPMP = GETHPMP()
			IF $HPMP[0] / $HPMP[1] < 0.65 THEN
				EXECUTEMACRO(2, FALSE)
				CONTINUELOOP
			ENDIF
			$DEMONSIN = FALSE
			IF $RANGEDONLY THEN
				$ISMELEE = ISMELEECLASS2()
				IF GETGLOBALSETTING("venoUsedInRangedNuke") AND GETGLOBALSETTING("seekerUsedInRangedNuke") THEN
					$ISMELEE = ISMELEECLASS2()
				ELSEIF GETGLOBALSETTING("venoUsedInRangedNuke") AND NOT GETGLOBALSETTING("seekerUsedInRangedNuke") THEN
					$ISMELEE = ISMELEECLASS4()
				ELSEIF NOT GETGLOBALSETTING("venoUsedInRangedNuke") AND GETGLOBALSETTING("seekerUsedInRangedNuke") THEN
					$ISMELEE = ISMELEECLASS3()
				ELSEIF NOT GETGLOBALSETTING("venoUsedInRangedNuke") AND NOT GETGLOBALSETTING("seekerUsedInRangedNuke") THEN
					$ISMELEE = ISMELEECLASS5()
				ENDIF
				$CURRENTPOS = PLAYERPOS()
				IF $FAIRYBOSSNUKEDHJ AND $CURRENTPOS[2] > 61.25 AND NOT $ISMELEE THEN
					MOVETO2(RANDOM(208, 210), RANDOM(38, 40))
					CONTINUELOOP
				ENDIF
				IF $RETURNTOSTARTINGPOSITION AND NOT $ISMELEE AND DISTANCE2D($POS[0], $POS[1]) > 2 AND INSTANCEID() == 186 THEN
					IF DISTANCE2D($POS[0], $POS[1]) > 1 THEN MOVETO2($POS[0], $POS[1])
					CONTINUELOOP
				ENDIF
				IF $RETURNTOSTARTINGPOSITION AND $ISMELEE THEN
					IF DISTANCE2D($POS[0], $POS[1]) > 1 THEN MOVETO2($POS[0], $POS[1])
					CONTINUELOOP
				ENDIF
				IF $FAIRYBOSSNUKEDHJ AND $CURRENTPOS[2] > 61.25 AND NOT $ISMELEE THEN
					MOVETO2(208.68, 38.93)
					CONTINUELOOP
				ENDIF
				IF INSTANCEID() == 186 AND $FAIRYBOSSNUKEDHJ AND $ISMELEE THEN
					IF DISTANCE2D(191.49, 38.93) > 2 THEN
						MOVETO2(191.49, 38.93)
					ENDIF
					CONTINUELOOP
				ENDIF
			ENDIF
			IF MOVEKEY() <> 0 THEN
				CANCELACTION()
				LOCAL $EMPTYINDEX = FINDFIRSTEMPTYSLOT($IGNORE_CLIENTS)
				IF $EMPTYINDEX <> -1 THEN
					$IGNORE_CLIENTS[$EMPTYINDEX] = $CLIENTS[$INDEX][2]
				ENDIF
				CONTINUELOOP
			ENDIF
			QUICKSELECT($TARGET)
			IF CLASS() == 5 AND $RANGEDONLY THEN
				IF SKILLOFFCOOLDOWN(3248) THEN
					CASTSKILL(3248)
				ELSE
					CASTFIRSTSKILL($SINKNIFETHROWSKILLIDS)
				ENDIF
				CONTINUELOOP
			ENDIF
			IF CLASS() == 5 AND $INDEXLOCATIONOFBESTSIN <> -1 AND $I == $INDEXLOCATIONOFBESTSIN AND $TARGETPOS <> -1 THEN
				IF GETGLOBALSETTING("MassNukeUseFrenzySin") AND TIMERDIFF($GENIESKILLTIMER) > 5000 AND NOT $CASTFRENZYALREADY THEN
					USEGENIESKILL(978, PLAYERID())
					$CASTFRENZYALREADY = TRUE
				ENDIF
				$SINTARGET = PLAYERTARGET()
				IF $SINTARGET THEN
					$TARGETPOS = TARGETPOS()
				ELSE
					CONTINUELOOP
				ENDIF
				IF $TARGETPOS == 0 THEN CONTINUELOOP
				IF SKILLOFFCOOLDOWN(361) THEN
					$DEMONSIN = TRUE
				ENDIF
				IF SKILLOFFCOOLDOWN(1268) OR DISTANCE2D($TARGETPOS[0], $TARGETPOS[1]) > 5.65 OR NOT $USELIFEHUNTERSPAM OR($DEMONSIN AND SKILLOFFCOOLDOWN(1283)) THEN
					EXECUTEMACRO(3)
					CONTINUELOOP
				ELSE
					IF CURRENTSKILL() == 1269 OR CURRENTSKILL() == 1268 THEN
						CONTINUELOOP
					ELSE
						CANCELACTION()
						SLEEP($SLEEPDURATION2)
						$SINTARGET = PLAYERTARGET()
						IF $SINTARGET THEN
							USESKILL(3777, $SINTARGET)
						ENDIF
						CONTINUELOOP
					ENDIF
				ENDIF
			ENDIF
			IF CLASS() == 4 AND $RANGEDONLY THEN
				$SKILLUSED = FALSE
				IF $TARGET <> 0 THEN USEFIRSTSKILL($BARBRANGEDSKILLIDS, $TARGET)
				IF CURRENTSKILL() OR QUEUEDSKILL() THEN
					CONTINUELOOP
				ELSEIF $RETURNTOSTARTINGPOSITION THEN
					IF DISTANCE2D($POS[0], $POS[1]) > 1 THEN MOVETO2($POS[0], $POS[1])
					CONTINUELOOP
				ENDIF
			ENDIF
			IF CLASS() == 8 THEN
				IF GETGLOBALSETTING("MassNukeUseTanglingMireSeeker") AND TIMERDIFF($GENIESKILLTIMER) > 5000 THEN
					IF $TARGET THEN
						USEGENIESKILL(1002, $TARGET)
					ENDIF
				ENDIF
			ENDIF
			IF CLASS() == 8 AND NOT HASBUFF("Attack Level increased", 135) THEN
				IF TIMERDIFF($SEEKERATTACKGEARTIMER) > 29000 OR $SEEKERATTACKGEARTIMER == 0 THEN
					$SEEKEREQUIPDEF = TRUE
					$SEEKERATTACKGEARTIMER = TIMERINIT()
				ENDIF
				IF $SEEKEREQUIPDEF == TRUE THEN
					SWAPGEAR(2)
					$SEEKEREQUIPDEF = FALSE
					$SEEKEREQUIPATTACK = TRUE
				ENDIF
			ELSEIF CLASS() == 8 AND HASBUFF("Attack Level increased", 135) AND $SEEKEREQUIPATTACK == TRUE THEN
				SWAPGEAR(0)
				$SEEKEREQUIPATTACK = FALSE
				$SEEKERATTACKGEARTIMER = TIMERINIT()
			ENDIF
			IF CLASS() == 7 AND NOT HASBUFF("Focus Accelerated channeling", 37) AND CURRENTSKILL() <> 566 THEN
				USESKILL(566, PLAYERID())
				CONTINUELOOP
			ENDIF
			IF CLASS() == 7 AND(HASBUFF("Specific skill's damage is increased.", 366) OR CURRENTSKILL() == 6920) THEN
				USESKILL(921, $TARGET)
				CONTINUELOOP
			ENDIF
			IF CLASS() == 0 AND CHI() > 200 AND GETGLOBALSETTING("forceBMToUseHF") THEN
				$SKILLID = CHECKIFBMHFREADY($BMHFIDS)
				IF $SKILLID <> 0 THEN USESKILL($SKILLID, $TARGET)
				CONTINUELOOP
			ENDIF
			IF GETGLOBALSETTING("useSkillSender") THEN
				IF TIMERDIFF($CHECKDISTANCETOTARGETTIMER) > 1000 OR $CHECKDISTANCETOTARGETTIMER == 0 THEN
					EXECUTEMACRO(5, TRUE)
				ELSE
					EXECUTEMACRONORANGECHECK(5, TRUE)
				ENDIF
			ELSE
				EXECUTEMACRO(5, FALSE)
			ENDIF
		NEXT
		IF TIMERDIFF($CHECKDISTANCETOTARGETTIMER) > 1000 OR $CHECKDISTANCETOTARGETTIMER == 0 THEN
			$CHECKDISTANCETOTARGETTIMER = TIMERINIT()
		ENDIF
		SLEEP(100)
		SWITCHTO($MAIN)
	WEND
	$ALREADYUSINGSKILLSENDER = FALSE
	SWITCHTO($MAIN)
	IF $MAINDIED THEN
		SETSTATUS("XXX ----------- Mass Nuke cancelled because main is dead -------------- XXX")
		$ALREADYUSINGSKILLSENDER = FALSE
		FOR $I = 0 TO UBOUND($IGNORE_CLIENTS) - 1
			$IGNORE_CLIENTS[$I] = ""
		NEXT
		RETURN
	ENDIF
	IF $FOLLOW THEN MASSFOLLOW($CLIENTSINDEXES)
	SETSTATUS("------------------------------- Mass Nuke cancelled ------------------------------ ")
	FOR $I = 0 TO UBOUND($IGNORE_CLIENTS) - 1
		$IGNORE_CLIENTS[$I] = ""
	NEXT
ENDFUNC
FUNC CHECKIFBMHFREADY($BMHFIDS)
	DIM $BMHFIDS[7] = [413, 3931, 3932, 3933, 3934, 3935, 3936]
	$SKILL = 0
	FOR $I = 0 TO UBOUND($BMHFIDS) - 1
		IF SKILLOFFCOOLDOWN($BMHFIDS[$I]) THEN
			$SKILL = $BMHFIDS[$I]
			EXITLOOP
		ENDIF
	NEXT
	RETURN $SKILL
ENDFUNC
FUNC FINDMINIMUMRANGEFORCLASS($CLASS)
	$RANGE = 4.5
	IF ISMELEECLASS2() THEN
		$RANGE = 4.5
	ENDIF
	IF CLASS() == 0 THEN
		$RANGE = 5.2
	ELSEIF CLASS() == 4 THEN
		$RANGE = 5.2
	ELSEIF CLASS() == 3 THEN
		IF INHUMANFORM() THEN
			$RANGE = 28
		ELSE
			$RANGE = 11
		ENDIF
	ELSEIF CLASS() == 5 THEN
		$RANGE = 5.5
	ELSE
		$RANGE = 28
	ENDIF
	RETURN $RANGE
ENDFUNC
FUNC MASSNUKEALTWITHGENIECHI()
	MASSNUKEALT(TRUE)
ENDFUNC
FUNC MASSNUKEALTNOGENIECHI()
	MASSNUKEALT(FALSE)
ENDFUNC
FUNC MASSNUKEALT($GENIECHI)
	$CLIENTSINDEXES = GETNEARBYALTS()
	MASSNUKESPECIFICMACROSLOT(7, $CLIENTSINDEXES)
	$WAITSPARK = GETGLOBALSETTING("WaitThreeSecondsOnNuke")
	IF $WAITSPARK THEN SLEEP(2000)
	IF $GENIECHI THEN MASSGENIECHISKILL($CLIENTSINDEXES)
	IF $WAITSPARK THEN SLEEP(1000)
	IF GETGLOBALSETTING("WaitThreeExtraSecondsOnNuke", FALSE) THEN SLEEP(3000)
	SWITCHTO($MAIN)
	MASSMACRO(3, $CLIENTSINDEXES)
ENDFUNC
FUNC MASSNUKESPECIFICMACROSLOT($SLOT, $CLIENTSINDEXES)
	$TARGET = PLAYERTARGET()
	IF $TARGET == 0 THEN RETURN
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		IF $CLIENTS[$INDEX][2] <> $MAIN THEN QUICKSELECT($TARGET)
		CASTSKILL(MACROARRAY(3)[$SLOT])
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSATTACK()
	MASSSELECT2()
	$TARGET = PLAYERTARGET()
	IF $TARGET == 0 THEN RETURN
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($I)
		IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
		$MACROARRAY = MACROARRAY(3)
		IF $MACROARRAY[0] <> 0 THEN
			TRIPLESPARK()
		ENDIF
	NEXT
	SLEEP(2950)
	SWITCHTO($MAIN)
	$IGNORE_CLIENT = 0
	WHILE(GETHPMP())[0] AND MOVEKEY() == 0 AND PLAYERTARGET()
		$TARGET = PLAYERTARGET()
		FOR $I = 0 TO UBOUND($CLIENTS) - 1
			SWITCHTONUM($I)
			IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
			QUICKSELECT($TARGET)
			EXECUTEMACRO(3)
		NEXT
		SLEEP(100)
		SWITCHTO($MAIN)
	WEND
	SWITCHTO($MAIN)
ENDFUNC
FUNC ENHANCEDMASSNUKE()
	$TARGET = PLAYERTARGET()
	IF $TARGET == 0 THEN RETURN
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($INDEX)
		CASTSKILL(MACROARRAY(5)[0])
	NEXT
	SWITCHTO($MAIN)
	WHILE MOVEKEY() == 0 AND GETHPMP()[0] <> 0
		$TARGET = PLAYERTARGET()
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
			QUICKSELECT($TARGET)
			EXECUTEMACRO(3)
		NEXT
		SWITCHTO($MAIN)
	WEND
	MASSFOLLOW($CLIENTSINDEXES)
ENDFUNC
FUNC MASSTRIPLESPARK()
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		TRIPLESPARK()
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSTRIPLESPARKWITHOUTCLERIC()
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF CLASS() <> 7 THEN TRIPLESPARK()
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSTRIPLESPARKWITHOUTBM()
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF CLASS() <> 0 THEN TRIPLESPARK()
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSTRIPLESPARKWITHOUTCLERICANDBM()
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF CLASS() <> 7 AND CLASS() <> 0 THEN TRIPLESPARK()
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSAREAOFEFFECT()
	$TARGET = PLAYERTARGET()
	IF $TARGET == 0 THEN RETURN
	WHILE MOVEKEY() == 0 AND GETHPMP()[0] <> 0
		$TARGET = PLAYERTARGET()
		FOR $I = 0 TO UBOUND($CLIENTS) - 1
			SWITCHTONUM($I)
			IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
			QUICKSELECT($TARGET)
			EXECUTEMACRO(1)
		NEXT
		SLEEP(100)
		SWITCHTO($MAIN)
	WEND
ENDFUNC
FUNC MASSMACRO0()
	$CLIENTSINDEXES = GETNEARBYALTS()
	MASSMACRO(0, $CLIENTSINDEXES)
ENDFUNC
FUNC MASSMACRO1()
	$CLIENTSINDEXES = GETNEARBYALTS()
	MASSMACRO(1, $CLIENTSINDEXES)
ENDFUNC

FUNC MASSMACRO2()
	$CLIENTSINDEXES = GETNEARBYALTS()
	MASSMACRO(2, $CLIENTSINDEXES)
	
ENDFUNC

FUNC MASSMACRO5()
	$CLIENTSINDEXES = GETNEARBYALTS()
	MASSMACRO(5, $CLIENTSINDEXES)
ENDFUNC
FUNC MASSMACRO6()
	$CLIENTSINDEXES = GETNEARBYALTS()
	MASSMACRO(6, $CLIENTSINDEXES)
ENDFUNC
FUNC MASSMACRO7()
	$CLIENTSINDEXES = GETNEARBYALTS()
	MASSMACRO(7, $CLIENTSINDEXES)
ENDFUNC
DIM $BANNEDTARGETIDS[1] = [48833]
FUNC MASSMACROUPD($MACRONUMBER, $CLIENTSINDEXES, BYREF $PERMITTEDMOBSARRAY, $FOLLOWALLOWED = TRUE, $ENDWITHTARGETDEATH = FALSE, $SKIPCLERIC = FALSE, $TIMELIMIT = 0, $SKIPMYSTIC = FALSE)
	SWITCHTO($MAIN)
	$TARGET = PLAYERTARGET()
	$TIMER = TIMERINIT()
	$MOBINDEX = -1
	IF $TARGET == 0 THEN RETURN
	FOR $I = 0 TO UBOUND($IGNORE_CLIENTS) - 1
		$IGNORE_CLIENTS[$I] = ""
	NEXT
	SETSTATUS("Mass Macro" & $MACRONUMBER & " started.")
	$LOOP = 1
	$CHECKDISTANCETOTARGETTIMER = 0
	WHILE MOVEKEY() == 0 AND GETHPMP()[0] > 0 AND GETHPMP()[2] > 0
		IF $TIMELIMIT <> 0 THEN
			IF TIMERDIFF($TIMER) > $TIMELIMIT THEN
				SETSTATUS("Mass Macro UPD ended because " & $TIMELIMIT / 1000 & "s exceeded.")
				$ALREADYUSINGSKILLSENDER = FALSE
				FOR $I = 0 TO UBOUND($IGNORE_CLIENTS) - 1
					$IGNORE_CLIENTS[$I] = ""
				NEXT
				RETURN
			ENDIF
		ENDIF
		FOR $J = 0 TO UBOUND($BANNEDTARGETIDS) - 1
			IF $TARGET == $BANNEDTARGETIDS[$J] THEN
				DESELECTTARGET()
				IF $PERMITTEDMOBSARRAY THEN
					$MOBS = NPCARRAY()
					$MOBINDEX = FINDINDEXOFANYMOBALIVEFROMLIST($PERMITTEDMOBSARRAY)
					IF $MOBINDEX <> -1 THEN
						$TARGET = $MOBS[$MOBINDEX][0]
						SELECTTARGET($TARGET)
						SLEEP(50)
						MASSSELECT2()
					ENDIF
				ELSE
					$ALREADYUSINGSKILLSENDER = FALSE
					FOR $I = 0 TO UBOUND($IGNORE_CLIENTS) - 1
						$IGNORE_CLIENTS[$I] = ""
					NEXT
					SETSTATUS("Mass Macro UPD ended because no permitted mobs array.")
					RETURN
				ENDIF
			ENDIF
		NEXT
		IF NOT $TARGET AND $ENDWITHTARGETDEATH AND $MOBINDEX <> -1 THEN
			$ALREADYUSINGSKILLSENDER = FALSE
			FOR $I = 0 TO UBOUND($IGNORE_CLIENTS) - 1
				$IGNORE_CLIENTS[$I] = ""
			NEXT
			SETSTATUS("Mass Macro UPD ended because no target, endwithtargetdeath, and no mobs found.")
			RETURN
		ENDIF
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
			IF CLIENTINGROUP($CLIENTS[$INDEX][2], "ignore") THEN CONTINUELOOP
			SWITCHTONUM($INDEX)
			IF $SKIPCLERIC AND CLASS() == 7 THEN CONTINUELOOP
			IF $SKIPMYSTIC AND CLASS() == 9 THEN CONTINUELOOP
			IF NOT INCOMBAT() AND TIMERDIFF($TIMER) > 15000 THEN
				SETSTATUS("Mass Macro" & $MACRONUMBER & " cancelled.")
				$ALREADYUSINGSKILLSENDER = FALSE
				FOR $I = 0 TO UBOUND($IGNORE_CLIENTS) - 1
					$IGNORE_CLIENTS[$I] = ""
				NEXT
				SETSTATUS("Mass Macro UPD ended because out of combat more than 15s.")
				RETURN
			ENDIF
			IF $CLIENTS[$INDEX][2] <> $MAIN THEN QUICKSELECT($TARGET)
			IF CLASS() == 7 AND INHUMANFORM() THEN
				SWITCHTOSECONDFORM()
			ENDIF
			IF MOVEKEY() <> 0 THEN
				CANCELACTION()
				LOCAL $EMPTYINDEX = FINDFIRSTEMPTYSLOT($IGNORE_CLIENTS)
				IF $EMPTYINDEX <> -1 THEN
					$IGNORE_CLIENTS[$EMPTYINDEX] = $CLIENTS[$INDEX][2]
				ENDIF
				CONTINUELOOP
			ENDIF
			$HPMP = GETHPMP()
			IF $HPMP[0] / $HPMP[1] < 0.65 THEN
				EXECUTEMACRO(2, FALSE)
				CONTINUELOOP
			ENDIF
			IF GETGLOBALSETTING("useSkillSender") THEN
				IF TIMERDIFF($CHECKDISTANCETOTARGETTIMER) > 1000 OR $CHECKDISTANCETOTARGETTIMER == 0 THEN
					EXECUTEMACRO($MACRONUMBER, TRUE)
				ELSE
					EXECUTEMACRONORANGECHECK($MACRONUMBER, TRUE)
				ENDIF
			ELSE
				EXECUTEMACRO($MACRONUMBER, FALSE)
			ENDIF
		NEXT
		IF TIMERDIFF($CHECKDISTANCETOTARGETTIMER) > 1000 OR $CHECKDISTANCETOTARGETTIMER == 0 THEN
			$CHECKDISTANCETOTARGETTIMER = TIMERINIT()
		ENDIF
		SWITCHTO($MAIN)
		SLEEP(100)
	WEND
	SETSTATUS("Mass Macro UPD ended because of movement or death..")
	$ALREADYUSINGSKILLSENDER = FALSE
	IF GETGLOBALSETTING("MassMacroFollow") AND $FOLLOWALLOWED THEN
		MASSFOLLOW($CLIENTSINDEXES)
		SLEEP(200)
		MASSFOLLOW($CLIENTSINDEXES)
	ENDIF
	FOR $I = 0 TO UBOUND($IGNORE_CLIENTS) - 1
		$IGNORE_CLIENTS[$I] = ""
	NEXT
ENDFUNC
FUNC MASSMACRO($MACRONUMBER, $CLIENTSINDEXES, $FOLLOWALLOWED = TRUE, $ENDWITHTARGETDEATH = FALSE, $SKIPCLERIC = FALSE, $SKIPMYSTICAOE = FALSE)
	$TARGET = PLAYERTARGET()
	$TIMER = TIMERINIT()
	IF $TARGET == 0 THEN RETURN
	FOR $I = 0 TO UBOUND($IGNORE_CLIENTS) - 1
		$IGNORE_CLIENTS[$I] = ""
	NEXT
	SETSTATUS("Mass Macro" & $MACRONUMBER & " started.")
	$LOOP = 1
	$CHECKDISTANCETOTARGETTIMER = 0
	WHILE MOVEKEY() == 0 AND GETHPMP()[0] > 0 AND GETHPMP()[2] > 0
		$TARGET = PLAYERTARGET()
		IF NOT $TARGET AND $ENDWITHTARGETDEATH THEN
			SETSTATUS("Mass Macro ended because no target and endWithTargetDeath.")
			$ALREADYUSINGSKILLSENDER = FALSE
			FOR $I = 0 TO UBOUND($IGNORE_CLIENTS) - 1
				$IGNORE_CLIENTS[$I] = ""
			NEXT
			RETURN
		ENDIF
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
			IF CLIENTINGROUP($CLIENTS[$INDEX][2], "ignore") THEN CONTINUELOOP
			SWITCHTONUM($INDEX)
			IF $SKIPCLERIC AND CLASS() == 7 THEN CONTINUELOOP
			IF INCOMBAT() THEN $TIMER = TIMERINIT()
			IF NOT INCOMBAT() AND TIMERDIFF($TIMER) > 10000 THEN
				SETSTATUS("Mass Macro ended because not in combat since 10s.")
				$ALREADYUSINGSKILLSENDER = FALSE
				FOR $I = 0 TO UBOUND($IGNORE_CLIENTS) - 1
					$IGNORE_CLIENTS[$I] = ""
				NEXT
				RETURN
			ENDIF
			IF $CLIENTS[$INDEX][2] <> $MAIN THEN QUICKSELECT($TARGET)
			IF CLASS() == 7 AND INHUMANFORM() THEN
				SWITCHTOSECONDFORM()
			ENDIF
			IF MOVEKEY() <> 0 THEN
				CANCELACTION()
				LOCAL $EMPTYINDEX = FINDFIRSTEMPTYSLOT($IGNORE_CLIENTS)
				IF $EMPTYINDEX <> -1 THEN
					$IGNORE_CLIENTS[$EMPTYINDEX] = $CLIENTS[$INDEX][2]
				ENDIF
				CONTINUELOOP
			ENDIF
			$HPMP = GETHPMP()
			IF $HPMP[0] / $HPMP[1] < 0.65 THEN
				EXECUTEMACRO(2, FALSE)
				CONTINUELOOP
			ENDIF
			IF $SKIPMYSTICAOE AND CLASS() == 9 THEN
				IF GETGLOBALSETTING("useSkillSender") THEN
					EXECUTEMACRO(0)
				ELSE
					EXECUTEMACRO(0, FALSE)
				ENDIF
				CONTINUELOOP
			ENDIF
			IF GETGLOBALSETTING("useSkillSender") THEN
				IF TIMERDIFF($CHECKDISTANCETOTARGETTIMER) > 1000 OR $CHECKDISTANCETOTARGETTIMER == 0 THEN
					EXECUTEMACRO($MACRONUMBER, TRUE)
				ELSE
					EXECUTEMACRONORANGECHECK($MACRONUMBER, TRUE)
				ENDIF
			ELSE
				EXECUTEMACRO($MACRONUMBER, FALSE)
			ENDIF
		NEXT
		IF TIMERDIFF($CHECKDISTANCETOTARGETTIMER) > 1000 OR $CHECKDISTANCETOTARGETTIMER == 0 THEN
			$CHECKDISTANCETOTARGETTIMER = TIMERINIT()
		ENDIF
		SWITCHTO($MAIN)
		SLEEP(100)
	WEND
	IF GETHPMP()[0] == 0 OR GETHPMP()[2] == 0 THEN
		SETSTATUS("Mass Macro ended because of death or no mana.")
	ELSE
		SETSTATUS("Mass Macro ended because of movement.")
	ENDIF
	$ALREADYUSINGSKILLSENDER = FALSE
	IF GETGLOBALSETTING("MassMacroFollow") AND $FOLLOWALLOWED THEN
		MASSFOLLOW($CLIENTSINDEXES)
		SLEEP(200)
		MASSFOLLOW($CLIENTSINDEXES)
	ENDIF
	FOR $I = 0 TO UBOUND($IGNORE_CLIENTS) - 1
		$IGNORE_CLIENTS[$I] = ""
	NEXT
ENDFUNC
FUNC MASSAUTOATTACK()
	$CLIENTSINDEXES = GETNEARBYALTS()
	$TARGET = PLAYERTARGET()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF $CLIENTS[$INDEX][2] <> $MAIN THEN QUICKSELECT($TARGET)
		EXECUTEREGULARATTACK()
	NEXT
ENDFUNC
FUNC MASSSWITCHTOHUMANFORM($WAITFORSBANDDB = TRUE, $SKIPCLERIC = FALSE)
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF $SKIPCLERIC AND CLASS() == 7 THEN CONTINUELOOP
		WHILE NOT INHUMANFORM()
			HANDLEFORMCHANGE()
			SLEEP(50)
		WEND
		IF $WAITFORSBANDDB AND CLASS() == 10 AND HASBUFF("Shadow Awakening", 278) THEN
			WHILE HASBUFF("Shadow Awakening", 278)
				SLEEP(100)
			WEND
		ENDIF
		IF $WAITFORSBANDDB AND CLASS() == 11 AND HASBUFF("Luna Awakening", 279) THEN
			WHILE HASBUFF("Luna Awakening", 279)
				SLEEP(100)
			WEND
		ENDIF
	NEXT
  SwitchTo($Main)
ENDFUNC
FUNC VENOSWITCHTOHUMANFORM()
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF CLASS() == 3 THEN
			WHILE NOT INHUMANFORM()
				HANDLEFORMCHANGE()
				SLEEP(50)
			WEND
		ENDIF
	NEXT
ENDFUNC
FUNC VENOSWITCHTOFOXFORM()
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF CLASS() == 3 THEN
			WHILE INHUMANFORM()
				HANDLEFORMCHANGE()
				SLEEP(50)
			WEND
		ENDIF
	NEXT
ENDFUNC
FUNC TOWNPORTAL()
	DIM $SKILLIDS[6] = [167, 3391, 3392, 3393, 3394, 3395]
	RETURN CASTFIRSTSKILL($SKILLIDS)
ENDFUNC
FUNC MASSTOWNPORTAL()
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($I)
		TOWNPORTAL()
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSRESTOTOWN()
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($I)
		IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
		IF(GETHPMP())[2] == 0 OR(GETHPMP())[2] == 0 THEN
			GOTOTOWNAFTERDEATH()
		ENDIF
	NEXT
	SLEEP(6000)
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSRES()
	$SOMEBODYREZZED = FALSE
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($I)
		IF(GETHPMP())[2] == 0 OR(GETHPMP())[0] == 0 THEN
			RESINPLACE()
			$SOMEBODYREZZED = TRUE
		ENDIF
	NEXT
	SWITCHTO($MAIN)
	RETURN $SOMEBODYREZZED
ENDFUNC
FUNC MASSRES2($CLIENTSINDEXES)
	$NUMDEAD = 0
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		$HPMP = GETHPMP()
		IF $HPMP[2] == 0 OR $HPMP[0] == 0 THEN
			RESINPLACE()
			$NUMDEAD += 1
		ENDIF
	NEXT
	SWITCHTO($MAIN)
	RETURN $NUMDEAD
ENDFUNC
FUNC MASSRES3($CLIENTSINDEXES, $X, $Y, $NUMCHAREXPECTED, $INSTANCEID)
	$RESTIMER = TIMERINIT()
	$NUMDEAD = 0
	$SOMEBODYWASDEAD = FALSE
	DO
		IF TIMERDIFF($RESTIMER) > 25000 THEN
			SETSTATUS("25s exceeded while trying to rez dead alts in place. Continuing...")
			EXITLOOP
		ENDIF
		$NUMDEAD = MASSRES2($CLIENTSINDEXES)
		IF $NUMDEAD == 0 THEN
			EXITLOOP
		ELSE
			$SOMEBODYWASDEAD = TRUE
			SETSTATUS("Some alts were dead. Ressing and waiting 7s.")
			SLEEP(7000)
		ENDIF
	UNTIL $NUMDEAD == 0
	IF $NUMDEAD > 0 THEN
		SETSTATUS("Some alts didn't rez in place. Returning squad to town and pathing to " & $X & ", " & $Y)
		MASSTELEPORTINCENSESQUAD($CLIENTSINDEXES)
		MASSRESTOTOWN()
		SLEEP(7000)
		MASSMOVETOCOORDENHANCED($X, $Y, $CLIENTSINDEXES, 10, 176, 240000, 10)
	ENDIF
	SWITCHTO($MAIN)
	RETURN $SOMEBODYWASDEAD
ENDFUNC
FUNC MASSAUTOBANK()
	$CLIENTSINDEXES = GETNEARBYALTS(30)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		BANKITEMS()
	NEXT
	MASSCLOSENPCWINDOW()
	$CLIENTSCOUNT = 0
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		$CLIENTSCOUNT += 1
	NEXT
	SWITCHTO($MAIN)
	$NOTDONE = TRUE
	DIM $ACCOUNTS[UBOUND($CLIENTS)]
	DIM $ACCOUNTS2[UBOUND($CLIENTS)]
	FOR $I = 0 TO UBOUND($ACCOUNTS) - 1
		$ACCOUNTS[$I] = 0
	NEXT
	DIM $ITEMSARRAY[14] = [42062, 47239, 42191, 42192, 69914, 74449, 48097, 54333, 49634, 49635, 49636, 49637, 49638, 49639]
	$COUNTER = 0
	WHILE $NOTDONE == TRUE
		$TEMPCOUNT = 0
		FOR $I = 0 TO UBOUND($ACCOUNTS) - 1
			$TEMPCOUNT += $ACCOUNTS[$I]
		NEXT
		IF $TEMPCOUNT == $CLIENTSCOUNT THEN
			$NOTDONE = FALSE
			CONTINUELOOP
		ENDIF
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			$INDEX = $CLIENTSINDEXES[$I]
			SWITCHTONUM($INDEX)
			IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
			IF $ACCOUNTS[$INDEX] == 1 THEN CONTINUELOOP
			IF NOT USEANYITEM($ITEMSARRAY) THEN
				IF $COUNTER == 0 THEN
					$ACCOUNTS2[$I] = 1
				ENDIF
				$ACCOUNTS[$INDEX] = 1
			ENDIF
		NEXT
		SLEEP(3500)
		$COUNTER += 1
	WEND
	SWITCHTO($MAIN)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF NOT CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN CONTINUELOOP
		IF NOT $ACCOUNTS2[$I] == 1 THEN
			BANKITEMS()
		ENDIF
	NEXT
	SWITCHTO($MAIN)
	SLEEP(100)
	MASSCLOSENPCWINDOW()
ENDFUNC
FUNC MASSAUTOOPENPACKS()
	$HASITEMSTOOPEN = FALSE
	$HIGHESTCOUNTSOFAR = 0
	SWITCHTO($MAIN)
	SETSTATUS("Mass opening packs. Opens pack in last inv slot of each char.")
	DIM $PACKSTOOPEN[UBOUND($CLIENTS)]
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($I)
		IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
		$ITEMS = INVARRAY()
		$ITEMID = $ITEMS[UBOUND($ITEMS) - 1][1]
		IF $ITEMID THEN
			$HASITEMSTOOPEN = TRUE
			$COUNT = ITEMCOUNTTOTAL($ITEMID)
			$PACKSTOOPEN[$I] = $COUNT
			IF $COUNT > $HIGHESTCOUNTSOFAR THEN
				$HIGHESTCOUNTSOFAR = $COUNT
			ENDIF
		ENDIF
	NEXT
	IF $HASITEMSTOOPEN THEN
		FOR $J = 0 TO $HIGHESTCOUNTSOFAR - 1
			$SUM = 0
			FOR $I = 0 TO UBOUND($PACKSTOOPEN) - 1
				IF $PACKSTOOPEN[$I] <> 0 THEN
					$TEMP = $PACKSTOOPEN[$I]
					$SUM = $SUM + $TEMP
				ENDIF
			NEXT
			IF $J <> 0 THEN
				SETSTATUS("---------")
			ENDIF
			IF $SUM == 0 THEN
				SETSTATUS("Done opening packs for now.")
				EXITLOOP
			ENDIF
			FOR $I = 0 TO UBOUND($CLIENTS) - 1
				SWITCHTONUM($I)
				IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
				$TEMP = $PACKSTOOPEN[$I]
				IF $PACKSTOOPEN[$I] <> 0 THEN
					$ITEMS = INVARRAY()
					$ITEMID = $ITEMS[UBOUND($ITEMS) - 1][1]
					USEITEMID($ITEMID)
					$PACKSTOOPEN[$I] = $TEMP - 1
				ENDIF
			NEXT
			SLEEP(3000)
			FOR $I = 0 TO UBOUND($CLIENTS) - 1
				SWITCHTONUM($I)
				IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
				IF $PACKSTOOPEN[$I] <> 0 THEN
					$ITEMS = INVARRAY()
					$ITEMID = $ITEMS[UBOUND($ITEMS) - 1][1]
					$COUNT = ITEMCOUNTTOTAL($ITEMID)
					IF $J <> 0 THEN SETSTATUS("Item ID: " & $ITEMID & "; Quantity = " & $COUNT)
					IF $COUNT == 0 OR $COUNT > $PACKSTOOPEN[$I] THEN
						$PACKSTOOPEN[$I] = 0
					ENDIF
				ENDIF
			NEXT
			SWITCHTO($MAIN)
		NEXT
	ENDIF
	SWITCHTO($MAIN)
ENDFUNC
FUNC DANCEEVENT()
	SETSTATUS("Doing dance2 in base.")
	IF INSTANCEID() <> 135 THEN
		ENTERFACTIONBASE()
		SLEEP(3000)
	ENDIF
	SWITCHTOHUMANFORM()
	SLEEP(2000)
	IF DISTANCE2D(58.59, 560.64) > 5 THEN
		MOVE2(58.4, 560.45)
	ENDIF
	SENDEXPRESSION(502)
	SLEEP(1000)
	SENDEMOTE(502)
	SLEEP(1000)
	SETSTATUS("dancing")
	WHILE NOT MOVEKEY()
		SLEEP(1000)
	WEND
ENDFUNC
FUNC MASSDANCEVENT()
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($I)
		ENTERFACTIONBASE()
	NEXT
	SLEEP(5000)
	MASSMOVE3(58.4, 560.45)
	SLEEP(5000)
	MASSDANCE2()
ENDFUNC
FUNC MASSDANCE2()
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		SENDEMOTE(502)
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSMOUNTCOMMAND()
	$CLIENTSINDEXES = GETNEARBYALTS()
	MASSMOUNT($CLIENTSINDEXES)
ENDFUNC
FUNC MASSDISMOUNTCOMMAND()
	$CLIENTSINDEXES = GETNEARBYALTS()
	MASSDISMOUNT($CLIENTSINDEXES)
ENDFUNC
FUNC MASSMOUNT($CLIENTSINDEXES)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF NOT MOUNTSUMMONED() AND CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN
			SWITCHTOHUMANFORM()
			SUMMONPET(21)
		ENDIF
	NEXT
	WAITCLIENTSTOFINISH($CLIENTSINDEXES)
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSDISMOUNT($CLIENTSINDEXES)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF MOUNTSUMMONED() AND CLIENTINGROUP($CLIENTS[$INDEX][2], "masstarget") THEN STOREPET()
	NEXT
	WAITCLIENTSTOFINISH($CLIENTSINDEXES)
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSREPAIRALL($CLIENTSINDEXES, $NPCNAME)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		TALKTONPC($NPCNAME)
	NEXT
	SLEEP(300)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		REPAIRALL()
	NEXT
	SLEEP(500)
	MASSCLOSENPCWINDOW()
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSSELECT3($CLIENTSINDEXES, $NPCNAME)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		TALKTONPC2($NPCNAME, 2, TRUE, TRUE, TRUE, 5000)
	NEXT
	SLEEP(500)
	MASSCLOSENPCWINDOW()
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSENTERHOME()
	$ENTERHOME = INITIALMAP() <> $MAP_HOME
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($I)
		IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
		IF $ENTERHOME THEN
			ENTERHOME(PLAYERID())
		ELSE
			EXITHOME()
		ENDIF
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSEXITHOME()
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($I)
		IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
		EXITHOME()
	NEXT
	SWITCHTO($MAIN)
	EXITHOME()
ENDFUNC
FUNC AUTOBANKDAILY4()
	AUTOBANKDAILY()
ENDFUNC
FUNC AUTOBANKDAILY3()
	AUTOBANKDAILY()
ENDFUNC
FUNC AUTOBANKDAILY2()
	AUTOBANKDAILY()
ENDFUNC
FUNC AUTOBANKDAILY()
	SETSTATUS("Auto-banking")
	IF GETGLOBALSETTING("AutoBankRepairSpotAlternate", TRUE) AND GETGLOBALSETTING("AutoBankRepairSpotAlternate2", TRUE) THEN
		SETSTATUS("Both Bamboo Village and Silver Pool setting selected. Make sure to only select one tick box please. Going to Plume Bank for now.")
		TRANSFERMAP($MAP_MAIN, 0, -629, -1365, 24)
	ELSEIF GETGLOBALSETTING("AutoBankReairSpotAlternate", TRUE) THEN
		TRANSFERMAP($MAP_MAIN, 0, -305.77, -1992.67)
	ELSEIF GETGLOBALSETTING("AutoBankRepairSpotAlternate2", TRUE) THEN
		TRANSFERMAP($MAP_MAIN, 0, 490.75, 179.28)
	ELSE
		TRANSFERMAP($MAP_MAIN, 0, RANDOM(964, 974), RANDOM(3196, 3206))
	ENDIF
	BANKITEMS()
	SLEEP(1000)
	$BANKTIMER = TIMERINIT()
	IF(ITEMCOUNT(47239) > 0 OR ITEMCOUNT(69914) > 0 OR ITEMCOUNT(48097) > 0 OR ITEMCOUNT(42062) > 0 OR ITEMCOUNT(42191) > 0 OR ITEMCOUNT(42192) > 0) THEN
		WHILE(ITEMCOUNT(47239) > 0 OR ITEMCOUNT(69914) > 0 OR ITEMCOUNT(48097) > 0 OR ITEMCOUNT(42062) > 0 OR ITEMCOUNT(42191) > 0 OR ITEMCOUNT(42192) > 0)
			IF TIMERDIFF($BANKTIMER) > 120000 THEN EXITLOOP
			USEITEMID(47239)
			USEITEMID(69914)
			USEITEMID(48097)
			USEITEMID(42062)
			USEITEMID(42191)
			USEITEMID(42192)
			SLEEP(3000)
		WEND
		SLEEP(1000)
		WHILE(ITEMCOUNT(47239) > 0 OR ITEMCOUNT(69914) > 0 OR ITEMCOUNT(48097) > 0 OR ITEMCOUNT(42062) > 0 OR ITEMCOUNT(42191) > 0 OR ITEMCOUNT(42192) > 0)
			IF TIMERDIFF($BANKTIMER) > 120000 THEN EXITLOOP
			USEITEMID(47239)
			USEITEMID(69914)
			USEITEMID(48097)
			USEITEMID(42062)
			USEITEMID(42191)
			USEITEMID(42192)
			SLEEP(3000)
		WEND
		BANKITEMS()
	ENDIF
ENDFUNC
FUNC AUTOREPAIRDAILY()
	SETSTATUS("Repairing Gear")
	IF GETGLOBALSETTING("AutoBankRepairSpotAlternate", TRUE) AND GETGLOBALSETTING("AutoBankRepairSpotAlternate2", TRUE) THEN
		SETSTATUS("Both Bamboo Village and Silver Pool setting selected. Make sure to only select one tick box please. Going to Plume Bank for now.")
		TRANSFERMAP($MAP_MAIN, 0, -629, -1365)
		TALKTONPC("Apothecary Tu")
		REPAIRALL()
		SLEEP(1000)
		IF GETGLOBALSETTING("FeedGenie") THEN FEEDGENIEDAILY()
		SETSTATUS("Finished Repairing")
	ELSEIF GETGLOBALSETTING("AutoBankRepairSpotAlternate2", TRUE) THEN
		TRANSFERMAP($MAP_MAIN, 0, 490.75, 179.28)
		TALKTONPC("Craftsman Shang")
		REPAIRALL()
		SLEEP(1000)
		IF GETGLOBALSETTING("FeedGenie") THEN FEEDGENIEDAILY()
		SETSTATUS("Finished Repairing")
	ELSEIF GETGLOBALSETTING("AutoBankRepairSpotAlternate", TRUE) THEN
		TRANSFERMAP($MAP_MAIN, 0, -305.77, -1992.67)
		TALKTONPC("Craftsman Wang")
		REPAIRALL()
		SLEEP(1000)
		IF GETGLOBALSETTING("FeedGenie") THEN FEEDGENIEDAILY()
		SETSTATUS("Finished Repairing")
	ELSE
		TRANSFERMAP($MAP_MAIN, 0, RANDOM(987, 988), RANDOM(3184, 3190))
		TALKTONPC("Blacksmith Chang")
		REPAIRALL()
		SLEEP(1000)
		IF GETGLOBALSETTING("FeedGenie") THEN FEEDGENIEDAILY()
		SETSTATUS("Finished Repairing")
	ENDIF
ENDFUNC
FUNC FEEDGENIEDAILY()
	$ARRAY = INVARRAY(0, FALSE)
	$INDEX = SEARCHITEMID($ARRAY, 5639)
	IF $INDEX == -1 THEN RETURN
	FEEDGENIE($INDEX, 1000)
	SLEEP(500)
ENDFUNC
FUNC BUYPERFECTSTONES()
	BUYITEM(773, 0, 10)
	SLEEP(1000)
ENDFUNC
FUNC TELEPORTINCENSE()
	$ARRAY = INVARRAY()
	DIM $ITEMIDS[5] = [36906, 2100, 23434, 26652, 33917]
	FOR $I = 0 TO UBOUND($ITEMIDS) - 1
		$INDEX = SEARCHITEMID($ARRAY, $ITEMIDS[$I])
		IF $INDEX <> -1 THEN
			USEITEM($ARRAY[$INDEX][0], $ARRAY[$INDEX][1])
			SETSTATUS("Using teleport incense to go back to town fast.")
			RETURN TRUE
		ENDIF
	NEXT
	RETURN FALSE
ENDFUNC
FUNC MASSTELETOBASE()
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($I)
		CASTSKILL(4636, 4)
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSTELEPORTINCENSE()
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		TELEPORTINCENSE()
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSTELEPORTINCENSESQUAD($CLIENTSINDEXES)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		TELEPORTINCENSE()
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC SWITCHSQUADRANDOM()
	SWITCHSQUAD(0)
ENDFUNC
FUNC SWITCHSQUADFREE()
	SWITCHSQUAD(1)
ENDFUNC
FUNC KICKWHOLESQUAD()
	SWITCHSQUAD(2)
ENDFUNC
FUNC ROTATESKILL()
	STATIC $CURR = 24
	SENDPACKET("39000800" & HEX($CURR, 2) & "01000000", 9, $GAME_PID)
	$CURR = MOD($CURR - 24 + 1, NUMBER(2)) + 24
	SLEEP(25)
	SENDPACKET("390008" & HEX($CURR, 2) & "0001000000", 9, $GAME_PID)
ENDFUNC
FUNC SWITCHSQUAD($TYPE)
	$ARRAY = PARTYARRAY()
	FOR $I = 1 TO UBOUND($ARRAY) - 1
		KICKFROMSQUAD($ARRAY[$I][0])
		SLEEP(300)
	NEXT
	IF $TYPE == 2 THEN RETURN
	SENDPACKET("22000" & $TYPE & "00", 4, $GAME_PID)
	SLEEP(500)
	FOR $I = 1 TO UBOUND($ARRAY) - 1
		INVITESQUAD($ARRAY[$I][0])
		SLEEP(300)
	NEXT
	MASSSQUADACCEPT()
ENDFUNC
FUNC G17HELMSKILL()
	CASTSKILL(5300, 3)
	CASTSKILL(5301, 3)
ENDFUNC
FUNC G17PANTSSKILL()
	CASTSKILL(5290, 3)
	CASTSKILL(5291, 3)
ENDFUNC
FUNC G17BOOTSSKILL()
	CASTSKILL(5306, 3)
	CASTSKILL(5307, 3)
	CASTSKILL(5308, 3)
ENDFUNC
FUNC PICKUPKEYSFROMFACTIONBASE()
	CLOSENPCWINDOW()
	$POS = PLAYERPOS()
	DIM $QUESTS[3] = [35515, 37945, 40364]
	IF NOT ANYQUESTAVAILABLE($QUESTS) THEN
		SETSTATUS("Already collected keys today. Continuing dailies.")
		RETURN
	ENDIF
	$ENTERMANUALLY = FALSE
	IF FACTIONID() == 0 THEN RETURN
	IF INSTANCEID() == $MAP_NORTHERNREALM THEN TRANSFERMAP($MAP_MAIN)
	$SKILL = SKILLOFFCOOLDOWN(4636, 4)
	IF NOT $SKILL THEN
		SETSTATUS("Back to base skill not available right now. Entering base manually instead.")
		$ENTERMANUALLY = TRUE
	ENDIF
	$TIMER = TIMERINIT()
	WHILE SKILLOFFCOOLDOWN(4636, 4) AND TIMERDIFF($TIMER) < 20000 AND INSTANCEID() <> 135
		CASTSKILL(4636, 4)
		SETSTATUS("Trying to use back to base skill to collect daily keys.")
		SLEEP(1000)
		WAITSTOP()
	WEND
	IF INSTANCEID() <> 135 AND TIMERDIFF($TIMER) > 20000 THEN
		SETSTATUS("Was unable to enter base after 20s of trying with back to base skill. Will enter base manually.")
		$ENTERMANUALLY = TRUE
		SLEEP(100)
	ENDIF
	IF $ENTERMANUALLY == TRUE AND INSTANCEID() <> 135 THEN
		IF NOT ENTERFACTIONBASEFROMNPC() THEN
			SETSTATUS("Failed to enter faction base. Continuing dailies. Consider selecting the tickboxes to get keys from Primal World locations instead")
			RETURN
		ENDIF
	ENDIF
	SLEEP(1000)
	IF INSTANCEID() <> 135 THEN
		SETSTATUS("Unable to enter faction base right now. Continuing dailies. Consider selecting the tickboxes to get keys from Primal World locations instead.")
		RETURN
	ENDIF
	$TIMER2 = TIMERINIT()
	WHILE TIMERDIFF($TIMER2) < 10000 AND NOT GETNPCUNIQUEID("Ticket Master Luto")
		SLEEP(1000)
	WEND
	IF TIMERDIFF($TIMER2) > 10000 AND NOT GETNPCUNIQUEID("Ticket Master Luto") THEN
		SETSTATUS("NPC for keys not available right now. Exiting base to continue dailies. Consider selecting the tickboxes to get keys from Primal World locations instead")
		RETURN
	ENDIF
	SETSTATUS("Picking Keys from Faction Base")
	IF GETNPCUNIQUEID("Ticket Master Luto") THEN
		MOVE2(-28.34, 719.71)
		SLEEP(100)
		TAKEQUEST("Ticket Master Luto", 37945)
		SLEEP(1000)
		TAKEQUEST("Ticket Master Luto", 35515)
		SLEEP(1000)
		TAKEQUEST("Ticket Master Luto", 40364)
		SLEEP(1000)
		SETSTATUS("Keys collected from base.")
	ENDIF
	TRANSFERMAP($MAP_MAIN)
	SLEEP(2000)
ENDFUNC
FUNC HOTKEYCONTROLS()
	ADDHELPCONTROL("Example hotkeys:" & @CRLF & "" & @CRLF & "!a is Alt+A" & @CRLF & "^!{F4} is Ctrl+Alt+F4" & @CRLF & "+6 is Shift+6" & @CRLF & @CRLF & "Google 'AutoIT SendKey' for more key codes" & @CRLF & @CRLF & "Macros bot uses:" & @CRLF & @CRLF & "Macro(0) = single target (no aoes)" & @CRLF & "Macro(1) = aoes" & @CRLF & "Macro(2) = survival" & @CRLF & "Macro(3) = nuke (e.g bosses)" & @CRLF & "Macro(5) = buffs" & @CRLF & "Macro(7) = build chi (no target)" & @CRLF & "(Tick the 'Use Chi Macro(7)' setting to use)")
	$Y = 5 + $YOFFSET
	GUICTRLCREATELABEL("^=Ctrl    !=Alt    +=Shift    #=Win    {F2}=F2", 20, $Y, 280, 20)
	GUICTRLSETRESIZING(-1, $GUI_DOCKALL)
	$Y += 15
	$HHOTKEYGUI = GUICREATE("", 270, 250 + $WINDOW_EXTRA_HEIGHT, 20, $Y, $WS_POPUP, $WS_EX_MDICHILD, $HGUI)
	GUISETBKCOLOR($COLOR_WHITE, $HHOTKEYGUI)
	_GUISCROLLBARS_GENERATE($HHOTKEYGUI, 250, UBOUND($MISC_COMMANDS) * 25, 1, 1, TRUE)
	REGISTERGUI($HHOTKEYGUI, UBOUND($MISC_COMMANDS) * 25)
	FOR $I = 0 TO UBOUND($MISC_COMMANDS) - 1
		GUICTRLCREATELABEL($MISC_COMMANDS[$I][0], 0, $I * 25, 150, 20)
		GUICTRLSETRESIZING(-1, $GUI_DOCKALL)
		IF $MISC_COMMANDS[$I][3] <> "" THEN
			GUICTRLSETTIP(-1, $MISC_COMMANDS[$I][3])
		ENDIF
		$MISC_COMMANDS[$I][2] = GUICTRLCREATEINPUT(INIREAD("settings.ini", "hotkeys", $MISC_COMMANDS[$I][1], ""), 150, $I * 25, 100, 20)
		GUICTRLSETRESIZING(-1, $GUI_DOCKSIZE + $GUI_DOCKRIGHT + $GUI_DOCKTOP)
	NEXT
	$Y += 250
	GUISWITCH($HGUI)
	$Y += 20 + $WINDOW_EXTRA_HEIGHT
	$SETHOTKEYSBUTTON = GUICTRLCREATEBUTTON("Set Hotkeys", 0 * 140 + 20, $Y, 130, 30)
	GUICTRLSETONEVENT(-1, "SetHotkeys")
	GUICTRLSETBKCOLOR($SETHOTKEYSBUTTON, 11195366)
	GUICTRLSETCOLOR($SETHOTKEYSBUTTON, 139)
	GUICTRLSETRESIZING(-1, $GUI_DOCKSIZE + $GUI_DOCKBOTTOM + $GUI_DOCKLEFT)
	GUICTRLCREATEBUTTON("Unbind All Hotkeys", 1 * 140 + 20, $Y, 130, 30)
	GUICTRLSETONEVENT(-1, "UnbindHotkeys")
	GUICTRLSETRESIZING(-1, $GUI_DOCKSIZE + $GUI_DOCKBOTTOM + $GUI_DOCKRIGHT)
	SETHOTKEYS()
ENDFUNC
FUNC UNBINDHOTKEYS()
	FOR $I = 0 TO UBOUND($MISC_COMMANDS) - 1
		IF $MISC_COMMANDS[$I][4] THEN
			HOTKEYSET($MISC_COMMANDS[$I][4])
			$MISC_COMMANDS[$I][4] = ""
		ENDIF
	NEXT
	SETSTATUS("Hotkeys unbound.")
ENDFUNC
FUNC SETHOTKEYS()
	UNBINDHOTKEYS()
	FOR $I = 0 TO UBOUND($MISC_COMMANDS) - 1
		$TEXT = STRINGSTRIPWS(GUICTRLREAD($MISC_COMMANDS[$I][2]), 3)
		$MISC_COMMANDS[$I][4] = $TEXT
		IF $TEXT THEN
			HOTKEYSET($TEXT, "HOTKEYHANDLER")
			PRINT("Setting Hotkey = " & $TEXT & "  -  " & $MISC_COMMANDS[$I][1])
		ENDIF
		INIWRITE("settings.ini", "hotkeys", $MISC_COMMANDS[$I][1], $TEXT)
	NEXT
	SETSTATUS("Hotkeys set.")
ENDFUNC
FUNC HOTKEYHANDLER()
	$SWITCH = GETGLOBALSETTING("hotkeysforegroundclient")
	$FOREGROUNDSETTINGCHECK = GETGLOBALSETTING("onlytriggerhotkeyifagameclientisforeground")
	$PREVMAIN = $MAIN
	$CAPTURE = FALSE
	IF $SWITCH THEN
		$FOREWIN = _WINAPI_GETFOREGROUNDWINDOW()
		FOR $I = 0 TO UBOUND($CLIENTS) - 1
			IF $CLIENTS[$I][5] == $FOREWIN THEN
				$MAIN = $CLIENTS[$I][2]
				SWITCHTO($MAIN)
				$CAPTURE = TRUE
				EXITLOOP
			ENDIF
		NEXT
	ENDIF
	FOR $I = 0 TO UBOUND($MISC_COMMANDS) - 1
		IF @HOTKEYPRESSED == $MISC_COMMANDS[$I][4] THEN
			IF $FOREGROUNDSETTINGCHECK AND NOT $CAPTURE THEN
				EXITLOOP
			ELSE
				CALL($MISC_COMMANDS[$I][1])
				EXITLOOP
			ENDIF
		ENDIF
	NEXT
	IF $PREVMAIN <> $MAIN THEN
		$MAIN = $PREVMAIN
		SWITCHTO($MAIN)
	ENDIF
ENDFUNC
HOTKEYSET("+{ESC}", "_EXIT")
MAKEGUI()
FUNC HEAVENFALLTEMPLEINFO()
	MSGBOX(-1, "Heavenfall Temple Information", "TO ENSURE HEAVENFALL TEMPLE WORKS, PLEASE DO THE FOLLOWING!" & @CRLF & @CRLF & "1)Set your character's macros IN-GAME macros like so:" & @CRLF & "Macro(0) = single-target skills ONLY; (some rooms require *not* aoeing)" & @CRLF & "Macro(1) = majority-aoe skills; (some rooms require aoeing)" & @CRLF & "Macro(2) = survival skills (used if your character hp gets low)" & @CRLF & "Macro(3) = nuke (combine your skills that gives you best dps for bosses)" & @CRLF & "Macro(4) = buff (we rebuff using this macro when your buffs run out)" & @CRLF & "Macro(7) = chi-builder skill (optional: use setting to decide.)" & @CRLF & @CRLF & '2) Tree of Protection (genie skill) is necessary unless "strong character"' & @CRLF & "setting is selected below. Bot relies on using Tree of Protection as an" & @CRLF & "emergency source of healing for weaker characters in certain rooms," & @CRLF & "and if your character doesn't have ""Tree of Protection"" on genie, it" & @CRLF & 'will stop once it reaches high-number "portal" room type.' & @CRLF & @CRLF & '3) Go to "Gear Swap" tab. Put in your normal gear set. Press "save"' & @CRLF & 'for "Gear Set #1". Take off some (or if your character is very strong' & @CRLF & 'ALL of your gear) and press "save" for "Gear Set #2". There are some' & @CRLF & "rooms that will FAIL unless the bot is able to give your character LESS" & @CRLF & 'damage, and we use the "Gear Swap" feature to allow us to do so!' & @CRLF & "FAILURE TO SET GEAR SET 1 & 2 MAY CAUSE BOT TO CRASH!!!" & @CRLF & @CRLF & '4) Use "Chaotic Essence" to make the HFT run go much smoother and' & @CRLF & 'easier! "Chaotic Essence" grants character 4000 points immediately.' & @CRLF & 'At the "Master of Solitude" npc inside HFT, craft this item with' & @CRLF & "20 War Avator Orders or purchase for 1mil, then right click it in" & @CRLF & 'your inventory. Very weak characters should use 2 "Chaotic Essence"' & @CRLF & "for 8000 points. Bot will allocate these points automatically into" & @CRLF & "powerful buffs used inside HFT.")
ENDFUNC
