FUNC INVITEALTS2()
    SENDPACKET("22000" & 2 & "00", 4, $GAME_PID)
    MASSSQUADINVITE2()
    SWITCHTO($MAIN)
    SLEEP(300)
    MASSSQUADACCEPT2()
ENDFUNC

FUNC MASSSQUADINVITE2()
    FOR $I = 0 TO UBOUND($CLIENTS) - 1
        IF CLIENTINGROUP($CLIENTS[$I][2], "alts") THEN
            INVITESQUAD(SQUADIDNUM($I))
        ENDIF
    NEXT
    SWITCHTO($MAIN)
ENDFUNC

FUNC MASSSQUADACCEPT2()
    SLEEP(200)
    $MAINID = PLAYERID()
    FOR $I = 0 TO UBOUND($CLIENTS) - 1
        IF CLIENTINGROUP($CLIENTS[$I][2], "alts") THEN
            SWITCHTONUM($I)
            ACCEPTSQUADID($MAINID)
        ENDIF
    NEXT
    SWITCHTO($MAIN)
ENDFUNC

FUNC INVITEALTSSLOW()
    SWITCHTO($MAIN)
    $MAINID = PLAYERID()
    FOR $I = 0 TO UBOUND($CLIENTS) - 1
        IF CLIENTINGROUP($CLIENTS[$I][2], "alts") THEN
            INVITESQUAD(SQUADIDNUM($I))
            SLEEP(500)  ; Adjust the sleep time as needed
            SWITCHTONUM($I)
            ACCEPTSQUADID($MAINID)
            SLEEP(500)  ; Adjust the sleep time as needed
            SWITCHTO($MAIN)
        ENDIF
    NEXT
ENDFUNC

FUNC MOVEWEAKESTCLIENT($CLIENTSINDEXES, $weakestX, $weakestY, $strongestX, $strongestY)
    LOCAL $WEAKESTINDEX = -1
    LOCAL $MINHP = 9999999 ; Set a high initial value to find the lowest HP
    LOCAL $OTHERCLIENTSINDEXES = []
    LOCAL $CURRENTCLIENTHP

    ; Find the weakest client by HP
    For $I = 0 To UBOUND($CLIENTSINDEXES) - 1
        SwitchToNum($CLIENTSINDEXES[$I])
        $HPMP = GETHPMP()
        $CURRENTCLIENTHP = $HPMP[0] ; Current HP
        
        If $CURRENTCLIENTHP < $MINHP Then
            $MINHP = $CURRENTCLIENTHP
            $WEAKESTINDEX = $I
        EndIf
    Next

    ; Create a list of the other clients
    For $I = 0 To UBOUND($CLIENTSINDEXES) - 1
        If $I <> $WEAKESTINDEX Then
            ; Manually add the client index to the array
            LOCAL $COUNT = UBOUND($OTHERCLIENTSINDEXES)
            REDIM $OTHERCLIENTSINDEXES[$COUNT + 1]
            $OTHERCLIENTSINDEXES[$COUNT] = $CLIENTSINDEXES[$I]
        EndIf
    Next

    ; Move the weakest client to the first set of coordinates
    If $WEAKESTINDEX <> -1 Then
        LOCAL $WEAKESTCLIENT[1]
        $WEAKESTCLIENT[0] = $CLIENTSINDEXES[$WEAKESTINDEX]
        ClientsMoveAndWait(-256.68, -170.39, $WEAKESTCLIENT, 197)
        ClientsDoubleJumpAndMove($weakestX, $weakestY, $WEAKESTCLIENT, 200, 200)
    EndIf

    ; Move the other clients to the second set of coordinates
    If UBOUND($OTHERCLIENTSINDEXES) > 0 Then
        ClientsMoveAndWait($strongestX, $strongestY, $OTHERCLIENTSINDEXES, 197)
    EndIf

    ; Return both the weakest client index and the array of other clients
    Local $Result[2]
    $Result[0] = $CLIENTSINDEXES[$WEAKESTINDEX]
    $Result[1] = $OTHERCLIENTSINDEXES
    Return $Result
EndFunc




FUNC TTR4_1()
	SWITCHTO($MAIN)
