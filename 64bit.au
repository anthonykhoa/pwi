	$Y = 5 + $YOFFSET
	GLOBAL $HAUTOPOT = GUICTRLCREATECHECKBOX("Autopot Enabled", 30, $Y, 100, 20, $BS_AUTOCHECKBOX)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Allow or disallow use of TheNightmareStuff's autopot for this specific character.")
	$SAVESETTINGSBUTTON = GUICTRLCREATEBUTTON("Save Settings", 134, $Y + 1, 110, 23)
	GUICTRLSETBKCOLOR($SAVESETTINGSBUTTON, 11195366)
	GUICTRLSETCOLOR($SAVESETTINGSBUTTON, 139)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKRIGHT + $GUI_DOCKSIZE)
	GUICTRLSETONEVENT(-1, "SaveAutoPotSettings")
	GUICTRLSETTIP(-1, "Save current settings to use them next time TheNightmareStuff is opened")
	$Y += 27
	GUICTRLCREATEGROUP("FOODS", 20, $Y, 270, 110)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKHEIGHT)
	$FOODSLABEL = GUICTRLCREATELABEL("", 20, $Y, 270, 10)
	GUICTRLSETBKCOLOR($FOODSLABEL, $GUI_BKCOLOR_TRANSPARENT)
	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKLEFT + $GUI_DOCKRIGHT + $GUI_DOCKHEIGHT)
