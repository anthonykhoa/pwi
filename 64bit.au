	HANDINQUEST(51839, 0)
	IF HASQUEST(51848) THEN
		FLYTOCOORDS(117, 297, 53)
		TALKTONPC("Rainno Xiaoxiao")
		ACCEPTQUEST(51916)
		SLEEP(5000)
	ENDIF
	FLYTOCOORDS(184, 404, 69)
	SLEEP(5000)
	TALKTONPC("Holy Ritualmaster")
	SLEEP(5000)
	HANDINQUEST(51848, 0)
ENDFUNC
FUNC GATHERALTSINSQUAD()
	$PARTYARRAY = PARTYARRAY()
	$PARTYCOUNT = UBOUND($PARTYARRAY)
	SETSTATUS("Calling up " & $PARTYCOUNT - 1 & " alts (those in our squad).")
	$COUNTER = 0
	$POS = PLAYERPOS()
	$CURRENT_MAP = INITIALMAP()
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF CLIENTINGROUP($CLIENTS[$I][2], "main") THEN CONTINUELOOP
		FOR $J = 0 TO UBOUND($PARTYARRAY) - 1
			IF $CLIENTS[$I][3] == $PARTYARRAY[$J][0] THEN
				SWITCHTONUM($I)
				$COUNTER += 1
				IF DISTANCE2D($POS[0], $POS[1]) > 5 THEN
					TRANSFERMAP($CURRENT_MAP, 0, $POS[0], $POS[1], $POS[2])
				ENDIF
			ENDIF
		NEXT
	NEXT
	SWITCHTO($MAIN)
	SETSTATUS("Done. " & $COUNTER & " alts were called.")
ENDFUNC
FUNC GATHERALTS()
	SETSTATUS("Calling all alts to current location. Please wait for this to finish.")
	$POS = PLAYERPOS()
	$CURRENT_MAP = INITIALMAP()
	$FINISHED = FALSE
	$CHECKTIME = 3000
	DIM $ALTSFINISHED[UBOUND($CLIENTS)]
	$ALTSCOUNT = 0
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF CLIENTINGROUP($CLIENTS[$I][2], "main") THEN CONTINUELOOP
		$ALTSCOUNT += 1
	NEXT
	SETSTATUS("Number of alts calling: " & $ALTSCOUNT)
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
		IF CLIENTINGROUP($CLIENTS[$I][2], "main") THEN CONTINUELOOP
		SWITCHTONUM($I)
		IF DISTANCE2D($POS[0], $POS[1]) > 5 THEN
			TRANSFERMAP($CURRENT_MAP, 0, $POS[0], $POS[1], $POS[2])
		ENDIF
	NEXT
	SWITCHTO($MAIN)
	SETSTATUS("Alts gathered. Done.")
ENDFUNC
FUNC TRANSFERMAP($MAP, $LOCATION = 0, $X = $INVALID_POS, $Y = $INVALID_POS, $HEIGHT = 50)
	IF $POSSIBLE_MAP_TRANSFER <> 0 THEN
		WHILE TIMERDIFF($POSSIBLE_MAP_TRANSFER) < 3000
			SLEEP(1000)
		WEND
		$POSSIBLE_MAP_TRANSFER = 0
	ENDIF
	IF LIGHTNINGSTONE($MAP, $X, $Y, $HEIGHT) THEN
		RETURN TRUE
	ENDIF
	$CURRENTMAP = $MAP_UNKNOWN
	$EXTRA_WAIT = FALSE
	WHILE $CURRENTMAP == $MAP_UNKNOWN
		$CURRENTMAP = INITIALMAP()
		IF $CURRENTMAP == $MAP_UNKNOWN THEN
			SETSTATUS("Manually move to a supported map")
			SLEEP(1000)
			$EXTRA_WAIT = TRUE
		ELSEIF $EXTRA_WAIT THEN
			SLEEP(6000)
		ENDIF
	WEND
	STATIC $CURRENTLOCATION = 0
	IF $MAP <> $CURRENTMAP THEN
	ELSEIF $MAP == $CURRENTMAP AND $LOCATION <> $CURRENTLOCATION THEN
	ELSE
		IF $X <> $INVALID_POS THEN
			FLY($X, $Y, $HEIGHT, 1, TRUE)
		ENDIF
		RETURN
	ENDIF
	PRINT("Transfer from " & $CURRENTMAP & "-" & $CURRENTLOCATION & " to " & $MAP & "-" & $LOCATION)
	IF $CURRENTMAP == $MAP_MAIN AND $MAP == $MAP_PRIMAL THEN
		ENTERPRIMAL()
	ELSEIF $MAP == $MAP_OHT THEN
		ENTEROHT()
		TRANSFERMAP($MAP, $LOCATION, $X, $Y, $HEIGHT)
	ELSEIF $CURRENTMAP == $MAP_OHT AND $MAP <> $MAP_OHT THEN
		EXITOHT()
		TRANSFERMAP($MAP, $LOCATION, $X, $Y, $HEIGHT)
	ELSEIF $CURRENTMAP == $MAP_MAIN AND $MAP == $MAP_STORY THEN
		TRANSFERMAP($MAP_PRIMAL, 0)
		TRANSFERMAP($MAP, $LOCATION, $X, $Y, $HEIGHT)
	ELSEIF $CURRENTMAP == $MAP_MAIN AND $MAP == $MAP_NEVERFALL THEN
		ENTERWESTERNSTEPPES()
	ELSEIF $CURRENTMAP == $MAP_MAIN AND $MAP == $MAP_MORAI THEN
		ENTERMORAI()
		SLEEP(2000)
	ELSEIF $CURRENTMAP == $MAP_MAIN AND $MAP == $MAP_ADVENTUREKINGDOM THEN
		ENTERADVENTUREKINGDOM()
	ELSEIF $CURRENTMAP == $MAP_ADVENTUREKINGDOM AND $MAP == $MAP_MAIN THEN
		EXITADVENTUREKINGDOM()
	ELSEIF $CURRENTMAP == $MAP_MAIN AND $MAP == $MAP_MOMA THEN
		ENTERMOMAGANON()
	ELSEIF $CURRENTMAP == $MAP_MAIN AND $MAP == $MAP_LOTH THEN
		ENTERLOTHRANIS()
	ELSEIF $CURRENTMAP == $MAP_MOMA AND $MAP == $MAP_MAIN THEN
		EXITMOMAGANON()
	ELSEIF $CURRENTMAP == $MAP_LOTH AND $MAP == $MAP_MAIN THEN
		EXITLOTHRANIS()
	ELSEIF $CURRENTMAP == $MAP_MOMA AND $MAP <> $MAP_MAIN AND $MAP <> $MAP_MOMA THEN
		TRANSFERMAP($MAP_MAIN, 0)
		TRANSFERMAP($MAP, $LOCATION, $X, $Y, $HEIGHT)
	ELSEIF $CURRENTMAP == $MAP_LOTH AND $MAP <> $MAP_MAIN AND $MAP <> $MAP_LOTH THEN
		TRANSFERMAP($MAP_MAIN, 0)
		TRANSFERMAP($MAP, $LOCATION, $X, $Y, $HEIGHT)
	ELSEIF $CURRENTMAP == $MAP_MAIN AND $MAP == $MAP_FACTIONBASE THEN
		RETURN ENTERFACTIONBASE()
	ELSEIF $CURRENTMAP == $MAP_FACTIONBASE AND $MAP == $MAP_MAIN THEN
		DOEXITFACTIONBASE()
	ELSEIF $CURRENTMAP == $MAP_FACTIONBASE AND $MAP <> $MAP_MAIN AND $MAP <> $MAP_FACTIONBASE THEN
		TRANSFERMAP($MAP_MAIN, 0)
		TRANSFERMAP($MAP, $LOCATION, $X, $Y, $HEIGHT)
	ELSEIF $CURRENTMAP == $MAP_MAIN AND $MAP == $MAP_ULFGARD THEN
		ENTERULFGARD()
	ELSEIF $CURRENTMAP == $MAP_ULFGARD AND $MAP == $MAP_MAIN THEN
		EXITULFGARD()
	ELSEIF $CURRENTMAP == $MAP_ULFGARD AND $MAP <> $MAP_MAIN AND $MAP <> $MAP_ULFGARD THEN
		TRANSFERMAP($MAP_MAIN, 0)
		TRANSFERMAP($MAP, $LOCATION, $X, $Y, $HEIGHT)
	ELSEIF $CURRENTMAP == $MAP_MAIN AND $MAP == $MAP_NORTHERNREALM THEN
		ENTERNORTHERNREALM()
	ELSEIF $CURRENTMAP == $MAP_NORTHERNREALM AND $MAP == $MAP_MAIN THEN
		EXITNORTHERNREALM()
	ELSEIF $CURRENTMAP == $MAP_NORTHERNREALM AND $MAP <> $MAP_MAIN AND $MAP <> $MAP_NORTHERNREALM THEN
		TRANSFERMAP($MAP_MAIN, 0)
		TRANSFERMAP($MAP, $LOCATION, $X, $Y, $HEIGHT)
	ELSEIF $CURRENTMAP == $MAP_MORAI AND $MAP == $MAP_MAIN THEN
		EXITMORAI()
	ELSEIF $CURRENTMAP == $MAP_NEVERFALL AND $MAP == $MAP_MAIN THEN
		EXITWESTERNSTEPPES()
	ELSEIF $CURRENTMAP == $MAP_PRIMAL AND $MAP == $MAP_MAIN THEN
		IF $CURRENTLOCATION == 3 THEN
			TAKEQUEST("Teleport Master Aquas", 31047)
		ELSE
			TAKENEARESTQUEST($PRIMAL_EXIT_NPCS)
		ENDIF
		WAITFORNPC("Messenger of Time Woyo")
		SLEEP(4000)
	ELSEIF $CURRENTMAP == $MAP_ADVENTUREKINGDOM AND $MAP <> $MAP_MAIN AND $MAP <> $MAP_ADVENTUREKINGDOM THEN
		TRANSFERMAP($MAP_MAIN, 0)
		TRANSFERMAP($MAP, $LOCATION, $X, $Y, $HEIGHT)
	ELSEIF $CURRENTMAP == $MAP_HOME AND $MAP <> $MAP_HOME THEN
		EXITHOME()
		TRANSFERMAP($MAP, $LOCATION, $X, $Y, $HEIGHT)
	ELSEIF $CURRENTMAP == $MAP_MORAI AND $MAP <> $MAP_MAIN AND $MAP <> $MAP_MORAI THEN
		TRANSFERMAP($MAP_MAIN, 0)
		WAITFORNPC("Messenger of Time Woyo")
		TRANSFERMAP($MAP, $LOCATION, $X, $Y, $HEIGHT)
	ELSEIF $CURRENTMAP == $MAP_NEVERFALL AND($MAP <> $MAP_MAIN AND $MAP <> $MAP_NEVERFALL) THEN
		TRANSFERMAP($MAP_MAIN, 0)
		WAITFORNPC("Messenger of Time Woyo")
		TRANSFERMAP($MAP, $LOCATION, $X, $Y, $HEIGHT)
	ELSEIF $CURRENTMAP == $MAP_STORY AND $MAP <> $MAP_PRIMAL AND $MAP <> $MAP_STORY THEN
		TRANSFERMAP($MAP_PRIMAL, 0)
		TRANSFERMAP($MAP, $LOCATION, $X, $Y, $HEIGHT)
	ELSEIF $CURRENTMAP == $MAP_PRIMAL AND $MAP <> $MAP_MAIN AND $MAP <> $MAP_STORY AND $MAP <> $MAP_PRIMAL THEN
		TRANSFERMAP($MAP_MAIN, 0)
		WAITFORNPC("Messenger of Time Woyo")
		TRANSFERMAP($MAP, $LOCATION, $X, $Y, $HEIGHT)
	ELSEIF $CURRENTMAP == $MAP_PRIMAL AND $MAP == $MAP_STORY THEN
		TAKENEARESTQUEST($PRIMAL_STORY_NPCS, -1, $X, $Y)
	ELSEIF $CURRENTMAP == $MAP_STORY AND $MAP == $MAP_PRIMAL THEN
		TAKENEARESTQUEST($STORY_EXIT_NPCS)
	ENDIF
	WHILE INITIALMAP() <> $MAP
		SLEEP(2000)
	WEND
	$CURRENTMAP = $MAP
	$CURRENTLOCATION = $LOCATION
	IF $X <> $INVALID_POS THEN
		FLY($X, $Y, $HEIGHT, 1, TRUE)
	ENDIF
	SLEEP(1000)
ENDFUNC
FUNC FINDTOWERACTIVATOR($ARRAY)
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		IF $ARRAY[$I][1] >= 47593 AND $ARRAY[$I][1] <= 47646 THEN
			RETURN $I
		ENDIF
	NEXT
	RETURN -1
ENDFUNC
FUNC TRYTOENTERTOWERROOM($ROOM)
	$INSTANCE = INSTANCEID()
	STARTLISTENING()
	IF INSTANCEVALUE(200009) > 0 AND $ROOM > (INSTANCEVALUE(200009) + 1) THEN RETURN FALSE
	FOR $I = 0 TO 3
		GOTOTOWERROOM($ROOM)
		IF SEETEXT("Stage selection is in cooldown") THEN
			SLEEP(30000)
		ELSE
			SLEEP(4000)
		ENDIF
		$IDX = FINDTOWERACTIVATOR(NPCARRAY())
		IF $IDX >= 0 THEN
			RETURN TRUE
		ENDIF
	NEXT
	IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
		SETSTATUS("Kicked out of tower.")
	ENDIF
	RETURN FALSE
ENDFUNC
FUNC TOWERSELFBUFF($RESET = FALSE)
	IF SHOULDUSESPIRITOFDEFENSE() THEN
		USEITEMID(38408)
		SLEEP(1000)
	ENDIF
	IF SHOULDUSESPIRITOFASSAULT() THEN
		USEITEMID(38407)
		SLEEP(1000)
	ENDIF
	TIMEDSELFBUFF($RESET)
ENDFUNC
GLOBAL $HEAVENFALL_LAST_ROOM = 0
FUNC DOTOWER($STOPROOM)
	IF $STOPROOM < 0 OR $STOPROOM > 108 THEN
		SETSTATUS("Invalid room number. Please set room number between 1 and 108.")
		RETURN
	ENDIF
	STARTLISTENING()
	REFRESHAUTOPOTSETTINGS()
	$REWARDROOM = 72
	$ROOMNUMBER = CURRENTROOMNUMBER()
	WHILE $ROOMNUMBER == 0
		SETSTATUS("Waiting for you to manually enter a Tower room...")
		SLEEP(1000)
		$ROOMNUMBER = CURRENTROOMNUMBER()
	WEND
	TOWERSELFBUFF(TRUE)
	SETSTATUS("Heavenfall Tower - Starting from room #" & $ROOMNUMBER)
	IF MOD($REWARDROOM, 9) > 0 AND $REWARDROOM < 100 THEN RETURN
	IF $ROOMNUMBER == 0 THEN RETURN
	$I = $ROOMNUMBER
	$INSTANCE = INSTANCEID()
	$COMPLETED = FALSE
	WHILE $I <= $STOPROOM AND $INSTANCE <= 175 AND $INSTANCE >= 172
		DO
			SETSTATUS("Heavenfall Tower - Room #" & $I & " - Allocating Buffs")
			SWITCHTOHUMANFORM()
			HANDLEBUFFS()
			WHILE NOT TRYTOENTERTOWERROOM($I)
				$I -= 1
			WEND
			TOWERSELFBUFF()
			BUFFCHECK(TRUE)
			IF USEHOLYPATH() THEN
				IF NOT HASBUFF("", 44) THEN
					SpeedPATH()
					SLEEP(500)
				ENDIF
			ENDIF
			SETSTATUS("Heavenfall Tower - Room #" & $I & " - Activating Room")
			SLEEP(250)
			HANDLEROOM()
			HANDLETOWERANCIENTGIFT()
			IF MOD($I, 9) == 0 THEN
				ACCEPTTOWERREWARD($REWARDROOM)
				SLEEP(500)
			ENDIF
			ACCEPTTOWERREWARD($REWARDROOM)
			SLEEP(1000)
			IF $I == 108 AND $STOPROOM == 108 THEN
				$COMPLETED = TRUE
			ENDIF
			PRINT(GETNPCUNIQUEID("Master of Solitude"))
			SLEEP(2000)
			$HPMP = GETHPMP()
			IF GETNPCUNIQUEID("Master of Solitude") THEN
				$PLAYERPOS = PLAYERPOS()
				MOVETO($PLAYERPOS[0] + 1, $PLAYERPOS[1] + 1)
			ENDIF
		UNTIL(NOT GETNPCUNIQUEID("Master of Solitude") AND $HPMP[0] > 0) OR INSTANCEID() <> 172
		IF $I == 108 AND $STOPROOM == 108 THEN
			$COMPLETED = TRUE
		ENDIF
		$I += 1
		$INSTANCE = INSTANCEID()
	WEND
	IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
		SETSTATUS("Kicked out of tower or game crashed.")
		$ALLOCATED = 0
	ELSE
		IF $COMPLETED THEN
			SETSTATUS("Returning to home village with teleport stone...")
			WHILE INCOMBAT()
				SLEEP(1000)
			WEND
			IF GETGLOBALSETTING("AutoBankRepairSpotAlternate", TRUE) AND GETGLOBALSETTING("AutoBankRepairSpotAlternate2", TRUE) THEN
				$ID = 4502
				TELEPORTSTONETO($ID)
			ELSEIF GETGLOBALSETTING("AutoBankRepairSpotAlternate", TRUE) THEN
				$ID = 6001
				TELEPORTSTONETO($ID)
			ELSEIF GETGLOBALSETTING("AutoBankRepairSpotAlternate2", TRUE) THEN
				$ID = 4502
				TELEPORTSTONETO($ID)
			ELSE
				$ID = 2103
				TELEPORTSTONETO($ID)
			ENDIF
			SETSTATUS("Finished.")
		ELSE
			SETSTATUS("Possibly finished. Double check.")
		ENDIF
	ENDIF
ENDFUNC
FUNC GOTOTOWER()
	CLOSENPCWINDOW()
	$CURRENTMAP = INITIALMAP()
	$POS = PLAYERPOS()
	$INSTANCE = INSTANCEID()
	IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
		IF $CURRENTMAP <> 121 THEN
			SETSTATUS("Transferring to Lothranis to fly towards Heavenfall.")
			TRANSFERMAP(121, 0, 341, -781, 500)
			DROPDOWN()
			SETSTATUS("Walking into Heavenfall entrance.")
			MOVETO(352, -797)
			SLEEP(5000)
		ENDIF
		IF $CURRENTMAP == 121 THEN
			IF $POS[2] > 550 THEN DROPDOWN()
			IF DISTANCE2D($POS[0], $POS[1]) < 8 AND $POS[2] > 429 THEN
				SETSTATUS("Walking into Heavenfall entrance.")
				MOVETO(352, -797)
			ELSE
				SETSTATUS("Flying towards Heavenfall entrance.")
				FLY(263.61, -782.05, 500, 0)
				FLYUP(500)
				FLY(341, -781, 500)
				SETSTATUS("Walking into Heavenfall entrance.")
				MOVETO(352, -797)
			ENDIF
		ENDIF
		IF $CURRENTMAP == 999 THEN
			SETSTATUS("Didn't enter Tower. Please move to supported map and try again.")
		ENDIF
	ENDIF
	SLEEP(7000)
	IF GETNPCUNIQUEID("Master of Solitude") THEN
		DO
			MOVETO(-382.14, 473.91)
		UNTIL DISTANCE2D(-382.14, 473.91) < 5
		SLEEP(250)
		DO
			JUMPMOVE(-382.07, 472.04)
		UNTIL DISTANCE2D(-382.07, 472.04) < 5
		SLEEP(250)
		DO
			MOVETO(-379.99, 410.62)
		UNTIL DISTANCE2D(-379.99, 410.62) < 5
		SLEEP(1000)
		TAKEQUEST("Master of Solitude", 40638)
		SLEEP(2000)
		CLOSENPCWINDOW()
	ENDIF
ENDFUNC
FUNC CURRENTROOMNUMBER()
	RETURN INSTANCEVALUE(200006)
	$CHAT = CHATARRAY()
	IF UBOUND($CHAT) == 0 THEN RETURN 0
	FOR $I = 0 TO 40
		IF $I >= UBOUND($CHAT) THEN
			RETURN 0
		ENDIF
		$IDX = UBOUND($CHAT) - 1 - $I
		IF STRINGINSTR($CHAT[$IDX][1], "Current Challenge: Floor #^00ffff") THEN
			$NUM = STRINGTRIMRIGHT(STRINGTRIMLEFT($CHAT[$IDX][1], STRINGINSTR($CHAT[$IDX][1], "ffff") + 3), 7)
			RETURN INT($NUM)
		ENDIF
	NEXT
ENDFUNC
FUNC SMARTSELECT($TARGET)
	WHILE $TARGET > 0 AND PLAYERTARGET() <> $TARGET AND NPCALIVE($TARGET, 0)
		BUFFEREDSELECT($TARGET)
		SLEEP(100)
	WEND
ENDFUNC
FUNC ACTIVATEROOM()
	$INSTANCE = INSTANCEID()
	$IDX = -1
	$TIMER = TIMERINIT()
	$TIMER2 = TIMERINIT()
	$POS = PLAYERPOS()
	WHILE $IDX == -1 AND TIMERDIFF($TIMER) < 60000
		IF TIMERDIFF($TIMER) > 60000 THEN
			SETSTATUS("ACTIVATEROOM DEBUG: TIMERDIFF = " & TIMERDIFF($TIMER))
			EXITLOOP
		ENDIF
		$ARRAY = NPCARRAY()
		FOR $I = 0 TO UBOUND($ARRAY) - 1
			IF $ARRAY[$I][1] >= 47593 AND $ARRAY[$I][1] <= 47646 THEN
				$IDX = $I
				EXITLOOP
			ENDIF
		NEXT
		SLEEP(100)
	WEND
	WHILE DISTANCE2D($ARRAY[$IDX][4], $ARRAY[$IDX][5]) > 2 AND INSTANCEID() <= 175 AND INSTANCEID() >= 172 AND TIMERDIFF($TIMER) < 60000
		IF AREWESTUCK($TIMER, $POS[0], $POS[1], 5000) THEN
			TOWERUNSTUCK()
			$TIMER2 = TIMERINIT()
			$POS = PLAYERPOS
		ENDIF
		IF TIMERDIFF($TIMER) > 60000 THEN
			SETSTATUS("ACTIVATEROOM DEBUG: TIMERDIFF = " & TIMERDIFF($TIMER))
			EXITLOOP
		ENDIF
		IF HASBUFF("", 44) THEN
			MOVETO2($ARRAY[$IDX][4], $ARRAY[$IDX][5])
		ELSE
			MOVETO($ARRAY[$IDX][4], $ARRAY[$IDX][5])
		ENDIF
		SUMMONPETWITHREVIVE(0)
		WAITSTOPMOVE(2)
	WEND
	IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
		SETSTATUS("Kicked out of tower.")
	ENDIF
ENDFUNC
$HHEALSPELLTIMER = TIMERINIT()
FUNC HEALUP()
	$HPMP = GETHPMP()
	$HPPERCENT = $HPMP[0] / $HPMP[1]
	$TIMESINCELAST = TIMERDIFF($HHEALSPELLTIMER)
	IF $HPPERCENT < 0.85 AND $TIMESINCELAST > 60500 THEN
		$HHEALSPELLTIMER = TIMERINIT()
		SENDTOWERBUFF(5)
	ELSEIF $HPPERCENT < 0.4 AND SKILLOFFCOOLDOWN(1006, 1) AND GENIEENERGY() > 115 THEN
		CASTSKILL(1006, 1)
	ELSEIF $HPPERCENT < 0.4 AND CHI() > 300 AND ISMELEECLASS() THEN
		TRIPLESPARK()
	ELSEIF $HPPERCENT < 0.2 THEN
		SENDTOWERBUFF(4)
	ENDIF
	RETURN $HPPERCENT > 0.75
ENDFUNC
#Region Tower of Fate Room Handlers
	GLOBAL $ROOMHANDLERS = OBJCREATE("Scripting.Dictionary")
	$ROOMHANDLERS.add(33747, "HandleEnergy")
	$ROOMHANDLERS.add(33746, "HandlePortal")
	$ROOMHANDLERS.add(33733, "HandleCalamity")
	$ROOMHANDLERS.add(33727, "HandleProtector")
	$ROOMHANDLERS.add(33726, "HandleElements")
	$ROOMHANDLERS.add(33723, "HandleMonk")
	$ROOMHANDLERS.add(33722, "HandleBeliever")
	$ROOMHANDLERS.add(33759, "HandlePilgrim")
	$ROOMHANDLERS.add(33795, "HandleMatreya")
	$ROOMHANDLERS.add(33814, "HandleBodhi")
	$ROOMHANDLERS.add(33841, "HandleMaraPapman")
	$ROOMHANDLERS.add(33792, "HandleZenJi")
	$ROOMHANDLERS.add(33805, "HandleKings")
	$ROOMHANDLERS.add(33804, "HandleHighSageEsher")
#EndRegion Tower of Fate Room Handlers
FUNC ALLOCATEPOINTS($POINTS)
	DIM $RESULT[6] = [0, 0, 0, 0, 0, 0]
	$POINTS = MIN(($POINTS - MOD($POINTS, 100)) / 100, 120)
	IF $POINTS <= 40 THEN
		$RESULT[0] = INT($POINTS / 2)
		$RESULT[4] = $POINTS - $RESULT[0]
	ELSE
		$RESULT[0] = 20
		$RESULT[1] = INT(($POINTS - 40) / 4)
		$RESULT[2] = INT(($POINTS - $RESULT[1] - 40) / 3)
		$RESULT[3] = INT(($POINTS - $RESULT[1] - $RESULT[2] - 40) / 2)
		$RESULT[4] = 20
		$RESULT[5] = $POINTS - $RESULT[1] - $RESULT[2] - $RESULT[3] - 40
	ENDIF
	RETURN $RESULT
ENDFUNC
FUNC SCANTOWERBUFFS()
	$ALLOCATED = 0
	DIM $BUFFIDS[6] = [298, 299, 300, 301, 313, 314]
	DIM $RESULT[6] = [0, 0, 0, 0, 0, 0]
	$ARRAY = BUFFARRAY()
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		FOR $J = 0 TO 5
			IF $ARRAY[$I][0] == $BUFFIDS[$J] THEN
				$RESULT[$J] = $ARRAY[$I][2]
				$ALLOCATED += $ARRAY[$I][2] * 100
			ENDIF
		NEXT
	NEXT
	RETURN $RESULT
ENDFUNC
GLOBAL $ALLOCATED = 0
FUNC HANDLEBUFFS($MAXBUFF = 20)
	$INSTANCE = INSTANCEID()
	$POINTS = TOWERPOINTS()
	$OLDALLOC = SCANTOWERBUFFS()
	$WASTED = $POINTS[0] - $POINTS[1] - $ALLOCATED
	IF($ALLOCATED < 12000 AND $WASTED > 150) OR($ALLOCATED > 500 AND $POINTS[1] < 20) THEN
		RESETBUFFS()
		$POINTS[1] = $POINTS[0]
		DIM $OLDALLOC[6] = [0, 0, 0, 0, 0, 0]
	ENDIF
	DIM $BUFFS[6] = [0, 1, 2, 3, 8, 9]
	IF($POINTS[1] - 50 < 100) THEN
		RETURN
	ENDIF
	$NEWALLOC = ALLOCATEPOINTS(MAX($POINTS[1] - 50 + $ALLOCATED, $ALLOCATED))
	FOR $I = 1 TO 20
		$STOP = TRUE
		FOR $J = 0 TO 5
			SLEEP(185)
			IF $NEWALLOC[$J] > $OLDALLOC[$J] AND $OLDALLOC[$J] < $MAXBUFF THEN
				$OLDALLOC[$J] = $OLDALLOC[$J] + 1
				IF $NEWALLOC[$J] > $OLDALLOC[$J] THEN $STOP = FALSE
				SENDTOWERBUFF($BUFFS[$J])
				$ALLOCATED = $ALLOCATED + 100
			ENDIF
			IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
				SETSTATUS("Kicked out of tower.")
				RETURN
			ENDIF
		NEXT
		IF $STOP THEN EXITLOOP
	NEXT
	SLEEP(100)
	IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
		SETSTATUS("Kicked out of tower.")
	ENDIF
ENDFUNC
FUNC RESETBUFFS()
	$ALLOCATED = 0
	RESETTOWERBUFFS()
	SLEEP(100)
ENDFUNC
FUNC AREWESTUCK($TIMER, $POSX, $POSY, $CHECK_TIME = 10000, $STUCKDISTANCE = 0.5)
	PRINT("timerdiff($timer)) = " & TIMERDIFF($TIMER))
	$STUCK = FALSE
	IF(TIMERDIFF($TIMER) > $CHECK_TIME) THEN
		$DIST = DISTANCE2D($POSX, $POSY)
		IF CURRENTSKILL() == 0 AND QUEUEDSKILL() == 0 AND $DIST < $STUCKDISTANCE AND NOT INCOMBAT() THEN
			$STUCK = TRUE
		ENDIF
	ENDIF
	RETURN $STUCK
ENDFUNC
FUNC AREWESTUCK2($TIMER, $POSX, $POSY, $CHECK_TIME = 10000, $STUCKDISTANCE = 0.5)
	IF(TIMERDIFF($TIMER) > $CHECK_TIME) THEN
		$DIST = DISTANCE2D($POSX, $POSY)
		$TARGET = PLAYERTARGET()
		IF $TARGET AND NOT CURRENTSKILL() AND $DIST < $STUCKDISTANCE THEN
			RETURN TRUE
		ENDIF
	ELSE
		RETURN FALSE
	ENDIF
ENDFUNC
FUNC AREWESTUCK3($TIMER, $POSX, $POSY, $CHECK_TIME = 10000, $STUCKDISTANCE = 0.5)
	IF(TIMERDIFF($TIMER) > $CHECK_TIME) THEN
		$DIST = DISTANCE2D($POSX, $POSY)
		IF CURRENTSKILL() == 0 AND QUEUEDSKILL() == 0 AND(NOT INCOMBAT() OR NOT PLAYERTARGET()) AND $DIST < $STUCKDISTANCE THEN
			RETURN TRUE
		ENDIF
	ELSE
		RETURN FALSE
	ENDIF
ENDFUNC
FUNC TOWERUNSTUCK($DISTANCE_TO_MOVE = 2)
	IF INSTANCEID() > 175 OR INSTANCEID() < 172 THEN RETURN
	IF CURRENTSKILL() THEN RETURN
	SETSTATUS("Tower: getting unstuck")
	$POS_START = PLAYERPOS()
	IF ACTIONFLAG() THEN
		CANCELACTION()
		SLEEP(1000)
	ELSE
		SLEEP(100)
	ENDIF
	MOVETO2($POS_START[0] + 2 * RANDOM($DISTANCE_TO_MOVE) - $DISTANCE_TO_MOVE, $POS_START[1] + 2 * RANDOM($DISTANCE_TO_MOVE) - $DISTANCE_TO_MOVE)
	SLEEP(100)
ENDFUNC
FUNC HANDLEROOM()
	ACTIVATEROOM()
	$CONTINUE = TRUE
	$TIMER = TIMERINIT()
	WHILE $CONTINUE
		IF TIMERDIFF($TIMER) > 60000 THEN
			SETSTATUS("DEBUG: HANDLEROOM TIMERDIFF IS " & TIMERDIFF($TIMER) & " exiting loop.")
			EXITLOOP
		ENDIF
		$QUESTS = QUESTARRAY()
		FOR $I = 0 TO UBOUND($QUESTS) - 1
			IF $ROOMHANDLERS.exists($QUESTS[$I][0]) THEN
				CALL($ROOMHANDLERS.item($QUESTS[$I][0]))
				$CONTINUE = FALSE
				EXITLOOP
			ENDIF
		NEXT
		SLEEP(100)
	WEND
ENDFUNC
FUNC DOENERGYMOB($MOBNAME, $SPAWNNAME)
	$ENERGYPOS = GETNPCPOSITION("Energy Orb")
	$TARGET = ""
	$NOTARGETCOUNT = 0
	$TIMER30S = TIMERINIT()
	$TIMER = TIMERINIT()
	$POS = PLAYERPOS()
	$FLOORHEIGHT = $POS[2]
	STARTLISTENING()
	$CURRENTROOM = CURRENTROOMNUMBER()
	$TARGET = GETNPCUNIQUEID($MOBNAME, 100, $ENERGYPOS)
	$USEDHOLYPATH = FALSE
	$MOVEDTOTARGET = FALSE
	$TRIPLESPARKCOUNT = 0
	$TRIPLESPARKTIMER = TIMERINIT()
	WHILE NOT GETNPCUNIQUEID($SPAWNNAME) AND NOT GETNPCUNIQUEID("Dead " & $SPAWNNAME) AND GETNPCUNIQUEID("Energy Orb")
		IF TIMERDIFF($TIMER) > 35000 THEN EXITLOOP
		BUFFCHECK(TRUE)
		$INSTANCE = INSTANCEID()
		IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
			EXITLOOP
		ENDIF
		IF GETNPCUNIQUEID("Master of Solitude") THEN EXITLOOP
		IF PLAYERTARGET() <> $TARGET THEN
			BUFFEREDSELECT($TARGET)
			$NOTARGETCOUNT = $NOTARGETCOUNT + 1
		ENDIF
		IF SEETEXT("Target is too close") THEN
			TOWERUNSTUCK(1.5)
		ENDIF
		IF $MOBNAME == "Wraithtouched Dragon" AND CLASS() <> 6 THEN
			IF NOT $MOVEDTOTARGET THEN
				FOR $I = 1 TO 2
					MOVETONPC($TARGET, FALSE, 0, 0.5, 0, TRUE, 10000)
				NEXT
				$MOVEDTOTARGET = TRUE
			ENDIF
			IF(CHI() > 300 AND CURRENTROOMNUMBER() > 72 AND $TRIPLESPARKCOUNT == 0) OR(TIMERDIFF($TRIPLESPARKTIMER) > 12000) THEN
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
				$TRIPLESPARKCOUNT += 1
				$TRIPLESPARKTIMER = TIMERINIT()
			ENDIF
		ENDIF
		IF $MOBNAME == "Timid Imp" THEN
			IF NOT $MOVEDTOTARGET THEN
				FOR $I = 1 TO 2
					MOVETONPC($TARGET, FALSE, 0, 0.5, 0, TRUE, 10000)
				NEXT
				$MOVEDTOTARGET = TRUE
			ENDIF
			IF(CHI() > 300 AND CURRENTROOMNUMBER() > 72 AND $TRIPLESPARKCOUNT == 0) OR(TIMERDIFF($TRIPLESPARKTIMER) > 12000) THEN
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
				$TRIPLESPARKCOUNT += 1
				$TRIPLESPARKTIMER = TIMERINIT()
			ENDIF
		ENDIF
		MONKEYTELEPORTSKILL()
		KILLUID($TARGET, 0)
		SLEEP(100)
		IF $NOTARGETCOUNT == 10 THEN
			$TARGET = GETNPCUNIQUEID($MOBNAME, 100, $ENERGYPOS)
			$NOTARGETCOUNT = 0
		ENDIF
		IF $MOBNAME <> "Wraithtouched Dragon" AND SEETEXT("^EC0D3CBring", -1, FALSE) THEN RETURN
	WEND
	$TARGET = GETNPCUNIQUEID($SPAWNNAME)
	BUFFEREDSELECT($TARGET)
	WHILE NPCALIVE($SPAWNNAME) AND NOT SEETEXT("^EC0D3CBring", -1, FALSE) AND TIMERDIFF($TIMER) < 45000
		$TARGETPOS = GETNPCPOSITION($SPAWNNAME)
		IF UBOUND($TARGETPOS) THEN
			IF DISTANCE2D($TARGETPOS[0], $TARGETPOS[1]) > 25 AND $USEDHOLYPATH == FALSE THEN
				SpeedPATH()
				$USEDHOLYPATH = TRUE
			ENDIF
		ENDIF
		FOR $I = 1 TO 2
			$TARGETPOS = GETNPCPOSITION($SPAWNNAME)
			IF UBOUND($TARGETPOS) THEN
				$DIST = DISTANCEBETWEEN3D($ENERGYPOS, $TARGETPOS)
				MOVETO($TARGETPOS[0] + ($TARGETPOS[0] - $ENERGYPOS[0]) / $DIST, $TARGETPOS[1] + ($TARGETPOS[1] - $ENERGYPOS[1]) / $DIST)
				WAITSTOP(1, 50)
			ENDIF
		NEXT
		IF SEETEXT("^EC0D3CBring", -1, FALSE) THEN RETURN
		SMARTSELECT($TARGET)
		USEITEMID(47812, 1)
	WEND
	DESELECTTARGET()
ENDFUNC
FUNC HEIGHTCHECK($FLOORHEIGHT, $HEIGHT_DIFFERENCE = 0.27)
	$POS = PLAYERPOS()
	IF $POS[2] > $FLOORHEIGHT + $HEIGHT_DIFFERENCE THEN
		SETSTATUS("Moved to possibly get unstuck from air")
		MOVETO2($POS[0] + 1, $POS[1] + 1)
	ENDIF
ENDFUNC
FUNC HANDLEENERGY()
	STARTLISTENING()
	$ROOMNUMBER = CURRENTROOMNUMBER()
	$HPMP = GETHPMP()
	$TIMER = TIMERINIT()
	$GLITCHTIMER = TIMERINIT()
	$POS = PLAYERPOS()
	$FLOORHEIGHT = $POS[2]
	SLEEP(1000)
	$MAXBUFF = 20
	IF ISWEAKCHARACTER() THEN
		IF $ROOMNUMBER <= 27 THEN
			RESETBUFFS()
			SLEEP(1000)
		ENDIF
		IF $ROOMNUMBER >= 0 AND $ROOMNUMBER <= 9 THEN
			$MAXBUFF = 4
		ELSEIF $ROOMNUMBER > 9 AND $ROOMNUMBER <= 18 THEN
			$MAXBUFF = 8
		ELSEIF $ROOMNUMBER > 18 AND $ROOMNUMBER <= 27 THEN
			$MAXBUFF = 12
		ELSEIF $ROOMNUMBER > 27 AND $ROOMNUMBER <= 36 THEN
			$MAXBUFF = 16
		ELSE
			$MAXBUFF = 20
		ENDIF
		IF CLASS() == 3 THEN
			SUMMONVENOPET()
		ENDIF
		HANDLEBUFFS($MAXBUFF)
	ELSEIF ISSTRONGCHARACTER() THEN
		IF $ROOMNUMBER <= 63 THEN
			RESETBUFFS()
			SLEEP(1000)
		ENDIF
		IF CLASS() == 3 OR CLASS() == 4 THEN
			HANDLEFORMCHANGE()
			SLEEP(500)
		ENDIF
		SLEEP(500)
		SWAPGEAR(1)
		SLEEP(1000)
		IF $ROOMNUMBER >= 0 AND $ROOMNUMBER <= 36 THEN
			$MAXBUFF = 0
		ELSEIF $ROOMNUMBER > 36 AND $ROOMNUMBER <= 45 THEN
			SWAPGEAR(0)
			$MAXBUFF = 5
		ELSEIF $ROOMNUMBER > 45 AND $ROOMNUMBER <= 54 THEN
			SWAPGEAR(0)
			$MAXBUFF = 10
		ELSEIF $ROOMNUMBER > 54 AND $ROOMNUMBER <= 63 THEN
			SWAPGEAR(0)
			$MAXBUFF = 15
		ELSE
			SWAPGEAR(0)
			$MAXBUFF = 20
		ENDIF
		IF CLASS() == 3 THEN
			SUMMONVENOPET()
		ENDIF
		HANDLEBUFFS($MAXBUFF)
	ELSE
		IF $ROOMNUMBER <= 45 THEN
			RESETBUFFS()
			SLEEP(1000)
		ENDIF
		IF $ROOMNUMBER >= 0 AND $ROOMNUMBER <= 9 THEN
			$MAXBUFF = 0
		ELSEIF $ROOMNUMBER > 9 AND $ROOMNUMBER <= 18 THEN
			$MAXBUFF = 3
		ELSEIF $ROOMNUMBER > 18 AND $ROOMNUMBER <= 27 THEN
			$MAXBUFF = 6
		ELSEIF $ROOMNUMBER > 27 AND $ROOMNUMBER <= 36 THEN
			$MAXBUFF = 9
		ELSEIF $ROOMNUMBER > 36 AND $ROOMNUMBER <= 45 THEN
			$MAXBUFF = 12
		ELSEIF $ROOMNUMBER > 45 AND $ROOMNUMBER <= 54 THEN
			$MAXBUFF = 16
		ELSE
			$MAXBUFF = 20
		ENDIF
		IF CLASS() == 3 THEN
			SUMMONVENOPET()
		ENDIF
		HANDLEBUFFS($MAXBUFF)
	ENDIF
	SETSTATUS("Heavenfall Tower - Room #" & CURRENTROOMNUMBER() & ": Energy, max buffs = " & $MAXBUFF)
	$BUILDCHITIMER = TIMERINIT()
	WHILE HASQUEST(33747) AND TIMERDIFF($GLITCHTIMER) < 720000
		$PLAYERTARGET = PLAYERTARGET()
		IF $PLAYERTARGET AND TARGETNAME() == "Wraithtouched Dragon" THEN
			IMMUNEAPOTH()
			SMARTHOLYPATH()
			KILL($PLAYERTARGET, 100, 2, 0)
		ENDIF
		IF NOT $PLAYERTARGET AND NOT ACTIONFLAG() AND TIMERDIFF($BUILDCHITIMER) > 10000 THEN
			IF USEMACRO7CHI() THEN BUILDCHI(2000, 399)
		ENDIF
		IF GETNPCUNIQUEID("Master of Solitude") THEN EXITLOOP
		BUFFCHECK(TRUE)
		$INSTANCE = INSTANCEID()
		IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
			SETSTATUS("Kicked out of tower.")
			EXITLOOP
		ENDIF
		IF $ROOMNUMBER > 72 AND USEGENIECHI() THEN GENIECHISKILL()
		HEIGHTCHECK($FLOORHEIGHT)
		IF SEETEXT("^EC0D3CBring Imp Gut to the") THEN
			DOENERGYMOB("Timid Imp", "Imp Gut")
		ELSEIF SEETEXT("^EC0D3CBring Dragon Essence to the") THEN
			DOENERGYMOB("Wraithtouched Dragon", "Dragon Essence")
		ELSEIF SEETEXT("^EC0D3CBring Ginseng Fruit to the") THEN
			DOENERGYMOB("Ginseng Tree", "Ginseng Fruit")
		ENDIF
		HEALUP()
		SLEEP(100)
	WEND
	IF $ROOMNUMBER < 36 THEN
		RESETBUFFS()
		SLEEP(100)
	ENDIF
	IF ISSTRONGCHARACTER() THEN
		SWITCHTOHUMANFORM()
		SLEEP(500)
		SWAPGEAR(0)
	ENDIF
ENDFUNC
FUNC ISPORTALMOB($ARRAY, $I)
	RETURN $ARRAY[$I][1] >= 47721 AND $ARRAY[$I][1] <= 47735
ENDFUNC
FUNC HANDLEPORTAL()
	SETSTATUS("Heavenfall Tower - Room #" & CURRENTROOMNUMBER() & ": Portal")
	DIM $MOBS[10] = ["Copperking", "Dryad Overmind", "Crazed Master", "Blazing Beetle Queen", "Celestial Rhinodrake Matriarch", "Blighted Dryad", "Crazed Student", "Copperman", "Celestial Rhinodrake", "Blazing Beetle"]
	$ROOMNUMBER = CURRENTROOMNUMBER()
	$TARGET = 0
	$CENTER = 0
	$HPMP = GETHPMP()
	$ISMELEE = ISMELEECLASS() OR ISSTRONGCHARACTER()
	$KILL10 = KILLPORTALMOBS10ATATIME()
	STARTLISTENING()
	$STUCKPOS = PLAYERPOS()
	DO
		$CENTER = GETNPCPOSITION("Portal")
	UNTIL UBOUND($CENTER)
	$SHOULDKILL = $ISMELEE
	$TIMER = TIMERINIT()
	$GLITCHTIMER = TIMERINIT()
	$POS = PLAYERPOS()
	$FLOORHEIGHT = $POS[2]
	$GATHEREDMOBSTOGETHER = FALSE
	$FIGHTACTIVATED = FALSE
	$TRIPLESPARKTIMER = TIMERINIT()
	$TRIPLESPARKCOUNT = 0
	$POS = PLAYERPOS()
	$POS2 = PLAYERPOS()
	$POS3 = PLAYERPOS()
	WHILE HASQUEST(33746) AND TIMERDIFF($GLITCHTIMER) < 900000
		IF(CLASS() == 7 AND INHUMANFORM()) THEN
			SWITCHTOSECONDFORM(TRUE)
			SLEEP(500)
		ENDIF
		$PLAYERTARGET = PLAYERTARGET()
		IF NOT $PLAYERTARGET AND NOT ACTIONFLAG() AND NOT INCOMBAT() THEN
			IF USEMACRO7CHI() THEN BUILDCHI(2000, 399)
			SLEEP(100)
		ENDIF
		IF GETNPCUNIQUEID("Master of Solitude") THEN EXITLOOP
		$INSTANCE = INSTANCEID()
		IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
			SETSTATUS("Kicked out of tower.")
			EXITLOOP
		ENDIF
		HEIGHTCHECK($FLOORHEIGHT)
		HEALUP()
		IF HASBUFF("Poison Taking Wood damage over time", 13) THEN USEITEMID(2040, 1)
		$PAUSE = FALSE
		$ARRAY = NPCARRAY()
		IF USEGENIECHI() THEN GENIECHISKILL(350)
		IF CURRENTROOMNUMBER() < 36 AND NOT ISWEAKCHARACTER() THEN
			$SHOULDKILL = (UBOUND($ARRAY) > 50)
		ELSEIF CURRENTROOMNUMBER() < 54 AND NOT ISWEAKCHARACTER() THEN
			$SHOULDKILL = (UBOUND($ARRAY) > 20)
		ELSEIF CURRENTROOMNUMBER() > 54 AND KILLPORTALMOBS10ATATIME() THEN
			$SHOULDKILL = TRUE
		ENDIF
		IF INSTANCEVALUE(100769) == 10 THEN $SHOULDKILL = TRUE
		$ALLPATHSAFE = TRUE
		$DESTPOS = 0
		FOR $I = 0 TO UBOUND($ARRAY) - 1
			IF $ARRAY[$I][1] >= 47736 AND $ARRAY[$I][1] <= 47745 AND STRINGLEFT($ARRAY[$I][2], 6) == "NoName" THEN
				DIM $DESTPOS[2] = [$ARRAY[$I][4], $ARRAY[$I][5]]
				EXITLOOP
			ENDIF
		NEXT
		$MINDIST = 99999
		$MINIDX = -1
		FOR $I = 0 TO UBOUND($ARRAY) - 1
			IF $ARRAY[$I][1] >= 47721 AND $ARRAY[$I][1] <= 47735 THEN
				$CURRDIST = DISTANCEBETWEEN($POS[0], $POS[1], $ARRAY[$I][4], $ARRAY[$I][5])
				IF $CURRDIST < $MINDIST THEN
					$MINIDX = $I
					$MINDIST = $CURRDIST
				ENDIF
				IF UBOUND($DESTPOS) THEN
					DIM $MOBPOS[2] = [$ARRAY[$I][4], $ARRAY[$I][5]]
					$ALLPATHSAFE = $ALLPATHSAFE AND CHECKPATHSAFE($MOBPOS, 18, $DESTPOS)
				ENDIF
			ENDIF
		NEXT
		$TARGET = 0
		DIM $TARGETPOS[2] = [0, 0]
		IF $MINIDX > -1 THEN
			$TARGET = $ARRAY[$MINIDX][0]
			$TARGETPOS[0] = $ARRAY[$MINIDX][4]
			$TARGETPOS[1] = $ARRAY[$MINIDX][5]
			$PAUSE = TRUE
		ENDIF
		$IGNOREMOBS = NOT(CURRENTROOMNUMBER() > 36 OR ISWEAKCHARACTER() OR UBOUND($DESTPOS) == 0)
		PRINT("PortalHere: " & $DESTPOS & "  " & $SHOULDKILL & " " & $IGNOREMOBS)
		IF NOT $SHOULDKILL THEN
			IF UBOUND($DESTPOS) AND($ALLPATHSAFE OR $IGNOREMOBS OR ISSTRONGCHARACTER()) THEN
				MOVETO($DESTPOS[0], $DESTPOS[1])
				WAITSTOPMOVE(3)
			ELSEIF $TARGET AND NOT $IGNOREMOBS AND NOT ISSTRONGCHARACTER() THEN
				CIRCLEAVOID($TARGET, 26, 33, $CENTER[0], $CENTER[1], 43, 0, 0, FALSE)
				WAITSTOPMOVE(1)
			ENDIF
		ELSEIF $TARGET AND NOT $ISMELEE AND $MINDIST < 22 AND NOT $IGNOREMOBS AND NOT ISSTRONGCHARACTER() AND INSTANCEVALUE(100768) < 98 AND NOT KILLPORTALMOBS10ATATIME() THEN
			IF CURRENTSKILL() == 0 OR $MINDIST < 10 THEN
				WHILE CIRCLEAVOID("FUNC:IsPortalMob", 30, 38, $CENTER[0], $CENTER[1], 43, 1, 0, FALSE)
					WAITSTOPMOVE(1)
				WEND
			ENDIF
		ELSEIF $TARGET OR $PAUSE AND UBOUND($DESTPOS) == 0 AND NOT $GATHEREDMOBSTOGETHER AND CURRENTROOMNUMBER() > 36 AND NOT $ISMELEE AND NOT ISSTRONGCHARACTER() AND NOT KILLPORTALMOBS10ATATIME() THEN
			$GATHERTIMER = TIMERINIT()
			WHILE TIMERDIFF($GATHERTIMER) < 30000
				CIRCLEAVOID($TARGET, 26, 33, $CENTER[0], $CENTER[1], 43, 0, 0, FALSE)
				WAITSTOPMOVE(1)
			WEND
			$GATHEREDMOBSTOGETHER = TRUE
		ELSEIF $TARGET OR $PAUSE THEN
			IF $TARGET THEN
				$MINDIST = 99999
				$MINIDX = -1
				FOR $I = 0 TO UBOUND($ARRAY) - 1
					IF $ARRAY[$I][1] >= 47721 AND $ARRAY[$I][1] <= 47735 THEN
						$CURRDIST = DISTANCEBETWEEN($POS[0], $POS[1], $ARRAY[$I][4], $ARRAY[$I][5])
						IF $CURRDIST < $MINDIST THEN
							$MINIDX = $I
							$MINDIST = $CURRDIST
						ENDIF
						IF UBOUND($DESTPOS) THEN
							DIM $MOBPOS[2] = [$ARRAY[$I][4], $ARRAY[$I][5]]
							$ALLPATHSAFE = $ALLPATHSAFE AND CHECKPATHSAFE($MOBPOS, 18, $DESTPOS)
						ENDIF
					ENDIF
				NEXT
				$TARGET = 0
				DIM $TARGETPOS[2] = [0, 0]
				IF $MINIDX > -1 THEN
					$TARGET = $ARRAY[$MINIDX][0]
					$TARGETPOS[0] = $ARRAY[$MINIDX][4]
					$TARGETPOS[1] = $ARRAY[$MINIDX][5]
					$PAUSE = TRUE
				ENDIF
				SMARTSELECT($TARGET)
				IF($TRIPLESPARKCOUNT == 0 OR TIMERDIFF($TRIPLESPARKTIMER) > 7000) AND(UBOUND($ARRAY) > 3) THEN
					IF CHI() > 300 THEN
						CANCELACTION()
						WHILE CHI() > 300
							TRIPLESPARK()
							SLEEP(50)
						WEND
						$TRIPLESPARKCOUNT += 1
						$TRIPLESPARKTIMER = TIMERINIT()
					ENDIF
				ENDIF
				BUFFCHECK(TRUE)
				IF(UBOUND($ARRAY) >= 5) THEN $SKILLID = AOE()
				IF(UBOUND($ARRAY) < 5) THEN $SKILLID = EXECUTEMACRO(0)
				IF SEETEXT("Target is too close") THEN
					TOWERUNSTUCK(2)
					$TIMER = TIMERINIT()
					$STUCKPOS = PLAYERPOS()
				ENDIF
				IF TIMERDIFF($TIMER) > 60000 THEN
					IF AREWESTUCK($TIMER, $POS[0], $POS[1], 60000) THEN
						TOWERUNSTUCK(2)
					ENDIF
					$TIMER = TIMERINIT()
					$POS = PLAYERPOS()
				ENDIF
				WHILE $SKILLID > 0 AND SKILLOFFCOOLDOWN($SKILLID) AND PLAYERTARGET() == $TARGET
					CASTSKILL($SKILLID)
					SLEEP(100)
					IF SEETEXT("Target is too close") THEN
						TOWERUNSTUCK(2)
						$TIMER = TIMERINIT()
						$STUCKPOS = PLAYERPOS()
					ENDIF
					IF TIMERDIFF($TIMER) > 60000 THEN
						IF AREWESTUCK($TIMER, $POS2[0], $POS2[1], 60000) THEN
							TOWERUNSTUCK(2)
						ENDIF
						$TIMER = TIMERINIT()
						$POS2 = PLAYERPOS()
					ENDIF
				WEND
				IF $SKILLID == 0 THEN
					IF SEETEXT("Target is too close") THEN
						TOWERUNSTUCK(2)
						$TIMER = TIMERINIT()
						$STUCKPOS = PLAYERPOS()
					ENDIF
					IF TIMERDIFF($TIMER) > 60000 THEN
						IF AREWESTUCK($TIMER, $POS3[0], $POS3[1], 60000) THEN
							TOWERUNSTUCK(2)
						ENDIF
						$TIMER = TIMERINIT()
						$POS3 = PLAYERPOS()
					ENDIF
					IF UBOUND($ARRAY) > 5 AND NOT ISMELEECLASS() AND CURRENTROOMNUMBER() > 54 AND NOT KILLPORTALMOBS10ATATIME() THEN CIRCLEAVOID("FUNC:IsPortalMob", 25, 28, $CENTER[0], $CENTER[1], 35, 1, 0, FALSE)
					WAITSTOP(1)
				ENDIF
			ENDIF
		ELSEIF UBOUND($DESTPOS) AND($ROOMNUMBER < 90 OR(HEALUP() AND ISWEAKCHARACTER() AND GENIEENERGY() > 90) OR ISSTRONGCHARACTER() OR(HEALUP() AND GENIEENERGY() > 90)) THEN
			MOVETO($DESTPOS[0], $DESTPOS[1])
			WAITSTOP(1)
		ENDIF
	WEND
ENDFUNC
FUNC HANDLEPROTECTOR()
	SETSTATUS("Heavenfall Tower - Room #" & CURRENTROOMNUMBER() & ": Protector")
	$ROOMNUMBER = CURRENTROOMNUMBER()
	$CHARGECOUNT = 0
	$USEDCOUNT = 0
	$CURPOS = 0
	$ISMELEE = ISMELEECLASS() AND CLASS() <> 8
	$CANCAST = TRUE
	$TIMER = TIMERINIT()
	$POS = PLAYERPOS()
	$FLOORHEIGHT = $POS[2]
	$GLITCHTIMER = TIMERINIT()
	STARTLISTENING()
	$TRIPLESPARKCOUNT = 0
	$FIGHTTIMER = 0
	$FIGHTACTIVATED = FALSE
	$TRIPLESPARKTIMER = 0
	$MOVECHECKTIMER = 0
	$MOVECHECKACTIVATED = FALSE
	$PLAYERCLASS = CLASS()
	$MOVED = FALSE
	$ONETIMEPAUSEOF4SECONDS = TRUE
	WHILE NOT GETNPCUNIQUEID("Celestial Bead")
		SLEEP(100)
	WEND
	DIM $PROTECTORNPCS[10][2] = [[47800, 2], [47799, 2], [47787, 3], [47789, 3], [47792, 3], [47793, 3], [47795, 3], [47797, 3], [47786, 3], [47783, 3]]
	IF CLASS() == 3 THEN SUMMONPETWITHREVIVE()
	WHILE HASQUEST(33727) AND TIMERDIFF($GLITCHTIMER) < 450000
		HEALUP()
		$CHARGECOUNT = INSTANCEVALUE(100787)
		$PLAYERTARGET = PLAYERTARGET()
		IF GETNPCUNIQUEID("Master of Solitude") THEN EXITLOOP
		$INSTANCE = INSTANCEID()
		BUFFCHECK(TRUE)
		IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
			SETSTATUS("Kicked out of tower.")
			EXITLOOP
		ENDIF
		HEIGHTCHECK($FLOORHEIGHT)
		$ARRAY = NPCARRAY()
		$BOSSPOS = GETNPCPOSITION("Tainted Guardian Equidus")
		$MOBTENPOS = GETNPCPOSITION("Earthen Rager")
		$ANDOPOS = GETNPCPOSITION(47799, 1)
		IF CHI() < 399 AND NOT GETNPCUNIQUEID("Tainted Guardian Equidus") AND USEGENIECHI() THEN GENIECHISKILL()
		IF GETNPCUNIQUEID("Tainted Guardian Equidus") THEN
			IF $ONETIMEPAUSEOF4SECONDS == TRUE THEN
				SLEEP(4000)
				$ONETIMEPAUSEOF4SECONDS = FALSE
			ENDIF
			IF NOT $MOVED THEN
				SpeedPATH()
				MOVETO($ANDOPOS[0] + 15, $ANDOPOS[1] - 10)
				$MOVED = TRUE
				WAITSTOPMOVE()
			ENDIF
			IF $FIGHTACTIVATED == FALSE THEN
				$FIGHTTIMER = TIMERINIT()
				$FIGHTACTIVATED = TRUE
			ENDIF
			IF $MOVECHECKACTIVATED == FALSE THEN
				$MOVECHECKTIMER = TIMERINIT()
				$MOVECHECKACTIVATED = TRUE
			ENDIF
			IF TIMERDIFF($FIGHTTIMER) < 25000 AND CHI() > 300 AND $TRIPLESPARKCOUNT == 0 THEN
				CANCELACTION()
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
				$TRIPLESPARKCOUNT += 1
				$TRIPLESPARKTIMER = TIMERINIT()
			ENDIF
			IF $CANCAST AND UBOUND($BOSSPOS) AND UBOUND($ANDOPOS) AND DISTANCEBETWEEN3D($BOSSPOS, $ANDOPOS) < 20 AND $ISMELEE THEN
				$CANCAST = FALSE
				SENDTOWERBUFF(7)
				SLEEP(100)
			ENDIF
			IF TIMERDIFF($FIGHTTIMER) < 20000 THEN
				$BOSSPOS1 = GETNPCPOSITION("Tainted Guardian Equidus")
				MONKEYTELEPORTSKILL(3)
				IF CLASS() == 14 OR CLASS() == 3 THEN
					KILL("Tainted Guardian Equidus", 200, 2, 0)
				ELSE
					KILL("Tainted Guardian Equidus", 200, 2, 3)
				ENDIF
			ELSE
				IF CHI() > 300 AND TIMERDIFF($TRIPLESPARKTIMER) > 7000 AND NPCALIVE("Tainted Guardian Equidus") THEN
					CANCELACTION()
					WHILE CHI() > 300
						TRIPLESPARK()
						SLEEP(50)
					WEND
					$TRIPLESPARKTIMER = TIMERINIT()
				ENDIF
				$BOSSPOS1 = GETNPCPOSITION("Tainted Guardian Equidus")
				$MYPOS = PLAYERPOS()
				IF UBOUND($BOSSPOS1) AND CLASS() <> 14 THEN
					IF $ISMELEE AND TIMERDIFF($MOVECHECKTIMER) > 2000 THEN
						IF DISTANCE2D($BOSSPOS1[0], $BOSSPOS1[1]) > 3 AND DISTANCE2D($BOSSPOS1[0], $BOSSPOS1[1]) <= 10 THEN
							SpeedPATH()
							SETSTATUS("Moving closer to boss.")
							MOVEANDOVERSHOOTTARGET($BOSSPOS1[0], $BOSSPOS1[1], 1.2)
							WAITTOFINISH()
							$MOVECHECKTIMER = TIMERINIT()
						ELSE
							IF GENIEENERGY() > 75 THEN
								SMARTHOLYPATH()
								MOVETO2($BOSSPOS1[0], $BOSSPOS1[1])
							ELSE
								MOVETO($BOSSPOS1[0], $BOSSPOS1[1])
							ENDIF
							WAITSTOP(1)
						ENDIF
					ELSEIF CLASS() == 3 AND NOT INHUMANFORM() AND DISTANCE2D($BOSSPOS1[0], $BOSSPOS1[1]) > 8 THEN
						IF GENIEENERGY() > 75 THEN
							SMARTHOLYPATH()
							MOVETO2($BOSSPOS1[0], $BOSSPOS1[1])
						ELSE
							MOVETO($BOSSPOS1[0], $BOSSPOS1[1])
						ENDIF
						WAITSTOP(1)
					ELSEIF DISTANCE2D($BOSSPOS1[0], $BOSSPOS1[1]) > 24 THEN
						IF GENIEENERGY() > 75 THEN
							SMARTHOLYPATH()
							MOVETO2($BOSSPOS1[0], $BOSSPOS1[1])
						ELSE
							MOVETO($BOSSPOS1[0], $BOSSPOS1[1])
						ENDIF
						WAITSTOP(1)
					ENDIF
					IF NPCALIVE("Tainted Guardian Equidus") THEN KILL("Tainted Guardian Equidus", 200, 2, 3)
				ELSE
					MONKEYTELEPORTSKILL(2)
					IF NPCALIVE("Tainted Guardian Equidus") THEN KILL("Tainted Guardian Equidus", 200, 2, 3)
				ENDIF
			ENDIF
			SLEEP(100)
			CONTINUELOOP
		ELSEIF UBOUND($MOBTENPOS) AND UBOUND($ANDOPOS) AND DISTANCEBETWEEN3D($MOBTENPOS, $ANDOPOS) < 10 THEN
			IF DISTANCE2D($ANDOPOS[0] + 15, $ANDOPOS[1] - 10) > 5 THEN
				IF DISTANCE2D($ANDOPOS[0] + 15, $ANDOPOS[1] - 10) > 60 THEN SpeedPATH()
				MOVETO($ANDOPOS[0] + 15, $ANDOPOS[1] - 10)
				$MOVED = TRUE
				WAITSTOPMOVE()
			ENDIF
		ENDIF
		$IDX = FINDCLOSEST($ARRAY, "Celestial Bead")
		$CHARGECOUNT = INSTANCEVALUE(100787)
		IF $CURPOS < UBOUND($PROTECTORNPCS) AND $CHARGECOUNT >= $PROTECTORNPCS[$CURPOS][1] AND NOT $MOVED AND NOT HASBUFF("Intuition Increased magic attack", 46) AND NOT HASBUFF("Sharpen Increased physical attack", 32) THEN
			$CHARGECOUNT = INSTANCEVALUE(100787)
			$IDX = FINDCLOSEST($ARRAY, $PROTECTORNPCS[$CURPOS][0], 1)
			IF $IDX > -1 THEN
				SMARTSELECT($ARRAY[$IDX][0])
				$LOCALTIMER = TIMERINIT()
				DO
					IF TIMERDIFF($LOCALTIMER) > 5000 THEN EXITLOOP
					SLEEP(350)
					USEITEMID(47813, 1)
					SLEEP(350)
				UNTIL INSTANCEVALUE(100787) + 1 == $CHARGECOUNT
				$USEDCOUNT += 1
				$PROTECTORNPCS[$CURPOS][1] -= 1
				IF $PROTECTORNPCS[$CURPOS][1] == 0 THEN $CURPOS += 1
			ENDIF
		ELSE
			IF NOT GETNPCUNIQUEID("Celestial Bead") AND NOT GETNPCUNIQUEID("Tainted Guardian Equidus") THEN DESELECTTARGET()
			IF NOT $PLAYERTARGET AND NOT ACTIONFLAG() AND CHI() < 399 THEN
				IF USEMACRO7CHI() THEN BUILDCHI(2000, 399)
				SLEEP(100)
			ENDIF
			IF $MOVED == FALSE AND $FIGHTACTIVATED == FALSE THEN
				IF $IDX > -1 AND $ARRAY[$IDX][8] > 0 THEN
					$CHARGECOUNT = FLOOR(30 * ($ARRAY[$IDX][8] - $ARRAY[$IDX][7]) / $ARRAY[$IDX][8])
				ENDIF
				$TARGET = GETNPCUNIQUEID("Celestial Bead")
				SMARTSELECT($TARGET)
				IF TIMERDIFF($GLITCHTIMER) < 240000 AND CHI() > 300 AND NPCALIVE("Celestial Bead") THEN
					WHILE CHI() > 300
						TRIPLESPARK()
						SLEEP(50)
					WEND
				ENDIF
				IF CLASS() == 14 THEN
					KILL("Celestial Bead", 200, 2, 1)
				ELSE
					KILL("Celestial Bead", 200, 2, 0)
				ENDIF
				IF SEETEXT("Target is too close") THEN
					TOWERUNSTUCK(2)
					$TIMER = TIMERINIT()
					$POS = PLAYERPOS()
				ENDIF
				IF TIMERDIFF($TIMER) > 30000 THEN
					IF AREWESTUCK($TIMER, $POS[0], $POS[1]) AND TARGETNAME() == "Celestial Bead" THEN
						TOWERUNSTUCK(2)
					ENDIF
					$TIMER = TIMERINIT()
					$POS = PLAYERPOS()
				ENDIF
			ENDIF
		ENDIF
		SLEEP(100)
	WEND
ENDFUNC
FUNC HANDLEPILGRIM()
	SETSTATUS("Heavenfall Tower - Room #" & CURRENTROOMNUMBER() & ": Pilgrim")
	$ROOMNUMBER = CURRENTROOMNUMBER()
	$TIMER = TIMERINIT()
	$GLITCHTIMER = TIMERINIT()
	STARTLISTENING()
	$POS = PLAYERPOS()
	$FLOORHEIGHT = $POS[2]
	WHILE HASQUEST(33759) AND TIMERDIFF($GLITCHTIMER) < 200000
		$PLAYERTARGET = PLAYERTARGET()
		IF NOT $PLAYERTARGET AND NOT ACTIONFLAG() THEN
			IF USEMACRO7CHI() THEN BUILDCHI(2000, 399)
			SLEEP(100)
		ENDIF
		IF GETNPCUNIQUEID("Master of Solitude") THEN EXITLOOP
		$INSTANCE = INSTANCEID()
		BUFFCHECK(TRUE)
		IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
			SETSTATUS("Kicked out of tower.")
			EXITLOOP
		ENDIF
		HEIGHTCHECK($FLOORHEIGHT)
		HEALUP()
		IF CURRENTROOMNUMBER() > 90 AND CHI() > 300 THEN
			WHILE CHI() > 300
				TRIPLESPARK()
				SLEEP(50)
			WEND
		ENDIF
		$TARGET = GETNPCUNIQUEID("Celestial Guardian")
		MONKEYTELEPORTSKILL()
		KILLNAME("Celestial Guardian", 0)
		HEALUP()
		IF SEETEXT("Target is too close") THEN
			TOWERUNSTUCK(2)
			$TIMER = TIMERINIT()
			$POS = PLAYERPOS()
		ENDIF
		IF TIMERDIFF($TIMER) > 10000 THEN
			IF AREWESTUCK($TIMER, $POS[0], $POS[1]) THEN
				HEALUP()
				TOWERUNSTUCK(2)
			ENDIF
			$TIMER = TIMERINIT()
			$POS = PLAYERPOS()
		ENDIF
		$CENTER = GETNPCPOSITION("Sage Pilgrim")
		IF UBOUND($CENTER) THEN
			HEALUP()
			CIRCLEAVOID("Celestial Nullifier", 7, 12, $CENTER[0], $CENTER[1], 30)
		ELSE
			SLEEP(100)
		ENDIF
	WEND
ENDFUNC
FUNC HANDLEBELIEVER()
	SETSTATUS("Heavenfall Tower - Room #" & CURRENTROOMNUMBER() & ": Believer")
	DIM $MOBS[4] = ["Vicious Monk", "Vile Monk", "Malicious Monk", "Servant of Mara Papman"]
	$POS2 = PLAYERPOS()
	$POS = PLAYERPOS()
	$FLOORHEIGHT = $POS[2]
	$TIMER = TIMERINIT()
	$GLITCHTIMER = TIMERINIT()
	$ROOMNUMBER = CURRENTROOMNUMBER()
	$TRIPLESPARKCOUNT = 0
	$TRIPLESPARKTIMER = TIMERINIT()
	$FIGHTACTIVATED = FALSE
	$CURRENTROOMNUMBER = CURRENTROOMNUMBER()
	STARTLISTENING()
	WHILE HASQUEST(33722) AND TIMERDIFF($GLITCHTIMER) < 480000
		$PLAYERTARGET = PLAYERTARGET()
		IF NOT $PLAYERTARGET AND NOT ACTIONFLAG() THEN
			IF USEMACRO7CHI() THEN BUILDCHI(2000, 399)
			SLEEP(100)
		ENDIF
		IF GETNPCUNIQUEID("Master of Solitude") THEN EXITLOOP
		$INSTANCE = INSTANCEID()
		BUFFCHECK(TRUE)
		IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
			SETSTATUS("Kicked out of tower.")
			EXITLOOP
		ENDIF
		HEIGHTCHECK($FLOORHEIGHT)
		HEALUP()
		IF $ROOMNUMBER > 72 AND USEGENIECHI() THEN GENIECHISKILL()
		$ARRAY = NPCARRAY()
		$IDX = CLOSESTNPCINLISTTOPOINT($ARRAY, $MOBS, $POS[0], $POS[1])
		IF $IDX == -1 THEN CONTINUELOOP
		$POS2[0] = $ARRAY[$IDX][4]
		$POS2[1] = $ARRAY[$IDX][5]
		IF CURRENTROOMNUMBER() > 54 AND $TRIPLESPARKCOUNT == 0 THEN
			CANCELACTION()
			WHILE CHI() > 300
				TRIPLESPARK()
				SLEEP(50)
			WEND
			$TRIPLESPARKCOUNT += 1
			IF $FIGHTACTIVATED == FALSE THEN
				$TRIPLESPARKTIMER = TIMERINIT()
				$FIGHTACTIVATED = TRUE
			ENDIF
		ENDIF
		IF CURRENTROOMNUMBER() > 54 AND TIMERDIFF($TRIPLESPARKTIMER) > 7000 THEN
			CANCELACTION()
			WHILE CHI() > 300
				TRIPLESPARK()
				SLEEP(50)
			WEND
			$TRIPLESPARKTIMER = TIMERINIT()
		ENDIF
		PRINT("Targeting " & $ARRAY[$IDX][2])
		SMARTSELECT($ARRAY[$IDX][0])
		$TARGET = $ARRAY[$IDX][0]
		KILLUID($ARRAY[$IDX][0], 0)
		IF SEETEXT("Target is too close") THEN
			TOWERUNSTUCK(2)
			$TIMER = TIMERINIT()
			$POS = PLAYERPOS()
		ENDIF
		IF TIMERDIFF($TIMER) > 10000 THEN
			IF AREWESTUCK($TIMER, $POS[0], $POS[1]) THEN
				TOWERUNSTUCK(2)
			ENDIF
			$TIMER = TIMERINIT()
			$POS = PLAYERPOS()
		ENDIF
		SLEEP(100)
	WEND
ENDFUNC
FUNC HANDLECALAMITY()
	SETSTATUS("Heavenfall Tower - Room #" & CURRENTROOMNUMBER() & ": Calamity")
	$HTIMER = TIMERINIT()
	$TIMER = TIMERINIT()
	$GLITCHTIMER = TIMERINIT()
	$ROOMNUMBER = CURRENTROOMNUMBER()
	STARTLISTENING()
	$POS = PLAYERPOS()
	$FLOORHEIGHT = $POS[2]
	$PLAYERCLASS = CLASS()
	$TRIPLESPARKCOUNT = 0
	$TRIPLESPARKTIMER = TIMERINIT()
	$FIGHTACTIVATED = FALSE
	WHILE HASQUEST(33733) AND TIMERDIFF($GLITCHTIMER) < 600000
		$PLAYERTARGET = PLAYERTARGET()
		IF NOT $PLAYERTARGET AND NOT ACTIONFLAG() THEN
			IF USEMACRO7CHI() THEN BUILDCHI(2000, 399)
			SLEEP(100)
		ENDIF
		IF GETNPCUNIQUEID("Master of Solitude") THEN EXITLOOP
		$INSTANCE = INSTANCEID()
		BUFFCHECK(TRUE)
		IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
			SETSTATUS("Kicked out of tower.")
			EXITLOOP
		ENDIF
		HEIGHTCHECK($FLOORHEIGHT)
		$TIME = TIMERDIFF($HTIMER)
		HEALUP()
		IF USEGENIECHI() THEN GENIECHISKILL()
		$ARRAY = NPCARRAY()
		$IDX = FINDCLOSEST($ARRAY, "Sage Mahamayuri")
		IF $IDX <> -1 AND $ARRAY[$IDX][7] < 1500000 AND $ARRAY[$IDX][8] > 0 THEN
			WHILE NPCDISTANCE("NoName 47751") > 3
				MOVETONPC("NoName 47751", FALSE, 2, 1)
				SLEEP(200)
				WAITSTOPMOVE()
			WEND
			WHILE $IDX <> -1 AND $ARRAY[$IDX][7] < 5500000
				SLEEP(1000)
				HEALUP()
				$ARRAY = NPCARRAY()
				$IDX = FINDCLOSEST($ARRAY, "Sage Mahamayuri")
			WEND
		ELSEIF MOD($TIME + 6000, 15000) > 14000 THEN
			MOVETONPC("NoName 47750", FALSE, 2, 1)
			IF CURRENTROOMNUMBER() > 54 THEN
				CANCELACTION()
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
			ENDIF
			IF ISMELEECLASS() THEN
				SLEEP(1400)
			ENDIF
		ELSE
			$TARGET = GETNPCUNIQUEID("Avatar of Calamity")
			MONKEYTELEPORTSKILL(5)
			KILL("Avatar of Calamity", 200, 2, 0)
			IF SEETEXT("Target is too close") THEN
				TOWERUNSTUCK(2)
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
			IF TIMERDIFF($TIMER) > 10000 THEN
				IF AREWESTUCK($TIMER, $POS[0], $POS[1], 20000) THEN
					TOWERUNSTUCK(2)
				ENDIF
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
		ENDIF
		SLEEP(100)
	WEND
ENDFUNC
FUNC HANDLEMONK()
	SETSTATUS("Heavenfall Tower - Room #" & CURRENTROOMNUMBER() & ": Monk")
	$ROOMNUMBER = CURRENTROOMNUMBER()
	$TIMER = TIMERINIT()
	$GLITCHTIMER = TIMERINIT()
	STARTLISTENING()
	$HOLYPATHTIMER = TIMERINIT()
	$POS = PLAYERPOS()
	$FLOORHEIGHT = $POS[2]
	$HOLYPATHUSES = 0
	$FIGHTACTIVATED = FALSE
	$TRIPLESPARKTIMER = 0
	$TRIPLESPARKCOUNT = 0
	$MACROTOUSE = 0
	IF CLASS() == 14 THEN $MACROTOUSE = 0
	IF $ROOMNUMBER > 72 AND CHI() > 300 THEN
		TRIPLESPARK()
		IF USEGENIECHI() THEN GENIECHISKILL()
	ENDIF
	WHILE HASQUEST(33723) AND TIMERDIFF($GLITCHTIMER) < 600000
		$PLAYERTARGET = PLAYERTARGET()
		IF NOT $PLAYERTARGET AND NOT ACTIONFLAG() AND NOT GETNPCUNIQUEID("Black Tortoise") AND NOT GETNPCUNIQUEID("White Tiger") AND NOT GETNPCUNIQUEID("Azure Dragon") AND NOT GETNPCUNIQUEID("Crimson Phoenix") THEN
			IF USEMACRO7CHI() THEN BUILDCHI(2000, 399)
			SLEEP(100)
		ENDIF
		IF GETNPCUNIQUEID("Master of Solitude") THEN EXITLOOP
		$INSTANCE = INSTANCEID()
		BUFFCHECK(TRUE)
		IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
			SETSTATUS("Kicked out of tower.")
			EXITLOOP
		ENDIF
		HEIGHTCHECK($FLOORHEIGHT)
		IF $ROOMNUMBER > 72 AND USEGENIECHI() THEN GENIECHISKILL()
		IF GETNPCUNIQUEID("Black Tortoise") THEN
			IF $ROOMNUMBER > 90 AND $HOLYPATHUSES == 0 THEN
				SpeedPATH()
				$HOLYPATHUSES += 1
				$HOLYPATHTIMER = TIMERINIT()
			ENDIF
			MONKEYTELEPORTSKILL(5)
			KILL("Black Tortoise", 200, 2, $MACROTOUSE)
		ELSEIF GETNPCUNIQUEID("White Tiger") THEN
			IF $ROOMNUMBER > 90 AND TIMERDIFF($HOLYPATHTIMER) > 7000 AND($HOLYPATHUSES == 0 OR $HOLYPATHUSES == 1) THEN
				SpeedPATH()
				$HOLYPATHUSES += 1
				$HOLYPATHTIMER = TIMERINIT()
			ENDIF
			MONKEYTELEPORTSKILL()
			KILL("White Tiger", 200, 2, $MACROTOUSE)
		ELSEIF GETNPCUNIQUEID("Azure Dragon") THEN
			IF $ROOMNUMBER > 90 AND TIMERDIFF($HOLYPATHTIMER) > 7000 AND($HOLYPATHUSES == 0 OR $HOLYPATHUSES == 1 OR $HOLYPATHUSES == 2) THEN
				SpeedPATH()
				$HOLYPATHTIMER = TIMERINIT()
			ENDIF
			MONKEYTELEPORTSKILL(5)
			KILL("Azure Dragon", 200, 2, $MACROTOUSE)
		ELSEIF GETNPCUNIQUEID("Crimson Phoenix") THEN
			MONKEYTELEPORTSKILL()
			KILL("Crimson Phoenix", 200, 2, $MACROTOUSE)
		ELSEIF CURRENTROOMNUMBER() > 54 AND $TRIPLESPARKCOUNT == 0 AND TIMERDIFF($GLITCHTIMER) > 22000 THEN
			CANCELACTION()
			WHILE CHI() > 300
				TRIPLESPARK()
				SLEEP(50)
			WEND
			$TRIPLESPARKCOUNT += 1
			IF $FIGHTACTIVATED == FALSE THEN
				$TRIPLESPARKTIMER = TIMERINIT()
				$FIGHTACTIVATED = TRUE
			ENDIF
		ELSEIF GETNPCUNIQUEID("Corrupted Monk") THEN
			HEALUP()
			IF CURRENTROOMNUMBER() > 54 AND TIMERDIFF($TRIPLESPARKTIMER) > 7000 THEN
				CANCELACTION()
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
				$TRIPLESPARKTIMER = TIMERINIT()
			ENDIF
			$TARGET = GETNPCUNIQUEID("Corrupted Monk")
			MONKEYTELEPORTSKILL(5)
			KILL("Corrupted Monk", 200, 2, 3)
			IF SEETEXT("Target is too close") THEN
				TOWERUNSTUCK(2)
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
			IF TIMERDIFF($TIMER) > 30000 THEN
				IF AREWESTUCK($TIMER, $POS[0], $POS[1]) THEN
					TOWERUNSTUCK(1.5)
				ENDIF
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
		ENDIF
		SLEEP(100)
	WEND
ENDFUNC
FUNC HANDLEELEMENTS()
	SETSTATUS("Heavenfall Tower - Room #" & CURRENTROOMNUMBER() & ": Elements")
	$ROOMNUMBER = CURRENTROOMNUMBER()
	$DAMAGETARGET = ""
	$TIMER = TIMERINIT()
	$GLITCHTIMER = TIMERINIT()
	STARTLISTENING()
	$POS = PLAYERPOS()
	$FLOORHEIGHT = $POS[2]
	$TRIPLESPARKCOUNT = 0
	$TRIPLESPARKTIMER = TIMERINIT()
	WHILE HASQUEST(33726) AND TIMERDIFF($GLITCHTIMER) < 300000
		$PLAYERTARGET = PLAYERTARGET()
		IF NOT $PLAYERTARGET AND NOT ACTIONFLAG() THEN
			IF USEMACRO7CHI() THEN BUILDCHI(2000, 399)
			SLEEP(100)
		ENDIF
		$ARRAY = NPCARRAY()
		IF GETNPCUNIQUEID("Master of Solitude") THEN EXITLOOP
		$INSTANCE = INSTANCEID()
		BUFFCHECK(TRUE)
		IF $INSTANCE > 175 OR $INSTANCE < 172 THEN
			SETSTATUS("Kicked out of tower.")
			EXITLOOP
		ENDIF
		HEIGHTCHECK($FLOORHEIGHT)
		IF SEETEXT("deal double damage to the Fire Totem") THEN
			$DAMAGETARGET = "Fire Dragon Totem"
		ELSEIF SEETEXT("deal double damage to the Earth Totem") THEN
			$DAMAGETARGET = "Earth Dragon Totem"
		ELSEIF SEETEXT("deal double damage to the Metal Totem") THEN
			$DAMAGETARGET = "Metal Dragon Totem"
		ELSEIF SEETEXT("deal double damage to the Water Totem") THEN
			$DAMAGETARGET = "Water Dragon Totem"
		ELSEIF SEETEXT("deal double damage to the Wood Totem") THEN
			$DAMAGETARGET = "Wood Dragon Totem"
		ENDIF
		IF $DAMAGETARGET THEN
			IF GETNPCUNIQUEID($DAMAGETARGET) == 0 THEN
				$DAMAGETARGET = ""
			ENDIF
		ENDIF
		IF $DAMAGETARGET == "" THEN
			IF GETNPCUNIQUEID("Fire Dragon Totem") THEN
				$DAMAGETARGET = "Fire Dragon Totem"
			ELSEIF GETNPCUNIQUEID("Earth Dragon Totem") THEN
				$DAMAGETARGET = "Earth Dragon Totem"
			ELSEIF GETNPCUNIQUEID("Metal Dragon Totem") THEN
				$DAMAGETARGET = "Metal Dragon Totem"
			ELSEIF GETNPCUNIQUEID("Water Dragon Totem") THEN
				$DAMAGETARGET = "Water Dragon Totem"
			ELSEIF GETNPCUNIQUEID("Wood Dragon Totem") THEN
				$DAMAGETARGET = "Wood Dragon Totem"
			ENDIF
		ENDIF
		HEALUP()
		IF $DAMAGETARGET THEN
			IF CURRENTROOMNUMBER() > 54 AND $TRIPLESPARKCOUNT == 0 AND CHI() > 300 THEN
				CANCELACTION()
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
				$TRIPLESPARKCOUNT += 1
				$TRIPLESPARKTIMER = TIMERINIT()
			ENDIF
			IF CURRENTROOMNUMBER() > 54 AND TIMERDIFF($TRIPLESPARKTIMER) > 7000 THEN
				CANCELACTION()
				WHILE CHI() > 300
					TRIPLESPARK()
					SLEEP(50)
				WEND
				$TRIPLESPARKTIMER = TIMERINIT()
			ENDIF
			MONKEYTELEPORTSKILL()
			IF CLASS() == 14 THEN
				KILL($DAMAGETARGET, 200, 2, 1)
			ELSE
				KILL($DAMAGETARGET, 200, 2, 0)
			ENDIF
			IF SEETEXT("Target is too close") THEN
				TOWERUNSTUCK(2)
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
			IF TIMERDIFF($TIMER) > 30000 THEN
				IF AREWESTUCK($TIMER, $POS[0], $POS[1]) THEN
					TOWERUNSTUCK(2)
				ENDIF
				$TIMER = TIMERINIT()
				$POS = PLAYERPOS()
			ENDIF
		ENDIF
		SLEEP(100)
	WEND
ENDFUNC
