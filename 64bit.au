		GLOBAL CONST $JOB_OBJECT_LIMIT_ACTIVE_PROCESS = 8
		GLOBAL CONST $JOB_OBJECT_LIMIT_AFFINITY = 16
		GLOBAL CONST $JOB_OBJECT_LIMIT_BREAKAWAY_OK = 2048
