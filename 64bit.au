FUNC VIPFLYEROPENER()
	SETSTATUS("opening vip flyer packs")
	FOR $I = 0 TO 23
		IF MOVEKEY() THEN
			SETSTATUS("cancelled. done.")
			EXITLOOP
		ENDIF
		IF ITEMCOUNT(36371) > 0 THEN
			TAKEQUEST("Assistant Wang Tsai", 27667)
			WHILE NOT HASQUEST(27667)
				SLEEP(200)
			WEND
			SLEEP(200)
			TURNINQUEST("Assistant Wang Tsai", 27722)
			TURNINQUESTFAKENPC(27722, 2)
		ELSE
			SETSTATUS("done")
			EXITLOOP
		ENDIF
	NEXT
	SETSTATUS("done")
ENDFUNC
