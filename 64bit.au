FUNC MARKTUROQUESTFINISHED($QUEST)
	FOR $I = 0 TO UBOUND($TURO_NPCS) - 1
		IF $TURO_NPCS[$I][1] == $QUEST THEN
			$TURO_NPCS[$I][5] = 1
		ENDIF
	NEXT
ENDFUNC
FUNC WRITEDAYTOFILE()
	$DAY = GETWEEKDAY()
	INIWRITE("settings.ini", "DATES", "weekday", $DAY)
ENDFUNC
FUNC READDAYFROMFILE()
	$CURRENTDAY = GETWEEKDAY()
	$DAY = INIREAD("settings.ini", "DATES", "weekday", $CURRENTDAY)
ENDFUNC
FUNC CHECKIFTUROQUESTSAREFINISHED()
	FOR $I = 0 TO UBOUND($TURO_NPCS) - 1
		SETSTATUS($TURO_NPCS[$I][1] & " = " & $TURO_NPCS[$I][5])
	NEXT
	FOR $I = 0 TO UBOUND($TURO_NPCS) - 1
		IF $TURO_NPCS[$I][5] == 0 THEN
			RETURN FALSE
		ENDIF
	NEXT
	RETURN TRUE
ENDFUNC
FUNC USEMESSAGEHOOK()
	ADVENTUREKINGDOMMAP()
	IF NOT GETNPCUNIQUEID("Magician Zoshan") THEN FLYUP()
	TAKEQUEST("Magician Zoshan", 39010, -526.67, -45.54, 17)
	WHILE HASQUEST(39010)
		SLEEP(1000)
	WEND
	IF ITEMCOUNT(56641) OR ITEMCOUNT(56642) THEN
		FLY(RANDOM(-752.99, -721.59), RANDOM(282.07, 296.23), 17)
	ELSE
		RETURN
	ENDIF
	SETSTATUS("Using Message Hook")
	WHILE ITEMCOUNT(56641) > 0
		DOFISHING(56641, 1)
		SLEEP(7000)
	WEND
	SETSTATUS("Using Message Bottle")
	WHILE ITEMCOUNT(56642) > 0
		DOBOTTLE()
		SLEEP(3000)
	WEND
	FLYUP()
	TAKEQUEST("Teleporter Kooh", 39235, -794.63, 227.42)
	WAITFORNPC("Teleporter Yeon")
	SETSTATUS("Finished.")
ENDFUNC
