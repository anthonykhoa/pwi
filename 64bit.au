FUNC RUNGAUNTLET()
	IF TIGERBUFFVALUE() < 2 THEN
		MOVE2(-362.37, -367.61)
		MOVESTRAIGHT(-346.88, -374.04)
		JUMPUPMOVE(-329.21, -374.39, 12, 1, TRUE)
		MOVEMOSTLYSTRAIGHT(-314.96, -372.79)
		GRABTIGERBUFF(2)
	ENDIF
	IF TIGERBUFFVALUE() < 3 THEN
		MOVE2(-296.56, -367.89)
		MOVEMOSTLYSTRAIGHT(-287.4, -361.08)
		JUMPUPMOVE(-274.33, -370.31, 12)
		JUMPUPMOVE(-264.21, -360.36, 8)
		JUMPUPMOVE(-252.49, -366.64, 8)
		MOVEMOSTLYSTRAIGHT(-246.13, -361.68)
		GRABTIGERBUFF(3)
	ENDIF
	IF TIGERBUFFVALUE() < 4 THEN
		MOVEMOSTLYSTRAIGHT(-239.18, -360.21)
		MOVEMOSTLYSTRAIGHT(-227.34, -347.46)
		MOVEMOSTLYSTRAIGHT(-223.11, -340.35)
