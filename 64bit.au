		$PACKET &= HEX($FACTIONID, 8)
		$PACKETSIZE = 26
		SENDPACKET($PACKET, $PACKETSIZE, $GAME_PID)
	ENDFUNC
	FUNC SENDEMOTE($ID)
		IF NOT INHUMANFORM() THEN
			SWITCHTOHUMANFORM()
			SLEEP(300)
		ENDIF
		$PACKET = "4500" & HEX($ID, 2)
		SENDPACKET($PACKET, 3, $GAME_PID)
