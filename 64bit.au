		ENDFUNC
		FUNC _WINAPI_LOADCURSOR($HINSTANCE, $SNAME)
			LOCAL $STYPEOFNAME = "int"
			IF ISSTRING($SNAME) THEN
				$STYPEOFNAME = "wstr"
			ENDIF
			LOCAL $ACALL = DLLCALL("user32.dll", "handle", "LoadCursorW", "handle", $HINSTANCE, $STYPEOFNAME, $SNAME)
