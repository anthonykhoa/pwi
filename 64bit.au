Func CleanDHItems()
	$INV = INVARRAY(0, FALSE)
	$AVATAR = INVARRAY(2, FALSE)
	$GLYPH = INVARRAY(5, FALSE)
	PUMPCPACKS($BAG_AVATAR, $INV, $AVATAR)
	PUMPGLYPHBAG($BAG_GLYPH, $INV, $GLYPH)
EndFunc

FUNC PUMPGLYPHBAG($BAGNUM, BYREF $INV, BYREF $BAG)
	LOCAL $GLYPHS[5] = [52175, 52185, 52195, 52205, 52215]
	FOR $I = 0 TO UBOUND($INV) - 1
		FOR $G = 0 TO UBOUND($GLYPHS) - 1
			$GLYPHID =  $GLYPHS[$G]
			IF $INV[$I][1] == $GLYPHID THEN
				$INDEX2 = SEARCHITEMID($BAG, $GLYPHID, 0)
				IF $INDEX2 <> -1 THEN
					FOR $J = 0 TO UBOUND($BAG) - 1
						IF $INV[$I][1] == $BAG[$J][1] THEN
							MOVEITEMFROMINVENTORYWITHCOUNT($BAGNUM, $INV[$I][0], $BAG[$J][0], $INV[$I][3])
							$TMPINV = Invarray(0, FALSE)
							$INDEX = SEARCHITEMID($TMPINV, $GLYPHID, 0)
							If $INDEX == -1 Then ExitLoop
							SLEEP(50)
						ENDIF
					NEXT
				ELSE
					FOR $J = UBOUND($BAG)-1 To 0 Step -1
