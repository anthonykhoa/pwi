	$MobName = "Illusion Lord: Tortoise" ;; next boss
	MASSNUKEBOSSTTR($MobName,True, True, False, False, 400, True, True, True)
	$MobName = "Illusion Lord Armageddon" ;; next boss
	MASSNUKEBOSSTTR($MobName,True, True, False, False, 400, True, True, True)
	
	TargetSpecificMobKillStop("Illusion Lord Hoard", 7)
	IF GETGLOBALSETTING("UsePickupAll") THEN
    		MASSPICKUPALL()
  	ELSE
    		MASSGATHERALL()
	ENDIF
	
	TTR4_1_HELP_MASS()

	FULLBUFF()
	MYSTICAOEREVIVE($CLIENTSINDEXES)
	VENOSWITCHTOFOXFORM()
	MYSTICCHIPLANT($CLIENTSINDEXES)
	ClientsMoveAndWait(-400.83, -174.52, $CLIENTSINDEXES, 197)
