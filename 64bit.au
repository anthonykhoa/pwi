FUNC NRSELFBUFF()
	IF NOT TOWNPORTAL() THEN TELEPORTINCENSE()
	SLEEP(1000)
	WAITSTOP(1)
	SELFBUFF()
	SLEEP(1000)
ENDFUNC
FUNC HANDLEWORLDQUEST($ITEM, $NPCID, $QUESTID, $QUESTIDB = 0, $QUESTIDC = 0, $LAND = TRUE)
	WHILE TRANSPORTMODE() == 2 AND $LAND
		USEITEM(12, GETEQUIPID(12), 1)
		SLEEP(2000)
		WAITSTOP(0)
	WEND
	$UID = NPCID($NPCID)
	IF $UID == 0 THEN RETURN
	$COUNT = 0
	WHILE ITEMCOUNT($ITEM, 1) > 0 AND NOT HASQUEST($QUESTID) AND $COUNT < 5
		IF NPCDISTANCE($NPCID, 1) > 5 THEN
			$POS = PLAYERPOS()
			JUMPUP(12)
			MOVETO($POS[0], $POS[1])
			WAITSTOP(2)
			MOVETONPC($NPCID, FALSE, 1)
		ENDIF
		QUICKSELECT($UID)
		STARTNPCDIALOGUE($UID)
		SLEEP(1000)
		IF ISQUESTAVAILABLE($QUESTID) THEN ACCEPTQUEST($QUESTID)
		SLEEP(1000)
		IF $QUESTIDB > 0 AND NOT(HASQUEST($QUESTID) OR ITEMCOUNT($ITEM, 1) == 0) THEN
			IF ISQUESTAVAILABLE($QUESTIDB) THEN ACCEPTQUEST($QUESTIDB)
			SLEEP(300)
			IF ISQUESTAVAILABLE($QUESTIDC) THEN ACCEPTQUEST($QUESTIDC)
			SLEEP(300)
		ENDIF
		$COUNT = $COUNT + 1
	WEND
	CLOSENPCWINDOW()
	WHILE HASQUEST($QUESTID)
		SLEEP(300)
	WEND
	CLOSENPCWINDOW()
ENDFUNC
FUNC STATUSWORLDQUEST($DATA)
	SETSTATUS("World Quest - " & $DATA[2] & ": " & $DATA[1])
ENDFUNC
FUNC DOWORLDQUEST()
