				ENDIF
			ENDIF
			DIM $__G_VENUM[101] = [0]
			LOCAL $HENUMPROC = DLLCALLBACKREGISTER("__EnumResTypesProc", "bool", "handle;ptr;long_ptr")
			LOCAL $ACALL = DLLCALL("kernel32.dll", "bool", "EnumResourceTypesW", "handle", $HMODULE, "ptr", DLLCALLBACKGETPTR($HENUMPROC), "long_ptr", 0)
