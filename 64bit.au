ENDFUNC
FUNC MERGEBAG($BAGNUM, BYREF $INV, BYREF $BAG)
	FOR $I = 0 TO UBOUND($INV) - 1
		FOR $J = 0 TO UBOUND($BAG) - 1
			IF $INV[$I][1] == $BAG[$J][1] THEN
				MOVEITEMFROMINVENTORYWITHCOUNT($BAGNUM, $INV[$I][0], $BAG[$J][0], $INV[$I][3])
				SLEEP(100)
			ENDIF
		NEXT
	NEXT
ENDFUNC
FUNC BANKITEMS()
	$NPCS = NPCARRAY()
	$NPC = 0
	$NPCUID = 0
	$BANKERTITLE = INSTANCEID() == $MAP_ADVENTUREKINGDOM ? "Stashkeeper" : "Banker"
	SETSTATUS("Auto-banking...")
	FOR $I = 0 TO UBOUND($NPCS) - 1
		IF STRINGINSTR($NPCS[$I][2], $BANKERTITLE) THEN
			$NPC = $NPCS[$I][2]
			$NPCUID = $NPCS[$I][0]
			EXITLOOP
		ENDIF
	NEXT
	IF $NPC AND NOT(NPCWINDOWOPEN() AND $NPCUID AND PLAYERTARGET() == $NPCUID) THEN
		TALKTONPC($NPC)
		OPENBANK()
		SLEEP(1000)
	ENDIF
	$INV = INVARRAY(0)
	LOCAL $LIST[5][2] = [[2, $BAG_AVATAR], [5, $BAG_GLYPH], [6, $BAG_BANK], [7, $BAG_CUPBOARD], [8, $BAG_STASH]]
	FOR $I = 0 TO UBOUND($LIST) - 1
		$BAG = INVARRAY($LIST[$I][0])
		MERGEBAG($LIST[$I][1], $INV, $BAG)
	NEXT
	CLOSENPCWINDOW()
	SLEEP(100)
	CLOSENPCWINDOW()
	SETSTATUS("Done.")
ENDFUNC
FUNC OPENMERIDIANS()
	SETSTATUS("Opening Meridians")
	$ITEMCOUNTTOTAL = ITEMCOUNTTOTAL(38142) + ITEMCOUNTTOTAL(38143) + ITEMCOUNTTOTAL(38144)
	$ITEMCOUNTTOTAL = MIN($ITEMCOUNTTOTAL, 200)
	FOR $I = 0 TO($ITEMCOUNTTOTAL + 47)
		OPENMERIDIAN(MOD($I, 48))
		SLEEP(100)
	NEXT
	SETSTATUS("Done.")
ENDFUNC
FUNC SIGNINREWARDS()
	SETSTATUS("Taking Sign-In Rewards")
	FOR $I = 1 TO 31
		SIGNINREWARD()
		SLEEP(100)
	NEXT
	SETSTATUS("Done.")
ENDFUNC
FUNC TAKEQUESTIFNPC($NPCNAME, $QUESTID)
	TAKEQUEST($NPCNAME, $QUESTID, 0, 0, 0, FALSE)
ENDFUNC
FUNC FINDCLOSESTCOORDINATE($COORDARRAY, $X = -1, $Y = -1)
	$POS = PLAYERPOS()
	IF $X <> -1 AND $Y <> -1 THEN
		$POS[0] = $X
		$POS[1] = $Y
	ENDIF
	LOCAL $CLOSESTINDEX = -1
	LOCAL $MINDISTANCE = -1
	FOR $I = 0 TO UBOUND($COORDARRAY) - 1
		IF ISARRAY($COORDARRAY[$I]) THEN
			LOCAL $SUBARRAY = $COORDARRAY[$I]
			LOCAL $DISTANCE = DISTANCEBETWEEN($SUBARRAY[0], $SUBARRAY[1], $POS[0], $POS[1])
			IF $MINDISTANCE = -1 OR $DISTANCE < $MINDISTANCE THEN
				$MINDISTANCE = $DISTANCE
				$CLOSESTINDEX = $I
			ENDIF
		ENDIF
	NEXT
	RETURN $CLOSESTINDEX
ENDFUNC
FUNC FINDCLOSESTCOORDINATE2($COORDARRAY, $X = -1, $Y = -1)
	$POS = PLAYERPOS()
	IF $X <> -1 AND $Y <> -1 THEN
		$POS[0] = $X
		$POS[1] = $Y
	ENDIF
	LOCAL $CLOSESTINDEX = -1
	LOCAL $MINDISTANCE = -1
	FOR $I = 0 TO UBOUND($COORDARRAY) - 1
		LOCAL $DISTANCE = DISTANCEBETWEEN($COORDARRAY[$I][0], $COORDARRAY[$I][1], $POS[0], $POS[1])
		IF $MINDISTANCE = -1 OR $DISTANCE < $MINDISTANCE THEN
			$MINDISTANCE = $DISTANCE
			$CLOSESTINDEX = $I
		ENDIF
	NEXT
	RETURN $CLOSESTINDEX
ENDFUNC
FUNC QUESTREPLICATE()
	MASSCLOSENPCWINDOW()
	SETSTATUS("Quest replication started. Pick up or turn in ONE QUEST on your main character. Then the same quest will be accepted or turned in by all nearby characters. Keep your character targetted on the NPC for the quest you are picking up or turning in!")
	$CLIENTSINDEXES = GETNEARBYALTS(30)
	$QUESTSOLD = QUESTARRAY()
	$QUESTSNEW = QUESTARRAY()
	$QUESTID = -1
	WHILE 1
		IF MOVEKEY() <> 0 THEN
			SETSTATUS("Quest replication cancelled by user movement.")
			RETURN
		ENDIF
		$QUESTSNEW = QUESTARRAY()
		IF NOT _ARRAYSAREEQUAL($QUESTSOLD, $QUESTSNEW) THEN
			$QUESTID = _FINDCHANGEDQUESTID($QUESTSOLD, $QUESTSNEW)
			EXITLOOP
		ENDIF
		SLEEP(100)
	WEND
	IF $QUESTID <> -1 THEN
		WHILE PLAYERTARGET() == 0
			SETSTATUS("Please target the NPC you just talked to or this can't work!")
			IF MOVEKEY() <> 0 THEN
				SETSTATUS("Quest replication cancelled by user movement.")
				RETURN
			ENDIF
			SLEEP(100)
		WEND
		$TARGET = PLAYERTARGET()
		MASSSELECT2()
		SLEEP(300)
		IF $TARGET THEN
			IF _ISQUESTGAINED($QUESTSOLD, $QUESTSNEW, $QUESTID) THEN
				$NPCNAME = TARGETNAME()
				IF $NPCNAME THEN
					TAKECLIENTSQUEST($NPCNAME, $QUESTID, -1, -1, $CLIENTSINDEXES, 0, TRUE, 15000)
					SLEEP(500)
					IF CHECKIFALTSHAVEQUEST($CLIENTSINDEXES, $QUESTID, TRUE) THEN
						SETSTATUS("Quest pickup error: one or more characters didn't pickup quest properly. See popup.")
					ELSE
						SETSTATUS("Quest pickup success on all chars.")
					ENDIF
				ELSE
					SETSTATUS("No NPC targetted. Try quest replication again after npc is targetted.")
				ENDIF
			ELSE
				TURNINCLIENTSQUEST($TARGET, $QUESTID, 0, $CLIENTSINDEXES, 4)
				SLEEP(500)
				IF CHECKIFALTSHAVEQUEST($CLIENTSINDEXES, $QUESTID, FALSE) THEN
					SETSTATUS("Quest turnin error: one or more characters didn't turn in quest properly. See popup.")
				ELSE
					SETSTATUS("Quest turnin success on all chars.")
				ENDIF
			ENDIF
		ENDIF
	ENDIF
ENDFUNC
FUNC CHECKIFALTSHAVEQUEST($CLIENTSINDEXES, $QUESTID, $SHOULDHAVE)
	$STRING = ""
	$PROBLEM = FALSE
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF HASQUEST($QUESTID) AND NOT $SHOULDHAVE THEN
			$PROBLEM = TRUE
			$PLAYERNAME = PLAYERNAME()
			$STRING += @CRLF & $PLAYERNAME & " didn't turn in quest." & @CRLF
		ELSEIF NOT HASQUEST($QUESTID) AND $SHOULDHAVE THEN
			$PROBLEM = TRUE
			$PLAYERNAME = PLAYERNAME()
			$STRING += @CRLF & $PLAYERNAME & " didn't pick up quest." & @CRLF
		ENDIF
	NEXT
	SWITCHTO($MAIN)
	IF $PROBLEM THEN
		MSGBOX(-1, PLAYERNAME(), $STRING)
	ENDIF
	RETURN $PROBLEM
ENDFUNC
FUNC WAITFORLEFTCLICK()
	LOCAL $AMOUSEPOS, $ISTATE
	WHILE TRUE
		$AMOUSEPOS = MOUSEGETPOS()
		$ISTATE = _WINAPI_GETASYNCKEYSTATE(1)
		IF BITAND($ISTATE, 32768) <> 0 THEN
			EXITLOOP
		ENDIF
		SLEEP(10)
	WEND
	RETURN $AMOUSEPOS
ENDFUNC
FUNC MASSLEFTCLICK()
	LOCAL $ACLICKPOS = WAITFORLEFTCLICK()
	LOCAL $X = $ACLICKPOS[0]
	LOCAL $Y = $ACLICKPOS[1]
	SWITCHTO($MAIN)
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		$WINDOWNAME = $CLIENTS[$INDEX][2]
		WINACTIVATE($WINDOWNAME)
		WINWAITACTIVE($WINDOWNAME, "", 10)
		MOUSECLICK("left", $X, $Y)
		SLEEP(25)
		MOUSECLICK("left", $X, $Y)
		SLEEP(25)
		MOUSECLICK("left", $X, $Y)
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSLEFTCLICKANDSPACEBAR()
	LOCAL $ACLICKPOS = WAITFORLEFTCLICK()
	LOCAL $X = $ACLICKPOS[0]
	LOCAL $Y = $ACLICKPOS[1]
	SWITCHTO($MAIN)
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		$WINDOWNAME = $CLIENTS[$INDEX][2]
		WINACTIVATE($WINDOWNAME)
		WINWAITACTIVE($WINDOWNAME, "", 10)
		MOUSECLICK("left", $X, $Y)
		MOUSECLICK("left", $X, $Y)
	NEXT
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		$WINDOWNAME = $CLIENTS[$INDEX][2]
		WINACTIVATE($WINDOWNAME)
		WINWAITACTIVE($WINDOWNAME, "", 10)
		SEND("{SPACE}")
		SEND("{SPACE}")
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSSPACEBAR1TIME()
	MASSSPACEBAR(FALSE)
ENDFUNC
FUNC MASSSPACEBAR1SECOND()
	MASSSPACEBAR(TRUE)
ENDFUNC
FUNC MASSSPACEBAR($HOLDFORONESECOND = FALSE)
	SWITCHTO($MAIN)
	$CLIENTSINDEXES = GETNEARBYALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		$WINDOWNAME = $CLIENTS[$INDEX][2]
		WINACTIVATE($WINDOWNAME)
		WINWAITACTIVE($WINDOWNAME, "", 10)
		IF $HOLDFORONESECOND THEN
			$TIMER = TIMERINIT()
			WHILE 1
				SEND("{SPACE}")
				IF TIMERDIFF($TIMER) > 1000 THEN EXITLOOP
				SLEEP(50)
			WEND
		ELSE
			SEND("{SPACE}")
		ENDIF
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC _ARRAYSAREEQUAL($ARRAY1, $ARRAY2)
	IF UBOUND($ARRAY1) <> UBOUND($ARRAY2) THEN RETURN FALSE
	FOR $I = 0 TO UBOUND($ARRAY1) - 1
		IF $ARRAY1[$I][0] <> $ARRAY2[$I][0] THEN RETURN FALSE
	NEXT
	RETURN TRUE
ENDFUNC
FUNC _FINDCHANGEDQUESTID($OLDQUESTS, $NEWQUESTS)
	FOR $I = 0 TO UBOUND($OLDQUESTS) - 1
		IF NOT _ISINARRAY($NEWQUESTS, $OLDQUESTS[$I][0]) THEN RETURN $OLDQUESTS[$I][0]
	NEXT
	FOR $I = 0 TO UBOUND($NEWQUESTS) - 1
		IF NOT _ISINARRAY($OLDQUESTS, $NEWQUESTS[$I][0]) THEN RETURN $NEWQUESTS[$I][0]
	NEXT
	RETURN -1
ENDFUNC
FUNC _ISINARRAY($ARRAY, $VALUE)
	FOR $I = 0 TO UBOUND($ARRAY) - 1
		IF $ARRAY[$I][0] == $VALUE THEN RETURN TRUE
	NEXT
	RETURN FALSE
ENDFUNC
FUNC _ISQUESTGAINED($OLDQUESTS, $NEWQUESTS, $QUESTID)
	RETURN NOT _ISINARRAY($OLDQUESTS, $QUESTID)
ENDFUNC
FUNC NPCHELPER()
	SETSTATUS("Instance Action")
	$INSTANCE = INSTANCEID()
	$CLIENTSINDEXES = GETNEARBYALTS(30)
	$TARGET = PLAYERTARGET()
	IF $INSTANCE == $MAP_PRIMAL THEN
		TAKECLIENTSQUEST("Emerald Spellcaster", 30945, -751.73, -205.09, $CLIENTSINDEXES)
		TAKECLIENTSQUEST("Swordsman Zenray", 34438, 931.96, -940.34, $CLIENTSINDEXES)
		TAKECLIENTSQUEST("Light Emperor of Alexander", 30827, -202.55, -769.77, $CLIENTSINDEXES)
	ELSEIF $INSTANCE == 176 THEN
		$NPCNAME = ""
		IF GETNPCUNIQUEID("Agent of Unity") THEN $NPCNAME = "Agent of Unity"
		IF GETNPCUNIQUEID("Agent of Painting") THEN $NPCNAME = "Agent of Painting"
		IF GETNPCUNIQUEID("Agent of Music") THEN $NPCNAME = "Agent of Music"
		IF GETNPCUNIQUEID("Agent of Wine") THEN $NPCNAME = "Agent of Wine"
		IF GETNPCUNIQUEID("Agent of Calligraphy") THEN $NPCNAME = "Agent of Calligraphy"
		IF GETNPCUNIQUEID("Agent of Strategy") THEN $NPCNAME = "Agent of Strategy"
		IF GETNPCUNIQUEID("Agent of Reflection") THEN $NPCNAME = "Agent of Reflection"
		IF $NPCNAME == "Agent of Unity" THEN
			SWITCHTOHUMANFORM()
			SLEEP(1000)
			IF ISQUESTAVAILABLE(35649) THEN
				TAKECLIENTSQUEST($NPCNAME, 35649, -292.87, -61.84, $CLIENTSINDEXES)
			ELSEIF ISQUESTAVAILABLE(35648) THEN
				TAKECLIENTSQUEST($NPCNAME, 35648, -292.87, -61.84, $CLIENTSINDEXES)
			ELSEIF ISQUESTAVAILABLE(35647) THEN
				TAKECLIENTSQUEST($NPCNAME, 35647, -292.87, -61.84, $CLIENTSINDEXES)
			ELSEIF ISQUESTAVAILABLE(35646) THEN
				TAKECLIENTSQUEST($NPCNAME, 35646, -292.87, -61.84, $CLIENTSINDEXES)
			ELSEIF ISQUESTAVAILABLE(35645) THEN
				TAKECLIENTSQUEST($NPCNAME, 35645, -292.87, -61.84, $CLIENTSINDEXES)
			ELSEIF ISQUESTAVAILABLE(35643) THEN
				TAKECLIENTSQUEST($NPCNAME, 35643, -292.87, -61.84, $CLIENTSINDEXES)
			ENDIF
		ELSEIF $NPCNAME == "Agent of Reflection" THEN
			TAKECLIENTSQUEST($NPCNAME, 35644, -119.42, 321.52, $CLIENTSINDEXES)
		ELSEIF $NPCNAME <> "" THEN
			TAKECLIENTSQUEST($NPCNAME, 35649, 0, 0, $CLIENTSINDEXES)
		ENDIF
	ELSEIF $INSTANCE == 197 THEN
		TAKECLIENTSQUEST("Ien the Arbor", 40660, 935.34, 521.7, $CLIENTSINDEXES)
		TAKECLIENTSQUEST("Rhapsody of the Revived Part 1", 40326, -540.27, -254.26, $CLIENTSINDEXES)
		TAKECLIENTSQUEST("Rhapsody of the Revived Part 2", 40327, -540.27, -254.26, $CLIENTSINDEXES)
		TAKECLIENTSQUEST("Tsuan", 40329, -173.76, -167.65, $CLIENTSINDEXES)
	ELSEIF $INSTANCE == 178 THEN
		TAKECLIENTSQUEST("Lieutenant Bennett", 37848, 328.95, 833.43, $CLIENTSINDEXES)
		TAKECLIENTSQUEST("Soulless Wanderer", 43283, 910.895, 1271.96, $CLIENTSINDEXES)
		IF NOT HASQUEST(38080) THEN
			TAKECLIENTSQUEST("General Summer", 38080, 799.6, -188.77, $CLIENTSINDEXES)
		ELSE
			TURNINCLIENTSQUEST(52516, 38080, 0, $CLIENTSINDEXES)
		ENDIF
		TURNINBHQUESTS($CLIENTSINDEXES)
	ELSEIF $INSTANCE == 186 THEN
		IF GETNPCUNIQUEID("Archmage Conrad") THEN
			TAKECLIENTSQUEST("Archmage Conrad", 37998, 91.67, 48.58, $CLIENTSINDEXES)
		ELSE
			TURNINBHQUESTS($CLIENTSINDEXES)
		ENDIF
	ELSEIF $INSTANCE == 195 THEN
		TAKECLIENTSQUEST("Icebound Gatekeeper Hak", 39752, -13.65, -30.71, $CLIENTSINDEXES)
	ELSEIF $INSTANCE == 1 THEN
		IF GETNPCUNIQUEID("Head Hunter") OR GETNPCUNIQUEID("Messenger of Time Woyo") OR GETNPCUNIQUEID("Faction Base Manager Zeen") THEN
			DIM $NPC_ARRAY[3]
			$NPC_ARRAY[0] = GETNPCPOSITION("Head Hunter")
			$NPC_ARRAY[1] = GETNPCPOSITION("Messenger of Time Woyo")
			$NPC_ARRAY[2] = GETNPCPOSITION("Faction Base Manager Zeen")
			$CLOSESTNPCINDEX = FINDCLOSESTCOORDINATE($NPC_ARRAY)
			IF $CLOSESTNPCINDEX == 0 THEN
				TURNINBHQUESTS($CLIENTSINDEXES)
			ELSEIF $CLOSESTNPCINDEX == 1 THEN
				MASSENTERNORTHERNREALM($CLIENTSINDEXES)
			ELSEIF $CLOSESTNPCINDEX == 2 THEN
				MASSENTERFACTIONBASE($CLIENTSINDEXES)
			ENDIF
		ELSEIF GETNPCUNIQUEID("Icebound Gatekeeper Sho") THEN
			TAKECLIENTSQUEST("Icebound Gatekeeper Sho", 39745, 3413.51, 3837.52, $CLIENTSINDEXES)
		ELSEIF GETNPCUNIQUEID("Thursday Night Fights Agent") THEN
			TAKECLIENTSQUEST("Thursday Night Fights Agent", 34156, 1331.337, 831.325, $CLIENTSINDEXES)
		ENDIF
	ELSEIF $INSTANCE == 177 THEN
		IF GETNPCUNIQUEID("Tournament Registrar") THEN
			TAKECLIENTSQUEST("Tournament Registrar", 34155, 380.545, -906.054, $CLIENTSINDEXES)
		ELSEIF GETNPCUNIQUEID("Exit Manager") THEN
			FOR $I = 0 TO UBOUND($CLIENTS) - 1
				IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
				SWITCHTONUM($I)
				$INSTANCE = INSTANCEID()
				IF $INSTANCE == 177 AND GETNPCUNIQUEID("Exit Manager") THEN
					TALKTONPC("Exit Manager")
					TAKEQUEST("Exit Manager", 34157)
				ENDIF
			NEXT
		ENDIF
	ELSEIF $INSTANCE == 121 THEN
		TAKECLIENTSQUEST("Lady Heidel", 43855, -687.21, -130.58, $CLIENTSINDEXES)
	ELSEIF $INSTANCE == 135 THEN
		$ID_ENVOY = GETNPCUNIQUEID("Faction Bounty Envoy")
		$ID_DUANYIN = GETNPCUNIQUEID("Duanyin Clan Teleport")
		IF $TARGET == $ID_ENVOY THEN
			IF HASQUEST(46885) THEN
				MASSSELECTPLAYERTARGET()
				TURNINCLIENTSQUEST(74079, 46885, 0, $CLIENTSINDEXES, 0)
			ELSE
				TAKECLIENTSQUEST("Faction Bounty Envoy", 46868, -100.5, 704.72, $CLIENTSINDEXES)
			ENDIF
		ELSEIF $TARGET == $ID_DUANYIN THEN
			TAKECLIENTSQUEST("Duanyin Clan Teleport", 46869, -98.79, 715.74, $CLIENTSINDEXES)
		ENDIF
		TURNINCLIENTSQUEST(74335, 47046, 0, $CLIENTSINDEXES, 0)
	ELSEIF $INSTANCE == 136 THEN
		IF DISTANCE2D(-401.41, 1411.58) < 10 THEN
			TAKECLIENTSQUEST("Dixue Clan Guide", 46872, -401.41, 1411.58, $CLIENTSINDEXES)
		ELSEIF DISTANCE2D(-370.34, -1445.2) < 10 THEN
			TAKECLIENTSQUEST("Dixue Clan Guide", 46882, -370.34, -1445.2, $CLIENTSINDEXES)
		ENDIF
	ELSEIF $INSTANCE == 93 THEN
		$NPCNAME = ""
		IF GETNPCUNIQUEID("Citadel Outpost Teleporter") AND GETNPCUNIQUEID("Outpost Officer Sulhba") THEN
			$NPCNAME = "Citadel Outpost Teleporter"
			TAKECLIENTSQUEST($NPCNAME, 41934, 244.11, 98.68, $CLIENTSINDEXES)
		ELSEIF GETNPCUNIQUEID("Citadel Outpost Teleporter") AND GETNPCUNIQUEID("Penal Judge Santinov") THEN
			$NPCNAME = "Citadel Outpost Teleporter"
			TAKECLIENTSQUEST($NPCNAME, 41941, -258.78, 63.06, $CLIENTSINDEXES)
		ELSEIF GETNPCUNIQUEID("Imperial Campsite Teleporter") AND DISTANCE2D(1378.24, -50.9) < DISTANCE2D(1394.64, -41.47) THEN
			$NPCNAME = "Imperial Campsite Teleporter"
			TAKECLIENTSQUEST($NPCNAME, 41937, 1378.24, -50.9, $CLIENTSINDEXES)
		ELSEIF GETNPCUNIQUEID("Path Guide Ankei") AND DISTANCE2D(1378.24, -50.9) > DISTANCE2D(1394.64, -41.47) THEN
			$NPCNAME = "Path Guide Ankei"
			TAKECLIENTSQUEST($NPCNAME, 41945, 1394.64, -41.47, $CLIENTSINDEXES)
		ELSEIF GETNPCUNIQUEID("Divine Garrison Teleporter") AND DISTANCE2D(-1394, -87) < DISTANCE2D(-1418.4, -74.5) THEN
			$NPCNAME = "Divine Garrison Teleporter"
			TAKECLIENTSQUEST($NPCNAME, 41937, -1394, -87, $CLIENTSINDEXES)
		ELSEIF GETNPCUNIQUEID("Path Guide Donri") AND DISTANCE2D(-1394, -87) > DISTANCE2D(-1418.4, -74.5) THEN
			$NPCNAME = "Path Guide Donri"
			TAKECLIENTSQUEST($NPCNAME, 41950, -1418.4, -74.5, $CLIENTSINDEXES)
		ELSEIF GETNPCUNIQUEID("Spirit Bastion Teleporter") THEN
			$NPCNAME = "Spirit Bastion Teleporter"
			TAKECLIENTSQUEST($NPCNAME, 41934, 697, -405, $CLIENTSINDEXES)
		ELSEIF GETNPCUNIQUEID("Arar Outpost Teleporter") THEN
			$NPCNAME = "Arar Outpost Teleporter"
			TAKECLIENTSQUEST($NPCNAME, 41934, 684, 184, $CLIENTSINDEXES)
		ELSEIF GETNPCUNIQUEID("Oracle Village Teleporter") THEN
			$NPCNAME = "Oracle Village Teleporter"
			TAKECLIENTSQUEST($NPCNAME, 41941, -623, 404, $CLIENTSINDEXES)
		ELSEIF GETNPCUNIQUEID("Divine Garrison Teleporter") THEN
			$NPCNAME = "Divine Garrison Teleporter"
			TAKECLIENTSQUEST($NPCNAME, 41937, -1394, -87, $CLIENTSINDEXES)
		ENDIF
	ENDIF
	SLEEP(1000)
	MASSCLOSENPCWINDOW()
	SETSTATUS("Done.")
ENDFUNC
FUNC DYNAMICHELPER()
	$CLIENTSINDEXES = GETNEARBYALTS(30)
	LOCAL $FILE = FILEOPEN("dynamic-npcs.txt")
	$LINE = FILEREADLINE($FILE)
	WHILE $LINE
		$VALS = STRINGSPLIT($LINE, ";", 2)
		TAKECLIENTSQUEST($VALS[0], INT($VALS[1]), -1, -1, $CLIENTSINDEXES)
		$LINE = FILEREADLINE($FILE)
	WEND
	FILECLOSE($FILE)
ENDFUNC
FUNC DYNAMICHELPER2()
	$CLIENTSINDEXES = GETNEARBYALTS(30)
	LOCAL $FILE = FILEOPEN("dynamic-npcs2.txt")
	$LINE = FILEREADLINE($FILE)
	WHILE $LINE
		$VALS = STRINGSPLIT($LINE, ";", 2)
		TURNINCLIENTSQUEST($VALS[0], INT($VALS[1]), 0, $CLIENTSINDEXES)
		$LINE = FILEREADLINE($FILE)
	WEND
	FILECLOSE($FILE)
ENDFUNC
FUNC GLITCHUPDKEY()
	$CLIENTSINDEXES = GETNEARBYALTS()
	WAITCLIENTSTOBEOUTOFCOMBAT($CLIENTSINDEXES)
	REFORMSQUAD()
	SLEEP(3000)
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		SWITCHTONUM($CLIENTSINDEXES[$I])
		GLITCHCHARACTER()
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSBASETALK()
	FOR $J = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($J)
		TALKTONPC("Faction Base Manager Zeen")
		ENTERFACTIONBASEPACKET(PLAYERID(), FACTIONID())
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MASSBASE()
	FOR $J = 0 TO UBOUND($CLIENTS) - 1
		SWITCHTONUM($J)
		ENTERFACTIONBASEFROMNPC()
		WAITTOFINISH()
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
FUNC MAKEMEDIA()
	IF ITEMCOUNT(54464) < 1 OR ITEMCOUNT(54465) < 1 THEN RETURN FALSE
	$SQUIREBADGE = ITEMCOUNTTOTAL(54329)
	$KNIGHTBADGE = ITEMCOUNTTOTAL(54330) + ITEMCOUNTTOTAL(54464) - 1
	$ROYALBADGE = ITEMCOUNTTOTAL(54331) + ITEMCOUNTTOTAL(54465) - 1
	$REQROYAL = 2
	$REQKNIGHT = 5 + _MAX($REQROYAL - $ROYALBADGE, 0) * 4
	$REQSQUIRE = 30 + _MAX($REQKNIGHT - $KNIGHTBADGE, 0) * 4
	IF $SQUIREBADGE < $REQSQUIRE THEN RETURN FALSE
	TRANSFERMAP($MAP_NEVERFALL, 0, -512.7, 435.5, 13)
	FLY(-512.7, 435.5, 13)
	TALKTONPC("Royal Knight Hector")
	$NEEDEDKNIGHT = $REQKNIGHT - $KNIGHTBADGE
	IF $NEEDEDKNIGHT > 0 THEN
		MANUFACTURE(9499, $NEEDEDKNIGHT)
		WHILE $KNIGHTBADGE < $REQKNIGHT
			SLEEP(100)
			$KNIGHTBADGE = ITEMCOUNTTOTAL(54330) + ITEMCOUNTTOTAL(54464) - 1
		WEND
	ENDIF
	$PROMOTECOUNT = ITEMCOUNTTOTAL(54464)
	WHILE $PROMOTECOUNT > 1
		$ARRAY = INVARRAY(0, 0)
		$FROM = SEARCHITEMID($ARRAY, 54464)
		$TO = SEARCHITEMID($ARRAY, 0)
		IF $TO == -1 THEN EXITLOOP
		MOVEINVENTORYITEM($FROM, $TO, 1)
		SLEEP(100)
		USEITEM($TO, 54464)
		WHILE ITEMCOUNTTOTAL(54464) == $PROMOTECOUNT
			SLEEP(100)
		WEND
		SLEEP(100)
		WHILE HASQUEST(37686)
			SLEEP(100)
		WEND
		$PROMOTECOUNT = ITEMCOUNTTOTAL(54464)
	WEND
	$NEEDEDROYAL = $REQROYAL - $ROYALBADGE
	IF $NEEDEDROYAL > 0 THEN
		MANUFACTURE(9500, $NEEDEDROYAL)
		WHILE $ROYALBADGE < $REQROYAL
			SLEEP(100)
			$ROYALBADGE = ITEMCOUNTTOTAL(54331) + ITEMCOUNTTOTAL(54465) - 1
		WEND
	ENDIF
	$PROMOTECOUNT = ITEMCOUNTTOTAL(54465)
	WHILE $PROMOTECOUNT > 1
		$ARRAY = INVARRAY(0, 0)
		$FROM = SEARCHITEMID($ARRAY, 54465)
		$TO = SEARCHITEMID($ARRAY, 0)
		IF $TO == -1 THEN EXITLOOP
		MOVEINVENTORYITEM($FROM, $TO, 1)
		SLEEP(100)
		USEITEM($TO, 54465)
		WHILE ITEMCOUNTTOTAL(54465) == $PROMOTECOUNT
			SLEEP(100)
		WEND
		SLEEP(100)
		WHILE HASQUEST(37688)
			SLEEP(100)
		WEND
		$PROMOTECOUNT = ITEMCOUNTTOTAL(54465)
	WEND
	$MEDIACOUNT = ITEMCOUNTTOTAL(54466)
	MANUFACTURE(9486, 1)
	WHILE $MEDIACOUNT == ITEMCOUNTTOTAL(54466)
		SLEEP(100)
	WEND
	RETURN TRUE
ENDFUNC
FUNC WAITCLIENTSTOBEOUTOFCOMBAT($CLIENTSINDEXES)
	$QUIT = FALSE
	WHILE NOT $QUIT
		$QUIT = TRUE
		FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
			SWITCHTONUM($CLIENTSINDEXES[$I])
			IF INCOMBAT() THEN $QUIT = FALSE
			SLEEP(200)
		NEXT
		SLEEP(5000)
	WEND
ENDFUNC
FUNC TELEPORTSTONETO($ID)
	$ARRAY = INVARRAY()
	$INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
	IF $INDEX == -1 THEN RETURN False
	USETELESTONE($ARRAY[$INDEX][1], $ARRAY[$INDEX][0], $ID)
  Return True
ENDFUNC
FUNC TELEPORTSTONETOETHERBLADE()
	$ARRAY = INVARRAY()
	$INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
	IF $INDEX == -1 THEN RETURN
	USETELESTONE($ARRAY[$INDEX][1], $ARRAY[$INDEX][0], 2101)
	SLEEP(5000)
ENDFUNC

FUNC GLITCHCHARACTER()
	$QUESTSAMOUNT = UBOUND(QUESTARRAY())
	$ARRAY = INVARRAY()
	$INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
	IF $INDEX == -1 THEN RETURN
	SMARTHOLYPATH()
	MOVETO2(-317.27, -182.94)
	WHILE UBOUND(QUESTARRAY()) == $QUESTSAMOUNT
		SLEEP(100)
	WEND
	USETELESTONE($ARRAY[$INDEX][1], $ARRAY[$INDEX][0], 6101)
ENDFUNC
FUNC FINDANYTELEPORTSTONESINDEX($ARRAY)
	LOCAL $TELEPORTSTONESID[8] = [59410, 59411, 59412, 72926, 33916, 36905, 26651, 14351]
	FOR $I = 0 TO UBOUND($TELEPORTSTONESID) - 1
		$INDEX = SEARCHITEMID($ARRAY, $TELEPORTSTONESID[$I])
		IF $INDEX <> -1 THEN RETURN $INDEX
	NEXT
	RETURN -1
ENDFUNC
FUNC FINDUNLIMITEDTELEPORTSTONESINDEX($ARRAY, $INCLUDELIMITED = FALSE)
	LOCAL $TELEPORTSTONESID[4] = [59410, 59411, 59412, 72926]
	FOR $I = 0 TO UBOUND($TELEPORTSTONESID) - 1
		$INDEX = SEARCHITEMID($ARRAY, $TELEPORTSTONESID[$I])
		IF $INDEX <> -1 THEN RETURN $INDEX
	NEXT
	RETURN -1
ENDFUNC
FUNC TRIAL2HELP()
	$INSTANCEVALUES = INSTANCEVALUETABLE()
	$INSTANCEVALUES2 = INSTANCEVALUETABLE()
	FOR $I = 0 TO UBOUND($INSTANCEVALUES) - 1
		$VALUE = $INSTANCEVALUES[$I][0]
		$VALUE2 = $INSTANCEVALUES[$I][1]
		IF $VALUE == 104089 AND $VALUE2 == 2 THEN
			FOR $J = 0 TO UBOUND($INSTANCEVALUES2) - 1
				$VALUE3 = $INSTANCEVALUES2[$J][0]
				$VALUE4 = $INSTANCEVALUES2[$J][1]
				IF $VALUE3 == 104090 AND $VALUE4 == 4 THEN
					NORTHANTICLOCKWISE()
				ELSEIF $VALUE3 == 104090 AND $VALUE4 == 1 THEN
					EASTANTICLOCKWISE()
				ELSEIF $VALUE3 == 104090 AND $VALUE4 == 2 THEN
					SOUTHANTICLOCKWISE()
				ELSEIF $VALUE3 == 104090 AND $VALUE4 == 3 THEN
					WESTANTICLOCKWISE()
				ENDIF
			NEXT
		ELSEIF $VALUE == 104089 AND $VALUE2 == 1 THEN
			FOR $J = 0 TO UBOUND($INSTANCEVALUES2) - 1
				$VALUE3 = $INSTANCEVALUES2[$J][0]
				$VALUE4 = $INSTANCEVALUES2[$J][1]
				IF $VALUE3 == 104090 AND $VALUE4 == 4 THEN
					NORTHCLOCKWISE()
				ELSEIF $VALUE3 == 104090 AND $VALUE4 == 1 THEN
					EASTCLOCKWISE()
				ELSEIF $VALUE3 == 104090 AND $VALUE4 == 2 THEN
					SOUTHCLOCKWISE()
				ELSEIF $VALUE3 == 104090 AND $VALUE4 == 3 THEN
					WESTCLOCKWISE()
				ENDIF
			NEXT
		ENDIF
	NEXT
ENDFUNC
FUNC TRIAL2HELP2()
	SETSTATUS("Trial 2 help (v2): checking what you typed...")
	STARTLISTENING()
	WHILE NOT MOVEKEY()
		IF SEETEXT("northcw", -1, TRUE) THEN
			SETSTATUS("Running clockwise north")
			NORTHCLOCKWISE()
			EXITLOOP
		ELSEIF SEETEXT("eastcw", -1, TRUE) THEN
			SETSTATUS("Running clockwise east")
			EASTCLOCKWISE()
			EXITLOOP
		ELSEIF SEETEXT("southcw", -1, TRUE) THEN
			SETSTATUS("Running clockwise south")
			SOUTHCLOCKWISE()
			EXITLOOP
		ELSEIF SEETEXT("westcw", -1, TRUE) THEN
			SETSTATUS("Running clockwise west")
			WESTCLOCKWISE()
			EXITLOOP
		ELSEIF SEETEXT("northacw", -1, TRUE) THEN
			SETSTATUS("Running anticlockwise north")
			NORTHANTICLOCKWISE()
			EXITLOOP
		ELSEIF SEETEXT("eastacw", -1, TRUE) THEN
			SETSTATUS("Running anticlockwise east")
			EASTANTICLOCKWISE()
			EXITLOOP
		ELSEIF SEETEXT("southacw", -1, TRUE) THEN
			SETSTATUS("Running anticlockwise south")
			SOUTHANTICLOCKWISE()
			EXITLOOP
		ELSEIF SEETEXT("westacw", -1, TRUE) THEN
			SETSTATUS("Running anticlockwise west")
			WESTANTICLOCKWISE()
			EXITLOOP
		ENDIF
		SLEEP(100)
	WEND
ENDFUNC
FUNC NORTHCLOCKWISE()
	LOCAL $CLIENTSINDEXES = GETSQUADALTS()
	SWITCHTO($MAIN)
	LOCAL CONST $PLAYER_COUNT = 10
	LOCAL $PLAYERCOORDS[$PLAYER_COUNT][2] = [[-328.88, -1447.89], [-296.83, -1480.11], [-296.83, -1480.11], [-330.07, -1520.09], [-330.07, -1520.09], [-330.07, -1520.09], [-365.16, -1481.82], [-365.16, -1481.82], [-365.16, -1481.82], [-365.16, -1481.82]]
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		IF $I >= $PLAYER_COUNT THEN EXITLOOP
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		LOCAL $X = $PLAYERCOORDS[$I][0]
		LOCAL $Y = $PLAYERCOORDS[$I][1]
		MOVETO($X, $Y)
	NEXT
	SWITCHTO($MAIN)
ENDFUNC
