	ADDMISCBUTTON("Mass Select Target", "MassSelectPlayerTarget", TRUE, -1, 0, -1, "Have all alts select your current target." & @CRLF & "If used after you open an NPC window then alts will" & @CRLF & "open the NPC window as well.")
