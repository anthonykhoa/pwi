			$__G_TTABBUFFER = DLLSTRUCTCREATE("wchar Text[4096]")
			$__G_TTABBUFFERANSI = DLLSTRUCTCREATE("char Text[4096]", DLLSTRUCTGETPTR($__G_TTABBUFFER))
		ENDIF
		IF ISHWND($HWND) THEN
			RETURN _SENDMESSAGE($HWND, $TCM_GETUNICODEFORMAT) <> 0
		ELSE
