			LOCAL $ACALL = DLLCALL("kernel32.dll", "bool", "BackupWrite", "handle", 0, "ptr", 0, "dword", 0, "dword*", 0, "bool", 1, "bool", 0, "ptr*", $PCONTEXT)
			IF @ERROR OR NOT $ACALL[0] THEN RETURN SETERROR(@ERROR, @EXTENDED, FALSE)
			$PCONTEXT = $ACALL[7]
			RETURN $ACALL[0]
		ENDFUNC
