FUNC SENDMAKEFROMITEM($ITEMID, $QUANTITY, $SLOTID, $SLOT2ID)
	$PACKET = "6D000001" & _HEX($SLOTID, 4) & _HEX($ITEMID) & _HEX($ITEMID) & _HEX($QUANTITY) & _HEX($SLOT2ID, 2)
	SENDPACKET($PACKET, 22, $GAME_PID)
ENDFUNC
FUNC MAKEFROMITEM($ITEMAID, $ITEMBID)
	$ARRAY = INVARRAY()
	$INDEXA = SEARCHITEMID($ARRAY, $ITEMAID)
	$INDEXB = SEARCHITEMID($ARRAY, $ITEMBID)
	IF $INDEXA == -1 OR $INDEXB == -1 THEN RETURN
	SENDMAKEFROMITEM($ITEMAID, 1, $ARRAY[$INDEXA][0], $ARRAY[$INDEXB][0])
ENDFUNC
FUNC ADVENTUREKINGDOMTHRILL()
	ADVENTUREKINGDOMMAP()
	SETSTATUS("Divination of Luck - Adventure Kingdom Thrill")
	SWITCHTOHUMANFORM()
	TAKEQUEST("Goldfish Flower Manager", 39234, -534.26, -56.7, 55, TRUE, FALSE)
	WAITFORNPC("Horizon Leap Manager")
	FLYUP()
	TURNINQUEST("Tiger Babe", 39155, -577.89, 318.47, 15, 0, FALSE, TRUE)
	FLYUP()
	MOVE2(-594.01, 229.68, 148.56, 1)
	TURNINQUEST("Horizon Leap Manager", 39440, -620.83, 160.8, 15, 0, FALSE, TRUE)
	WHILE NOT INVEHICLE()
		$SEAT = RANDOM(0, 7, 1)
		SENDENTERVEHICLE(NPCID(56505), $SEAT)
		SLEEP(5000)
	WEND
	WHILE INVEHICLE()
		SLEEP(2000)
	WEND
	TAKEQUEST("Horizon Leap Manager", 39231, -620.83, 160.8, 15, TRUE, FALSE)
	WAITFORNPC("Eye of Jade Manager")
	MOVE2(-215.21, -37.04)
	TURNINQUEST("Eye of Jade Manager", 39441)
	WHILE NOT INVEHICLE()
		$SEAT = RANDOM(0, 7, 1)
		SENDENTERVEHICLE(NPCID(56507), $SEAT)
		SLEEP(5000)
	WEND
	WHILE INVEHICLE()
		SLEEP(2000)
	WEND
	MOVE2(-215.21, -37.04)
	TAKEQUEST("Eye of Jade Manager", 39234)
	WAITFORNPC("Horizon Leap Manager")
	FLYUP()
	TURNINQUEST("Tiger Babe", 39205, -577.89, 318.47, 15, 0, FALSE)
	SENDEXPRESSION(8)
	TURNINQUEST("Tiger Babe", 39206, -577.89, 318.47, 15, 0, FALSE)
	TAKENEARESTQUEST($ADVENTUREKINGDOMRIDETELEPORTS, 39235)
	WAITFORNPC("Goldfish Flower Manager")
ENDFUNC
FUNC CIRCUSEXPLORATION()
	ADVENTUREKINGDOMMAP()
	SETSTATUS("Divination of Luck - Circus Exploration")
	FLYUP()
	TURNINQUEST("Trembling Cat", 39133, -673.17, -207.05, 10, 0, FALSE, TRUE)
	FLYUP()
	FLY(-346.08, 349.04, 10)
	WHILE ITEMCOUNT(57297) < 3 AND HASQUEST(39305)
		DIGITEM("Wooden Stick")
	WEND
	WHILE ITEMCOUNT(57230) < 3 AND HASQUEST(39304)
		DIGITEM("Candy")
	WEND
	WHILE ITEMCOUNT(57231) < 3 AND ITEMCOUNT(57297) AND ITEMCOUNT(57230)
		MAKEFROMITEM(57297, 57230)
		SLEEP(6000)
	WEND
	FLYUP()
	TURNINQUEST("Trembling Cat", 39056, -673.17, -207.05, 10)
	FLYUP()
	FLY(-521.66, -466.19, 10)
	MOVE(-521.6, -488.09)
	TURNINQUEST("Angel of Divinity", 39197)
	MOVE(-522.44, -452.08)
	MOVE(-449.65, -467.22)
	FLYUP()
	$ESPIONAGETIMER = 0
	WHILE HASQUEST(39198) AND QUESTKILLCOUNT(39198) < 3
		GENIECHISKILL()
		$HPMP = GETHPMP()
		$HP = $HPMP[0]
		IF $HP == 0 THEN
			SETSTATUS("We died killing ghost mobs, returning... :<")
			RESURRECTIFDEAD()
			USEITEMID(38408)
			SELFBUFF()
			FLY(-449.65, -467.22, 10)
		ENDIF
		IF NOT GETNPCUNIQUEID("Flying Ghost") AND NOT HASBUFF("Super Sight", 150) AND NOT HASQUEST(38919) THEN
			IF ITEMCOUNT(57301) > 0 THEN
				USEITEMID(57301)
			ELSEIF ITEMCOUNT(32228) > 0 AND NOT HASQUEST(24956) THEN
				SETSTATUS("Divination of Luck - Circus Exploration - using Espionage Potion instead.")
				USEITEMID(32228)
				$ESPIONAGETIMER = TIMERINIT()
				SLEEP(3000)
			ELSEIF ITEMCOUNT(32228) > 0 AND HASQUEST(24956) THEN
				$TIMETOSLEEP = 0
				$TIMESINCEESPIONAGE = TIMERDIFF($ESPIONAGETIMER)
				IF $TIMESINCEESPIONAGE < 120000 THEN
					$TIMETOSLEEP = 120000 - $TIMESINCEESPIONAGE
				ELSE
					$TIMETOSLEEP = 90000
				ENDIF
				SLEEP($TIMETOSLEEP)
			ELSE
				SETSTATUS("Divination of Luck - Circus Exploration - ran out of stealth detection items. Failed.")
				SETSTATUS("If your character is weak, obtain Espionage Potion to allow them to finish this quest in future.")
				EXITLOOP
			ENDIF
			SLEEP(1000)
		ENDIF
		KILL("Flying Ghost", 200, 2, 0)
	WEND
	FLY(-522.44, -452.08, 5)
	MOVE(-521.6, -488.09)
	TURNINQUEST("Angel of Divinity", 39198)
	TURNINQUEST("Angel of Divinity", 39199)
	MOVE(-522.44, -452.08)
	MOVE(-440.81, -455.23)
	MOVE(-402.81, -443.76)
	MOVE(-400.63, -473.88)
	FLYUP()
	WHILE HASQUEST(39200) AND QUESTKILLCOUNT(39200) < 3
		IF NOT GETNPCUNIQUEID("Ghost Accomplice") AND NOT HASBUFF("Super Sight", 150) AND NOT HASQUEST(38919) THEN
			IF ITEMCOUNT(57301) > 0 THEN
				USEITEMID(57301)
			ELSEIF ITEMCOUNT(32228) > 0 THEN
				SETSTATUS("Divination of Luck - Circus Exploration - using Espionage Potion instead.")
				USEITEMID(32228)
			ELSE
				SETSTATUS("Divination of Luck - Circus Exploration - ran out of stealth detection items. Failed.")
				SETSTATUS("If your character is weak, obtain Espionage Potion to allow them to finish this quest in future.")
				EXITLOOP
			ENDIF
			SLEEP(1000)
			USEITEMID(57301)
			SLEEP(1000)
		ENDIF
		KILL("Ghost Accomplice", 200, 2, 0)
	WEND
	FLY(-400.63, -473.88)
	MOVE(-402.81, -443.76)
	MOVE(-440.81, -455.23)
	MOVE(-522.44, -452.08)
	MOVE(-521.6, -488.09)
	TURNINQUEST("Angel of Divinity", 39200)
	MOVE(-521.66, -466.19)
	FLYUP(55)
ENDFUNC
