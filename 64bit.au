	GUICTRLSETRESIZING(-1, $GUI_DOCKTOP + $GUI_DOCKSIZE)
	GUICTRLSETTIP(-1, "Best to leave this checked; if checked immediately collects rewards from Elysian Arena building" & @CRLF & "once your Points are high enough. If you don't leave this checked," & @CRLF & "there is a chance your Points will drop if you lose a minion battle, and" & @CRLF & "you will be unable to collect a higher tier reward you were temporarily able to collect.")
