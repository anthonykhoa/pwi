	ENDFUNC
	FUNC TELEPORTBELL($IDS)
		$PACKET = "2500" & _HEX(73) & _HEX(4 * UBOUND($IDS) + 4) & _HEX(UBOUND($IDS))
		FOR $I = 0 TO UBOUND($IDS) - 1
			$PACKET = $PACKET & _HEX($IDS[$I])
		NEXT
		SENDPACKET($PACKET, 14 + 4 * UBOUND($IDS), $GAME_PID)
	ENDFUNC
	FUNC ENTERFACTIONBASEPACKET($PLAYERID, $FACTIONID)
