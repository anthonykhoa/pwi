	IF HASQUEST(39054) OR HASQUEST(39133) THEN
		CIRCUSEXPLORATION()
	ENDIF
	IF HASQUEST(39061) OR HASQUEST(39234) OR HASQUEST(39155) THEN
		ADVENTUREKINGDOMTHRILL()
	ENDIF
	IF HASQUEST(39049) OR HASQUEST(39236) OR HASQUEST(39139) THEN
