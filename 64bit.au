FUNC MASSTELEPORTSTONETOALL($TELEPORT_LOCATION_ID, $X, $Y)
	FOR $I = 0 TO UBOUND($CLIENTS) - 1
		IF NOT CLIENTINGROUP($CLIENTS[$I][2], "masstarget") THEN CONTINUELOOP
		SWITCHTONUM($I)
		IF DISTANCE2D($X, $Y) < 30 THEN CONTINUELOOP
		$ARRAY = INVARRAY()
		$INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
		IF $INDEX <> -1 THEN
			USETELESTONE($ARRAY[$INDEX][1], $ARRAY[$INDEX][0], $TELEPORT_LOCATION_ID)
		ENDIF
		SLEEP(500)
    switchto($main)
	NEXT
ENDFUNC
FUNC MASSTELEPORTSTONETOSQUAD($TELEPORT_LOCATION_ID, $X, $Y, $NpcName)
	$CLIENTSINDEXES = GETSQUADALTS()
	FOR $I = 0 TO UBOUND($CLIENTSINDEXES) - 1
		$INDEX = $CLIENTSINDEXES[$I]
		SWITCHTONUM($INDEX)
		IF DISTANCE2D($X, $Y) < 5 THEN CONTINUELOOP
		$ARRAY = INVARRAY()
		$INDEX = FINDANYTELEPORTSTONESINDEX($ARRAY)
		IF $INDEX <> -1 THEN
			USETELESTONE($ARRAY[$INDEX][1], $ARRAY[$INDEX][0], $TELEPORT_LOCATION_ID)
		ENDIF
	NEXT
  WaitClientsForNpc($NpcName, $ClientsIndexes)
  Switchto($MAIN)
ENDFUNC
