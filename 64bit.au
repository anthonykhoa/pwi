			ENDIF
			IF $ILIBRARY THEN
				_WINAPI_FREELIBRARY($HMODULE)
			ENDIF
			DLLCALLBACKFREE($HENUMPROC)
			IF $__G_VENUM THEN RETURN SETERROR($__G_VENUM, 0, 0)
