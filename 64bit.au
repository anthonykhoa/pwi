FUNC EXECUTEMACRO0WITHCANCELCASTCOMMAND()
	$MACRO = 0
	$SLEEP_DURATION = 110
	EXECUTEMACROCANCELCAST($MACRO, $SLEEP_DURATION)
ENDFUNC
FUNC EXECUTEMACROCANCELCAST($MACRO, $SLEEP_DURATION = 250)
	WHILE MOVEKEY() == 0 AND GETHPMP()[0] > 0
		IF CURRENTSKILL() == 3777 THEN CANCELACTION()
		EXECUTEMACRO($MACRO)
		SLEEP($SLEEP_DURATION)
	WEND
ENDFUNC
FUNC NPCWINDOWOPEN()
	$PLAYER = PLAYERADDRESS()
	RETURN _MEMORYREAD($PLAYER + $PLAYERNPCWINDOW, $GAME_PROCESS, "byte")
ENDFUNC
FUNC CLOSENPCWINDOW()
	IF NPCWINDOWOPEN() THEN
		$PLAYER = PLAYERADDRESS()
		_MEMORYWRITE($PLAYER + $PLAYERNPCWINDOW, $GAME_PROCESS, 0)
	ENDIF
ENDFUNC
FUNC PLAYERTARGET($TARGET = -1)
	$PLAYER = PLAYERADDRESS()
	IF $TARGET == -1 THEN
		RETURN _MEMORYREAD($PLAYER + $PLAYERTARGET_OFFSET, $GAME_PROCESS)
	ELSE
		_MEMORYWRITE($PLAYER + $PLAYERTARGET_OFFSET, $GAME_PROCESS, $TARGET)
	ENDIF
ENDFUNC
FUNC CLEARTARGET()
	$PLAYER = PLAYERADDRESS()
	$TARGET = -1
	_MEMORYWRITE($PLAYER + $PLAYERTARGET_OFFSET, $GAME_PROCESS, $TARGET)
ENDFUNC
FUNC ACTIONFLAG()
	$POINTER_BASE = _MEMORYREAD(_MEMORYREAD($ADDRESS_BASE, $GAME_PROCESS) + 28, $GAME_PROCESS)
	$POINTER_CHAR = _MEMORYREAD($POINTER_BASE + $PLAYER_OFFSET, $GAME_PROCESS)
	$POINTER_ACTION = _MEMORYREAD($POINTER_CHAR + $OFFSET_ACTIONBASE, $GAME_PROCESS)
	RETURN _MEMORYREAD($POINTER_ACTION + 36, $GAME_PROCESS)
ENDFUNC
FUNC AUTOPATH($DEST_X, $DEST_Y, $ALT = 0, $DISMOUNT = 0, $USESECONDFORM = TRUE, $ROUTES = FALSE)
	$OPCODE = "60"
	$OPCODE &= "B9" & _HEX($DEST_Y, 8, "float")
	$OPCODE &= "BA" & _HEX($ALT)
	$OPCODE &= "B8" & _HEX($DEST_X, 8, "float")
	$OPCODE &= "6A00"
	$OPCODE &= "51"
	$OPCODE &= "52"
	$OPCODE &= "50"
	$OPCODE &= "6A03"
	$OPCODE &= "6A00"
	$OPCODE &= "6A01"
	$OPCODE &= "684A010000"
	$OPCODE &= "B9" & _HEX($ADDRESS_BASE)
	$OPCODE &= "8B09"
	$OPCODE &= "83C11C"
	$OPCODE &= "8B09"
	$OPCODE &= "BB" & _HEX($ADDRESS_AUTOPATH)
	$OPCODE &= "FFD3"
	$OPCODE &= "B9" & _HEX($ALT)
	$OPCODE &= "6A00"
	$OPCODE &= "6A00"
	$OPCODE &= "6A" & _HEX($DISMOUNT, 2)
	$OPCODE &= "51"
	$OPCODE &= "6A01"
	$OPCODE &= "6A00"
	$OPCODE &= "6A01"
	$OPCODE &= "684A010000"
	$OPCODE &= "B9" & _HEX($ADDRESS_BASE)
	$OPCODE &= "8B09"
	$OPCODE &= "83C11C"
	$OPCODE &= "8B09"
	$OPCODE &= "BB" & _HEX($ADDRESS_AUTOPATH)
	$OPCODE &= "FFD3"
	$OPCODE &= "61"
	$OPCODE &= "C3"
	INJECTCODE($OPCODE)
	IF TRANSPORTMODE() == 0 AND NOT MOUNTSUMMONED() AND $USESECONDFORM == TRUE THEN SWITCHTOSECONDFORM()
	IF NOT $ROUTES AND NOT MOUNTSUMMONED() THEN SMARTSpeed($DEST_X, $DEST_Y)
ENDFUNC
FUNC POSTMESSAGE($DWMSG, $IMANAGER, $ISUBID, $DWPARAM1 = 0, $DWPARAM2 = 0, $DWPARAM3 = 0, $DWPARAM4 = 0, $PDATA = 0)
	$OPCODE = "60"
	$OPCODE &= "8B0D" & _HEX($ADDRESS_BASE)
	$OPCODE &= "8B491C"
	$OPCODE &= "68" & _HEX($PDATA)
	$OPCODE &= "68" & _HEX($DWPARAM4)
	$OPCODE &= "68" & _HEX($DWPARAM3)
	$OPCODE &= "68" & _HEX($DWPARAM2)
	$OPCODE &= "68" & _HEX($DWPARAM1)
	$OPCODE &= "68" & _HEX($ISUBID)
	$OPCODE &= "68" & _HEX($IMANAGER)
	$OPCODE &= "68" & _HEX($DWMSG)
	$OPCODE &= "BB" & _HEX($ADDRESS_POSTMESSAGE)
	$OPCODE &= "FFD3"
	$OPCODE &= "61"
	$OPCODE &= "C3"
	PRINT("PostMessage")
	INJECTCODE($OPCODE)
ENDFUNC
FUNC CASTSKILLWITHPOINTER($SKILL_POINTER, $SKILL_ID)
	$OPCODE = "60"
	$OPCODE &= "B8" & _HEX($ADDRESS_BASE)
	$OPCODE &= "8B00"
	$OPCODE &= "8B401C"
	$OPCODE &= "8B70" & _HEX($PLAYER_OFFSET, 2)
	$OPCODE &= "B8" & _HEX($SKILL_POINTER)
	$OPCODE &= "6AFF"
	$OPCODE &= "6A00"
	$OPCODE &= "6A00"
	$OPCODE &= "B9" & _HEX($SKILL_ID)
	$OPCODE &= "51"
	$OPCODE &= "8BCE"
	$OPCODE &= "BA" & _HEX($ADDRESS_CASTSKILL)
	$OPCODE &= "FFD2"
	$OPCODE &= "61"
	$OPCODE &= "C3"
	INJECTCODE($OPCODE)
ENDFUNC
FUNC ISQUESTAVAILABLE($QUESTID)
	IF NOT GAMEREADY() THEN RETURN 1
	$PROCESSHANDLE = $GAME_PROCESS[1]
	$RETURNADDRESS = DLLCALL("kernel32.dll", "ptr", "VirtualAllocEx", "handle", $PROCESSHANDLE, "ptr", 0, "ulong_ptr", 4, "dword", 4096, "dword", 64)
	$OPCODE = "60"
	$OPCODE &= "B8" & _HEX($ADDRESS_BASE)
	$OPCODE &= "8B00"
	$OPCODE &= "8B401C"
	$OPCODE &= "8B78" & _HEX($PLAYER_OFFSET, 2)
	$OPCODE &= "8B8F" & _HEX($QUESTLIST_OFFSET)
	$OPCODE &= "6A00"
	$OPCODE &= "68" & _HEX($QUESTID)
	$OPCODE &= "B8" & _HEX($ADDRESS_ISQUESTAVAILABLE)
	$OPCODE &= "FFD0"
	$OPCODE &= "A3" & _HEX($RETURNADDRESS[0])
	$OPCODE &= "61"
	$OPCODE &= "C3"
	INJECTCODE($OPCODE)
	$RETVAL = _MEMORYREAD($RETURNADDRESS[0], $GAME_PROCESS)
	DLLCALL("kernel32.dll", "bool", "VirtualFreeEx", "handle", $PROCESSHANDLE, "ptr", $RETURNADDRESS[0], "ulong_ptr", 0, "dword", 32768)
	RETURN $RETVAL == 0
ENDFUNC
FUNC ADDCHATMESSAGE($MESSAGE, $TYPE = 8, $EMOTESET = 0)
	IF NOT GAMEREADY() THEN RETURN
	$PROCESSHANDLE = $GAME_PROCESS[1]
	$DBINARY = STRINGTOBINARY($MESSAGE & CHR(0), $SB_UTF16LE)
	$STRINGADD = DLLCALL("kernel32.dll", "ptr", "VirtualAllocEx", "handle", $PROCESSHANDLE, "ptr", 0, "ulong_ptr", BINARYLEN($DBINARY), "dword", 4096, "dword", 64)
	$VBUFFER = DLLSTRUCTCREATE("byte[" & (BINARYLEN($DBINARY)) & "]")
	DLLSTRUCTSETDATA($VBUFFER, 1, $DBINARY)
	DLLCALL("kernel32.dll", "bool", "WriteProcessMemory", "handle", $PROCESSHANDLE, "ptr", $STRINGADD[0], "ptr", DLLSTRUCTGETPTR($VBUFFER), "ulong_ptr", DLLSTRUCTGETSIZE($VBUFFER), "ulong_ptr*", 0)
	DIM $PARAMS[9] = [$STRINGADD[0], $TYPE, -1, 0, 0, $EMOTESET, 0, 0, 0]
	$UIMANAGER = _MEMORYREAD(_MEMORYREAD(_MEMORYREAD($ADDRESS_BASE, $GAME_PROCESS) + 28, $GAME_PROCESS) + 24, $GAME_PROCESS)
	$CURRMANAGER = _MEMORYREAD($UIMANAGER + 8, $GAME_PROCESS)
	CALLCLASSMETHOD($CURRMANAGER, $ADDRESS_ADDCHATMESSAGE, $PARAMS)
ENDFUNC
FUNC GRADIENTTEXT($TEXT, $COLOR1, $COLOR2)
	$R1 = BITSHIFT(BITAND($COLOR1, 16711680), 16)
	$G1 = BITSHIFT(BITAND($COLOR1, 65280), 8)
	$B1 = BITSHIFT(BITAND($COLOR1, 255), 0)
	$R2 = BITSHIFT(BITAND($COLOR2, 16711680), 16)
	$G2 = BITSHIFT(BITAND($COLOR2, 65280), 8)
	$B2 = BITSHIFT(BITAND($COLOR2, 255), 0)
	$LEN = STRINGLEN($TEXT) - 1
	$RESULT = ""
	FOR $I = 0 TO $LEN
		$R3 = ROUND(($R1 * ($LEN - $I) + $R2 * $I) / $LEN)
		$G3 = ROUND(($G1 * ($LEN - $I) + $G2 * $I) / $LEN)
		$B3 = ROUND(($B1 * ($LEN - $I) + $B2 * $I) / $LEN)
		$RESULT = $RESULT & "^" & HEX($R3, 2) & HEX($G3, 2) & HEX($B3, 2) & STRINGMID($TEXT, $I + 1, 1)
	NEXT
	RETURN $RESULT
ENDFUNC
FUNC EMOTE($I)
	RETURN CHRW(57344) & "<0><0:" & $I & ">"
ENDFUNC
FUNC CALLCLASSMETHOD($THIS, $ADDRESS, $PARAMS, $RETURNVAL = FALSE)
	IF $THIS == 0 THEN RETURN FALSE
	$RESULT = 0
	$PROCESSHANDLE = $GAME_PROCESS[1]
	IF $RETURNVAL THEN $RETURNADDRESS = DLLCALL("kernel32.dll", "ptr", "VirtualAllocEx", "handle", $PROCESSHANDLE, "ptr", 0, "ulong_ptr", 4, "dword", 4096, "dword", 64)
	$OPCODE = "60"
	$OPCODE &= "B9" & _HEX($THIS)
	FOR $I = UBOUND($PARAMS) - 1 TO 0 STEP -1
		$OPCODE &= "68" & _HEX($PARAMS[$I])
	NEXT
	$OPCODE &= "B8" & _HEX($ADDRESS)
	$OPCODE &= "FFD0"
	IF $RETURNVAL THEN $OPCODE &= "A3" & _HEX($RETURNADDRESS[0])
	$OPCODE &= "61"
	$OPCODE &= "C3"
	INJECTCODE($OPCODE)
	IF $RETURNVAL THEN
		$RESULT = _MEMORYREAD($RETURNADDRESS[0], $GAME_PROCESS)
		DLLCALL("kernel32.dll", "bool", "VirtualFreeEx", "handle", $PROCESSHANDLE, "ptr", $RETURNADDRESS[0], "ulong_ptr", 0, "dword", 32768)
	ENDIF
	RETURN $RESULT
ENDFUNC
FUNC INJECTCODE($OPCODE)
	$PROCESSHANDLE = $GAME_PROCESS[1]
	LOCAL $CODESIZE = STRINGLEN($OPCODE) / 2
	IF $CODESIZE < 256 THEN $CODESIZE = 256
	$FUNCTIONADDRESS = DLLCALL("kernel32.dll", "ptr", "VirtualAllocEx", "handle", $PROCESSHANDLE, "ptr", 0, "ulong_ptr", $CODESIZE, "dword", 4096, "dword", 64)
	$VBUFFER = DLLSTRUCTCREATE("byte[" & STRINGLEN($OPCODE) / 2 & "]")
	FOR $LOOP = 1 TO DLLSTRUCTGETSIZE($VBUFFER)
		DLLSTRUCTSETDATA($VBUFFER, 1, DEC(STRINGMID($OPCODE, ($LOOP - 1) * 2 + 1, 2)), $LOOP)
	NEXT
	DLLCALL("kernel32.dll", "bool", "WriteProcessMemory", "handle", $PROCESSHANDLE, "ptr", $FUNCTIONADDRESS[0], "ptr", DLLSTRUCTGETPTR($VBUFFER), "ulong_ptr", DLLSTRUCTGETSIZE($VBUFFER), "ulong_ptr*", 0)
	$HREMOTETHREAD = DLLCALL("kernel32.dll", "handle", "CreateRemoteThread", "handle", $PROCESSHANDLE, "ptr", 0, "ulong_ptr", 0, "ptr", $FUNCTIONADDRESS[0], "ptr", 0, "dword", 0, "dword*", 0)
	$RESULT = DLLCALL("kernel32.dll", "dword", "WaitForSingleObject", "handle", $HREMOTETHREAD[0], "dword", -1)
	IF $RESULT[0] <> 0 THEN PRINT("WaitForSingleObject Failed? " & $RESULT[0])
	DLLCALL("kernel32.dll", "bool", "CloseHandle", "handle", $HREMOTETHREAD[0])
	DLLCALL("kernel32.dll", "bool", "VirtualFreeEx", "handle", $PROCESSHANDLE, "ptr", $FUNCTIONADDRESS[0], "ulong_ptr", 0, "dword", 32768)
	RETURN TRUE
ENDFUNC
FUNC GATHERITEM($ITEM_UNIQUE_ID, $ACTION_TYPE = 0)
	$OPCODE = "60"
	$OPCODE &= "B9" & _HEX($ADDRESS_BASE)
	$OPCODE &= "8B09"
	$OPCODE &= "8B491C"
	$OPCODE &= "8B49" & _HEX($PLAYER_OFFSET, 2)
	$OPCODE &= "68" & _HEX($ACTION_TYPE)
	$OPCODE &= "68" & _HEX($ITEM_UNIQUE_ID)
	$OPCODE &= "BB" & _HEX($ADDRESS_GATHER)
	$OPCODE &= "FFD3"
	$OPCODE &= "61"
	$OPCODE &= "C3"
	INJECTCODE($OPCODE)
ENDFUNC
FUNC FLYXYZ($GAME_X, $GAME_Y, $GAME_Z, $DISMOUNT = 0)
	$DEST_X = $GAME_X * 10 - 4000
	$DEST_Y = $GAME_Y * 10 - 5500
	$DEST_Z = $GAME_Z * 10
	FLY($DEST_X, $DEST_Y, $DEST_Z, $DISMOUNT)
ENDFUNC
FUNC MOVEXYZ($GAME_X, $GAME_Y, $GAME_Z, $MOVEVERT = 0)
