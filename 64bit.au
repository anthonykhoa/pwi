			LOCAL $ACALL = DLLCALL("kernel32.dll", "dword", "GetFinalPathNameByHandleW", "handle", $HFILE, "wstr", "", "dword", 4096, "dword", $IFLAGS)
			IF @ERROR OR NOT $ACALL[0] THEN RETURN SETERROR(@ERROR + 10, @EXTENDED, "")
			RETURN $ACALL[2]
