GLOBAL ENUM $TAB_DAILY, $TAB_TOWER, $TAB_MINIONS, $TAB_AK, $TAB_INFO, $TAB_MISC, $TAB_COMBAT, $TAB_AUTOPOT, $TAB_GEARSWAP, $TAB_ROUTES, $TAB_REFINE, $TAB_NAVIGATION, $TAB_HOTKEYS, $TAB_COUNT
DIM $TAB_DATA[$TAB_COUNT][3] = [["DAILY", 0, "Automate routine daily quests to improve your character's strength."], ["HFT", 0, "Complete weekly instance Heavenfall Temple to gain XP, star chart mats, & more."], ["Minions", 0, "Fight with Homestead minions 200x/month to gain various rewards."], ["Wndlnd", 0, "Wonderland: a sometimes-open map to farm titles, fashion, baby pets & more"], ["Info", 0, "Useful settings, log actions, and more are located here."], ["Misc", 0, "Many useful functions sorted here."], ["Combat", 0, "Frequently used utility functions for controlling squad in combat."], ["Autopot", 0, "Increase your character's survival with use of various items and skills."], ["Gear Swap", 0, "Assign various gear sets and swap between them instantly with hotkeys."], ["Routes", 0, "Plot routes through instances for your characters to automatically carry out"], ["Refine", 0, "Assign refine rules then automatically refine gear to increase it's power"], ["Navigate", 0, "Path your characters to various useful, predetermined places."], ["Hotkeys", 0, "Assign hotkeys for the many possible actions TheNightmareStuff can take"]]
FUNC REMOVEFLICKER($GUI)
	_WINAPI_SETCLASSLONGEX($GUI, $GCL_STYLE, BITAND(_WINAPI_GETCLASSLONGEX($GUI, $GCL_STYLE), BITNOT(1), BITNOT(2)))
ENDFUNC
FUNC ISCHECKED($IDCONTROLID)
	RETURN BITAND(GUICTRLREAD($IDCONTROLID), $GUI_CHECKED) = $GUI_CHECKED
ENDFUNC
GLOBAL $DAILY_SINGLE_CALL = FALSE
DIM $GUI_LIST[0][6]
$GUI_CLIENT_AREA = -1
FUNC REGISTERGUI($GUI, $SCROLLHEIGHT = -1)
	$RECT = WINGETPOS($GUI)
	GUISETSTATE(@SW_HIDE, $GUI)
	REMOVEFLICKER($GUI)
	REDIM $GUI_LIST[UBOUND($GUI_LIST) + 1][6]
	$GUI_LIST[UBOUND($GUI_LIST) - 1][0] = $GUI
	$GUI_LIST[UBOUND($GUI_LIST) - 1][1] = $RECT[0]
	$GUI_LIST[UBOUND($GUI_LIST) - 1][2] = $RECT[1]
	$GUI_LIST[UBOUND($GUI_LIST) - 1][3] = $RECT[2]
	$GUI_LIST[UBOUND($GUI_LIST) - 1][4] = $RECT[3]
	$GUI_LIST[UBOUND($GUI_LIST) - 1][5] = $SCROLLHEIGHT
ENDFUNC
FUNC RESIZEALL($RECT = -1)
	$DELTAX = 0
	$DELTAY = 0
	$DELTAW = 0
	$DELTAH = 0
	IF UBOUND($RECT) == 0 THEN
		$RECT = WINGETPOS($GUI_LIST[0][0])
		$DELTAX = $RECT[0] - $GUI_LIST[0][1]
		$DELTAY = $RECT[1] - $GUI_LIST[0][2]
		$DELTAW = $RECT[2] - $GUI_LIST[0][3]
		$DELTAH = $RECT[3] - $GUI_LIST[0][4]
	ELSE
		$DELTAX = $RECT[0] - $GUI_CLIENT_AREA[0]
		$DELTAY = $RECT[1] - $GUI_CLIENT_AREA[1]
		$DELTAW = $RECT[2] - $GUI_CLIENT_AREA[2]
		$DELTAH = $RECT[3] - $GUI_CLIENT_AREA[3]
	ENDIF
	FOR $I = 1 TO UBOUND($GUI_LIST) - 1
		$HW = WINMOVE($GUI_LIST[$I][0], "", DEFAULT, DEFAULT, $GUI_LIST[$I][3] + $DELTAW, $GUI_LIST[$I][4] + $DELTAH)
		IF $GUI_LIST[$I][5] <> -1 THEN
			_GUISCROLLBARS_SETSCROLLINFOPOS($GUI_LIST[$I][0], $SB_VERT, 0)
			_GUISCROLLBARS_GENERATE($GUI_LIST[$I][0], 250, $GUI_LIST[$I][5], 1, 1, TRUE)
		ENDIF
	NEXT
ENDFUNC
GLOBAL ENUM $MAP_MAIN = 1, $MAP_PRIMAL = 163, $MAP_STORY = 168, $MAP_NEVERFALL = 178, $MAP_MORAI = 137, $MAP_ADVENTUREKINGDOM = 191, $MAP_MOMA = 122, $MAP_LOTH = 121, $MAP_HOME = 180, $MAP_ULFGARD = 91, $MAP_FACTIONBASE = 135, $MAP_NORTHERNREALM = 93, $MAP_UNKNOWN = 999, $MAP_OHT = 133
GLOBAL $INVALID_POS = -1000000
GLOBAL $HGUI
GLOBAL $GLOBAL_SETTINGS_OPTIONS = OBJCREATE("Scripting.Dictionary")
FUNC GETGLOBALSETTING($KEY, $DEFAULT = FALSE)
	IF $GLOBAL_SETTINGS_OPTIONS.exists($KEY) THEN RETURN ISCHECKED($GLOBAL_SETTINGS_OPTIONS.item($KEY))
	RETURN $DEFAULT
ENDFUNC
